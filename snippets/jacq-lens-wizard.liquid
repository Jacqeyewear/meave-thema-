  <script>
  // Fallback opener: alleen gebruiken als jacq-lens-wizard.js niet laadt
  window.addEventListener('DOMContentLoaded', function(){
    var btn    = document.getElementById('jacq-lens-open');
    var drawer = document.getElementById('jacq-lens-drawer');
    if (!btn || !drawer) return;

    // ✅ Cleanup: als drawer dicht is, nooit scroll-lock laten hangen
    if (drawer.hasAttribute('hidden') || drawer.hidden || drawer.getAttribute('aria-hidden') === 'true') {
      document.documentElement.classList.remove('jacq-open','jacq-no-scroll');
      document.documentElement.style.removeProperty('--jacq-scrollbar-comp');
      document.body.classList.remove('jacq-no-scroll');
    }

    if (!btn.dataset.jacqBound){
      btn.dataset.jacqBound = '1';
      btn.addEventListener('click', function(){
        if (window.__jacqLensWizardLoaded) return;

        // open
        drawer.hidden = false;
        drawer.removeAttribute('hidden');
        drawer.style.removeProperty('display');
        drawer.setAttribute('aria-hidden','false');
        drawer.classList.add('is-open');

        document.documentElement.classList.add('jacq-open','jacq-no-scroll');
      });
    }

    document.addEventListener('click', function(e){
      if (window.__jacqLensWizardLoaded) return;
      var close = e.target.closest('[data-close]');
      if (!close) return;

      // close
      drawer.classList.remove('is-open','is-closing');
      drawer.setAttribute('aria-hidden','true');
      drawer.hidden = true;
      drawer.setAttribute('hidden','');
      drawer.style.display = 'none';

      document.documentElement.classList.remove('jacq-open','jacq-no-scroll');
      document.documentElement.style.removeProperty('--jacq-scrollbar-comp');
      document.body.classList.remove('jacq-no-scroll');
    });
  });
</script>
</section>