    var keys = Object.keys(variantGlbUrls);
    for (var k = 0; k < keys.length; k++) {
      if (typeof variantGlbUrls[keys[k]] === 'string' && variantGlbUrls[keys[k]]) {
        return variantGlbUrls[keys[k]];
      }
    }
    return null;
  }

  function buildVariantUI() {
    variantsEl.innerHTML = '';

    var firstGlbUrl = getFirstGlbUrl();

    var entries = [];
    productVariants.forEach(function(v, idx) {
      var name = (v.option1 || v.title || '').trim();
      var glbUrl = findGlbForVariant(idx) || firstGlbUrl;

      if (glbUrl) {
        entries.push({
          glbUrl: glbUrl,
          image: v.image || null,
          title: name || v.title
        });
      }
    });

    if (entries.length === 0 && firstGlbUrl) {
      entries.push({ glbUrl: firstGlbUrl, image: null, title: 'Model 1' });
    }

    if (entries.length === 0) return entries;

    entries.forEach(function(entry, idx) {
      var btn = document.createElement('button');
      btn.className = 'vto-thumb' + (idx === 0 ? ' vto-thumb-active' : '');
      btn.type = 'button';
      btn.setAttribute('aria-label', entry.title);
      btn.dataset.glbUrl = entry.glbUrl;
      btn.dataset.title = entry.title;

      if (entry.image) {
        var img = document.createElement('img');
        img.src = entry.image;
        img.alt = entry.title;
        img.loading = 'lazy';
        btn.appendChild(img);
      } else {
        btn.textContent = entry.title.charAt(0).toUpperCase();
        btn.style.cssText = 'display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:600;color:#666';
      }

      btn.addEventListener('click', function() {
        var thumbs = variantsEl.querySelectorAll('.vto-thumb');
        for (var i = 0; i < thumbs.length; i++) thumbs[i].classList.remove('vto-thumb-active');
        btn.classList.add('vto-thumb-active');
        varNameEl.textContent = entry.title;
        loadGLB(entry.glbUrl);
      });

      variantsEl.appendChild(btn);
    });

    varNameEl.textContent = entries[0].title;
    return entries;
  }

  /* ========================================
     GLB Model Loading
     ======================================== */
  function trimTempleGeometry(group) {
    var THREE = window.THREE;

    group.traverse(function(child) {
      if (!child.isMesh) return;

      var geo = child.geometry;
      var index = geo.index;
      var position = geo.attributes.position;
      if (!index) return;

      geo.computeBoundingBox();
      var bb = geo.boundingBox;
      var zMin = bb.min.z;
      var zMax = bb.max.z;
      var zRange = zMax - zMin;

      var keepFraction = 0.45;
      var cutoffZ = zMax - (zRange * keepFraction);

      console.log('[VTO] Trim mesh:', child.name,
        '| local Z range:', zMin.toFixed(4), 'to', zMax.toFixed(4),
        '| cutoff:', cutoffZ.toFixed(4));

      var oldIndices = index.array;
      var newIndices = [];

      for (var i = 0; i < oldIndices.length; i += 3) {
        var i0 = oldIndices[i];
        var i1 = oldIndices[i + 1];
        var i2 = oldIndices[i + 2];

        var z0 = position.getZ(i0);
        var z1 = position.getZ(i1);
        var z2 = position.getZ(i2);

        if (z0 > cutoffZ || z1 > cutoffZ || z2 > cutoffZ) {
          newIndices.push(i0, i1, i2);
        }
      }

      console.log('[VTO] Kept', (newIndices.length / 3), 'of', (oldIndices.length / 3), 'triangles');

      geo.setIndex(new THREE.BufferAttribute(new Uint32Array(newIndices), 1));
      geo.index.needsUpdate = true;
      geo.computeBoundingBox();
      geo.computeBoundingSphere();
    });
  }

  function loadGLB(url) {
    if (!scene) return;
    console.log('[VTO] Loading GLB:', url);

    if (currentModel) {
      scene.remove(currentModel);
      currentModel = null;
    }

    if (glbCache[url]) {
      glassesModelWidth = glbCache[url].width;
      currentModel = glbCache[url].group.clone();
      currentModel.traverse(function(child) {
        if (child.isMesh) child.renderOrder = 1;
      });
      scene.add(currentModel);
      poseInit = false;
      emaInitialized = false;
      console.log('[VTO] GLB loaded from cache, width:', glassesModelWidth.toFixed(4));
      return;
    }

    var loader = new window.THREE.GLTFLoader();
    loader.load(
      url,
      function(gltf) {
        var model = gltf.scene;
        var THREE = window.THREE;

        var box = new THREE.Box3().setFromObject(model);
        var center = box.getCenter(new THREE.Vector3());
        model.position.sub(center);

        var size = box.getSize(new THREE.Vector3());
        model.position.y -= size.y * 0.12;

        var xWidth = size.x > 0 ? size.x : Math.max(size.x, size.y, size.z);
        if (xWidth > 0) {
          model.scale.multiplyScalar(CONFIG.glbNormalizedSize / xWidth);
        }

        var frameCorrection = productFrameWidth / CONFIG.referenceFrameWidth;
        model.scale.multiplyScalar(frameCorrection);

        var scaledBox = new THREE.Box3().setFromObject(model);
        var scaledSize = scaledBox.getSize(new THREE.Vector3());
        model.position.z -= scaledSize.z * 0.45;

        var normalizedBox = new THREE.Box3().setFromObject(model);
        var normalizedSize = normalizedBox.getSize(new THREE.Vector3());
        glassesModelWidth = normalizedSize.x;

        console.log('[VTO] GLB loaded, size:', size.x.toFixed(3), size.y.toFixed(3), size.z.toFixed(3), '| normalized width:', glassesModelWidth.toFixed(4));

        var group = new THREE.Group();
        group.add(model);

        trimTempleGeometry(group);

        glbCache[url] = { group: group, width: glassesModelWidth };

        if (currentModel) scene.remove(currentModel);
        currentModel = group.clone();
        poseInit = false;
        emaInitialized = false;
        currentModel.traverse(function(child) {
          if (child.isMesh) child.renderOrder = 1;
        });
        scene.add(currentModel);
      },
      undefined,
      function(err) {
        console.error('[VTO] GLB load error:', url, err);
      }
    );
  }

  /* ========================================
     Face Results → Head Pose → Model Update
     ======================================== */
  var emaFaceWidth = 0;
  var emaInitialized = false;

  function onFaceResults(results) {
    if (!isOpen) return;

    var landmarks = results.multiFaceLandmarks && results.multiFaceLandmarks[0];

    if (!landmarks) {
      if (faceVisible) {
        faceVisible = false;
        lastFaceTime = Date.now();
      }
      if (!noFaceShown && lastFaceTime > 0 && (Date.now() - lastFaceTime) > CONFIG.noFaceTimeout) {
        noFaceEl.classList.add('vto-show');
        noFaceShown = true;
      }
      if (occluderMesh) occluderMesh.visible = false;
      return;
    }

    if (!faceVisible) console.log('[VTO] Face detected, model:', !!currentModel);
    faceVisible = true;
    if (noFaceShown) {
      noFaceEl.classList.remove('vto-show');
      noFaceShown = false;
    }

    var THREE = window.THREE;

    function mx(lm) { return { x: 1 - lm.x, y: lm.y, z: lm.z }; }

    var noseBridgeLm   = mx(landmarks[168]);
    var noseMidLm      = mx(landmarks[6]);
    var leftTemple     = mx(landmarks[454]);
    var rightTemple    = mx(landmarks[234]);
    var foreheadLm     = mx(landmarks[10]);
    var innerEyeLeftLm  = mx(landmarks[362]);
    var innerEyeRightLm = mx(landmarks[133]);

    var fovRad = (CONFIG.cameraFOV * Math.PI) / 180;
    var camZ = threeCamera ? threeCamera.position.z : 1;
    var visH = 2 * Math.tan(fovRad / 2) * camZ;
    var visW = visH * (threeCamera ? threeCamera.aspect : 4 / 3);

    function toVec3(lm) {
      return new THREE.Vector3(
        (lm.x - 0.5) * visW,
        -(lm.y - 0.5) * visH,
        -(lm.z || 0) * visW
      );
    }

    var noseVec     = toVec3(noseBridgeLm);
    var leftVec     = toVec3(leftTemple);
    var rightVec    = toVec3(rightTemple);
    var foreheadVec = toVec3(foreheadLm);
    var innerLeftVec  = toVec3(innerEyeLeftLm);
    var innerRightVec = toVec3(innerEyeRightLm);
    var noseMidVec = toVec3(noseMidLm);

    var eyeMidY = (innerLeftVec.y + innerRightVec.y) / 2;
    var targetX = noseVec.x;
    var targetY = eyeMidY * 0.4 + noseMidVec.y * 0.6;
    var targetZ = noseVec.z + CONFIG.zOffset;

    var dx = rightVec.x - leftVec.x;
    var dy = rightVec.y - leftVec.y;
    var dz = rightVec.z - leftVec.z;
    var rawFaceWidth = Math.sqrt(dx * dx + dy * dy + dz * dz);

    if (!emaInitialized) {
      emaFaceWidth = rawFaceWidth;
      emaInitialized = true;
    } else {
      var widthChange = Math.abs(rawFaceWidth - emaFaceWidth) / (emaFaceWidth || 1);
      var emaFactor = widthChange > 0.06 ? 0.4 : 0.08;
      emaFaceWidth = emaFaceWidth + (rawFaceWidth - emaFaceWidth) * emaFactor;
    }
    var targetS = (emaFaceWidth / glassesModelWidth) * CONFIG.scaleMultiplier;

    var xAxis = new THREE.Vector3().subVectors(rightVec, leftVec).normalize();
    var upHint = new THREE.Vector3().subVectors(foreheadVec, noseVec).normalize();
    var zAxis = new THREE.Vector3().crossVectors(xAxis, upHint).normalize();
    var yAxis = new THREE.Vector3().crossVectors(zAxis, xAxis).normalize();

    targetY -= visH * 0.005;

    var rotMatrix = new THREE.Matrix4().makeBasis(xAxis, yAxis, zAxis);
    var targetEuler = new THREE.Euler().setFromRotationMatrix(rotMatrix, 'YXZ');

    var targetRX = targetEuler.x;
    var targetRY = targetEuler.y;
    var targetRZ = targetEuler.z;

    if (!poseInit) {
      sm.x = targetX;
      sm.y = targetY;
      sm.z = targetZ;
      sm.rx = targetRX;
      sm.ry = targetRY;
      sm.rz = targetRZ;
      sm.s = targetS;
      poseInit = true;
    } else {
      var lp = CONFIG.lerpPosition;
      var lr = CONFIG.lerpRotation;

      var posDiff = Math.sqrt(
        (targetX - sm.x) * (targetX - sm.x) +
        (targetY - sm.y) * (targetY - sm.y)
      );
      var posThreshold = visW * 0.01;
      var adaptiveLP = posDiff > posThreshold ? Math.min(lp * 1.5, 0.95) : lp;

      sm.x = lerp(sm.x, targetX, adaptiveLP);
      sm.y = lerp(sm.y, targetY, adaptiveLP);
      sm.z = lerp(sm.z, targetZ, adaptiveLP);

      var rotDiff = Math.abs(targetRY - sm.ry);
      var rotThreshold = 0.03;
      var adaptiveLR = rotDiff > rotThreshold ? Math.min(lr * 1.5, 0.9) : lr;

      sm.rx = lerpAngle(sm.rx, targetRX, adaptiveLR);
      sm.ry = lerpAngle(sm.ry, targetRY, adaptiveLR);
      sm.rz = lerpAngle(sm.rz, targetRZ, adaptiveLR);

      sm.s = lerp(sm.s, targetS, 0.15);
    }

    if (currentModel) {
      currentModel.position.set(sm.x, sm.y, sm.z);
      currentModel.rotation.order = 'YXZ';
      currentModel.rotation.set(sm.rx, sm.ry, sm.rz, 'YXZ');
      currentModel.scale.setScalar(sm.s);
    }

    // Update invisible face occluder mesh
    if (occluderMesh && occluderGeometry) {
      var THREE = window.THREE;
      var positions = new Float32Array(468 * 3);
      var zScale = visW * CONFIG.occluderZScale;

      for (var i = 0; i < 468; i++) {
        var lm = landmarks[i];
        var lx = 1 - lm.x;
        positions[i * 3]     = (lx - 0.5) * visW;
        positions[i * 3 + 1] = -(lm.y - 0.5) * visH;
        positions[i * 3 + 2] = -(lm.z || 0) * zScale;
      }

      occluderGeometry.setAttribute('position',
        new THREE.BufferAttribute(positions, 3));

      if (!occluderIndexSet) {
        occluderGeometry.setIndex(FACE_TRI);
        occluderIndexSet = true;
      }

      occluderGeometry.attributes.position.needsUpdate = true;
      occluderGeometry.computeVertexNormals();
      occluderMesh.visible = true;
    }
  }

  /* ========================================
     Render Loop (also drives face detection)
     ======================================== */
  function renderLoop() {
    if (!isOpen) return;

    if (faceMesh && video.readyState >= 2 && !sendingFrame) {
      sendingFrame = true;
      faceMesh.send({ image: video }).then(function() {
        sendingFrame = false;
      }).catch(function() {
        sendingFrame = false;
      });
    }

    if (renderer && scene && threeCamera) {
      renderer.render(scene, threeCamera);
    }
    animFrameId = requestAnimationFrame(renderLoop);
  }

  /* ========================================
     Camera
     ======================================== */
  async function startCamera() {
    try {
      cameraStream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 960 } }
      });
      video.srcObject = cameraStream;
      await new Promise(function(resolve) {
        video.onloadedmetadata = function() { video.play(); resolve(); };
      });
    } catch (err) {
      if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
        showError('Cameratoegang geweigerd. Wijzig dit in je browserinstellingen.');
      } else {
        showError('Camera niet beschikbaar. Sta cameratoegang toe in je browserinstellingen.');
      }
      throw err;
    }
  }

  function stopCamera() {
    if (cameraStream) {
      cameraStream.getTracks().forEach(function(t) { t.stop(); });
      cameraStream = null;
    }
    video.srcObject = null;
  }

  /* ========================================
     Three.js Cleanup
     ======================================== */
  function disposeModel(obj) {
    if (!obj) return;
    obj.traverse(function(child) {
      if (child.geometry) child.geometry.dispose();
      if (child.material) {
        if (Array.isArray(child.material)) {
          child.material.forEach(function(m) { m.dispose(); });
        } else {
          child.material.dispose();
        }
      }
    });
  }

  function cleanupScene() {
    if (currentModel && scene) {
      scene.remove(currentModel);
      currentModel = null;
    }
    if (occluderMesh && scene) {
      scene.remove(occluderMesh);
      occluderMesh = null;
    }
    if (occluderGeometry) {
      occluderGeometry.dispose();
      occluderGeometry = null;
    }
    occluderIndexSet = false;
  }

  function fullDispose() {
    cleanupScene();
    Object.keys(glbCache).forEach(function(url) {
      disposeModel(glbCache[url].group);
    });
    glbCache = {};
    if (renderer) {
      renderer.dispose();
      renderer = null;
    }
    scene = null;
    threeCamera = null;
  }

  /* ========================================
     Open / Close Modal
     ======================================== */
  async function openModal() {
    if (isOpen) return;
    isOpen = true;

    // Reset pose state
    poseInit = false;
    emaInitialized = false;
    faceVisible = false;
    noFaceShown = false;
    lastFaceTime = 0;

    // Reset UI
    noFaceEl.classList.remove('vto-show');
    errorEl.classList.remove('vto-show');
    tipEl.classList.remove('vto-hidden');

    // Show modal with animation
    overlay.classList.add('vto-active');
    void overlay.offsetWidth;
    overlay.classList.add('vto-visible');
    document.body.classList.add('vto-modal-open');

    showLoading();

    console.log('[VTO] Media:', productMedia.length, '| Variants:', productVariants.length);

    var entries = buildVariantUI();
    console.log('[VTO] Variant entries built:', entries ? entries.length : 0);

    // Step 1: Start camera
    try {
      await startCamera();
    } catch (err) {
      console.error('[VTO] Camera error:', err);
      hideLoading();
      return;
    }

    // Step 2: Load libraries and init 3D rendering
    try {
      await loadLibraries();

      initThreeJS();
      ensureOccluder();
      initFaceMesh();
      resizeRenderer();

      if (entries && entries.length > 0) {
        loadGLB(entries[0].glbUrl);
      } else {
        var fallbackUrl = getFirstGlbUrl();
        if (fallbackUrl) loadGLB(fallbackUrl);
      }

      hideLoading();
      showTip();

      renderLoop();

    } catch (err) {
      console.error('[VTO] Library/3D init error:', err);
      hideLoading();
      showError('3D laden mislukt: ' + (err.message || err));
    }
  }

  function closeModal() {
    if (!isOpen) return;
    isOpen = false;

    overlay.classList.remove('vto-visible');

    setTimeout(function() {
      overlay.classList.remove('vto-active');
      document.body.classList.remove('vto-modal-open');

      if (animFrameId) {
        cancelAnimationFrame(animFrameId);
        animFrameId = null;
      }

      stopCamera();
      cleanupScene();

      noFaceEl.classList.remove('vto-show');
      tipEl.classList.add('vto-hidden');
    }, 200);
  }

  /* ========================================
     Event Listeners
     ======================================== */
  // Move overlay to document.body so parent transforms don't break position:fixed
  document.body.appendChild(overlay);

  // Move button into product image area — must be on a non-scrolling container
  // so it stays visible when swiping through slides.
  // The slider itself has overflow-x:auto, so absolute-positioned children
  // inside it scroll with the slides. Attach to the slider's PARENT instead.
  (function() {
    var wrapper = null;
    var btn = openBtn;
    if (!btn) return;

    // Find the horizontally-scrolling slider (slider-element custom element
    // with class .slider). Its parent is a stable, non-scrolling wrapper.
    var slider = document.querySelector('slider-element.slider')
              || document.querySelector('.slider.slider--mobile')
              || document.querySelector('.slider.slider--tablet')
              || document.querySelector('.slider.slider--desktop');

    // Fallback: find via product__media-list and step up to its slider parent
    if (!slider) {
      var list = document.querySelector('.product__media-list');
      if (list) slider = list.closest('slider-element, .slider') || list.parentElement;
    }

    if (slider && slider.parentElement) {
      wrapper = slider.parentElement;
    }

    // Last-resort fallbacks (unchanged)
    if (!wrapper) {
      wrapper = document.querySelector('.product__media-gallery')
              || document.querySelector('.product__media-wrapper')
              || document.querySelector('.product-media-container')
              || document.querySelector('.product__media.card.media')
              || document.querySelector('.product__media-item')
              || document.querySelector('.product__media');
    }

    if (wrapper) {
      var style = window.getComputedStyle(wrapper);
      if (style.position === 'static') {
        wrapper.style.position = 'relative';
      }
      wrapper.appendChild(btn);
    }
  })();

  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);

  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && isOpen) closeModal();
  });

  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      if (isOpen) resizeRenderer();
    }, 100);
  });

})();
</script>

