    if (window.FaceMesh) return Promise.resolve();
    return loadScript('https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh@0.4.1633559619/face_mesh.js');
  }

  async function loadLibraries() {
    if (libsLoaded) return;
    await Promise.all([loadThreeScripts(), loadMediaPipeScripts()]);
    libsLoaded = true;
  }

  /* ========================================
     Three.js Init
     ======================================== */
  function initThreeJS() {
    if (renderer) return;

    var THREE = window.THREE;

    renderer = new THREE.WebGLRenderer({
      canvas: canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance'
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.outputEncoding = THREE.sRGBEncoding;
    renderer.sortObjects = true;

    scene = new THREE.Scene();

    threeCamera = new THREE.PerspectiveCamera(CONFIG.cameraFOV, 4 / 3, 1, CONFIG.cameraZ * 3);
    threeCamera.position.set(0, 0, CONFIG.cameraZ);

    // Lighting
    scene.add(new THREE.AmbientLight(0xffffff, 1.0));

    var keyLight = new THREE.DirectionalLight(0xffffff, 0.6);
    keyLight.position.set(0.5, 1, 1);
    scene.add(keyLight);

    var fillLight = new THREE.DirectionalLight(0xffffff, 0.3);
    fillLight.position.set(-0.5, -0.5, 0.5);
    scene.add(fillLight);

    var leftSideLight = new THREE.DirectionalLight(0xffffff, 0.4);
    leftSideLight.position.set(-1, 0.3, -0.5);
    scene.add(leftSideLight);

    var rightSideLight = new THREE.DirectionalLight(0xffffff, 0.4);
    rightSideLight.position.set(1, 0.3, -0.5);
    scene.add(rightSideLight);

    // Invisible face occluder
    occluderGeometry = new THREE.BufferGeometry();
    var occluderMat = new THREE.MeshBasicMaterial({
      colorWrite: false,
      depthWrite: true,
      depthTest: true,
      side: THREE.DoubleSide
    });
    occluderMesh = new THREE.Mesh(occluderGeometry, occluderMat);
    occluderMesh.renderOrder = 0;
    occluderMesh.frustumCulled = false;
    scene.add(occluderMesh);

    resizeRenderer();
  }

  function ensureOccluder() {
    if (occluderMesh && occluderGeometry) return;

    var THREE = window.THREE;
    occluderGeometry = new THREE.BufferGeometry();
    var occluderMat = new THREE.MeshBasicMaterial({
      colorWrite: false,
      depthWrite: true,
      depthTest: true,
      side: THREE.DoubleSide
    });
    occluderMesh = new THREE.Mesh(occluderGeometry, occluderMat);
    occluderMesh.renderOrder = 0;
    occluderMesh.frustumCulled = false;
    occluderIndexSet = false;
    scene.add(occluderMesh);
  }

  function resizeRenderer() {
    if (!renderer || !viewport) return;
    var rect = viewport.getBoundingClientRect();
    if (rect.width === 0 || rect.height === 0) return;
    renderer.setSize(rect.width, rect.height);
    threeCamera.aspect = rect.width / rect.height;
    threeCamera.updateProjectionMatrix();
  }

