     ======================================== */
  function loadThreeScripts() {
    if (window.THREE && window.THREE.GLTFLoader) return Promise.resolve();
    return loadScript('https://unpkg.com/three@0.128.0/build/three.min.js')
      .then(function() {
        return loadScript('https://unpkg.com/three@0.128.0/examples/js/loaders/GLTFLoader.js');
      });
  }

