{% comment %}
  Meave sofa-cover wizard – same look & feel as the lamp wizard (right-hand
  slide-out, numbered step tabs, colour swatches, cart-style summary), but
  driven by the CURRENT sofa-cover product's own colour + size variants.

  Flow: 1 Colour → 2 Size (bundle a cover per part of the sofa) → 3 Overview.
  Colours are de-duplicated. Each size the shopper adds becomes its own line
  item, so a full sofa can be covered in one go. Variant ids come straight
  from Shopify — no codes by hand.

  Reuses meave-lamp-wizard.css for the shell so it matches the lamp wizard
  exactly; meave-sofa-wizard.css only adds the size rows + size guide.

  @param {object} block   - meave_sofa_wizard block settings
  @param {object} product - Current sofa-cover product
{% endcomment %}

{%- liquid
  assign colour_pos = 0
  assign size_pos = 0
  for opt in product.options_with_values
    assign on = opt.name | downcase
    if colour_pos == 0
      if on contains 'kleur'
        assign colour_pos = forloop.index
      elsif on contains 'colour'
        assign colour_pos = forloop.index
      elsif on contains 'color'
        assign colour_pos = forloop.index
      endif
    endif
    if size_pos == 0
      if on contains 'maat'
        assign size_pos = forloop.index
      elsif on contains 'afmeting'
        assign size_pos = forloop.index
      elsif on contains 'size'
        assign size_pos = forloop.index
      elsif on contains 'zit'
        assign size_pos = forloop.index
      endif
    endif
  endfor
  if colour_pos == 0
    assign colour_pos = 1
  endif
  if size_pos == 0
    if product.options.size > 1
      assign size_pos = 2
    else
      assign size_pos = 1
    endif
  endif
  assign ci = colour_pos | minus: 1
  assign si = size_pos | minus: 1
  assign size_values = product.options_with_values[si].values
  assign btn_label = block.settings.button_label | default: 'Customise yours'
  assign after_add = block.settings.after_add | default: 'checkout'

  comment
    single : whole-sofa cover, pick ONE size (seat-count or plain dimensions)
    hybrid : whole-sofa cover sized by dimensions + optional cushion covers
    bundle : per-part cover (seat cushion / backrest / headrest / chaise)
  endcomment
  assign has_part = false
  assign has_cushion = false
  for sv in size_values
    assign svd = sv | downcase
    if svd contains 'backrest' or svd contains 'headrest' or svd contains 'chaise' or svd contains 'longue' or svd contains 'seat cushion'
      assign has_part = true
    elsif svd contains 'cushion'
      assign has_cushion = true
    endif
  endfor
  assign size_mode = 'single'
  if has_part
    assign size_mode = 'bundle'
  elsif has_cushion
    assign size_mode = 'hybrid'
  endif
-%}

<meave-sofa-wizard
  class="mlw"
  data-after-add="{{ after_add }}"
  data-title="{{ btn_label | escape }}"
  data-mode="{{ size_mode }}"
  data-set2-code="{{ block.settings.set2_discount_code | default: 'SOFA-SET-10' | escape }}"
  data-set3-code="{{ block.settings.set3_discount_code | default: 'SOFA-SET-15' | escape }}"
  {{ block.shopify_attributes }}
>
  <script type="application/json" data-msw-variants>
    [
      {%- for v in product.variants -%}
        {%- if v.image -%}{%- assign vimg = v.image | image_url: width: 300 -%}{%- else -%}{%- assign vimg = product.featured_image | image_url: width: 300 -%}{%- endif -%}
        {"id":{{ v.id }},"c":{{ v.options[ci] | default: '' | json }},"s":{{ v.options[si] | default: '' | json }},"price":{{ v.price }},"pf":{{ v.price | money | strip_html | json }},"av":{{ v.available }},"img":{{ vimg | json }}}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>

  {%- assign upsell_items = block.settings.upsell_products -%}
  {%- if upsell_items and upsell_items.size > 0 -%}
    <script type="application/json" data-msw-upsell>
      [
        {%- assign u = 0 -%}
        {%- for up in upsell_items -%}
          {%- if up == blank or up.available == false -%}{%- continue -%}{%- endif -%}
          {%- assign uv = up.selected_or_first_available_variant | default: up.variants.first -%}
          {%- if uv == blank -%}{%- continue -%}{%- endif -%}
          {%- if u > 0 -%},{%- endif -%}
          {"id":{{ uv.id }},"title":{{ up.title | json }},"pf":{{ up.price | money | strip_html | json }},"price":{{ up.price }},"img":{{ up.featured_image | image_url: width: 200 | json }}}
          {%- assign u = u | plus: 1 -%}
        {%- endfor -%}
      ]
    </script>
  {%- endif -%}

  <button type="button" class="mlw-trigger{% unless product.available %} mlw-trigger--soldout{% endunless %}"
    {% if product.available %}data-msw-open aria-haspopup="dialog"{% else %}disabled aria-disabled="true"{% endif %}>
    {%- if product.available -%}<span class="mlw-trigger__wave" aria-hidden="true"></span>{%- endif -%}
    <span class="mlw-trigger__label">
      {%- if product.available -%}{{ btn_label }}{%- else -%}{{ 'products.product.sold_out' | t | default: 'Sold out' }}{%- endif -%}
    </span>
  </button>

  {%- if product.available -%}
    <div class="mlw-sticky" data-msw-sticky aria-hidden="true">
      <div class="mlw-sticky__inner">
        <div class="mlw-sticky__info">
          <span class="mlw-sticky__name">{{ product.title }}</span>
          <span class="mlw-sticky__price"><span class="mlw-sticky__now">From {{ product.price | money }}</span></span>
        </div>
        <button type="button" class="mlw-sticky__btn" data-msw-sticky-open>
          <span class="mlw-sticky__btn-label">{{ btn_label }}</span>
          <span class="mlw-sticky__btn-price" aria-hidden="true"><span class="mlw-sticky__btn-now">From {{ product.price | money }}</span></span>
        </button>
      </div>
    </div>
  {%- endif -%}

  <div class="mlw-root" data-msw-root hidden aria-hidden="true">
    <div class="mlw-overlay" data-msw-close tabindex="-1"></div>

    <aside class="mlw-panel" role="dialog" aria-modal="true" aria-label="{{ btn_label | escape }}">
      <header class="mlw-head">
        <button type="button" class="mlw-back" data-msw-back aria-label="Back" hidden>
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <span class="mlw-head__title">{{ btn_label }}</span>
        <button type="button" class="mlw-close" data-msw-close aria-label="Close">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </header>

      <nav class="mlw-tabs" aria-label="Steps">
        <button type="button" class="mlw-tab is-active" data-msw-tab="1">
          <span class="mlw-tab__num">1.</span><span class="mlw-tab__txt">Colour</span>
        </button>
        <button type="button" class="mlw-tab" data-msw-tab="2">
          <span class="mlw-tab__num">2.</span><span class="mlw-tab__txt">Size</span>
        </button>
        <button type="button" class="mlw-tab" data-msw-tab="3">
          <span class="mlw-tab__num">3.</span><span class="mlw-tab__txt">Overview</span>
        </button>
      </nav>

      <div class="mlw-body">
        {%- comment -%} STEP 1: COLOUR {%- endcomment -%}
        <section class="mlw-step is-active" data-msw-step="1">
          <div class="mlw-preview" aria-hidden="true"><img data-msw-preview src="" alt=""></div>
          <div class="mlw-picker">
            <div class="mlw-step__intro">
              <h3 class="mlw-step__title">Choose your colour</h3>
            </div>
            <div class="mlw-colors" data-msw-colors role="radiogroup" aria-label="Colour"></div>
            <div class="msw-inline-size" data-msw-sizes-inline hidden></div>
          </div>
        </section>

        {%- comment -%} STEP 2: SIZE (bundle a cover per part) {%- endcomment -%}
        <section class="mlw-step" data-msw-step="2" hidden>
          <div class="mlw-step__intro">
            <h3 class="mlw-step__title">Choose your size<span class="msw-colour-tag" data-msw-colour-label></span></h3>
            <p class="mlw-step__sub" data-msw-sub></p>
          </div>

          {%- comment -%} Size guide — only shown for per-part covers, collapsed by default {%- endcomment -%}
          <details class="msw-guide msw-guide--parts">
            <summary>
              <span>Size guide — which cover goes where</span>
              <svg class="msw-guide__chev" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="msw-guide__body">
              <svg class="msw-guide__svg" viewBox="0 0 500 360" role="img" aria-label="Sofa diagram labelling the backrest, armrest, seat cushion and scatter cushion">
                <g class="msw-sofa" fill="#f2efe9" stroke="#b3aaa0" stroke-width="2.4" stroke-linejoin="round">
                  <rect x="126" y="128" width="248" height="66" rx="22"/>
                  <rect x="98" y="156" width="44" height="104" rx="20"/>
                  <rect x="358" y="156" width="44" height="104" rx="20"/>
                  <rect x="128" y="182" width="244" height="84" rx="24"/>
                  <rect x="142" y="188" width="108" height="32" rx="12"/>
                  <rect x="250" y="188" width="108" height="32" rx="12"/>
                  <rect x="296" y="146" width="50" height="50" rx="13" transform="rotate(8 321 171)"/>
                  <line x1="150" y1="266" x2="150" y2="286"/>
                  <line x1="350" y1="266" x2="350" y2="286"/>
                </g>
                <g class="msw-lead" stroke="#a99f94" stroke-width="1.6" fill="none">
                  <path d="M128 66 L188 128"/>
                  <path d="M394 70 L330 150"/>
                  <path d="M86 300 L118 250"/>
                  <path d="M372 302 L300 232"/>
                </g>
                <g class="msw-dot" fill="#2b2620">
                  <circle cx="188" cy="128" r="3.4"/>
                  <circle cx="330" cy="150" r="3.4"/>
                  <circle cx="118" cy="250" r="3.4"/>
                  <circle cx="300" cy="232" r="3.4"/>
                </g>
                <g class="msw-pill" font-family="-apple-system, BlinkMacSystemFont, Helvetica, Arial, sans-serif">
                  <g transform="translate(90 52)"><rect x="-56" y="-17" width="112" height="34" rx="17"/><text>Backrest</text></g>
                  <g transform="translate(410 54)"><rect x="-74" y="-17" width="148" height="34" rx="17"/><text>Scatter cushion</text></g>
                  <g transform="translate(74 316)"><rect x="-52" y="-17" width="104" height="34" rx="17"/><text>Armrest</text></g>
                  <g transform="translate(374 318)"><rect x="-66" y="-17" width="132" height="34" rx="17"/><text>Seat cushion</text></g>
                </g>
              </svg>
              <p class="msw-guide__note">Measure the part you want to cover, then choose the matching size from the list below. Building a full set? Add one cover per part.</p>
            </div>
          </details>

          <div class="msw-sizes-grid" data-msw-sizes></div>
        </section>

        {%- comment -%} STEP 3: OVERVIEW — cart-style summary {%- endcomment -%}
        <section class="mlw-step" data-msw-step="3" hidden>
          <div class="mlw-step__intro">
            <h3 class="mlw-step__title" data-msw-ovtitle>Your selection</h3>
          </div>

          <div class="mlw-summary-card">
            <div class="mlw-lines" data-msw-lines></div>
            <div class="mlw-totals">
              <div class="mlw-totals__row mlw-totals__row--minor" data-msw-disc-row hidden>
                <span data-msw-disc-label>Bundle saving</span>
                <strong class="mlw-totals__save" data-msw-disc>—</strong>
              </div>
              <div class="mlw-totals__row mlw-totals__row--minor">
                <span>Shipping</span>
                <strong class="mlw-free">Free</strong>
              </div>
              <div class="mlw-totals__row mlw-totals__row--total">
                <span>Total</span>
                <strong data-msw-total>—</strong>
              </div>
            </div>
          </div>

          <div class="mlw-upsell" data-msw-upsell-wrap hidden>
            <h4 class="mlw-upsell__title">Often bought together</h4>
            <div class="mlw-upsell__grid" data-msw-upsell-grid></div>
          </div>

          <p class="mlw-ship-note">Ships within 24 hours</p>

          <ul class="mlw-usps" aria-label="Why shop with us">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l9-4.5L21 8v8.5L12 21l-9-4.5z"/><path d="M3 8l9 4.5L21 8"/><path d="M12 12.5V21"/></svg>
              <span>Free UK delivery</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="5" width="17" height="15" rx="2.5"/><path d="M8 3.5v3M16 3.5v3M3.5 10h17"/></svg>
              <span>30-day returns</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="M9.2 12l2 2 3.6-3.8"/></svg>
              <span>Machine washable</span>
            </li>
          </ul>
        </section>
      </div>

      <footer class="mlw-foot">
        <p class="mlw-trust" data-msw-trust>Free UK delivery · 30-day returns · Machine washable</p>
        <button type="button" class="mlw-next" data-msw-next>Next</button>
        <button type="button" class="mlw-add" data-msw-add hidden>
          <span class="mlw-add__label">Checkout</span>
          <span class="mlw-add__spinner" aria-hidden="true"></span>
        </button>
        <p class="mlw-paypal" data-msw-paypal hidden>
          <svg class="mlw-paypal__lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
          <span>Secure checkout with</span>
          <span class="mlw-paypal__brand">
            <svg class="mlw-paypal__logo" viewBox="0 0 24 24" aria-hidden="true"><path fill="#003087" d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106z"/><path fill="#0070e0" d="M21.222 6.917a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527-.336 2.133a.563.563 0 0 0 .556.647h3.882c.46 0 .85-.334.922-.788l.038-.207.731-4.632.047-.255a.932.932 0 0 1 .922-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"/></svg>
            <span class="mlw-paypal__word"><span class="a">Pay</span><span class="b">Pal</span></span>
          </span>
        </p>
        <p class="mlw-error" data-msw-error hidden></p>
      </footer>
    </aside>
  </div>

  {{ 'meave-lamp-wizard.css' | asset_url | stylesheet_tag }}
  {{ 'meave-sofa-wizard.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'meave-sofa-wizard.js' | asset_url }}" defer></script>
</meave-sofa-wizard>
