{%- doc -%}
  Renders a feature-rich product card with media, pricing, and interactive elements for collection grids and product listings.

  Supports quick add functionality, variant swatches, ratings, badges, countdown timers, and responsive layouts with hover effects.

  @param {object} product - Shopify product object to display
  @param {string} product_id - Unique product identifier for component targeting
  @param {string} section_id - Section identifier for component namespacing
  @param {string} [block_id] - Optional block identifier for additional uniqueness
  @param {string} [image_ratio] - Image aspect ratio ('square', 'landscape', 'portrait')
  @param {boolean} [image_fill] - Crop images to fill container
  @param {boolean} [lazy_load] - Enable lazy loading (reserved for future use)
  @param {boolean} [show_secondary_image] - Show hover image carousel
  @param {boolean} [show_vendor] - Display product vendor name
  @param {boolean} [show_rating] - Show product ratings from metafields
  @param {boolean} [show_quick_add] - Display quick add button
  @param {boolean} [show_quick_view] - Enable quick view modal
  @param {boolean} [show_color_swatches] - Show color variant swatches
  @param {boolean} [show_countdown] - Display countdown timer
  @param {boolean} [show_save_amount] - Show savings badge
  @param {boolean} [show_icon_list] - Display feature icons from metafields
  @param {string} [save_type] - Savings calculation method for badges
  @param {boolean} [mobile_quick_add] - Add mobile-specific quick add button
  @param {string} [amount_type] - Savings display format for badges
  @param {string} [display_mode] - Rating display mode ('count' or value)

  @example
  {% render 'product-card',
     product: product,
     product_id: product.id,
     section_id: section.id,
     image_ratio: 'square'
  %}
{%- enddoc -%}

{%- if product != blank -%}
  {%- liquid
    assign featured_media = product.featured_media
    assign product_media = product.media
    assign media_count = product_media.size

    assign product_url = product.url | within: collection
    if settings.product_disable_collection_portion
      assign product_url = product.url
    endif
  -%}

  {%- comment -%} Variant image matching: show variant image when color filter is active {%- endcomment -%}
  {%- liquid
    assign matched_variant = nil
    assign active_filter_color = blank
    assign swatch_triggers = 'products.general.color_swatch_trigger' | t | downcase | split: ','

    for filter in collection.filters
      assign filter_lbl = filter.label | downcase
      assign is_color_filter = false
      for trigger in swatch_triggers
        assign trigger_clean = trigger | strip
        if filter_lbl contains trigger_clean
          assign is_color_filter = true
          break
        elsif trigger_clean == 'color' and filter_lbl contains 'colour'
          assign is_color_filter = true
          break
        endif
      endfor
      if is_color_filter and filter.active_values.size > 0
        assign active_filter_color = filter.active_values[0].label
        break
      endif
    endfor

    if active_filter_color != blank
      assign active_filter_color_dc = active_filter_color | downcase
      assign color_option_idx = -1

      for option in product.options_with_values
        assign opt_name_dc = option.name | downcase
        for trigger in swatch_triggers
          assign trigger_clean = trigger | strip
          if opt_name_dc contains trigger_clean
            assign color_option_idx = forloop.parentloop.index0
            break
          elsif trigger_clean == 'color' and opt_name_dc contains 'colour'
            assign color_option_idx = forloop.parentloop.index0
            break
          endif
        endfor
        if color_option_idx >= 0
          break
        endif
      endfor

      for variant in product.variants
        assign variant_match = false
        if color_option_idx >= 0
          assign variant_color_dc = variant.options[color_option_idx] | downcase
          if variant_color_dc == active_filter_color_dc
            assign variant_match = true
          endif
        endif
        unless variant_match
          assign metafield_color_dc = variant.metafields.custom.kleur | downcase
          if metafield_color_dc == active_filter_color_dc
            assign variant_match = true
          endif
        endunless
        if variant_match and variant.featured_media
          assign featured_media = variant.featured_media
          assign matched_variant = variant
          assign product_url = product_url | split: '?' | first | append: '?variant=' | append: variant.id
          break
        endif
      endfor
    endif
  -%}

  {%- comment -%} Determine hover media, scoped to the matched variant when present {%- endcomment -%}
  {%- liquid
    assign hover_media = nil

    if matched_variant != nil
      if matched_variant.metafields.theme.gang_media.value != blank and matched_variant.metafields.theme.gang_media.list?
        for media in matched_variant.metafields.theme.gang_media.value
          unless media.id == featured_media.id
            assign hover_media = media
            break
          endunless
        endfor
      endif

      if hover_media == nil
        for media in product.media
          unless media.id == featured_media.id
            assign include_media = false
            if media.alt contains '#'
              assign gang_connect_alt = media.alt | split: '#' | last
              assign gang_connect_list = gang_connect_alt | split: ','
              for gang_connect_value in gang_connect_list
                assign gang_connect_item = gang_connect_value
                if gang_connect_item contains ':' and localization.language.iso_code != blank
                  assign gang_split_param = localization.language.iso_code | append: ':'
                  assign gang_connect_item = gang_connect_item | split: gang_split_param | last
                endif
                if gang_connect_item contains '_'
                  assign gang_option_name = gang_connect_item | split: '_' | first | handleize
                  for option_name in product.options
                    assign option_name_handlized = option_name | handleize | replace: '_', '-'
                    if option_name_handlized == gang_option_name
                      assign option_key = 'option' | append: forloop.index
                      assign current_option_value = matched_variant[option_key] | handleize
                      assign current_connect = option_name_handlized | append: '_' | append: current_option_value
                      if gang_connect_item == current_connect
                        assign include_media = true
                      endif
                      break
                    endif
                  endfor
                endif
                if include_media
                  break
                endif
              endfor
            endif
            if include_media
              assign hover_media = media
              break
            endif
          endunless
        endfor
      endif

      if hover_media == nil
        # Positional fallback: the media immediately after the variant featured media, skipping other variants' featured images and 3D models
        assign other_variant_featured_ids = ''
        for variant in product.variants
          if variant.id != matched_variant.id and variant.featured_media
            assign other_variant_featured_ids = other_variant_featured_ids | append: ',' | append: variant.featured_media.id | append: ','
          endif
        endfor

        assign past_featured = false
        for media in product.media
          if past_featured
            assign this_id_token = ',' | append: media.id | append: ','
            unless other_variant_featured_ids contains this_id_token
              if media.media_type != 'model'
                assign hover_media = media
                break
              endif
            endunless
          endif
          if media.id == featured_media.id
            assign past_featured = true
          endif
        endfor
      endif
    else
      for media in product_media
        if media.id != featured_media.id
          assign hover_media = media
          break
        endif
      endfor
    endif

    assign show_hover_media = false
    if show_secondary_image and hover_media and hover_media.media_type != 'model'
      assign show_hover_media = true
    endif
  -%}
  <div class="card product-card product-card--{{ settings.card_style }}{% if settings.card_border_thickness > 0 %} product-card--thickness{% endif %}{% unless featured_media %} no-media{% endunless %}{% if product.available and show_quick_add and mobile_quick_add %} mobile:with-quick-add{% endif %} flex flex-col leading-none relative">
    {%- if featured_media -%}
      <div class="product-card__media relative h-auto">
        {%- if show_quick_view -%}
          {%- capture quick_view_id -%}Quickview-{{ section_id }}{% if block_id != blank %}-{{ block_id }}{% endif %}-{{ product_id }}{%- endcapture -%}
          <button type="button" class="quick-view__button button button--secondary z-2 absolute top-0 right-0 opacity-0" is="hover-button" aria-controls="{{ quick_view_id }}" aria-expanded="false">
            <span class="btn-fill" data-fill></span>
            <span class="btn-text">
              {%- render 'icon', icon: 'eye', size: 'sm' -%}
              <span class="sr-only">{{ 'products.product.quick_view' | t }}</span>
            </span>
          </button>
          <quick-view id="{{ quick_view_id }}" class="quick-view x-modal drawer z-40 fixed bottom-0 left-0 h-full w-full pointer-events-none" data-product-url="{{ product_url }}" role="dialog" aria-label="{{ 'products.product.choose_product_options' | t: product_name: product.title | escape }}" aria-modal="true" hidden>
            <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="{{ quick_view_id }}" aria-expanded="false"></overlay-element>
            <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
              <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative">
                <button class="button button--secondary button--close drawer__close z-1 absolute top-0 right-0 flex items-center justify-center opacity-0" type="button" is="hover-button" aria-controls="{{ quick_view_id }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">
                    {%- render 'icon', icon: 'close', size: 'sm' -%}
                  </span>
                </button>
              </gesture-element>
              <div class="quick-view__content drawer__content opacity-0 invisible flex flex-col h-full grow shrink"></div>
            </div>
          </quick-view>
        {%- endif -%}

        {%- if show_rating -%}
          {%- liquid
            assign rating_max = 5
          
            if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count.value > 0
              assign rating_value = product.metafields.reviews.rating.value.rating | round: 1
              assign rating_count = product.metafields.reviews.rating_count.value
              assign rating_max = product.metafields.reviews.rating.value.scale_max
            else
              assign hide_rating = true
            endif
          -%}
          
          {%- unless hide_rating -%}
            <div class="rating product-card__rating z-2 absolute rounded-full flex items-center gap-2 md:gap-1d5 pointer-events-none" title="{{ 'general.accessibility.star_reviews_count' | t: count: rating_count | escape }}">
              <span role="img" aria-label="{{ 'general.accessibility.star_reviews_info' | t: rating_value: rating_value, rating_max: rating_max }}">
                {%- render 'icon', icon: 'star', size: 'xs' -%}
              </span>
              {%- liquid
                if display_mode == 'count'
                  echo 'general.accessibility.star_reviews_count' | t: count: rating_count
                else
                  echo rating_value
                endif
              -%}
            </div>
          {%- endunless -%}
        {%- endif -%}

        {%- render 'product-badges', product: product, show_save_amount: show_save_amount, save_type: save_type, class: 'z-2 absolute grid gap-3' -%}

        {%- render 'kinderbril-leeftijd-tag', product: product, context: 'card' -%}

        <a class="block relative media media--{{ image_ratio }}{% unless image_fill %} media--contain{% endunless %}{% unless show_hover_media %} overflow-hidden{% endunless %}" href="{{ product_url }}" aria-label="{{ product.title | escape }}" tabindex="-1">
          {%- unless featured_media.media_type == 'video' or featured_media.media_type == 'external_video' -%}
            {%- if show_hover_media -%}
              <template>
                <div class="media media--height{% unless image_fill %} media--contain{% endunless %} w-full h-full overflow-hidden">
                  {{- featured_media | image_url: width: featured_media.width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', is: 'lazy-image' -}}
                </div>
                {%- if matched_variant -%}
                  <div class="media media--height{% unless image_fill %} media--contain{% endunless %} w-full h-full overflow-hidden">
                    {{- hover_media | image_url: width: hover_media.width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', is: 'lazy-image' -}}
                  </div>
                {%- else -%}
                  {%- assign carousel_count = 1 -%}
                  {%- for media in product_media -%}
                    {%- if media.id != featured_media.id and carousel_count < 4 -%}
                      {%- assign carousel_count = carousel_count | plus: 1 -%}
                      <div class="media media--height{% unless image_fill %} media--contain{% endunless %} w-full h-full overflow-hidden">
                        {{- media | image_url: width: media.width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', is: 'lazy-image' -}}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              </template>
              <secondary-media class="product-card__carousel block absolute top-0 left-0 w-full h-full hidden md:block"></secondary-media>
            {%- endif -%}

            {{- featured_media | image_url: width: featured_media.width | image_tag: loading: 'lazy', widths: '180,360,540,720,900,1080', is: 'lazy-image' -}}
          {%- else -%}
            {%- render 'product-video',
              video: featured_media,
              muted: false,
              autoplay: false,
              loop: false,
              cover_image: featured_media,
              show_play_button: true,
              class: 'relative w-full overflow-hidden'
            -%}
          {%- endunless -%}
        </a>

        {%- if product.available -%}
          {%- if show_quick_add -%}
            <div class="quick-add flex justify-end md:justify-center absolute w-full z-1 pointer-events-none">
              {%- if product.variants.size == 1 -%}
                {%- capture product_form_id -%}QuickAddProductForm-{{ section_id }}-{{ product_id }}{%- endcapture -%}
                {%- form 'product', product, is: 'product-form', id: product_form_id -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
                  {%- liquid
                    if product.template_suffix != 'pre-order'
                      assign quick_add_label = 'products.product.add_to_cart' | t
                    else
                      assign quick_add_label = 'products.product.pre_order' | t
                    endif
                  -%}
                  <button type="submit" class="button button--primary pointer-events-auto md:opacity-0" is="hover-button" data-variant-id="{{ product.selected_or_first_available_variant.id }}" aria-label="{{ quick_add_label | escape }}">
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">
                      {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                      <span class="hidden md:block" data-sold-out="{{ 'products.product.sold_out' | t | escape }}">
                        {{- quick_add_label -}}
                      </span>
                    </span>
                  </button>
                {%- endform -%}
              {%- else -%}
                {%- if show_quick_view -%}
                  <button type="button" class="button button--primary pointer-events-auto md:opacity-0" is="hover-button" aria-controls="{{ quick_view_id }}" aria-expanded="false" aria-label="{{ 'products.product.choose_options' | t | escape }}">
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">
                      {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                      <span class="hidden md:block">
                        {{- 'products.product.choose_options' | t -}}
                      </span>
                    </span>
                  </button>
                {%- else -%}
                  <a href="{{ product_url }}" class="button button--primary pointer-events-auto md:opacity-0" is="hover-link" aria-label="{{ 'products.product.view_product' | t | escape }}">
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">
                      {%- render 'icon', icon: 'cart', size: 'sm', class: 'md:hidden' -%}
                      <span class="hidden md:block">
                        {{- 'products.product.view_product' | t -}}
                      </span>
                    </span>
                  </a>
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="quick-add flex justify-center absolute w-full z-1 pointer-events-none">
            <button type="button" class="button button--secondary button--blur" disabled="disabled">
              {{- 'products.product.sold_out' | t -}}
            </button>
          </div>
        {%- endif -%}

        {%- if show_countdown and product.metafields.theme.countdown.value != blank -%}
          {%- liquid
            assign now_time = 'now' | date: '%s' | times: 1
            assign countdown_time = product.metafields.theme.countdown.value | date: '%s' | times: 1
          -%}
          {%- if countdown_time > now_time -%}
            <div class="product-card__countdown hidden sm:flex justify-center absolute w-full z-0 pointer-events-none no-js-hidden">
              <div class="button icon-with-text">
                <div class="btn-text">
                  {%- render 'icon', icon: 'countdown-compact', size: 'sm', class: 'shrink-0 hidden md:block' -%}
                  <countdown-timer
                    class="flex gap-3"
                    data-expires="{{ product.metafields.theme.countdown.value | date: '%FT%T%:z' | escape }}"
                    data-compact="true"
                  >
                    <div class="countdown__item">
                      <p>--{{ 'general.date.d' | t }}</p>
                    </div>
                    <div class="countdown__item">
                      <p>--{{ 'general.date.h' | t }}</p>
                    </div>
                    <div class="countdown__item">
                      <p>--{{ 'general.date.m' | t }}</p>
                    </div>
                    <div class="countdown__item">
                      <p>--{{ 'general.date.s' | t }}</p>
                    </div>
                  </countdown-timer>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="product-card__media h-auto overflow-hidden">
        <span class="block aspect-{{ image_ratio }}"></span>
      </div>
    {%- endif -%}
    <div class="product-card__content grow flex flex-col{% if featured_media %} justify-start text-{{ settings.card_text_alignment }}{% else %} justify-center items-center absolute top-0 left-0 w-full h-full{% endif %}">
      {%- if show_vendor -%}
        <div class="product-card__top w-full">
          <span class="sr-only">{{ 'general.accessibility.vendor' | t }}</span>
          {{- product.vendor | link_to_vendor : class: "caption reversed-link uppercase leading-none tracking-widest" -}}
        </div>
      {%- endif -%}

      <div class="product-card__details flex flex-col lg:flex-row items-baseline gap-2 w-full">
        <p class="grow">
          <a class="product-card__title reversed-link text-base-xl font-medium leading-tight" href="{{ product_url }}">
            {{- product.title | escape -}}
          </a>
        </p>
        {%- render 'product-price', product: product, class: 'flex flex-wrap lg:flex-col lg:items-end gap-2 md:gap-1d5' -%}
        {%- if product.quantity_price_breaks_configured? -%}
          <div class="text-sm font-medium leading-tight">{{ 'products.volume_pricing.note' | t }}</div>
        {%- endif -%}
      </div>

      {%- if show_color_swatches -%}
        {%- liquid
          assign swatch_trigger_list = 'products.general.color_swatch_trigger' | t | downcase | split: ','
          assign color_count = 0
        -%}
        {%- for option in product.options_with_values -%}
          {%- liquid
            assign is_color = false
            assign option_name = option.name | downcase
            for trigger in swatch_trigger_list
              assign swatch_trigger = trigger | strip
              if option_name contains swatch_trigger
                assign is_color = true
              elsif swatch_trigger == 'color' and option_name contains 'colour'
                assign is_color = true
              endif

              if is_color == true
                break
              endif
            endfor
          -%}
          {%- if is_color -%}
            {%- liquid
              assign option_index = forloop.index0
              assign values = ''
              assign max_color_count = settings.product_max_color_swatches
            -%}
            <div class="product-card__bottom flex items-center gap-2">
              <ul class="swatches swatches--{{ settings.rounded_swatch }}{% if settings.product_color_swatch_type == 'variant' %} swatches--variant{% endif %} swatches--{{ product.id }} inline-flex items-start gap-2">
                {%- for variant in product.variants -%}
                  {%- assign value = variant.options[option_index] %}
                  {%- unless values contains value -%}
                    {%- liquid
                      assign values = values | join: ',' | append: ',' | append: value | split: ','
                      assign color_count = color_count | plus: 1
                      assign color_title = product.title | append: ' - ' | append: value
                      assign color_url = variant.url | within: collection
                      if settings.product_disable_collection_portion
                        assign color_url = variant.url
                      endif

                      assign swatch = blank
                      if value.swatch != blank
                        assign swatch = value.swatch
                      endif

                      if settings.product_color_swatch_type == 'variant' and variant.image
                        assign swatch = variant
                      endif
                    -%}
                    {%- if color_count <= max_color_count -%}
                      <li>
                        {%- render 'swatch', href: color_url, title: color_title, value: value, value_label: value, swatch: swatch -%}
                      </li>
                    {%- endif -%}
                  {%- endunless -%}
                {%- endfor -%}
              </ul>
              {%- if color_count > max_color_count -%}
                <a href="{{ product_url }}" class="reversed-link font-medium text-xs text-opacity leading-none tracking-widest" is="hover-link" aria-controls="{{ quick_view_id }}" aria-expanded="false">+{{ color_count | minus: max_color_count }}</a>
              {%- endif -%}
            </div>
            {%- if color_count < 1 -%}
              <style>
                .swatches--{{ product.id }} { display: none; }
              </style>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if show_icon_list -%}
      {%- if settings.product_icon_list_metafield != blank -%}
        {%- liquid
          assign metafield_parts = settings.product_icon_list_metafield | split: '.'
          assign metafield_namespace = metafield_parts | first
          assign metafield_key = metafield_parts | last
          assign product_icon_list_metafield = product.metafields[metafield_namespace][metafield_key]
        -%}
        {%- if product_icon_list_metafield.value != blank and product_icon_list_metafield.list? -%}
          <scroll-shadow class="product-card__spec block overflow-hidden">
            <div class="product-card__icons{% unless settings.product_icon_list_carousel %} product-card__icons--grid md:grid md:grid-cols-2{% endunless %} flex flex-nowrap" is="icons-carousel" tabindex="0">
              {%- for item in product_icon_list_metafield.value limit: settings.product_icon_list_max -%}
                <div class="product-card__icon shrink-0">
                  <div class="flex flex-col items-center md:flex-row md:items-start gap-2">
                    {%- if item.icon != blank -%}
                      <figure class="shrink-0 media media--transparent relative inline-block">
                        {{- item.icon | image_url: width: item.icon.width | image_tag: loading: 'lazy', sizes: '24px', widths: '80,96,160,192', class: 'w-full h-full', is: 'lazy-image' -}}
                      </figure>
                    {%- endif -%}
                    <div class="flex flex-col items-center md:items-start gap-1 text-center md:text-left text-xs font-medium leading-none">
                      {{- item.title -}}
                      {%- if item.description != blank -%}
                        <p class="text-opacity font-normal text-3xs leading-tight">{{ item.description }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
            <template>
              <slot></slot>
              <s dir="{% render 'direction' %}" style="--t: 0;--b: 0;--l: 0;--r: 0;">
                <span class="l"></span>
                <span class="r"></span>
              </s>
              <style>
                :host{display:inline-block;position:relative}:host([hidden]){display:none}
                s{position:absolute;inset:0;pointer-events:none;border-radius:var(--card-shadow-radius);overflow:hidden;}
                s span{position:absolute;inset-block:0;width:clamp(var(--sp-12),4.73vw,var(--sp-23));opacity:0;transition:opacity var(--animation-short);}
                s .l{inset-inline-start:0;opacity:var(--l);background:linear-gradient(90deg,rgb(var(--color-background)) 0%,transparent 100%);}
                s .r{inset-inline-end:0;opacity:var(--r);background:linear-gradient(270deg,rgb(var(--color-background)) 0%,transparent 100%);}
                s[dir=rtl] :is(.icon-chevron-left,.icon-chevron-right){transform:scaleX(-1);}
              </style>
            </template>
          </scroll-shadow>
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}

    {%- if show_quick_add and mobile_quick_add -%}
      <div class="lg:hidden">
        {%- if product.available -%}
          {%- if product.variants.size == 1 -%}
            {%- capture product_form_id -%}MobileQuickAddProductForm-{{ section_id }}-{{ product_id }}{%- endcapture -%}
            {%- form 'product', product, is: 'product-form', id: product_form_id -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
              <button type="submit" class="button button--primary button--small icon-with-text" is="hover-button" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- liquid
                    render 'icon', icon: 'plus', size: '2xs'
                    echo 'products.product.quick_add' | t
                  -%}
                </span>
              </button>
            {%- endform -%}
          {%- else -%}
            {%- if show_quick_view -%}
              <button type="button" class="button button--primary button--small icon-with-text" is="hover-button" aria-controls="{{ quick_view_id }}" aria-expanded="false">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- liquid
                    render 'icon', icon: 'plus', size: '2xs'
                    echo 'products.product.quick_view' | t
                  -%}
                </span>
              </button>
            {%- else -%}
              <a href="{{ product.url }}" class="button button--primary button--small icon-with-text" is="hover-link">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- liquid
                    render 'icon', icon: 'plus', size: '2xs'
                    echo 'products.product.quick_view' | t
                  -%}
                </span>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- else -%}
          <span class="button button--primary button--small" disabled="disabled">
            {{- 'products.product.sold_out' | t -}}
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
{%- else -%}
  {%- render 'product-card-placeholder', placeholder: 'product-1', image_ratio: image_ratio, show_vendor: show_vendor -%}
{%- endif -%}