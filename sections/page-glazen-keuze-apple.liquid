{% comment %}
  JACQ — Page: Glazen (Apple)
  Layout consistent with Over Ons:
  - Hero image w/ overlay
  - Alternating two-col blocks
  - Center band
  - 4 glass cards (like wizard)
  - Subtle reveal
{% endcomment %}

<section class="jacq-apple ja-glazen" data-section-id="{{ section.id }}">

  <!-- HERO -->
  <header class="ja-hero">
    {% if section.settings.hero_image != blank %}
      <div class="ja-hero__media" aria-hidden="true">
        {{ section.settings.hero_image | image_url: width: 2400 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '800, 1200, 1600, 2000, 2400',
          alt: section.settings.hero_image_alt | escape
        }}
      </div>
    {% endif %}

    <div class="ja-hero__overlay">
  <div class="ja-wrap">
    <div class="ja-hero__content ja-reveal">
      <p class="ja-eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
      <h1 class="ja-h1">{{ section.settings.hero_title | escape }}</h1>
      {% if section.settings.hero_subtitle != blank %}
        <p class="ja-lead">{{ section.settings.hero_subtitle | escape }}</p>
      {% endif %}
    </div>
  </div>
</div>
  </header>

  <!-- INTRO SPLIT (text left, image right) -->
  <section class="ja-wrap ja-two-col ja-block ja-reveal">
    <div class="ja-col">
      <h2 class="ja-h2">{{ section.settings.s1_title | escape }}</h2>
      <div class="ja-richtext">
        {{ section.settings.s1_text }}
      </div>
    </div>

    <div class="ja-col ja-col--media">
      {% if section.settings.s1_image != blank %}
        {{ section.settings.s1_image | image_url: width: 1600 | image_tag:
          loading: 'lazy',
          sizes: '(min-width: 990px) 40vw, 100vw',
          widths: '600, 900, 1200, 1600',
          alt: section.settings.s1_image_alt | escape
        }}
      {% endif %}
    </div>
  </section>

  <!-- CENTER BAND -->
  <section class="ja-band ja-block">
    <div class="ja-wrap ja-center ja-reveal">
      <h2 class="ja-h2">{{ section.settings.band_title | escape }}</h2>
      <div class="ja-richtext ja-richtext--center">
        {{ section.settings.band_text }}
      </div>
    </div>
  </section>

  <!-- CARDS: 4 GLASS OPTIONS -->
  <section class="ja-wrap ja-block ja-reveal">
    <div class="ja-cards__head ja-center">
      <h2 class="ja-h2">{{ section.settings.cards_title | escape }}</h2>
      {% if section.settings.cards_subtitle != blank %}
        <p class="ja-sub">{{ section.settings.cards_subtitle | escape }}</p>
      {% endif %}
    </div>

    <div class="ja-glassgrid">
      {% for i in (1..4) %}
        {% capture t_id %}g{{ i }}_title{% endcapture %}
        {% capture p_id %}g{{ i }}_price{% endcapture %}
        {% capture s_id %}g{{ i }}_sub{% endcapture %}
        {% capture b_id %}g{{ i }}_bullets{% endcapture %}
        {% capture n_id %}g{{ i }}_note{% endcapture %}

        <article class="ja-gcard">
          <div class="ja-gcard__top">
            <h3 class="ja-h3">{{ section.settings[t_id] | escape }}</h3>
            <span class="ja-price">{{ section.settings[p_id] | escape }}</span>
          </div>

          {% if section.settings[s_id] != blank %}
            <p class="ja-kicker">{{ section.settings[s_id] | escape }}</p>
          {% endif %}

          {% if section.settings[b_id] != blank %}
            <ul class="ja-check">
              {{ section.settings[b_id] }}
            </ul>
          {% endif %}

          {% if section.settings[n_id] != blank %}
            <p class="ja-note">{{ section.settings[n_id] | escape }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </section>

  <!-- SPLIT 2 (image left on desktop, text right) -->
  <section class="ja-wrap ja-two-col ja-two-col--reverse ja-block ja-reveal">
    <div class="ja-col">
      <h2 class="ja-h2">{{ section.settings.s2_title | escape }}</h2>
      <div class="ja-richtext">
        {{ section.settings.s2_text }}
      </div>
    </div>

    <div class="ja-col ja-col--media">
      {% if section.settings.s2_image != blank %}
        {{ section.settings.s2_image | image_url: width: 1600 | image_tag:
          loading: 'lazy',
          sizes: '(min-width: 990px) 40vw, 100vw',
          widths: '600, 900, 1200, 1600',
          alt: section.settings.s2_image_alt | escape
        }}
      {% endif %}
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="ja-cta ja-block">
    <div class="ja-wrap ja-center ja-reveal">
      <h2 class="ja-h2 ja-h2--cta">{{ section.settings.cta_title | escape }}</h2>
      <div class="ja-richtext ja-richtext--center">
        {{ section.settings.cta_text }}
      </div>

      {% if section.settings.cta_button_label != blank and section.settings.cta_button_link != blank %}
        <a class="ja-btn" href="{{ section.settings.cta_button_link }}">
          {{ section.settings.cta_button_label | escape }}
        </a>
      {% endif %}
    </div>
  </section>

  <!-- BACK LINK -->
  {% assign back_url = section.settings.back_link %}
  {% if back_url == blank %}
    {% assign back_url = '/pages/onze-brillen-op-sterkte' %}
  {% endif %}
  <footer class="ja-wrap ja-sign ja-reveal">
    <a class="ja-backlink" href="{{ back_url }}">← Terug naar Onze brillen op sterkte</a>
  </footer>

</section>

<style>
  /* Base (same vibe as Over Ons) */
  .jacq-apple.ja-glazen{
    --ja-max: 1120px;
    --ja-pad: clamp(18px, 3.2vw, 28px);
    --ja-gap: clamp(18px, 3.2vw, 48px);
    --ja-radius: 20px;
    --ja-bg: #ffffff;
    --ja-band: #f5f5f7;
    --ja-text: rgba(0,0,0,.88);
    --ja-muted: rgba(0,0,0,.62);
    --ja-hairline: rgba(0,0,0,.10);
    background: var(--ja-bg);
    color: var(--ja-text);
  }
  .jacq-apple.ja-glazen *{ box-sizing:border-box; }

  .jacq-apple.ja-glazen .ja-wrap{
    max-width: var(--ja-max);
    margin: 0 auto;
    padding-left: max(var(--ja-pad), env(safe-area-inset-left));
    padding-right: max(var(--ja-pad), env(safe-area-inset-right));
  }
  .jacq-apple.ja-glazen .ja-center{ text-align:center; }

  /* HERO */
  .jacq-apple.ja-glazen .ja-hero{ position:relative; overflow:hidden; background:var(--ja-band); }
  .jacq-apple.ja-glazen .ja-hero__media img{
    width:100%;
    height: clamp(420px, 52vw, 680px);
    object-fit:cover;
    display:block;
    transform: scale(1.02);
  }
  .jacq-apple.ja-glazen .ja-hero__overlay{
    position:absolute; inset:0;
    display:grid; align-content:end;
    padding-bottom: clamp(34px, 5vw, 56px);
    pointer-events:none;
    padding-left: max(var(--ja-pad), env(safe-area-inset-left));
    padding-right: max(var(--ja-pad), env(safe-area-inset-right));
  }
  .jacq-apple.ja-glazen .ja-eyebrow{
    margin:0 0 10px;
    font-size:13px; letter-spacing:.08em; text-transform:uppercase;
    color: rgba(255,255,255,.78);
    text-shadow: 0 1px 18px rgba(0,0,0,.32);
  }
  .jacq-apple.ja-glazen .ja-h1{
    margin:0 0 12px;
    font-size: clamp(34px, 5.0vw, 56px);
    line-height:1.05;
    letter-spacing:-0.025em;
    color:#fff;
    text-shadow: 0 1px 18px rgba(0,0,0,.38);
    max-width: 22ch;
  }
  .jacq-apple.ja-glazen .ja-lead{
    margin:0;
    font-size: clamp(16px, 1.6vw, 20px);
    line-height:1.55;
    color: rgba(255,255,255,.86);
    text-shadow: 0 1px 18px rgba(0,0,0,.32);
    max-width: 62ch;
  }

  .jacq-apple.ja-glazen .ja-block{ padding: clamp(54px, 7vw, 92px) 0; }

  /* Two col */
  .jacq-apple.ja-glazen .ja-two-col{
    display:grid;
    grid-template-columns: 1.05fr .95fr;
    gap: var(--ja-gap);
    align-items:center;
  }
  .jacq-apple.ja-glazen .ja-two-col--reverse{ grid-template-columns: .95fr 1.05fr; }
  @media (min-width: 990px){
    .jacq-apple.ja-glazen .ja-two-col--reverse .ja-col--media{ order:1; }
    .jacq-apple.ja-glazen .ja-two-col--reverse .ja-col:not(.ja-col--media){ order:2; }
  }
  .jacq-apple.ja-glazen .ja-col--media img{
    width:100%; height:auto; display:block;
    border-radius: var(--ja-radius);
  }

  /* Typography */
  .jacq-apple.ja-glazen .ja-h2{
    margin:0 0 14px;
    font-size: clamp(24px, 2.6vw, 34px);
    line-height:1.12;
    letter-spacing:-0.02em;
  }
  .jacq-apple.ja-glazen .ja-richtext{
    font-size:16px; line-height:1.75; color: var(--ja-text);
    max-width: 70ch;
  }
  .jacq-apple.ja-glazen .ja-richtext p{ margin:0 0 14px; }
  .jacq-apple.ja-glazen .ja-richtext p:last-child{ margin-bottom:0; }
  .jacq-apple.ja-glazen .ja-richtext--center{ margin:0 auto; }
  .jacq-apple.ja-glazen .ja-sub{
    margin: 6px auto 0;
    color: var(--ja-muted);
    max-width: 60ch;
    line-height: 1.6;
  }

  /* Band */
  .jacq-apple.ja-glazen .ja-band{
    background: var(--ja-band);
    border-top: 1px solid var(--ja-hairline);
    border-bottom: 1px solid var(--ja-hairline);
  }

  /* Glass cards */
  .jacq-apple.ja-glazen .ja-glassgrid{
    display:grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
    margin-top: 22px;
  }
  .jacq-apple.ja-glazen .ja-gcard{
    border:1px solid var(--ja-hairline);
    border-radius: var(--ja-radius);
    background:#fff;
    padding: 18px 18px 16px;
  }
  .jacq-apple.ja-glazen .ja-gcard__top{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap: 12px;
  }
  .jacq-apple.ja-glazen .ja-h3{
    margin:0;
    font-size: 18px;
    letter-spacing:-0.01em;
  }
  .jacq-apple.ja-glazen .ja-price{
    font-size: 14px;
    color: rgba(0,0,0,.72);
    border: 1px solid rgba(0,0,0,.14);
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(245,245,247,.75);
    white-space: nowrap;
  }
  .jacq-apple.ja-glazen .ja-kicker{
    margin: 10px 0 10px;
    font-size: 12px;
    letter-spacing:.08em;
    text-transform: uppercase;
    color: rgba(0,0,0,.55);
  }
  .jacq-apple.ja-glazen .ja-check{
    margin: 0;
    padding: 0;
    list-style: none;
    display:grid;
    gap: 8px;
  }
  .jacq-apple.ja-glazen .ja-check li{
    padding-left: 18px;
    position: relative;
    color: rgba(0,0,0,.78);
    line-height: 1.55;
    font-size: 14px;
  }
  .jacq-apple.ja-glazen .ja-check li:before{
    content:"";
    width: 10px; height: 6px;
    border-left: 2px solid rgba(0,0,0,.38);
    border-bottom: 2px solid rgba(0,0,0,.38);
    transform: rotate(-45deg);
    position:absolute;
    left: 0;
    top: .55em;
  }
  .jacq-apple.ja-glazen .ja-note{
    margin: 12px 0 0;
    color: rgba(0,0,0,.62);
    font-size: 13px;
    line-height: 1.55;
  }

  /* CTA */
  .jacq-apple.ja-glazen .ja-cta{
    background: var(--ja-band);
    border-top: 1px solid var(--ja-hairline);
  }
  .jacq-apple.ja-glazen .ja-h2--cta{ margin-bottom: 10px; }
  .jacq-apple.ja-glazen .ja-btn{
    display:inline-flex;
    align-items:center; justify-content:center;
    margin-top: 18px;
    padding: 12px 18px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.22);
    color: rgba(0,0,0,.86);
    text-decoration:none;
    background: rgba(255,255,255,.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .jacq-apple.ja-glazen .ja-btn:hover{ border-color: rgba(0,0,0,.35); }

  /* Footer */
  .jacq-apple.ja-glazen .ja-sign{
    padding: 44px 0 clamp(64px, 7vw, 96px);
    border-top: 1px solid var(--ja-hairline);
  }
  .jacq-apple.ja-glazen .ja-backlink{
    font-size: 14px;
    color: rgba(0,0,0,.72);
    text-decoration:none;
  }
  .jacq-apple.ja-glazen .ja-backlink:hover{ text-decoration:underline; }

  /* Reveal */
  .jacq-apple.ja-glazen .ja-reveal{
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 700ms ease, transform 700ms ease;
    will-change: opacity, transform;
  }
  .jacq-apple.ja-glazen .ja-reveal.is-visible{
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce){
    .jacq-apple.ja-glazen .ja-reveal{
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  /* Responsive */
  @media (max-width: 989px){
    .jacq-apple.ja-glazen .ja-two-col,
    .jacq-apple.ja-glazen .ja-two-col--reverse{
      grid-template-columns: 1fr;
      align-items: start;
    }
    .jacq-apple.ja-glazen .ja-richtext{ max-width: 100%; }
    .jacq-apple.ja-glazen .ja-glassgrid{ grid-template-columns: 1fr; }
  }
  /* === HERO ALIGNMENT (exact like Over Ons) === */
.jacq-apple.ja-glazen .ja-hero{
  position: relative;
  overflow: hidden;
}

/* de overlay zelf krijgt GEEN padding meer */
.jacq-apple.ja-glazen .ja-hero__overlay{
  position: absolute;
  inset: 0;
  display: grid;
  align-content: end;
  padding-bottom: clamp(34px, 5vw, 56px);
  pointer-events: none;

  /* belangrijk: geen left/right padding hier */
  padding-left: 0 !important;
  padding-right: 0 !important;
}

/* h1/lead niet door theme laten “centeren” */
.jacq-apple.ja-glazen .ja-hero__content *{
  text-align: left !important;
}
/* FIX: hero overlay mag GEEN horizontale padding hebben,
   want .ja-wrap doet dat al. Anders krijg je dubbel. */
.jacq-apple.ja-glazen .ja-hero__overlay{
  padding-left: 0 !important;
  padding-right: 0 !important;
}
/* === FINAL: hero text uses ONLY .ja-wrap for alignment === */
.jacq-apple.ja-glazen .ja-hero__overlay{
  padding-left: 0 !important;
  padding-right: 0 !important;
}

/* .ja-wrap bepaalt de gutters; content zelf niet meer */
.jacq-apple.ja-glazen .ja-hero__content{
  max-width: none !important;
  margin: 0 !important;
  padding: 0 !important;
  text-align: left !important;
}
/* --- HARD OVERRIDE: align hero with first .ja-wrap (per section) --- */
#shopify-section-{{ section.id }} .ja-hero__overlay{
  padding-left: 0 !important;
  padding-right: 0 !important;
}

/* zorg dat de ja-wrap in de overlay echt full width ‘pakt’ */
#shopify-section-{{ section.id }} .ja-hero__overlay > .ja-wrap{
  width: 100% !important;
}

/* content zelf mag geen extra centering/padding hebben */
#shopify-section-{{ section.id }} .ja-hero__content{
  max-width: none !important;
  margin: 0 !important;
  padding: 0 !important;
  text-align: left !important;
}
/* MOBILE FIX: force container padding (theme override-proof) */
@media (max-width: 749px){
  #shopify-section-{{ section.id }} .jacq-apple.ja-glazen .ja-wrap{
    padding-left: max(22px, env(safe-area-inset-left)) !important;
    padding-right: max(22px, env(safe-area-inset-right)) !important;
  }
}

</style>

<script>
  (function(){
    const root = document.querySelector('.jacq-apple.ja-glazen[data-section-id="{{ section.id }}"]');
    if(!root) return;
    const els = root.querySelectorAll('.ja-reveal');
    if(!('IntersectionObserver' in window)){
      els.forEach(el => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if(entry.isIntersecting){
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });
    els.forEach(el => io.observe(el));
  })();
</script>

{% schema %}
{
  "name": "Page – Glazen",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_image_alt", "label": "Hero image alt", "default": "Jacq Eyewear" },
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "JACQ EYEWEAR" },
    { "type": "text", "id": "hero_title", "label": "Hero title", "default": "Welke glazen heb ik nodig?" },
    { "type": "text", "id": "hero_subtitle", "label": "Hero subtitle", "default": "Helder uitgelegd, zonder technisch gedoe." },

    { "type": "text", "id": "s1_title", "label": "Intro title", "default": "Eenvoudige keuze, beter draagcomfort" },
    { "type": "richtext", "id": "s1_text", "label": "Intro text", "default": "<p>Niet elk glas is beter — het hangt af van je sterkte, comfort en wat je prettig vindt om te dragen. Daarom houden we het bij Jacq overzichtelijk.</p><p>Je kunt altijd beginnen met standaardglas, en alleen opschalen naar dunner glas als dat voor jouw sterkte en comfort echt verschil maakt.</p>" },
    { "type": "image_picker", "id": "s1_image", "label": "Intro image" },
    { "type": "text", "id": "s1_image_alt", "label": "Intro image alt", "default": "Persoon met bril" },

    { "type": "text", "id": "band_title", "label": "Band title", "default": "Welke optie past bij jou?" },
    { "type": "richtext", "id": "band_text", "label": "Band text", "default": "<p>Zie het zo: hoe hoger de sterkte, hoe vaker dunner glas prettiger draagt. Hieronder zie je de vier opties en wanneer ze meestal worden gekozen.</p>" },

    { "type": "text", "id": "cards_title", "label": "Cards title", "default": "Glastypes" },
    { "type": "text", "id": "cards_subtitle", "label": "Cards subtitle", "default": "Vier keuzes. Duidelijk verschil." },

    { "type": "text", "id": "g1_title", "label": "Card 1 title", "default": "Basis" },
    { "type": "text", "id": "g1_price", "label": "Card 1 price", "default": "Gratis" },
    { "type": "text", "id": "g1_sub", "label": "Card 1 subtitle", "default": "Standaardglas" },
    { "type": "liquid", "id": "g1_bullets", "label": "Card 1 bullets (<li>…</li>)", "default": "<li>Standaardglazen</li><li>Anti-reflectie</li><li>Anti-kras</li>" },
    { "type": "text", "id": "g1_note", "label": "Card 1 note", "default": "Aanbevolen bij sterktes tot ongeveer ±2.00." },

    { "type": "text", "id": "g2_title", "label": "Card 2 title", "default": "Comfort" },
    { "type": "text", "id": "g2_price", "label": "Card 2 price", "default": "+€35" },
    { "type": "text", "id": "g2_sub", "label": "Card 2 subtitle", "default": "Dunner en lichter" },
    { "type": "liquid", "id": "g2_bullets", "label": "Card 2 bullets (<li>…</li>)", "default": "<li>Dunner en lichter glas</li><li>Anti-reflectie</li><li>Anti-kras</li>" },
    { "type": "text", "id": "g2_note", "label": "Card 2 note", "default": "Mooi bij sterktes rond ±2.00 tot ±3.00." },

    { "type": "text", "id": "g3_title", "label": "Card 3 title", "default": "Premium" },
    { "type": "text", "id": "g3_price", "label": "Card 3 price", "default": "+€65" },
    { "type": "text", "id": "g3_sub", "label": "Card 3 subtitle", "default": "Extra dun en licht" },
    { "type": "liquid", "id": "g3_bullets", "label": "Card 3 bullets (<li>…</li>)", "default": "<li>Extra dun glas</li><li>Anti-reflectie</li><li>Anti-kras</li>" },
    { "type": "text", "id": "g3_note", "label": "Card 3 note", "default": "Ideaal bij sterktes ongeveer ±3.00 tot ±6.00." },

    { "type": "text", "id": "g4_title", "label": "Card 4 title", "default": "Luxe" },
    { "type": "text", "id": "g4_price", "label": "Card 4 price", "default": "+€95" },
    { "type": "text", "id": "g4_sub", "label": "Card 4 subtitle", "default": "Ultradun glas" },
    { "type": "liquid", "id": "g4_bullets", "label": "Card 4 bullets (<li>…</li>)", "default": "<li>Ultradun glas</li><li>Anti-reflectie</li><li>Anti-kras</li>" },
    { "type": "text", "id": "g4_note", "label": "Card 4 note", "default": "Perfect bij sterktes boven ±6.00 of als je de dunste optie wilt." },

    { "type": "text", "id": "s2_title", "label": "Outro title", "default": "Twijfel je? Begin simpel." },
    { "type": "richtext", "id": "s2_text", "label": "Outro text", "default": "<p>Je kunt altijd starten met standaardglas. Als je een hogere sterkte hebt en dunner glas prettiger vindt, kies je later voor 1.60, 1.67 of 1.74.</p><p>En met 100 dagen bedenktijd heb je de ruimte om het in het dagelijks leven te ervaren.</p>" },
    { "type": "image_picker", "id": "s2_image", "label": "Outro image" },
    { "type": "text", "id": "s2_image_alt", "label": "Outro image alt", "default": "Close-up bril" },

    { "type": "text", "id": "cta_title", "label": "CTA title", "default": "Rustig kiezen" },
    { "type": "richtext", "id": "cta_text", "label": "CTA text", "default": "<p>Je ervaart een bril pas echt als je hem draagt. Daarom krijg je bij Jacq Eyewear <strong>100 dagen bedenktijd</strong>.</p>" },
