{% comment %}
  JACQ — Page: Past deze bril bij mij?
  - Apple clean layout
  - Hero overlay aligned with .ja-wrap (no centering drift)
  - Mobile gutters hard-fixed (min 20px + safe-area)
  - Sections: How to choose, Fit-notes, Quick measure, 100 days, FAQ, CTA
  - Subtle scroll reveal
{% endcomment %}

<section class="jacq-apple ja-fit" data-section-id="{{ section.id }}">
  <!-- HERO -->
  <header class="ja-hero">
    {% if section.settings.hero_image != blank %}
      <div class="ja-hero__media" aria-hidden="true">
        {{ section.settings.hero_image | image_url: width: 2400 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '800, 1200, 1600, 2000, 2400',
          alt: section.settings.hero_image_alt | escape
        }}
      </div>
    {% endif %}

    <div class="ja-hero__overlay">
      <div class="ja-wrap">
        <div class="ja-hero__content ja-reveal">
          {% if section.settings.hero_eyebrow != blank %}
            <p class="ja-eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
          {% endif %}
          <h1 class="ja-h1">{{ section.settings.hero_title | escape }}</h1>
          {% if section.settings.hero_subtitle != blank %}
            <p class="ja-lead">{{ section.settings.hero_subtitle | escape }}</p>
          {% endif %}

          {% if section.settings.hero_cta_label != blank and section.settings.hero_cta_link != blank %}
            <div class="ja-hero__actions">
              <a class="ja-btn ja-btn--primary" href="{{ section.settings.hero_cta_link }}">
                {{ section.settings.hero_cta_label | escape }}
              </a>

              {% if section.settings.hero_cta2_label != blank and section.settings.hero_cta2_link != blank %}
                <a class="ja-btn ja-btn--ghost" href="{{ section.settings.hero_cta2_link }}">
                  {{ section.settings.hero_cta2_label | escape }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </header>

  <!-- INTRO SPLIT -->
  <section class="ja-wrap ja-two-col ja-block ja-reveal">
    <div class="ja-col">
      <h2 class="ja-h2">{{ section.settings.intro_title | escape }}</h2>
      <div class="ja-richtext">
        {{ section.settings.intro_text }}
      </div>

      {% if section.settings.intro_points != blank %}
        <ul class="ja-mini">
          {{ section.settings.intro_points }}
        </ul>
      {% endif %}
    </div>

    <div class="ja-col ja-col--media">
      {% if section.settings.intro_image != blank %}
        {{ section.settings.intro_image | image_url: width: 1600 | image_tag:
          loading: 'lazy',
          sizes: '(min-width: 990px) 42vw, 100vw',
          widths: '600, 900, 1200, 1600',
          alt: section.settings.intro_image_alt | escape
        }}
      {% endif %}
    </div>
  </section>

  <!-- 3 CHECKS (cards) -->
  <section class="ja-band ja-block">
    <div class="ja-wrap ja-center ja-reveal">
      <h2 class="ja-h2">{{ section.settings.cards_title | escape }}</h2>
      {% if section.settings.cards_subtitle != blank %}
        <p class="ja-sub">{{ section.settings.cards_subtitle | escape }}</p>
      {% endif %}
    </div>

    <div class="ja-wrap ja-reveal">
      <div class="ja-cards">
        {% for i in (1..3) %}
          {% capture t %}card{{ i }}_title{% endcapture %}
          {% capture d %}card{{ i }}_text{% endcapture %}
          {% capture p %}card{{ i }}_points{% endcapture %}

          <article class="ja-card">
            <div class="ja-card__top">
              <span class="ja-pill">{{ section.settings.card_badge_prefix | escape }} {{ i }}</span>
              {% capture meta %}card{{ i }}_meta{% endcapture %}
              {% if section.settings[meta] != blank %}
                <span class="ja-time">{{ section.settings[meta] | escape }}</span>
              {% endif %}
            </div>

            <h3 class="ja-h3">{{ section.settings[t] | escape }}</h3>
            <p class="ja-p">{{ section.settings[d] | escape }}</p>

            {% if section.settings[p] != blank %}
              <ul class="ja-bullets">
                {{ section.settings[p] }}
              </ul>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- FIT NOTES SPLIT -->
  <section class="ja-wrap ja-two-col ja-two-col--reverse ja-block ja-reveal">
    <div class="ja-col">
      <h2 class="ja-h2">{{ section.settings.fitnotes_title | escape }}</h2>
      <div class="ja-richtext">
        {{ section.settings.fitnotes_text }}
      </div>

      <div class="ja-fitgrid">
        {% for i in (1..4) %}
          {% capture ft %}fn{{ i }}_title{% endcapture %}
          {% capture fd %}fn{{ i }}_text{% endcapture %}
          <div class="ja-fititem">
            <div class="ja-fititem__dot" aria-hidden="true"></div>
            <div>
              <div class="ja-fititem__t">{{ section.settings[ft] | escape }}</div>
              <div class="ja-fititem__d">{{ section.settings[fd] | escape }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ja-col ja-col--media">
      {% if section.settings.fitnotes_image != blank %}
        {{ section.settings.fitnotes_image | image_url: width: 1600 | image_tag:
          loading: 'lazy',
          sizes: '(min-width: 990px) 42vw, 100vw',
          widths: '600, 900, 1200, 1600',
          alt: section.settings.fitnotes_image_alt | escape
        }}
      {% endif %}
    </div>
  </section>

  <!-- QUICK MEASURE -->
  <section class="ja-wrap ja-block ja-reveal">
    <div class="ja-center">
      <h2 class="ja-h2">{{ section.settings.measure_title | escape }}</h2>
      {% if section.settings.measure_subtitle != blank %}
        <p class="ja-sub">{{ section.settings.measure_subtitle | escape }}</p>
      {% endif %}
    </div>

    <div class="ja-stepsgrid">
      {% for i in (1..4) %}
        {% capture st %}m{{ i }}_title{% endcapture %}
        {% capture sd %}m{{ i }}_text{% endcapture %}
        <article class="ja-scard">
          <div class="ja-scard__num">{{ i }}</div>
          <h3 class="ja-h3">{{ section.settings[st] | escape }}</h3>
          <p class="ja-p">{{ section.settings[sd] | escape }}</p>
        </article>
      {% endfor %}
    </div>

    {% if section.settings.measure_note != blank %}
      <div class="ja-note">
        <div class="ja-note__icon" aria-hidden="true"></div>
        <div class="ja-note__text">{{ section.settings.measure_note | escape }}</div>
      </div>
    {% endif %}
  </section>

  <!-- 100 DAYS -->
  <section class="ja-cta ja-block">
    <div class="ja-wrap ja-reveal">
      <div class="ja-ctaBox">
        <div class="ja-ctaBox__left">
          <h2 class="ja-h2 ja-h2--cta">{{ section.settings.trial_title | escape }}</h2>
          <div class="ja-richtext">
            {{ section.settings.trial_text }}
          </div>

          {% if section.settings.trial_points != blank %}
            <ul class="ja-mini ja-mini--light">
              {{ section.settings.trial_points }}
            </ul>
          {% endif %}
        </div>

        <div class="ja-ctaBox__right">
          {% if section.settings.trial_button_label != blank and section.settings.trial_button_link != blank %}
            <a class="ja-btn ja-btn--primary ja-btn--wide" href="{{ section.settings.trial_button_link }}">
              {{ section.settings.trial_button_label | escape }}
            </a>
          {% endif %}

          {% if section.settings.trial_button2_label != blank and section.settings.trial_button2_link != blank %}
            <a class="ja-btn ja-btn--soft ja-btn--wide" href="{{ section.settings.trial_button2_link }}">
              {{ section.settings.trial_button2_label | escape }}
            </a>
          {% endif %}

          {% if section.settings.trial_small != blank %}
            <p class="ja-small">{{ section.settings.trial_small | escape }}</p>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="ja-wrap ja-block ja-reveal">
    <div class="ja-center ja-faqHead">
      <h2 class="ja-h2">{{ section.settings.faq_title | escape }}</h2>
      {% if section.settings.faq_subtitle != blank %}
        <p class="ja-sub">{{ section.settings.faq_subtitle | escape }}</p>
      {% endif %}
    </div>

    <div class="ja-faq">
      {% assign has_faq = false %}
      {% for block in section.blocks %}
        {% if block.type == 'faq' %}
          {% assign has_faq = true %}
        {% endif %}
      {% endfor %}

      {% if has_faq %}
        {% for block in section.blocks %}
          {% if block.type != 'faq' %}{% continue %}{% endif %}
          <details class="ja-acc" {{ block.shopify_attributes }}>
            <summary class="ja-acc__sum">
              <span class="ja-acc__q">{{ block.settings.q | escape }}</span>
              <span class="ja-acc__icon" aria-hidden="true"></span>
            </summary>
            <div class="ja-acc__a">
              {{ block.settings.a }}
            </div>
          </details>
        {% endfor %}
      {% else %}
        <p class="ja-sub ja-center">Voeg “FAQ” blocks toe in de editor.</p>
      {% endif %}
    </div>
  </section>

  <!-- CTA (final) -->
  <section class="ja-wrap ja-block ja-reveal">
    <div class="ja-final">
      <div class="ja-final__copy">
        <h2 class="ja-h2">{{ section.settings.final_title | escape }}</h2>
        <div class="ja-richtext">
          {{ section.settings.final_text }}
        </div>
      </div>

      <div class="ja-final__actions">
        {% if section.settings.final_button_label != blank and section.settings.final_button_link != blank %}
          <a class="ja-btn ja-btn--primary ja-btn--wide" href="{{ section.settings.final_button_link }}">
            {{ section.settings.final_button_label | escape }}
          </a>
        {% endif %}
        {% if section.settings.final_button2_label != blank and section.settings.final_button2_link != blank %}
          <a class="ja-btn ja-btn--soft ja-btn--wide" href="{{ section.settings.final_button2_link }}">
            {{ section.settings.final_button2_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>
  </section>

  <!-- BACK LINK -->
  {% assign back_url = section.settings.back_link %}
  {% if back_url == blank %}
    {% assign back_url = '/pages/onze-brillen-op-sterkte' %}
  {% endif %}
  <footer class="ja-wrap ja-sign ja-reveal">
    <a class="ja-backlink" href="{{ back_url }}">{{ section.settings.back_label | escape }}</a>
  </footer>
</section>

<style>
  .jacq-apple.ja-fit{
    --ja-max: 1120px;
    --ja-pad: clamp(18px, 3.2vw, 28px);
    --ja-gap: clamp(18px, 3.2vw, 48px);
    --ja-radius: 20px;
    --ja-bg: #fff;
    --ja-band: #f5f5f7;
    --ja-text: rgba(0,0,0,.88);
    --ja-muted: rgba(0,0,0,.62);
    --ja-hairline: rgba(0,0,0,.10);
    background: var(--ja-bg);
    color: var(--ja-text);
  }
  .jacq-apple.ja-fit *{ box-sizing: border-box; }

  .jacq-apple.ja-fit .ja-wrap{
    max-width: var(--ja-max);
    margin: 0 auto;
    padding-left: max(var(--ja-pad), env(safe-area-inset-left));
    padding-right: max(var(--ja-pad), env(safe-area-inset-right));
  }
  .jacq-apple.ja-fit .ja-center{ text-align:center; }

  /* HERO */
  .jacq-apple.ja-fit .ja-hero{ position:relative; overflow:hidden; background: var(--ja-band); }
  .jacq-apple.ja-fit .ja-hero__media img{
    width:100%;
    height: clamp(440px, 54vw, 720px);
    object-fit: cover;
    display:block;
    transform: scale(1.02);
  }
  .jacq-apple.ja-fit .ja-hero__overlay{
    position:absolute; inset:0;
    display:grid;
    align-content:end;
    padding-bottom: clamp(34px, 5vw, 56px);
    pointer-events:none;
  }
  .jacq-apple.ja-fit .ja-hero__content{ text-align:left; }

  .jacq-apple.ja-fit .ja-eyebrow{
    margin:0 0 10px;
    font-size:13px;
    letter-spacing:.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,.78);
    text-shadow: 0 1px 18px rgba(0,0,0,.32);
  }
  .jacq-apple.ja-fit .ja-h1{
    margin:0 0 12px;
    font-size: clamp(34px, 5.0vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color:#fff;
    text-shadow: 0 1px 18px rgba(0,0,0,.38);
    max-width: 22ch;
  }
  .jacq-apple.ja-fit .ja-lead{
    margin:0;
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.55;
    color: rgba(255,255,255,.86);
    text-shadow: 0 1px 18px rgba(0,0,0,.32);
    max-width: 62ch;
  }

  .jacq-apple.ja-fit .ja-hero__actions{
    margin-top: 18px;
    display:flex;
    gap: 10px;
    flex-wrap: wrap;
    pointer-events:auto;
  }

  .jacq-apple.ja-fit .ja-block{ padding: clamp(54px, 7vw, 92px) 0; }

  /* Two-col */
  .jacq-apple.ja-fit .ja-two-col{
    display:grid;
    grid-template-columns: 1.05fr .95fr;
    gap: var(--ja-gap);
    align-items:center;
  }
  .jacq-apple.ja-fit .ja-two-col--reverse{ grid-template-columns: .95fr 1.05fr; }
  @media (min-width: 990px){
    .jacq-apple.ja-fit .ja-two-col--reverse .ja-col--media{ order:1; }
    .jacq-apple.ja-fit .ja-two-col--reverse .ja-col:not(.ja-col--media){ order:2; }
  }
  .jacq-apple.ja-fit .ja-col--media img{
    width:100%;
    height:auto;
    display:block;
    border-radius: var(--ja-radius);
  }

  /* Typography */
  .jacq-apple.ja-fit .ja-h2{
    margin:0 0 14px;
    font-size: clamp(24px, 2.6vw, 34px);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }
  .jacq-apple.ja-fit .ja-h3{
    margin:0 0 6px;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: rgba(0,0,0,.92);
  }
  .jacq-apple.ja-fit .ja-richtext{
    font-size:16px;
    line-height: 1.75;
    color: var(--ja-text);
    max-width: 72ch;
  }
  .jacq-apple.ja-fit .ja-richtext p{ margin:0 0 14px; }
  .jacq-apple.ja-fit .ja-richtext p:last-child{ margin-bottom:0; }
  .jacq-apple.ja-fit .ja-sub{
    margin: 6px auto 0;
    color: var(--ja-muted);
    max-width: 62ch;
    line-height: 1.6;
  }
  .jacq-apple.ja-fit .ja-p{
    margin:0;
    font-size: 14px;
    line-height: 1.65;
    color: rgba(0,0,0,.72);
  }
  .jacq-apple.ja-fit .ja-small{
    margin: 12px 0 0;
    font-size: 13px;
    color: rgba(0,0,0,.60);
    line-height: 1.6;
  }

  /* Band */
  .jacq-apple.ja-fit .ja-band{
    background: var(--ja-band);
    border-top: 1px solid var(--ja-hairline);
    border-bottom: 1px solid var(--ja-hairline);
  }

  /* Mini list */
  .jacq-apple.ja-fit .ja-mini{
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
    display:grid;
    gap: 10px;
    max-width: 70ch;
  }
  .jacq-apple.ja-fit .ja-mini li{
    padding-left: 18px;
    position: relative;
    color: rgba(0,0,0,.78);
    line-height: 1.6;
  }
  .jacq-apple.ja-fit .ja-mini li:before{
    content:"";
    width:6px;height:6px;border-radius:99px;background:rgba(0,0,0,.28);
    position:absolute;left:0;top:.65em;
  }
  .jacq-apple.ja-fit .ja-mini--light li{ color: rgba(0,0,0,.72); }
  .jacq-apple.ja-fit .ja-mini--light li:before{ background: rgba(0,0,0,.22); }

  /* Cards */
  .jacq-apple.ja-fit .ja-cards{
    display:grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 22px;
    align-items: stretch;
  }
  .jacq-apple.ja-fit .ja-card{
    background:#fff;
    border: 1px solid var(--ja-hairline);
    border-radius: var(--ja-radius);
    padding: 18px 18px 16px;
    overflow:hidden;
  }
  .jacq-apple.ja-fit .ja-card__top{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 12px;
    margin-bottom: 10px;
  }
  .jacq-apple.ja-fit .ja-pill{
    display:inline-flex;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.12);
    background: rgba(255,255,255,.75);
    font-size: 12px;
    color: rgba(0,0,0,.72);
  }
  .jacq-apple.ja-fit .ja-time{
    font-size: 12px;
    color: rgba(0,0,0,.55);
  }

  /* Bullets */
  .jacq-apple.ja-fit .ja-bullets{
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 10px;
  }
  .jacq-apple.ja-fit .ja-bullets li{
    padding-left: 18px;
    position: relative;
    color: rgba(0,0,0,.78);
    line-height: 1.6;
  }
  .jacq-apple.ja-fit .ja-bullets li:before{
    content:"";
    width:6px;height:6px;border-radius:99px;background:rgba(0,0,0,.28);
    position:absolute;left:0;top:.65em;
  }

  /* Fit notes grid */
  .jacq-apple.ja-fit .ja-fitgrid{
    margin-top: 18px;
    display:grid;
    gap: 12px;
  }
  .jacq-apple.ja-fit .ja-fititem{
    display:flex;
    gap: 12px;
    padding: 14px 14px;
    border: 1px solid rgba(0,0,0,.10);
    border-radius: 16px;
    background: rgba(245,245,247,.55);
  }
  .jacq-apple.ja-fit .ja-fititem__dot{
    width: 10px; height: 10px; border-radius: 99px;
    background: rgba(0,0,0,.32);
    margin-top: 6px;
    flex: 0 0 auto;
  }
  .jacq-apple.ja-fit .ja-fititem__t{
    font-weight: 600;
    color: rgba(0,0,0,.86);
    margin-bottom: 2px;
  }
  .jacq-apple.ja-fit .ja-fititem__d{
    color: rgba(0,0,0,.62);
    line-height: 1.55;
    font-size: 14px;
  }

  /* Steps grid */
  .jacq-apple.ja-fit .ja-stepsgrid{
    margin-top: 22px;
    display:grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .jacq-apple.ja-fit .ja-scard{
    border: 1px solid var(--ja-hairline);
    border-radius: var(--ja-radius);
    background:#fff;
    padding: 16px 16px 18px;
  }
  .jacq-apple.ja-fit .ja-scard__num{
    width: 34px;
    height: 34px;
    border-radius: 999px;
    display:flex;
    align-items:center;
    justify-content:center;
    border: 1px solid rgba(0,0,0,.12);
    background: rgba(245,245,247,.95);
    color: rgba(0,0,0,.72);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .jacq-apple.ja-fit .ja-note{
    margin-top: 18px;
    display:flex;
    gap: 12px;
    align-items:flex-start;
    padding: 16px 16px;
    border: 1px solid rgba(0,0,0,.10);
    border-radius: 16px;
    background: rgba(245,245,247,.55);
  }
  .jacq-apple.ja-fit .ja-note__icon{
    width: 12px; height: 12px;
    border-radius: 99px;
    background: rgba(0,0,0,.28);
    margin-top: 4px;
    flex: 0 0 auto;
  }
  .jacq-apple.ja-fit .ja-note__text{
    color: rgba(0,0,0,.70);
    line-height: 1.65;
    font-size: 14px;
  }

  /* Trial CTA */
  .jacq-apple.ja-fit .ja-cta{
    background: var(--ja-band);
    border-top: 1px solid var(--ja-hairline);
    border-bottom: 1px solid var(--ja-hairline);
  }
  .jacq-apple.ja-fit .ja-ctaBox{
    border: 1px solid rgba(0,0,0,.10);
    border-radius: calc(var(--ja-radius) + 6px);
    background: rgba(255,255,255,.65);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: clamp(18px, 3vw, 26px);
    display:grid;
    grid-template-columns: 1.3fr .7fr;
    gap: 18px;
    align-items:center;
  }
  .jacq-apple.ja-fit .ja-h2--cta{ margin-bottom: 10px; }
  .jacq-apple.ja-fit .ja-ctaBox__right{
    display:grid;
    gap: 10px;
    justify-items: stretch;
  }
  .jacq-apple.ja-fit .ja-btn--wide{ width:100%; }

  /* Final CTA */
  .jacq-apple.ja-fit .ja-final{
    border: 1px solid rgba(0,0,0,.10);
    border-radius: calc(var(--ja-radius) + 6px);
    padding: clamp(18px, 3vw, 26px);
    background: #fff;
    display:grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 18px;
    align-items:center;
  }
  .jacq-apple.ja-fit .ja-final__actions{
    display:grid;
    gap: 10px;
  }

  /* Buttons */
  .jacq-apple.ja-fit .ja-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding: 12px 18px;
    border-radius: 999px;
    text-decoration:none;
    border: 1px solid rgba(0,0,0,.22);
    color: rgba(0,0,0,.86);
    background: rgba(255,255,255,.65);
  }
  .jacq-apple.ja-fit .ja-btn:hover{ border-color: rgba(0,0,0,.35); }
  .jacq-apple.ja-fit .ja-btn--primary{
    background: rgba(0,0,0,.86);
    color:#fff;
    border-color: rgba(0,0,0,.86);
  }
  .jacq-apple.ja-fit .ja-btn--primary:hover{ border-color: rgba(0,0,0,1); }
  .jacq-apple.ja-fit .ja-btn--ghost{
    background: rgba(255,255,255,.18);
    color:#fff;
    border-color: rgba(255,255,255,.35);
    text-shadow: 0 1px 14px rgba(0,0,0,.25);
  }
  .jacq-apple.ja-fit .ja-btn--soft{
    background: rgba(255,255,255,.72);
    color: rgba(0,0,0,.86);
    border-color: rgba(0,0,0,.16);
  }

  /* FAQ */
  .jacq-apple.ja-fit .ja-faqHead{ margin-bottom: 18px; }
  .jacq-apple.ja-fit .ja-acc{
    border: 1px solid var(--ja-hairline);
    border-radius: 16px;
    overflow: hidden;
    background:#fff;
  }
