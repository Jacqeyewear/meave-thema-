          <div class="pp-carousel" id="pp-carousel">
            <button type="button" class="pp-carousel__nav pp-carousel__nav--prev" id="pp-carousel-prev" aria-label="Vorige foto">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
            </button>
            <div class="pp-carousel__track" id="pp-carousel-track"></div>
            <button type="button" class="pp-carousel__nav pp-carousel__nav--next" id="pp-carousel-next" aria-label="Volgende foto">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l4 4-4 4"/></svg>
            </button>
            <div class="pp-carousel__dots" id="pp-carousel-dots"></div>
          </div>
        </div>

        <!-- Info tab — dimensions diagram + spec table -->
        <div class="pp-tab-panel" data-tab-panel="info" hidden>
          <div class="pp-dim" id="pp-dim">
            <div class="pp-dim__diagram">
              <img id="pp-dim-img" alt="" loading="lazy">
              <svg id="pp-dim-svg" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" aria-hidden="true"></svg>
            </div>
            <div class="pp-dim__table" id="pp-dim-table"></div>
          </div>
        </div>

        <!-- Tabs (below the photos) -->
        <div class="pp-tabs" role="tablist">
          <button type="button" class="pp-tabs__btn is-active" data-tab="photos" role="tab" aria-selected="true">Foto's</button>
          <button type="button" class="pp-tabs__btn" data-tab="info" role="tab" aria-selected="false">Maten &amp; info</button>
        </div>

        <p class="pp-variant-modal__hint" id="pp-variant-hint">Kies een kleur</p>
        <div class="pp-variant-list" id="pp-variant-list"></div>
      </div>

      <button type="button" class="pp-modal-cta" id="pp-modal-cta">Voeg toe aan pakket</button>
    </div>
  </div>

  <!-- Fullscreen photo viewer -->
  <div class="pp-fullscreen" id="pp-fullscreen" role="dialog" aria-modal="true" aria-label="Foto in volledig scherm">
    <div class="pp-fullscreen__inner">
      <button type="button" class="pp-fullscreen__nav pp-fullscreen__nav--prev" id="pp-fullscreen-prev" aria-label="Vorige foto">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
      </button>
      <img class="pp-fullscreen__img" id="pp-fullscreen-img" alt="">
      <button type="button" class="pp-fullscreen__nav pp-fullscreen__nav--next" id="pp-fullscreen-next" aria-label="Volgende foto">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l4 4-4 4"/></svg>
      </button>
      <button type="button" class="pp-fullscreen__close" id="pp-fullscreen-close" aria-label="Sluiten">&times;</button>
    </div>
  </div>

  <!-- "Zo werkt thuis passen" explanation modal -->
  <div class="pp-howto-overlay" id="pp-howto-overlay" role="dialog" aria-modal="true" aria-labelledby="pp-howto-title" aria-hidden="true">
    <div class="pp-howto-modal">
      <button type="button" class="pp-howto-close" id="pp-howto-close" aria-label="Sluiten">
        <svg viewBox="0 0 14 14" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
          <path d="M2 2l10 10M12 2L2 12"/>
        </svg>
      </button>
      <h3 class="pp-howto-title" id="pp-howto-title">Thuis passen</h3>
      <p class="pp-howto-lead">In vier stappen jouw bril.<br><span class="pp-howto-lead__sub">&euro;20 borg, levering en retour gratis.</span></p>
      <ol class="pp-howto-steps">
        <li>
          <span class="pp-howto-step__num">1</span>
          <div>
            <div class="pp-howto-step__title">Kies vier monturen</div>
            <div class="pp-howto-step__body">Voeg ze toe aan je paspakket.</div>
          </div>
        </li>
        <li>
          <span class="pp-howto-step__num">2</span>
          <div>
            <div class="pp-howto-step__title">Pas ze thuis</div>
            <div class="pp-howto-step__body">Vijf dagen, jouw spiegel.</div>
          </div>
        </li>
        <li>
          <span class="pp-howto-step__num">3</span>
          <div>
            <div class="pp-howto-step__title">Stuur retour</div>
            <div class="pp-howto-step__body">Gratis via PostNL, label zit erbij.</div>
          </div>
        </li>
        <li>
          <span class="pp-howto-step__num">4</span>
          <div>
            <div class="pp-howto-step__title">Bestel je favoriet</div>
            <div class="pp-howto-step__body">&euro;20 korting bij aankoop.</div>
          </div>
        </li>
      </ol>
      <p class="pp-howto-foot">De &euro;20 borg krijg je terug als korting zodra je een bril bestelt.</p>
    </div>
  </div>

  <!-- Toast -->
  <!-- Mobile-only floating "back to basket" button — Apple-style liquid
       glass. Shows current N/4 count, taps scroll back to the basket
       card. Appears once the basket scrolls out of view. -->
  <button type="button" class="pp-mini-basket" id="pp-mini-basket" aria-label="Terug naar je paspakket">
    <span class="pp-mini-basket__count"><span id="pp-mini-basket-count">0</span>/4</span>
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 14l6-6 6 6"/>
    </svg>
  </button>

  <div class="pp-toast" id="pp-toast"></div>
</section>

<script>
  /* Product data injected from Liquid. Each (collection, product)
     pair is emitted; the JS dedupes by id. Metafields drive the
     attribute filters (kleur, vorm, materiaal, brillen_voor,
     pasvorm) — same source the quiz uses. */
  window.PASPAKKET_DATA = {
    paspakketVariantId: {%- if section.settings.paspakket_product != blank and section.settings.paspakket_product.variants.first -%}
      {{ section.settings.paspakket_product.variants.first.id | json }}
    {%- else -%}52976738238800{%- endif -%},
    icons: {
      kleuren:   {{ 'kleur.svg'         | asset_url | json }},
      vorm:      {{ 'brillenvorm.svg'   | asset_url | json }},
      materiaal: {{ 'materiaal.svg'     | asset_url | json }},
      voor:      {{ 'brillen-voor.svg'  | asset_url | json }},
      pasvorm:   {{ 'montuurbreedte.svg'| asset_url | json }}
    },
    rawProducts: [
      {%- assign first_block = true -%}
      {%- comment -%}
        Shopify caps `collection.products` at 50 per collection when
        used outside a paginate block. To make sure every bril +
        zonnebril + kinderbril ends up in PASPAKKET_DATA we iterate
        every relevant collection (parents + gender / category sub-
        collections); the JS dedupes by product.id so overlapping
        items aren't loaded twice.

        If a handle below doesn't exist in your store, the block
        skips it via `{% if coll %}` — safe to leave in the list.
      {%- endcomment -%}
      {%- assign collection_handles = 'brillen-op-sterkte,dames-brillen,heren-brillen,leesbrillen,multifocaal,beeldschermbrillen,zonnebrillen,dames-zonnebrillen,heren-zonnebrillen,kinderbrillen,kinder' | split: ',' -%}
      {%- for collection_handle in collection_handles -%}
        {%- assign coll = collections[collection_handle] -%}
        {%- if coll == blank or coll.products_count == 0 -%}{%- continue -%}{%- endif -%}
        {%- for product in coll.products -%}
          {%- unless first_block -%},{%- endunless -%}
          {%- assign first_block = false -%}
          {%- assign type_label = 'bril' -%}
          {%- if collection_handle contains 'zonne' -%}{%- assign type_label = 'zonnebril' -%}{%- endif -%}
          {%- if collection_handle == 'kinderbrillen' or collection_handle == 'kinder' -%}{%- assign type_label = 'kinderbril' -%}{%- endif -%}
          {%- assign lens_w  = product.metafields.frame.lens_width.value    | default: product.metafields.frame.lens_width    | default: 0 | plus: 0 -%}
          {%- assign bridge_w = product.metafields.frame.bridge.value       | default: product.metafields.frame.bridge       | default: 0 | plus: 0 -%}
          {%- assign temple_l = product.metafields.frame.temple_length.value | default: product.metafields.frame.temple_length | default: 0 | plus: 0 -%}
          {%- assign total_w = product.metafields.frame.total_width.value   | default: product.metafields.frame.total_width   | default: 0 | plus: 0 -%}
          {
            "id": {{ product.id | json }},
            "title": {{ product.title | json }},
            "handle": {{ product.handle | json }},
            "url": {{ product.url | json }},
            "price": {{ product.price | money_without_currency | json }},
            "priceNum": {{ product.price | divided_by: 100.0 | json }},
            "compareAtPrice": {%- if product.compare_at_price and product.compare_at_price > product.price -%}{{ product.compare_at_price | divided_by: 100.0 | json }}{%- else -%}null{%- endif -%},
            "tags": {{ product.tags | join: ',' | downcase | json }},
            "image": {{ product.featured_image | image_url: width: 600 | json }},
            "images": [
              {%- for img in product.images limit: 12 -%}
                { "src": {{ img | image_url: width: 800 | json }}, "alt": {{ img.alt | default: '' | json }} }
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ],
            "type": {{ type_label | json }},
            "frame": {
              "lensWidth": {{ lens_w | json }},
              "bridge": {{ bridge_w | json }},
              "templeLength": {{ temple_l | json }},
              "totalWidth": {{ total_w | json }}
            },
            "voor": [
              {%- if product.metafields.custom.brillen_voor.value -%}
                {%- for item in product.metafields.custom.brillen_voor.value -%}
                  {%- if item.label.value != blank -%}{{ item.label.value | json }}
                  {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                  {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                  {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                  {%- else -%}{{ item | json }}{%- endif -%}
                  {%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ],
            "vorm": [
              {%- if product.metafields.custom.vorm.value -%}
                {%- for item in product.metafields.custom.vorm.value -%}
                  {%- if item.label.value != blank -%}{{ item.label.value | json }}
                  {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                  {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                  {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                  {%- else -%}{{ item | json }}{%- endif -%}
                  {%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ],
            "materiaal": [
              {%- if product.metafields.custom.materiaal.value -%}
                {%- for item in product.metafields.custom.materiaal.value -%}
                  {%- if item.label.value != blank -%}{{ item.label.value | json }}
                  {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                  {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                  {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                  {%- else -%}{{ item | json }}{%- endif -%}
                  {%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              {%- endif -%}
            ],
            "pasvorm": {{ product.metafields.custom.pasvorm | json }},
            "kleuren": [
              {%- assign seen_colors = '' -%}
              {%- assign first_color = true -%}
              {%- for v in product.variants -%}
                {%- assign color_val = v.metafields.custom.kleur | default: v.title -%}
                {%- assign color_key = color_val | downcase | append: '|' -%}
                {%- unless seen_colors contains color_key -%}
                  {%- assign seen_colors = seen_colors | append: color_key -%}
                  {%- unless first_color -%},{%- endunless -%}
                  {%- assign first_color = false -%}
                  {{ color_val | json }}
                {%- endunless -%}
              {%- endfor -%}
            ],
            "variants": [
              {%- for v in product.variants -%}
                {%- assign v_kleur = v.metafields.custom.kleur | default: v.title -%}
                {
                  "id": {{ v.id | json }},
                  "title": {{ v.title | json }},
                  "kleur": {{ v_kleur | json }},
                  "image": {%- if v.image -%}{{ v.image | image_url: width: 800 | json }}{%- else -%}null{%- endif -%}
                }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }
        {%- endfor -%}
      {%- endfor -%}
    ]
  };
</script>

<script>
(function () {
  'use strict';
  var data = window.PASPAKKET_DATA || { rawProducts: [], paspakketVariantId: null };

  // Dedupe rawProducts by id (a product may appear in both a
  // gender collection and brillen-op-sterkte). Last write wins for
  // metafields; first occurrence wins for type/order.
  var productMap = Object.create(null);
  var productOrder = [];
  (data.rawProducts || []).forEach(function (row) {
    if (productMap[row.id]) return;
    productMap[row.id] = row;
    productOrder.push(row);
  });
  var products = productOrder;

  var STORAGE_KEY = 'jacq-paspakket-v1';
  var MAX_SLOTS = 4;

  // Attribute filter definitions — order = display order.
  var ATTR_DEFS = [
    { key: 'kleuren',   label: 'Kleur' },
    { key: 'vorm',      label: 'Vorm' },
    { key: 'materiaal', label: 'Materiaal' },
    { key: 'voor',      label: 'Voor' },
    { key: 'pasvorm',   label: 'Pasvorm' }
  ];

  // Build value lists per attribute (deduped, sorted, case-insensitive).
  function attrValues(p, key) {
    var v = p[key];
    if (v == null) return [];
    if (Array.isArray(v)) return v.filter(function (x) { return x != null && String(x).trim() !== ''; }).map(String);
    var s = String(v).trim();
    return s ? [s] : [];
  }
  function buildAttrOptions() {
    var seen = {};
    ATTR_DEFS.forEach(function (def) { seen[def.key] = Object.create(null); });
    products.forEach(function (p) {
      ATTR_DEFS.forEach(function (def) {
        attrValues(p, def.key).forEach(function (val) {
          var k = val.toLowerCase();
          if (!seen[def.key][k]) seen[def.key][k] = val;
        });
      });
    });
    var out = {};
    ATTR_DEFS.forEach(function (def) {
      out[def.key] = Object.values(seen[def.key]).sort(function (a, b) {
        return a.localeCompare(b, 'nl', { sensitivity: 'base' });
      });
    });
    return out;
  }
  var attrOptions = buildAttrOptions();
  // Selected values per attribute (Set semantics via plain object).
  var activeAttrs = {};
  ATTR_DEFS.forEach(function (def) { activeAttrs[def.key] = Object.create(null); });

  var root = document.querySelector('[data-paspakket]');
  if (!root) return;

  // Load / save selection
  var selection = []; // array of {productId, variantId, productHandle, productTitle, variantTitle, image}
  try {
    var saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
    if (Array.isArray(saved)) selection = saved.slice(0, MAX_SLOTS);
  } catch (e) {}

  function saveSelection() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(selection)); } catch (e) {}
  }

  function $(sel, ctx) { return (ctx || root).querySelector(sel); }
  function $$(sel, ctx) { return Array.prototype.slice.call((ctx || root).querySelectorAll(sel)); }

  // ─── Slot rendering ───
  var slots = $$('.pp-slot');

  function renderSlots() {
    slots.forEach(function (slot, i) {
      var item = selection[i];
      var media = $('.pp-slot__media', slot);
      var titleEl = $('.pp-slot__title', slot);
      var variantEl = $('.pp-slot__variant', slot);
      var oldImg = media.querySelector('img');
      if (oldImg) oldImg.remove();

      if (item) {
        slot.classList.add('is-filled');
        var img = document.createElement('img');
        img.src = item.image;
        img.alt = item.productTitle;
        img.loading = 'lazy';
        media.appendChild(img);
        titleEl.textContent = item.productTitle;
        variantEl.textContent = item.variantTitle && item.variantTitle !== 'Default Title' ? item.variantTitle : '';
      } else {
        slot.classList.remove('is-filled');
        titleEl.textContent = '';
        variantEl.textContent = '';
      }
    });

    // CTA enable state
    var cta = $('#pp-cta');
    var n = selection.length;
    if (cta) cta.classList.toggle('is-inert', n < MAX_SLOTS);

    // Basket header count "n/4"
    var countEl = $('#pp-slots-count');
    if (countEl) countEl.textContent = n + '/' + MAX_SLOTS;
    var miniBasketCount = $('#pp-mini-basket-count');
    if (miniBasketCount) miniBasketCount.textContent = String(n);

    // Card highlights
    $$('.pp-card').forEach(function (card) {
      var pid = card.getAttribute('data-product-id');
      var has = selection.some(function (s) { return String(s.productId) === pid; });
      card.classList.toggle('is-selected', has);
      var btn = $('.pp-card__add', card);
      if (btn) btn.textContent = has ? '✓ Geselecteerd' : 'Voeg toe';
      // Disable when 4 selected and this card isn't already selected
      card.classList.toggle('is-disabled', !has && selection.length >= MAX_SLOTS);
    });

    saveSelection();
  }

  function addSelection(item) {
    if (selection.length >= MAX_SLOTS) {
      toast('Je hebt al ' + MAX_SLOTS + ' brillen gekozen.');
      return false;
    }
    if (selection.some(function (s) { return s.productId === item.productId; })) {
      toast('Deze bril zit al in je pakket.');
      return false;
    }
    var targetSlotIndex = selection.length;
    selection.push(item);
    renderSlots();
    // Pop animation on the slot that just got filled.
    var slotEl = slots[targetSlotIndex];
    if (slotEl) {
      slotEl.classList.remove('is-popping');
      // Force reflow so the animation re-triggers if added twice in
      // quick succession.
      void slotEl.offsetWidth;
      slotEl.classList.add('is-popping');
      setTimeout(function () { slotEl.classList.remove('is-popping'); }, 700);
    }
    return targetSlotIndex;
  }

  // Animate a ghost element from a source rect to the empty slot
  // that will receive the bril. Returns a promise that resolves
  // once the ghost finishes its trip (so callers can defer the
  // commit until the visual arrives).
  function flyToSlot(sourceEl, imageSrc, slotIndex) {
    return new Promise(function (resolve) {
      var slotEl = slots[slotIndex];
      if (!sourceEl || !slotEl || !imageSrc) return resolve();
      var srcRect = sourceEl.getBoundingClientRect();
      var dstRect = slotEl.getBoundingClientRect();
      if (!srcRect.width || !dstRect.width) return resolve();
      var ghost = document.createElement('div');
      ghost.className = 'pp-fly-ghost';
      ghost.style.top = srcRect.top + 'px';
      ghost.style.left = srcRect.left + 'px';
      ghost.style.width = srcRect.width + 'px';
      ghost.style.height = srcRect.height + 'px';
      ghost.style.backgroundImage = "url(" + imageSrc.replace(/"/g, '\\"') + ")";
      document.body.appendChild(ghost);
      // Force reflow before mutating transform so transition fires.
      void ghost.offsetWidth;
      var dx = (dstRect.left + dstRect.width / 2) - (srcRect.left + srcRect.width / 2);
      var dy = (dstRect.top + dstRect.height / 2) - (srcRect.top + srcRect.height / 2);
      var scale = Math.min(dstRect.width / srcRect.width, dstRect.height / srcRect.height) * 0.92;
      ghost.style.transform = 'translate(' + dx + 'px, ' + dy + 'px) scale(' + scale + ')';
      ghost.style.opacity = '0.3';
      setTimeout(function () {
        if (ghost.parentNode) ghost.parentNode.removeChild(ghost);
        resolve();
      }, 740);
    });
  }

  // Adds a bril to the pakket with the fly-to-slot ghost animation.
  // sourceEl is the visual element the ghost should originate from.
  function addWithFlyAnimation(sourceEl, item) {
    if (selection.length >= MAX_SLOTS) {
      toast('Je hebt al ' + MAX_SLOTS + ' brillen gekozen.');
      return false;
    }
    if (selection.some(function (s) { return s.productId === item.productId; })) {
      toast('Deze bril zit al in je pakket.');
      return false;
    }
    var slotIndex = selection.length;
    flyToSlot(sourceEl, item.image, slotIndex).then(function () {
      addSelection(item);
    });
    return true;
  }

  function removeFromSlot(index) {
    if (index < 0 || index >= selection.length) return;
    selection.splice(index, 1);
    renderSlots();
  }

  // ─── Slot click handlers ───
  slots.forEach(function (slot, i) {
    var removeBtn = $('.pp-slot__remove', slot);
    if (removeBtn) {
      removeBtn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        removeFromSlot(i);
      });
    }
    slot.addEventListener('click', function (e) {
      // Don't double-trigger if remove button was the actual target
      if (e.target.closest('.pp-slot__remove')) return;
      var item = selection[i];
      if (!item) return;
      // Re-open the variant picker for this product (instead of
      // navigating away to the PDP) and jump straight to the
      // variant the customer already chose.
      var product = productMap[item.productId];
      if (!product) {
        product = products.find(function (p) { return p.id === item.productId; });
      }
      if (!product) return;
      openVariantPicker(product);
      var variantIdx = (product.variants || []).findIndex(function (v) {
        return v.id === item.variantId;
      });
      if (variantIdx > 0) selectVariant(variantIdx);
    });
    // Drop target
    slot.addEventListener('dragover', function (e) {
      e.preventDefault();
      slot.classList.add('is-drop-target');
    });
    slot.addEventListener('dragleave', function () {
      slot.classList.remove('is-drop-target');
    });
    slot.addEventListener('drop', function (e) {
      e.preventDefault();
      slot.classList.remove('is-drop-target');
      var pid = e.dataTransfer.getData('text/x-paspakket-product-id');
      if (pid) {
        var p = products.find(function (x) { return String(x.id) === pid; });
        if (p) handleProductSelect(p);
      }
    });
  });

  // ─── Variant picker ───
  var variantOverlay = $('#pp-variant-overlay');
  var variantList = $('#pp-variant-list');
  var variantTitle = $('#pp-variant-title');
  var variantHint = $('#pp-variant-hint');

  // Build the same SVG arrow diagram as product-specs-tabs.liquid.
  function renderDimDiagram(svg, frame) {
    if (!svg) return;
    var lensWidth = Number(frame.lensWidth) || 0;
    var bridge = Number(frame.bridge) || 0;
    var totalWidth = Number(frame.totalWidth) || 0;
    if (lensWidth <= 0 && bridge <= 0) { svg.innerHTML = ''; return; }
    var bridgeArrowLength = bridge - 2;
    var lensArrowLength = lensWidth - 14;
    var halfBridge = bridgeArrowLength / 2;
    var bridgeStartX = 60 - halfBridge;
    var bridgeEndX = 60 + halfBridge;
    var lensEndX = bridgeEndX + lensArrowLength;
    var bridgeLabelX = (bridgeStartX + bridgeEndX) / 2;
    var lensLabelX = (bridgeEndX + lensEndX) / 2;
    var bridgeStartArrow = bridgeStartX + 1.5;
    var bridgeEndArrow = bridgeEndX - 1.5;
    var lensStartArrow = bridgeEndX + 1.5;
    var lensEndArrow = lensEndX - 1.5;
    var totalStartX = 6, totalEndX = 114, totalLabelX = 60;
    var totalStartArrow = 7.5, totalEndArrow = 112.5;
    var parts = [
      '<text x="' + bridgeLabelX + '" y="30" text-anchor="middle" fill="#86868b" font-size="4.5" font-family="-apple-system,BlinkMacSystemFont,sans-serif" font-weight="500">' + bridge + ' mm</text>',
      '<line x1="' + bridgeStartX + '" y1="34" x2="' + bridgeEndX + '" y2="34" stroke="#c7c7cc" stroke-width="0.4" stroke-dasharray="1.2,0.8"/>',
      '<polygon points="' + bridgeStartX + ',34 ' + bridgeStartArrow + ',32.8 ' + bridgeStartArrow + ',35.2" fill="#c7c7cc"/>',
      '<polygon points="' + bridgeEndX + ',34 ' + bridgeEndArrow + ',32.8 ' + bridgeEndArrow + ',35.2" fill="#c7c7cc"/>',
      '<text x="' + lensLabelX + '" y="30" text-anchor="middle" fill="#86868b" font-size="4.5" font-family="-apple-system,BlinkMacSystemFont,sans-serif" font-weight="500">' + lensWidth + ' mm</text>',
      '<line x1="' + bridgeEndX + '" y1="34" x2="' + lensEndX + '" y2="34" stroke="#c7c7cc" stroke-width="0.4" stroke-dasharray="1.2,0.8"/>',
      '<polygon points="' + bridgeEndX + ',34 ' + lensStartArrow + ',32.8 ' + lensStartArrow + ',35.2" fill="#c7c7cc"/>',
      '<polygon points="' + lensEndX + ',34 ' + lensEndArrow + ',32.8 ' + lensEndArrow + ',35.2" fill="#c7c7cc"/>'
    ];
    if (totalWidth > 0) {
      parts.push(
        '<line x1="' + totalStartX + '" y1="84" x2="' + totalEndX + '" y2="84" stroke="#c7c7cc" stroke-width="0.4" stroke-dasharray="1.2,0.8"/>',
        '<polygon points="' + totalStartX + ',84 ' + totalStartArrow + ',82.8 ' + totalStartArrow + ',85.2" fill="#c7c7cc"/>',
        '<polygon points="' + totalEndX + ',84 ' + totalEndArrow + ',82.8 ' + totalEndArrow + ',85.2" fill="#c7c7cc"/>',
        '<text x="' + totalLabelX + '" y="91" text-anchor="middle" fill="#86868b" font-size="4.5" font-family="-apple-system,BlinkMacSystemFont,sans-serif" font-weight="500">' + totalWidth + ' mm</text>'
      );
    }
    svg.innerHTML = parts.join('');
  }

  // Carousel state
  var carouselSlideIndex = 0;
  var carouselImages = [];
  // Per-variant carousel: each variant's "featured image" marks the
  // start of that variant's photos inside the product gallery. So a
  // variant's photo set is the contiguous slice of product.images
  // from its featured-image position up to (but not including) the
  // featured image of the NEXT variant. This matches the convention
  // the user uses when uploading photos in Shopify admin.
  function imgSrc(img) { return img && (typeof img === 'string' ? img : img.src) || ''; }
  // Variant.image and product.images come back from Shopify at
  // different widths, so their raw URLs never match by string. We
  // normalise by stripping the query string and any _NNxNN size
  // suffix so the featured-image lookup can find the right slot in
  // the gallery.
  function normalizeImgUrl(url) {
    if (!url) return '';
    var s = String(url).split('?')[0].split('#')[0];
    s = s.replace(/_(small|medium|large|grande|master|original|\d+x|x\d+|\d+x\d+)\.(jpg|jpeg|png|webp|gif)(?=$)/i, '.$2');
    return s;
  }
  function buildVariantImages(product, variantIndex) {
    var variants = product.variants || [];
    var v = variants[variantIndex] || null;
    var images = product.images || [];
    var srcs = images.map(imgSrc).filter(Boolean);

    if (!v) {
      return srcs.length ? srcs : [product.image].filter(Boolean);
    }
    if (!srcs.length) {
      return [v.image || product.image].filter(Boolean);
    }

    // Walk the gallery in order, recording at which index each
    // variant's featured image appears. Compare on normalised URLs
    // so a width-mismatch doesn't break the lookup.
    var srcsNorm = srcs.map(normalizeImgUrl);
    var variantStartIdx = variants.map(function (vv) {
      if (!vv || !vv.image) return -1;
      return srcsNorm.indexOf(normalizeImgUrl(vv.image));
    });
    var startIdx = variantStartIdx[variantIndex];

    if (startIdx < 0) {
      // This variant's featured image isn't in the gallery — fall
      // back to just its pinned image (or the product default).
      return [(v && v.image) || product.image].filter(Boolean);
    }

    // The slice ends at the NEXT variant's featured-image index that
    // appears later in the gallery. If none, take everything until
    // the end.
    var endIdx = srcs.length;
    for (var i = 0; i < variants.length; i++) {
      if (i === variantIndex) continue;
      var other = variantStartIdx[i];
      if (other > startIdx && other < endIdx) endIdx = other;
    }
    var slice = srcs.slice(startIdx, endIdx);
    return slice.length ? slice : [v.image || product.image].filter(Boolean);
  }
  function renderCarousel(product, variantIndex) {
    var track = $('#pp-carousel-track');
    var dots = $('#pp-carousel-dots');
    if (!track || !dots) return;
    carouselImages = buildVariantImages(product, variantIndex || 0);
    track.innerHTML = carouselImages.map(function (src) {
      return '<div class="pp-carousel__slide"><img src="' + src + '" alt="' + escapeHtml(product.title) + '" loading="lazy"></div>';
    }).join('');
    dots.innerHTML = carouselImages.map(function (_, i) {
      return '<button type="button" class="pp-carousel__dot' + (i === 0 ? ' is-active' : '') + '" data-slide="' + i + '" aria-label="Foto ' + (i + 1) + '"></button>';
    }).join('');
    carouselSlideIndex = 0;
    track.scrollLeft = 0;
    syncCarouselUI();
  }
  function syncCarouselUI() {
    var track = $('#pp-carousel-track');
    if (!track) return;
    var slides = track.children.length;
    $('#pp-carousel-prev').disabled = carouselSlideIndex <= 0;
    $('#pp-carousel-next').disabled = carouselSlideIndex >= slides - 1;
    $$('#pp-carousel-dots .pp-carousel__dot').forEach(function (d, i) {
      d.classList.toggle('is-active', i === carouselSlideIndex);
    });
  }
  function goToSlide(i) {
    var track = $('#pp-carousel-track');
    if (!track) return;
    var slides = track.children.length;
    carouselSlideIndex = Math.max(0, Math.min(slides - 1, i));
    track.scrollTo({ left: carouselSlideIndex * track.clientWidth, behavior: 'smooth' });
    syncCarouselUI();
  }
  $('#pp-carousel-prev').addEventListener('click', function () { goToSlide(carouselSlideIndex - 1); });
  $('#pp-carousel-next').addEventListener('click', function () { goToSlide(carouselSlideIndex + 1); });
  $('#pp-carousel-dots').addEventListener('click', function (e) {
    var dot = e.target.closest('.pp-carousel__dot');
    if (!dot) return;
    goToSlide(parseInt(dot.getAttribute('data-slide'), 10) || 0);
  });
  $('#pp-carousel-track').addEventListener('scroll', function () {
    var track = $('#pp-carousel-track');
    var idx = Math.round(track.scrollLeft / Math.max(1, track.clientWidth));
    if (idx !== carouselSlideIndex) {
      carouselSlideIndex = idx;
      syncCarouselUI();
    }
  }, { passive: true });

  // Tab switching
  $$('.pp-tabs__btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var tab = btn.getAttribute('data-tab');
      $$('.pp-tabs__btn').forEach(function (b) {
        var active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', String(active));
      });
      $$('.pp-tab-panel').forEach(function (p) {
        var active = p.getAttribute('data-tab-panel') === tab;
        p.classList.toggle('is-active', active);
        p.hidden = !active;
      });
    });
  });

  function openVariantPicker(product) {
    variantTitle.textContent = product.title;
    variantHint.textContent = 'Kies een kleur';

    // Reset to photos tab on each open.
    $$('.pp-tabs__btn').forEach(function (b) {
      var isPhotos = b.getAttribute('data-tab') === 'photos';
      b.classList.toggle('is-active', isPhotos);
      b.setAttribute('aria-selected', String(isPhotos));
    });
    $$('.pp-tab-panel').forEach(function (p) {
      var isPhotos = p.getAttribute('data-tab-panel') === 'photos';
      p.classList.toggle('is-active', isPhotos);
      p.hidden = !isPhotos;
    });

    // Build the photo carousel from the product's image gallery
    // (scoped to the default variant).
    renderCarousel(product, 0);

    // Dimensions panel (same fields as product-specs-tabs.liquid 'Details' tab).
    var dimImg = $('#pp-dim-img');
    var dimSvg = $('#pp-dim-svg');
    var dimTable = $('#pp-dim-table');
    var frame = product.frame || {};
    var hasDims = (Number(frame.lensWidth) > 0 || Number(frame.bridge) > 0);
    if (hasDims) {
      dimImg.src = product.image || '';
      dimImg.alt = product.title;
      renderDimDiagram(dimSvg, frame);
      var rows = [];
      if (frame.lensWidth)    rows.push(['Lensbreedte',   frame.lensWidth + ' mm']);
      if (frame.bridge)       rows.push(['Neusbrug',      frame.bridge + ' mm']);
      if (frame.templeLength) rows.push(['Pootlengte',    frame.templeLength + ' mm']);
      if (frame.totalWidth)   rows.push(['Totale breedte', frame.totalWidth + ' mm']);
      dimTable.innerHTML = rows.map(function (r) {
        return '<div class="pp-dim__row"><span class="pp-dim__label">' + escapeHtml(r[0]) + '</span><span class="pp-dim__value">' + escapeHtml(r[1]) + '</span></div>';
      }).join('');
    } else {
      dimTable.innerHTML = '<div class="pp-dim__row"><span class="pp-dim__label">Geen afmetingen beschikbaar voor deze bril.</span></div>';
    }

    variantList.innerHTML = '';
    activeVariantIndex = 0;
    product.variants.forEach(function (v, idx) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'pp-variant-option' + (idx === 0 ? ' is-active' : '');
      btn.setAttribute('data-variant-index', String(idx));
      btn.innerHTML =
        '<img src="' + (v.image || product.image) + '" alt="' + escapeHtml(v.title) + '" loading="lazy">' +
        '<span class="pp-variant-option__title">' + escapeHtml(v.title) + '</span>';
      btn.addEventListener('click', function () {
        selectVariant(idx);
      });
      variantList.appendChild(btn);
    });
    variantOverlay.classList.add('is-active');
    variantOverlay.setAttribute('aria-hidden', 'false');
  }

  // ─── Variant preview (carousel jump + highlight, no commit) ───
  var activeProduct = null;
  var activeVariantIndex = 0;
  function selectVariant(idx) {
    if (!activeProduct || !activeProduct.variants) return;
    activeVariantIndex = Math.max(0, Math.min(activeProduct.variants.length - 1, idx));
    $$('.pp-variant-option').forEach(function (b, i) {
      b.classList.toggle('is-active', i === activeVariantIndex);
    });
    // Rebuild the carousel so only THIS variant's photos are shown.
    renderCarousel(activeProduct, activeVariantIndex);
  }
  // Wrap openVariantPicker to remember the active product
  var __openVariantPicker = openVariantPicker;
  openVariantPicker = function (product) {
    activeProduct = product;
    activeVariantIndex = 0;
    __openVariantPicker(product);
  };

  // ─── 'Voeg toe' CTA at the bottom of the modal ───
  var modalCta = $('#pp-modal-cta');
  if (modalCta) {
    modalCta.addEventListener('click', function () {
      if (!activeProduct || !activeProduct.variants || !activeProduct.variants[activeVariantIndex]) return;
      var v = activeProduct.variants[activeVariantIndex];
      var newItem = {
        productId: activeProduct.id,
        variantId: v.id,
        productHandle: activeProduct.handle,
        productTitle: activeProduct.title,
        variantTitle: v.title,
        image: v.image || activeProduct.image
      };
      // If this product is already in the pakket (re-opened from a
      // filled slot), swap its variant in place instead of refusing
      // with a 'zit al in je pakket' toast.
      var existingIdx = selection.findIndex(function (s) {
        return s.productId === activeProduct.id;
      });
      if (existingIdx >= 0) {
        selection[existingIdx] = newItem;
        renderSlots();
        closeVariantPicker();
        return;
      }
      if (selection.length >= MAX_SLOTS) {
        toast('Je hebt al ' + MAX_SLOTS + ' brillen gekozen.');
        return;
      }
      // Start the fly animation from the active carousel slide, then
      // immediately close the modal so the ghost is visible flying
      // out of a fading backdrop into the empty slot.
      var track = $('#pp-carousel-track');
      var sourceImg = track ? track.querySelector('img') : null;
      addWithFlyAnimation(sourceImg, newItem);
      closeVariantPicker();
    });
  }

  // ─── Fullscreen photo viewer ───
  var fsOverlay = $('#pp-fullscreen');
  var fsImg = $('#pp-fullscreen-img');
  var fsPrev = $('#pp-fullscreen-prev');
  var fsNext = $('#pp-fullscreen-next');
  var fsIndex = 0;
  function openFullscreen(i) {
    fsIndex = Math.max(0, Math.min(carouselImages.length - 1, i));
    fsImg.src = carouselImages[fsIndex] || '';
    syncFsNav();
    fsOverlay.classList.add('is-active');
  }
  function closeFullscreen() { fsOverlay.classList.remove('is-active'); }
  function syncFsNav() {
    fsPrev.disabled = fsIndex <= 0;
    fsNext.disabled = fsIndex >= carouselImages.length - 1;
  }
  function fsGo(delta) {
    var next = fsIndex + delta;
    if (next < 0 || next >= carouselImages.length) return;
    fsIndex = next;
    fsImg.src = carouselImages[fsIndex] || '';
    syncFsNav();
  }
  fsPrev.addEventListener('click', function () { fsGo(-1); });
  fsNext.addEventListener('click', function () { fsGo(1); });
  $('#pp-fullscreen-close').addEventListener('click', closeFullscreen);
  fsOverlay.addEventListener('click', function (e) {
    if (e.target === fsOverlay || e.target.classList.contains('pp-fullscreen__inner')) closeFullscreen();
  });
  document.addEventListener('keydown', function (e) {
    if (!fsOverlay.classList.contains('is-active')) return;
    if (e.key === 'Escape') closeFullscreen();
    else if (e.key === 'ArrowLeft') fsGo(-1);
    else if (e.key === 'ArrowRight') fsGo(1);
  });
  $('#pp-carousel-track').addEventListener('click', function (e) {
    var slide = e.target.closest('.pp-carousel__slide');
    if (!slide) return;
    var slides = Array.prototype.slice.call($('#pp-carousel-track').children);
    openFullscreen(slides.indexOf(slide));
  });

  function closeVariantPicker() {
    variantOverlay.classList.remove('is-active');
    variantOverlay.setAttribute('aria-hidden', 'true');
  }

  $('#pp-variant-close').addEventListener('click', closeVariantPicker);
  variantOverlay.addEventListener('click', function (e) {
    if (e.target === variantOverlay) closeVariantPicker();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && variantOverlay.classList.contains('is-active')) closeVariantPicker();
  });

  // ─── "Zo werkt thuis passen" modal ───
  var howtoOverlay = $('#pp-howto-overlay');
  var howtoTrigger = $('#pp-howto-trigger');
  if (howtoOverlay && howtoTrigger) {
    var openHowto = function () {
      howtoOverlay.classList.add('is-active');
      howtoOverlay.setAttribute('aria-hidden', 'false');
    };
    var closeHowto = function () {
      howtoOverlay.classList.remove('is-active');
      howtoOverlay.setAttribute('aria-hidden', 'true');
    };
    howtoTrigger.addEventListener('click', openHowto);
    var howtoClose = $('#pp-howto-close');
    if (howtoClose) howtoClose.addEventListener('click', closeHowto);
    howtoOverlay.addEventListener('click', function (e) {
      if (e.target === howtoOverlay) closeHowto();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && howtoOverlay.classList.contains('is-active')) closeHowto();
    });
  }

  // ─── Product handling ───
  function handleProductSelect(product) {
    if (selection.some(function (s) { return s.productId === product.id; })) {
      // Already selected — remove
      var idx = selection.findIndex(function (s) { return s.productId === product.id; });
      if (idx >= 0) removeFromSlot(idx);
      return;
    }
    if (selection.length >= MAX_SLOTS) {
      toast('Je pakket is al vol (' + MAX_SLOTS + ' brillen).');
      return;
    }
