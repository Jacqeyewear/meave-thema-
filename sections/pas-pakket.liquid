  // ─── Filter + sort + search ───
  var activeType = 'all';
  var activeSort = 'default';
  var searchTerm = '';
  var activePreset = 'all';

  function activeAttrSet(key) {
    return Object.keys(activeAttrs[key]);
  }
  function totalActiveAttrs() {
    return ATTR_DEFS.reduce(function (n, def) { return n + activeAttrSet(def.key).length; }, 0);
  }

  function matchesType(card) {
    if (activeType === 'all') return true;
    return card.getAttribute('data-product-type') === activeType;
  }
  function matchesAttrs(card) {
    for (var i = 0; i < ATTR_DEFS.length; i++) {
      var def = ATTR_DEFS[i];
      var selected = activeAttrSet(def.key);
      if (selected.length === 0) continue;
      var cardVals = (card.getAttribute('data-attr-' + def.key) || '').split('|');
      var hit = false;
      for (var j = 0; j < selected.length; j++) {
        if (cardVals.indexOf(selected[j]) !== -1) { hit = true; break; }
      }
      if (!hit) return false;
    }
    return true;
  }
  function normalizeSearch(s) {
    return String(s || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[̀-ͯ]/g, '');
  }
  function matchesSearch(card) {
    if (!searchTerm) return true;
    var t = normalizeSearch(card.getAttribute('data-title') || '');
    return t.indexOf(searchTerm) !== -1;
  }
  function matchesPreset(card) {
    if (activePreset === 'all') return true;
    var type = card.getAttribute('data-product-type') || '';
    var voor = (card.getAttribute('data-attr-voor') || '').toLowerCase().split('|');
    var tags = (card.getAttribute('data-tags') || '').toLowerCase();
    var compareAt = parseFloat(card.getAttribute('data-compare-at-price'));
    var price = parseFloat(card.getAttribute('data-price'));
    var isUnisex = voor.indexOf('unisex') !== -1 || voor.length === 0 || (voor.length === 1 && voor[0] === '');
    switch (activePreset) {
      case 'damesbrillen':       return type === 'bril' && (voor.indexOf('dames') !== -1 || isUnisex);
      case 'herenbrillen':       return type === 'bril' && (voor.indexOf('heren') !== -1 || isUnisex);
      case 'multifocaal':        return type === 'bril';
      case 'leesbrillen':        return type === 'bril';
      case 'beeldschermbrillen': return type === 'bril';
      case 'kinderbrillen':      return type === 'kinderbril';
      case 'dameszonnebrillen':  return type === 'zonnebril' && (voor.indexOf('dames') !== -1 || isUnisex);
      case 'herenzonnebrillen':  return type === 'zonnebril' && (voor.indexOf('heren') !== -1 || isUnisex);
      case 'sale':               return !isNaN(compareAt) && !isNaN(price) && compareAt > price;
      default:                   return true;
    }
  }

  function updateCardImages() {
    var activeColors = activeAttrSet('kleuren'); // already lowercased keys
    $$('.pp-card').forEach(function (card) {
      var img = card.querySelector('.pp-card__media img');
      if (!img) return;
      var defaultSrc = img.getAttribute('data-default-src');
      if (activeColors.length === 0) {
        if (defaultSrc && img.src !== defaultSrc) img.src = defaultSrc;
        return;
      }
      var pid = card.getAttribute('data-product-id');
      var p = productMap[pid];
      if (!p || !p.variants) return;
      var match = null;
      for (var i = 0; i < p.variants.length; i++) {
        var v = p.variants[i];
        var vColor = String(v.kleur || v.title || '').toLowerCase();
        if (v.image && activeColors.indexOf(vColor) !== -1) { match = v; break; }
      }
      if (match) {
        if (img.src !== match.image) img.src = match.image;
      } else if (defaultSrc && img.src !== defaultSrc) {
        img.src = defaultSrc;
      }
    });
  }

  // Pagination state + helpers
  var PRODUCTS_PER_PAGE = 24;
  var currentPage = 1;

  function scrollToGridTop() {
    var grid = $('#pp-grid');
    if (!grid) return;
    var rect = grid.getBoundingClientRect();
    window.scrollTo({ top: window.pageYOffset + rect.top - 80, behavior: 'smooth' });
  }

  function renderPaginationControls(totalPages) {
    var nav = $('#pp-pagination');
    if (!nav) return;
    nav.innerHTML = '';
    if (totalPages <= 1) { nav.hidden = true; return; }
    nav.hidden = false;

    function btn(label, page, opts) {
      opts = opts || {};
      var b = document.createElement('button');
      b.type = 'button';
      b.className = 'pp-pagination__btn' + (opts.active ? ' is-active' : '');
      b.textContent = label;
      if (opts.disabled) b.disabled = true;
      b.addEventListener('click', function () {
        if (opts.disabled) return;
        currentPage = page;
        applyFilterAndSort();
        scrollToGridTop();
      });
      return b;
    }

    function ellipsis() {
      var s = document.createElement('span');
      s.className = 'pp-pagination__ellipsis';
      s.textContent = '…';
      return s;
    }

    nav.appendChild(btn('‹', currentPage - 1, { disabled: currentPage === 1 }));

    var pages = [];
    pages.push(1);
    for (var i = currentPage - 1; i <= currentPage + 1; i++) {
      if (i > 1 && i < totalPages) pages.push(i);
    }
    if (totalPages > 1) pages.push(totalPages);
    pages = pages.filter(function (v, i, a) { return a.indexOf(v) === i; }).sort(function (a, b) { return a - b; });

    var prev = 0;
    pages.forEach(function (p) {
      if (p - prev > 1) nav.appendChild(ellipsis());
      nav.appendChild(btn(String(p), p, { active: p === currentPage }));
      prev = p;
    });

    nav.appendChild(btn('›', currentPage + 1, { disabled: currentPage === totalPages }));
  }

  function paginate(visibleCards) {
    var totalPages = Math.max(1, Math.ceil(visibleCards.length / PRODUCTS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;

    var start = (currentPage - 1) * PRODUCTS_PER_PAGE;
    var end = start + PRODUCTS_PER_PAGE;
    visibleCards.forEach(function (c, i) {
      c.classList.toggle('pp-card--page-hidden', i < start || i >= end);
    });

    var countEl = $('#pp-product-count');
    if (countEl) {
      if (visibleCards.length === 0) {
        countEl.textContent = '';
      } else {
        var shownStart = start + 1;
        var shownEnd = Math.min(end, visibleCards.length);
        countEl.textContent = shownStart + '–' + shownEnd + ' van ' + visibleCards.length + ' brillen';
      }
    }

    renderPaginationControls(totalPages);
  }

  function resetPagination() { currentPage = 1; }

  function applyFilterAndSort() {
    var cards = $$('.pp-card');
    cards.forEach(function (c) {
      var show = matchesPreset(c) && matchesType(c) && matchesAttrs(c) && matchesSearch(c);
      c.classList.toggle('is-hidden', !show);
    });
    var visible = cards.filter(function (c) { return !c.classList.contains('is-hidden'); });
    visible.sort(function (a, b) {
      if (activeSort === 'price-asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
      if (activeSort === 'price-desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
      if (activeSort === 'title-asc' || activeSort === 'title') return a.dataset.title.localeCompare(b.dataset.title, 'nl');
      if (activeSort === 'title-desc') return b.dataset.title.localeCompare(a.dataset.title, 'nl');
      return 0;
    });
    if (activeSort !== 'default') {
      visible.forEach(function (c) { grid.appendChild(c); });
    }
    emptyEl.hidden = visible.length > 0;

    // Pagination
    paginate(visible);

    updateCardImages();

    // Update attribute pill counts + active states.
    ATTR_DEFS.forEach(function (def) {
      var n = activeAttrSet(def.key).length;
      var attrEl = root.querySelector('[data-attr-key="' + def.key + '"]');
      if (!attrEl) return;
      attrEl.classList.toggle('is-active', n > 0);
      var countEl = attrEl.querySelector('.pp-attr__count');
      if (countEl) {
        countEl.textContent = n > 0 ? n : '';
        countEl.hidden = n === 0;
      }
    });
    var clearBtn = $('#pp-clear');
    if (clearBtn) clearBtn.hidden = totalActiveAttrs() === 0;
    if (typeof syncMobileFilterCount === 'function') syncMobileFilterCount();
  }

  // Type pills.
  $$('#pp-type-pills .pp-pill').forEach(function (pill) {
    pill.addEventListener('click', function () {
      $$('#pp-type-pills .pp-pill').forEach(function (p) { p.classList.toggle('is-active', p === pill); });
      activeType = pill.getAttribute('data-type');
      resetPagination();
      applyFilterAndSort();
    });
  });

  // Preset colour pills (homepage style — quick presets above attribute filters).
  $$('#pp-colnav .pp-colnav-pill[data-preset]').forEach(function (pill) {
    pill.addEventListener('click', function () {
      resetPagination();
      $$('#pp-colnav .pp-colnav-pill[data-preset]').forEach(function (p) { p.classList.toggle('is-active', p === pill); });
      activePreset = pill.getAttribute('data-preset');
      applyFilterAndSort();
    });
  });

  // Attribute dropdowns.
  // One swatch per canonical colour. All variants of e.g. grey
  // (lichtgrijs / donkergrijs / gunmetal) share one swatch and
  // toggle all variants together when clicked.
  var CANONICAL_COLORS = [
    { key: 'zwart',  label: 'Zwart',  hex: '#1d1d1f', match: ['zwart'] },
    { key: 'wit',    label: 'Wit',    hex: '#ffffff', match: ['wit', 'transparant', 'transparent'] },
    { key: 'grijs',  label: 'Grijs',  hex: '#9aa0a6', match: ['grijs', 'lichtgrijs', 'donkergrijs', 'gunmetal'] },
    { key: 'zilver', label: 'Zilver', hex: '#c8cdd3', match: ['zilver'] },
    { key: 'bruin',  label: 'Bruin',  hex: '#8b4513', match: ['bruin', 'donkerbruin', 'havana'] },
    { key: 'beige',  label: 'Beige',  hex: '#d8c19a', match: ['beige'] },
    { key: 'blauw',  label: 'Blauw',  hex: '#2c4a8a', match: ['blauw', 'lichtblauw', 'donkerblauw'] },
    { key: 'groen',  label: 'Groen',  hex: '#2e6e44', match: ['groen', 'lichtgroen', 'donkergroen'] },
    { key: 'rood',   label: 'Rood',   hex: '#9b1c1c', match: ['rood', 'donkerrood'] },
    { key: 'roze',   label: 'Roze',   hex: '#e89bbf', match: ['roze', 'lichtroze'] },
    { key: 'paars',  label: 'Paars',  hex: '#7c3aed', match: ['paars'] },
    { key: 'oranje', label: 'Oranje', hex: '#d2691e', match: ['oranje'] },
    { key: 'geel',   label: 'Geel',   hex: '#d5b933', match: ['geel'] },
    { key: 'goud',   label: 'Goud',   hex: '#c9a14a', match: ['goud', 'gold', 'rosegoud'] }
  ];

  function canonicalForRawValue(val) {
    var v = val.toLowerCase();
    for (var i = 0; i < CANONICAL_COLORS.length; i++) {
      var c = CANONICAL_COLORS[i];
      for (var j = 0; j < c.match.length; j++) {
        if (v.indexOf(c.match[j]) !== -1) return c;
      }
    }
    return null;
  }

  function renderAttrFilters() {
    var row = $('#pp-attr-row');
    if (!row) return;
    row.innerHTML = '';
    var icons = (data.icons || {});
    ATTR_DEFS.forEach(function (def) {
      var values = attrOptions[def.key] || [];
      if (values.length === 0) return;

      // Custom accordion (div + button) so the open/close animation
      // isn't blocked by the native <details> UA behaviour. We avoid
      // the theme's .details / .details__summary classes so the theme
      // stylesheet (which injects pseudo content + its own layout)
      // can't interfere — we control the look fully.
      var det = document.createElement('div');
      det.className = 'pp-attr';
      det.setAttribute('data-attr-key', def.key);
      det.setAttribute('data-filter', '');

      var summary = document.createElement('button');
      summary.type = 'button';
      summary.setAttribute('aria-expanded', 'false');
      summary.className = 'pp-attr__btn';
      summary.addEventListener('click', function () {
        var isOpen = det.hasAttribute('open');
        if (isOpen) {
          det.removeAttribute('open');
          summary.setAttribute('aria-expanded', 'false');
          det.classList.remove('is-open');
        } else {
          det.setAttribute('open', '');
          summary.setAttribute('aria-expanded', 'true');
          det.classList.add('is-open');
        }
      });
      var iconHtml = icons[def.key]
        ? '<img class="pp-attr__icon" src="' + icons[def.key] + '" alt="" width="20" height="20" loading="lazy">'
        : '';
      summary.innerHTML =
        '<span class="pp-attr__label">' +
          iconHtml + escapeHtml(def.label) +
        '</span>' +
        '<span class="pp-attr__right">' +
          '<span class="pp-attr__count" hidden></span>' +
          '<svg class="pp-attr__chev" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>' +
        '</span>';
      det.appendChild(summary);

      var content = document.createElement('div');
      content.className = 'pp-attr__panel';

      var isColor = def.key === 'kleuren' || def.key === 'kleur';

      if (isColor) {
        // Group raw values by canonical colour
        var canonicalsPresent = [];
        var canonicalToVariants = {};
        values.forEach(function (val) {
          var canon = canonicalForRawValue(val);
          if (!canon) return;
          if (!canonicalToVariants[canon.key]) {
            canonicalToVariants[canon.key] = [];
            canonicalsPresent.push(canon);
          }
          canonicalToVariants[canon.key].push(val.toLowerCase());
        });

        // Use the theme's swatches markup so .color-swatch CSS applies
        var ul = document.createElement('ul');
        ul.className = 'swatches swatches--round flex items-center flex-wrap gap-4';
        canonicalsPresent.forEach(function (canon, idx) {
          var variants = canonicalToVariants[canon.key];
          var li = document.createElement('li');
          var inputId = 'pp-swatch-' + def.key + '-' + idx;
          li.innerHTML =
            '<input class="sr-only" type="checkbox" id="' + inputId + '">' +
            '<label class="color-swatch block relative" for="' + inputId + '" ' +
              'style="--swatch-background: ' + canon.hex + ';" ' +
              'title="' + canon.label + '">' +
              '<span class="sr-only">' + canon.label + '</span>' +
            '</label>';
          var input = li.querySelector('input');
          input.addEventListener('change', function () {
            variants.forEach(function (v) {
              if (input.checked) activeAttrs[def.key][v] = true;
              else delete activeAttrs[def.key][v];
            });
            resetPagination();
            applyFilterAndSort();
          });
          ul.appendChild(li);
        });
        content.appendChild(ul);
      } else {
        values.forEach(function (val) {
          var lbl = document.createElement('label');
          lbl.className = 'pp-attr__opt';
          var count = attrCounts && attrCounts[def.key] ? (attrCounts[def.key][val.toLowerCase()] || 0) : 0;
          lbl.innerHTML =
            '<input type="checkbox" value="' + escapeHtml(val.toLowerCase()) + '">' +
            '<span class="pp-attr__opt-text">' + escapeHtml(val) +
              (count > 0 ? ' <span class="pp-attr__opt-count">(' + count + ')</span>' : '') +
            '</span>';
          var input = lbl.querySelector('input');
          input.addEventListener('change', function () {
            var key = val.toLowerCase();
            if (input.checked) activeAttrs[def.key][key] = true;
            else delete activeAttrs[def.key][key];
            resetPagination();
            applyFilterAndSort();
          });
          content.appendChild(lbl);
        });
      }
      det.appendChild(content);

      row.appendChild(det);
    });
  }

  // Build per-attribute counts (how many products carry each value)
  var attrCounts = {};
  ATTR_DEFS.forEach(function (def) {
    attrCounts[def.key] = {};
    products.forEach(function (p) {
      attrValues(p, def.key).forEach(function (v) {
        var k = v.toLowerCase();
        attrCounts[def.key][k] = (attrCounts[def.key][k] || 0) + 1;
      });
    });
  });

  // Close any open dropdown on outside click / Escape.
  document.addEventListener('click', function (e) {
    if (!e.target.closest('.pp-attr')) {
      $$('.pp-attr.is-open').forEach(function (w) { w.classList.remove('is-open'); });
    }
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      $$('.pp-attr.is-open').forEach(function (w) { w.classList.remove('is-open'); });
    }
  });

  // Clear-all.
  function clearAllAttrs() {
    ATTR_DEFS.forEach(function (def) { activeAttrs[def.key] = Object.create(null); });
    $$('.pp-attr__opt input').forEach(function (i) { i.checked = false; });
    $$('.pp-swatch input').forEach(function (i) { i.checked = false; });
    $$('.pp-swatch.is-checked').forEach(function (l) { l.classList.remove('is-checked'); });
    resetPagination();
    applyFilterAndSort();
  }
  var clearBtn = $('#pp-clear');
  if (clearBtn) clearBtn.addEventListener('click', clearAllAttrs);

  // Desktop sidebar toggle: 'Filters verbergen' / 'Filters tonen'.
  var sidebarToggleBtn = $('#pp-sidebar-toggle');
  var shopEl = $('.pp-shop');
  if (sidebarToggleBtn && shopEl) {
    sidebarToggleBtn.addEventListener('click', function () {
      var nowHidden = shopEl.classList.toggle('is-sidebar-hidden');
      sidebarToggleBtn.setAttribute('aria-expanded', String(!nowHidden));
      var labelEl = sidebarToggleBtn.querySelector('.pp-sidebar-toggle__label');
      if (labelEl) labelEl.textContent = nowHidden ? 'Filters tonen' : 'Filters verbergen';
    });
  }

  // Mobile filters popup.
  function openMobileFilters() {
    document.body.classList.add('pp-mobile-filters-open');
  }
  function closeMobileFilters() {
    document.body.classList.remove('pp-mobile-filters-open');
    $$('.pp-attr.is-open').forEach(function (w) { w.classList.remove('is-open'); });
  }
  var mfToggle = $('#pp-mobile-filters-toggle');
  var mfClose  = $('#pp-mobile-filters-close');
  var mfDone   = $('#pp-mobile-filters-done');
  var mfClear  = $('#pp-mobile-filters-clear');
  var mfCount  = $('#pp-mobile-filters-count');
  if (mfToggle) mfToggle.addEventListener('click', openMobileFilters);
  if (mfClose)  mfClose.addEventListener('click', closeMobileFilters);
  if (mfDone)   mfDone.addEventListener('click', closeMobileFilters);
  if (mfClear)  mfClear.addEventListener('click', clearAllAttrs);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && document.body.classList.contains('pp-mobile-filters-open')) closeMobileFilters();
  });

  // Sync mobile filter count badge.
  function syncMobileFilterCount() {
    if (!mfCount) return;
    var n = totalActiveAttrs();
    mfCount.textContent = n;
    mfCount.hidden = n === 0;
  }

  // ─── Custom sort dropdown ───
  var sortWrap = $('#pp-sort-wrap');
  var sortTrigger = $('#pp-sort-trigger');
  var sortPanel = $('#pp-sort-panel');
  var sortLabel = $('#pp-sort-trigger-label');
  if (sortWrap && sortTrigger && sortPanel) {
    function closeSortPanel() {
      sortWrap.classList.remove('is-open');
      sortTrigger.setAttribute('aria-expanded', 'false');
    }
    function openSortPanel() {
      sortWrap.classList.add('is-open');
      sortTrigger.setAttribute('aria-expanded', 'true');
    }
    sortTrigger.addEventListener('click', function (e) {
      e.stopPropagation();
      if (sortWrap.classList.contains('is-open')) closeSortPanel();
      else openSortPanel();
    });
    $$('.pp-sort-panel__opt', sortPanel).forEach(function (btn) {
      btn.addEventListener('click', function () {
        activeSort = btn.getAttribute('data-sort') || 'default';
        $$('.pp-sort-panel__opt', sortPanel).forEach(function (b) {
          b.classList.toggle('is-active', b === btn);
        });
        if (sortLabel) sortLabel.textContent = btn.textContent.trim();
        closeSortPanel();
        resetPagination();
        applyFilterAndSort();
      });
    });
    document.addEventListener('click', function (e) {
      if (!sortWrap.contains(e.target)) closeSortPanel();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && sortWrap.classList.contains('is-open')) closeSortPanel();
    });
  }

  var searchInput = $('#pp-search');
  if (searchInput) {
    var searchTimer = null;
    searchInput.addEventListener('input', function (e) {
      clearTimeout(searchTimer);
      var v = normalizeSearch((e.target.value || '').trim());
      searchTimer = setTimeout(function () {
        searchTerm = v;
        resetPagination();
        applyFilterAndSort();
      }, 120);
    });
  }

  // ─── Toast ───
  var toastEl = $('#pp-toast');
  var toastTimer = null;
  function toast(msg) {
    toastEl.textContent = msg;
    toastEl.classList.add('is-visible');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function () {
      toastEl.classList.remove('is-visible');
    }, 2400);
  }

  // ─── CTA: add paspakket to cart ───
  $('#pp-cta').addEventListener('click', function () {
    if (selection.length < MAX_SLOTS) {
      toast('Kies eerst ' + MAX_SLOTS + ' brillen.');
      return;
    }
    if (!data.paspakketVariantId) {
      toast('Pas-pakket product is nog niet ingesteld in de section settings.');
      console.error('[paspakket] section.settings.paspakket_product is not configured.');
      return;
    }
    var btn = this;
    btn.classList.add('is-loading');
    btn.textContent = 'Toevoegen…';

    var props = {};
    selection.forEach(function (s, i) {
      var n = i + 1;
      props['Bril ' + n] = s.productTitle + (s.variantTitle && s.variantTitle !== 'Default Title' ? ' — ' + s.variantTitle : '');
      // Hidden properties (leading underscore) — used by main-cart.liquid
      // to render the "Inhoud paspakket" modal with images.
      if (s.image) props['_Bril ' + n + ' image'] = s.image;
      if (s.productHandle) props['_Bril ' + n + ' handle'] = s.productHandle;
      if (s.variantTitle && s.variantTitle !== 'Default Title') props['_Bril ' + n + ' kleur'] = s.variantTitle;
      if (s.productTitle) props['_Bril ' + n + ' title'] = s.productTitle;
    });

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        items: [{
          id: data.paspakketVariantId,
          quantity: 1,
          properties: props
        }]
      })
    })
      .then(function (r) {
        if (!r.ok) throw new Error('Cart add failed: ' + r.status);
        return r.json();
      })
      .then(function () {
        try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
        window.location.href = '/cart';
      })
      .catch(function (err) {
        console.error('[paspakket] add to cart error', err);
        btn.classList.remove('is-loading');
        btn.textContent = '{{ section.settings.cta_label | default: "Voeg pas pakket toe" }}';
        toast('Toevoegen mislukt — probeer opnieuw.');
      });
  });

  // ─── Hide sticky slot bar on FAST scroll-down only, show on scroll-up ───
  // Hysteresis: we accumulate scroll distance in the current direction
  // and only flip the bar once that travel exceeds a threshold. This
  // smooths over tiny jitter so the bar doesn't pop in/out on every
  // wheel tick or trackpad nudge.
  // Mobile-only floating "back to basket" pill.
  // Toggles visibility based on whether the basket card is out of
  // viewport; tapping scrolls smoothly back to it.
  var miniBasket = $('#pp-mini-basket');
  var miniBasketTarget = $('.pp-slots-wrap');
  if (miniBasket && miniBasketTarget) {
    var miniIsMobile = function () { return window.matchMedia('(max-width: 720px)').matches; };
    var miniVisible = false;
    function updateMiniBasket() {
      if (!miniIsMobile()) {
        if (miniVisible) { miniBasket.classList.remove('is-visible'); miniVisible = false; }
        return;
      }
      var r = miniBasketTarget.getBoundingClientRect();
      var shouldShow = r.bottom < 20; // basket has scrolled off-screen
      if (shouldShow !== miniVisible) {
        miniBasket.classList.toggle('is-visible', shouldShow);
        miniVisible = shouldShow;
      }
    }
    miniBasket.addEventListener('click', function () {
      var r = miniBasketTarget.getBoundingClientRect();
      var targetY = window.scrollY + r.top - 12;
      window.scrollTo({ top: Math.max(0, targetY), behavior: 'smooth' });
    });
    window.addEventListener('scroll', updateMiniBasket, { passive: true });
    window.addEventListener('resize', updateMiniBasket, { passive: true });
    updateMiniBasket();
  }

  var slotsWrap = $('.pp-slots-wrap');
  if (slotsWrap) {
    var lastY = window.scrollY;
    var lastT = performance.now();
    var ticking = false;
    var pinnedTop = 80;          // always shown when scrolled this close to top
    var fastDownVelocity = 1.4;  // px/ms — must exceed this to start counting
    var downTravel = 0;          // px scrolled down at >= fastDownVelocity
    var upTravel = 0;            // px scrolled up
    var hideAfterPx = 60;        // require this much fast-down travel to hide
    var showAfterPx = 16;        // require this much up travel to show again
    var isHidden = false;

    // Desktop only: detect when the hero scrolls past so the basket can
    // switch from "absolute in hero (right)" to "fixed top-centered".
    var heroEl = document.querySelector('.pp-header');
    var isDesktop = function () { return window.matchMedia('(min-width: 1024px)').matches; };
    function updateStuck() {
      if (!heroEl || !isDesktop()) {
        slotsWrap.classList.remove('is-stuck');
        return;
      }
      var headerH = (function () {
        var v = getComputedStyle(document.documentElement).getPropertyValue('--sticky-header-height') ||
                getComputedStyle(document.documentElement).getPropertyValue('--header-height') || '0';
        return parseInt(v, 10) || 0;
      })();
      var heroBottom = heroEl.getBoundingClientRect().bottom;
      // Stick once the hero's bottom passes above the sticky header line.
      slotsWrap.classList.toggle('is-stuck', heroBottom < headerH + 8);
    }
    window.addEventListener('resize', updateStuck, { passive: true });
    updateStuck();

    function updateSlotBar() {
      var y = window.scrollY;
      var t = performance.now();
      var dt = Math.max(1, t - lastT);
      var dy = y - lastY;
      var v = dy / dt; // px/ms; positive = down

      updateStuck();

      if (y < pinnedTop) {
        if (isHidden) {
          isHidden = false;
          slotsWrap.classList.remove('is-hidden-scrolling');
        }
        downTravel = 0;
        upTravel = 0;
      } else if (dy > 0) {
        // Scrolling down — only count it if it's a genuinely fast move.
        if (v >= fastDownVelocity) {
          downTravel += dy;
          upTravel = 0;
          if (!isHidden && downTravel >= hideAfterPx) {
            isHidden = true;
            slotsWrap.classList.add('is-hidden-scrolling');
          }
        } else {
          // Calm downward scroll — bleed off any accumulated fast travel
          // so a later slow scroll doesn't trigger a stale hide.
          downTravel = Math.max(0, downTravel - dy);
        }
      } else if (dy < 0) {
        upTravel += -dy;
        downTravel = 0;
        if (isHidden && upTravel >= showAfterPx) {
          isHidden = false;
          slotsWrap.classList.remove('is-hidden-scrolling');
        }
      }

      lastY = y;
      lastT = t;
      ticking = false;
    }
    window.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateSlotBar);
    }, { passive: true });
  }

  // ─── Boot ───
  renderAttrFilters();
  renderGrid();
  applyFilterAndSort();
})();
</script>

