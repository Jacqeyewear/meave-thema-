    // diagram + variant picker, even for single-variant products.
    openVariantPicker(product);
  }

  // ─── Product grid rendering ───
  var grid = $('#pp-grid');
  var emptyEl = $('#pp-empty');

  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function renderGrid() {
    grid.innerHTML = '';
    products.forEach(function (p) {
      var card = document.createElement('div');
      card.className = 'pp-card';
      card.setAttribute('data-product-id', p.id);
      card.setAttribute('data-product-type', p.type);
      card.setAttribute('data-price', p.priceNum);
      card.setAttribute('data-title', p.title);
      card.setAttribute('data-tags', p.tags || '');
      if (p.compareAtPrice != null) card.setAttribute('data-compare-at-price', p.compareAtPrice);
      ATTR_DEFS.forEach(function (def) {
        var vals = attrValues(p, def.key).map(function (v) { return v.toLowerCase(); });
        card.setAttribute('data-attr-' + def.key, vals.join('|'));
      });
      card.setAttribute('draggable', 'true');
      var onSale = p.compareAtPrice != null && p.compareAtPrice > p.priceNum;
      var korting = onSale ? Math.round(p.compareAtPrice - p.priceNum) : 0;
      var compareDisplay = onSale ? (p.compareAtPrice % 1 === 0 ? p.compareAtPrice.toFixed(0) : p.compareAtPrice.toFixed(2)) : '';
      card.innerHTML =
        '<div class="pp-card__media">' +
          (onSale ? '<span class="pp-card__badge">€' + korting + ',- Korting</span>' : '') +
          '<button type="button" class="pp-card__quick" aria-label="Snel toevoegen aan pas-pakket" title="Snel toevoegen">' +
            '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 3v10M3 8h10"/></svg>' +
          '</button>' +
          (p.image ? '<img src="' + p.image + '" data-default-src="' + p.image + '" alt="' + escapeHtml(p.title) + '" loading="lazy">' : '') +
        '</div>' +
        '<div class="pp-card__info">' +
          '<div class="pp-card__title-row">' +
            '<div class="pp-card__title">' + escapeHtml(p.title) + '</div>' +
            '<div class="pp-card__price' + (onSale ? ' pp-card__price--sale' : '') + '">' +
              '€' + escapeHtml(p.price) +
              (onSale ? ' <s class="pp-card__price--compare">€' + escapeHtml(compareDisplay) + '</s>' : '') +
            '</div>' +
          '</div>' +
          '<button type="button" class="pp-card__add">Voeg toe</button>' +
        '</div>';

      // Quick-add: skip the modal, use the product's first variant
      // and animate it straight into the next empty slot.
      var quickBtn = card.querySelector('.pp-card__quick');
      if (quickBtn) {
        quickBtn.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          if (!p.variants || !p.variants.length) return;
          if (selection.some(function (s) { return s.productId === p.id; })) {
