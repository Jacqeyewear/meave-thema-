    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    pointer-events: none;
  }
  .jacq-pp-panel {
    pointer-events: auto;
    background: #fff;
    border-radius: 22px;
    padding: 22px 22px 24px;
    box-shadow: 0 18px 40px rgba(0,0,0,0.18);
    max-width: 640px;
    width: 100%;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    transform: scale(0.96);
    opacity: 0;
    transition: transform 0.28s var(--pp-ease), opacity 0.22s var(--pp-ease);
  }
  #jacq-paspakket-modal.is-open .jacq-pp-panel { transform: scale(1); opacity: 1; }
  .jacq-pp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 4px;
  }
  .jacq-pp-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--pp-text);
    letter-spacing: -0.02em;
    margin: 0;
  }
  .jacq-pp-close {
    appearance: none;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(0,0,0,0.05);
    color: var(--pp-text);
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .jacq-pp-close:hover { background: rgba(0,0,0,0.08); }
  .jacq-pp-close svg { width: 16px; height: 16px; }
  .jacq-pp-sub {
    font-size: 13px;
    color: var(--pp-muted);
    margin: 0 0 16px;
  }
  .jacq-pp-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (max-width: 520px) {
    .jacq-pp-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
    .jacq-pp-panel { padding: 18px 16px 20px; }
  }
  .jacq-pp-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.04),
      0 4px 14px rgba(0,0,0,0.06);
    transition: box-shadow 0.24s var(--pp-ease), transform 0.24s var(--pp-ease);
  }
  .jacq-pp-card:hover { transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.08), 0 14px 32px rgba(0,0,0,0.10); }
  .jacq-pp-card__media {
    aspect-ratio: 1 / 1;
    background: var(--pp-image-bg);
    overflow: hidden;
  }
  .jacq-pp-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .jacq-pp-card__info {
    padding: 10px 12px 12px;
  }
  .jacq-pp-card__num {
    font-size: 11px;
    color: var(--pp-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 2px;
  }
  .jacq-pp-card__title {
    font-size: 14px;
    font-weight: 600;
    color: var(--pp-text);
    letter-spacing: -0.01em;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .jacq-pp-card__kleur {
    font-size: 12px;
    color: var(--pp-muted);
    margin: 2px 0 0;
  }
  html.jacq-pp-no-scroll { overflow: hidden; }
</style>

<script>
(function () {
  'use strict';
  var modal = document.getElementById('jacq-paspakket-modal');
  if (!modal) return;
  var grid = document.getElementById('jacq-pp-grid');

  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function buildPaspakketHtml(link) {
    var html = '<div class="jacq-wp-pp-grid">';
    for (var i = 1; i <= 4; i++) {
      var title = link.getAttribute('data-bril-' + i + '-title') || '';
      var image = link.getAttribute('data-bril-' + i + '-image') || '';
      var kleur = link.getAttribute('data-bril-' + i + '-kleur') || '';
      var handle = link.getAttribute('data-bril-' + i + '-handle') || '';
      if (!title && !image) continue;
      var displayTitle = title;
      if (!kleur && /\s—\s/.test(title)) {
        var parts = title.split(/\s—\s/);
        displayTitle = parts[0];
        kleur = parts.slice(1).join(' — ');
      }
      var inner =
        '<div class="jacq-wp-pp-card__media">' +
          (image ? '<img src="' + escapeHtml(image) + '" alt="' + escapeHtml(displayTitle) + '" loading="lazy">' : '') +
        '</div>' +
        '<div class="jacq-wp-pp-card__info">' +
          '<p class="jacq-wp-pp-card__num">Bril ' + i + '</p>' +
          '<p class="jacq-wp-pp-card__title">' + escapeHtml(displayTitle) + '</p>' +
          (kleur ? '<p class="jacq-wp-pp-card__kleur">' + escapeHtml(kleur) + '</p>' : '') +
        '</div>';
      if (handle) {
        html += '<a class="jacq-wp-pp-card" href="/products/' + encodeURIComponent(handle) + '" target="_blank" rel="noopener">' + inner + '</a>';
      } else {
        html += '<div class="jacq-wp-pp-card">' + inner + '</div>';
      }
    }
    html += '</div>';
    return html;
  }

  function getInlinePanelFor(key) {
    return document.querySelector('tr.jacq-wp-details-row[data-for-item="' + (window.CSS && CSS.escape ? CSS.escape(key) : key) + '"] .jacq-wp-details-panel');
  }

  function closeOtherPanels(except) {
    document.querySelectorAll('tr.jacq-wp-details-row[data-open="1"]').forEach(function (row) {
      if (row === except) return;
      row.removeAttribute('data-open');
      row.setAttribute('aria-hidden', 'true');
      var key = row.getAttribute('data-for-item');
      var trig = document.querySelector('a[data-jacq-wp-toggle][data-item-key="' + (window.CSS && CSS.escape ? CSS.escape(key) : key) + '"]');
      if (trig) {
        trig.setAttribute('aria-expanded', 'false');
        var lbl = trig.querySelector('.jacq-wp-toggle__label');
        if (lbl) lbl.textContent = lbl.dataset.labelClosed || 'Details';
      }
    });
  }

  function togglePanel(trigger, panel) {
    var row = panel.closest('tr.jacq-wp-details-row');
    var isOpen = row.getAttribute('data-open') === '1';
    closeOtherPanels(isOpen ? null : row);
    if (isOpen) {
      row.removeAttribute('data-open');
      row.setAttribute('aria-hidden', 'true');
      trigger.setAttribute('aria-expanded', 'false');
      var l = trigger.querySelector('.jacq-wp-toggle__label');
      if (l) l.textContent = l.dataset.labelClosed || 'Details';
    } else {
      row.setAttribute('data-open', '1');
      row.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
      var l2 = trigger.querySelector('.jacq-wp-toggle__label');
      if (l2) l2.textContent = l2.dataset.labelOpen || 'Sluiten';
    }
  }

  document.addEventListener('click', function (e) {
    var link = e.target.closest('.jacq-paspakket-open');
    if (!link) return;

    e.preventDefault();
    e.stopPropagation();

    var key = link.getAttribute('data-item-key');
    var panel = key ? getInlinePanelFor(key) : null;
    if (!panel) return; // No inline panel → silently ignore

    var row = panel.closest('tr.jacq-wp-details-row');
    if (row && row.getAttribute('data-open') !== '1') {
      var content = panel.querySelector('[data-jacq-wp-content]');
      if (content) content.innerHTML = buildPaspakketHtml(link);
    }
    togglePanel(link, panel);
  });

  // Auto-render paspakket grid for items that are server-rendered with data-open="1"
  function autoRenderOpenPaspakket(){
    document.querySelectorAll('tr.jacq-wp-details-row[data-open="1"]').forEach(function(row){
      var key = row.getAttribute('data-for-item');
      var panel = row.querySelector('.jacq-wp-details-panel');
      if (!panel) return;
      var content = panel.querySelector('[data-jacq-wp-content]');
      if (!content || content.innerHTML.trim()) return;
      var link = document.querySelector('.jacq-paspakket-open[data-item-key="' + (window.CSS && CSS.escape ? CSS.escape(key) : key) + '"]');
      if (!link) return;
      content.innerHTML = buildPaspakketHtml(link);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', autoRenderOpenPaspakket);
  } else {
    autoRenderOpenPaspakket();
  }
})();
</script>

