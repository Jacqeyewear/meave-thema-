    z-index: 2147483646;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display", sans-serif;
    letter-spacing: -0.01em;
  }
  #jacq-paspakket-modal[hidden] { display: none !important; }
  .jacq-pp-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.38);
