                                </div>
                              {%- endif -%}
                              {%- if has_vol_pricing -%}
                                {{ 'volume-pricing.aio.min.css' | asset_url | stylesheet_tag }}
                                <volume-pricing class="volume-pricing grid gap-6">
                                  <span class="caption-large font-medium">{{ 'products.volume_pricing.title' | t }}</span>
                                  <ul class="list-unstyled">
                                    <li class="text-sm flex gap-2d5 justify-between">
                                      <span class="font-medium">{{ item.variant.quantity_rule.min }}+</span>
                                      {%- assign price = item.variant.price | money_with_currency -%}
                                      <span> {{ 'sections.quick_order_list.each' | t: money: price }}</span>
                                    </li>
                                    {%- for price_break in item.variant.quantity_price_breaks -%}
                                      <li class="text-sm flex gap-2d5 justify-between">
                                        <span class="font-medium">
                                          {{- price_break.minimum_quantity -}}
                                          <span aria-hidden="true">+</span>
                                        </span>
                                        {%- assign price = price_break.price | money_with_currency -%}
                                        <span> {{ 'sections.quick_order_list.each' | t: money: price }}</span>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                </volume-pricing>
                              {%- endif -%}
                            {%- endcapture -%}
                          {%- endif -%}
                          <div class="cart-quantity__info grid md:flex items-center justify-end md:justify-start gap-3 md:gap-4">
                            {%- if has_qty_rules or has_vol_pricing -%}
                              <button type="button" class="hotspot hidden md:flex items-center justify-center relative cursor-pointer">
                                {%- render 'icon', icon: 'info', size: 'lg' -%}
                                <div class="hotspot__content grid gap-6 items-center absolute z-1 pointer-events-none overflow-hidden text-left">
                                  {{- qty_rules_vol_pricing -}}
                                </div>
                              </button>
                            {%- endif -%}
                            {%- unless is_gift_wrap_item -%}
                              <div class="flex gap-3">
                                {%- if has_qty_rules or has_vol_pricing -%}
                                  <button type="button" class="md:hidden flex items-center justify-center" aria-controls="VolumePricing-{{ section.id }}-{{ item.key }}" aria-expanded="false">
                                    {%- render 'icon', icon: 'info', size: 'sm' -%}
                                  </button>
                                  <x-modal id="VolumePricing-{{ section.id }}-{{ item.key }}" class="x-modal drawer z-30 fixed bottom-0 left-0 h-full w-full pointer-events-none"
                                    role="dialog"
                                    aria-modal="true"
                                    aria-label="{{ item.product.title | escape }}"
                                    hidden
                                  >
                                    <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="VolumePricing-{{ section.id }}-{{ item.key }}" aria-expanded="false"></overlay-element>
                                    <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
                                      <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative">
                                        <span class="drawer__title heading title-md grid gap-4">
                                          {{ item.product.title | escape }}
                                          {%- unless item.product.has_only_default_variant -%}
                                            <dl class="grid gap-1d5">
                                              {%- for option in item.options_with_values -%}
                                                <div class="flex gap-1 text-xs text-opacity leading-tight">
                                                  <dt class="sr-only">{{ option.name }}:</dt>
                                                  <dd>{{ option.value }}</dd>
                                                </div>
                                              {%- endfor -%}
                                            </dl>
                                          {%- endunless -%}
                                        </span>
                                        <button class="button button--secondary button--close drawer__close hidden sm:flex items-center justify-center" type="button" is="hover-button" aria-controls="VolumePricing-{{ section.id }}-{{ item.key }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
                                          <span class="btn-fill" data-fill></span>
                                          <span class="btn-text">
                                            {%- render 'icon', icon: 'close', size: 'sm' -%}
                                          </span>
                                        </button>
                                      </gesture-element>
                                      <div class="drawer__content opacity-0 invisible flex flex-col h-full grow shrink">
                                        <div class="drawer__scrollable relative flex flex-col gap-5 md:gap-7 grow shrink">
                                          <div class="text-base md:text-lg grid gap-6">
                                            {{- qty_rules_vol_pricing -}}
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                  </x-modal>
                                {%- endif -%}
                                <quantity-input class="cart-quantity flex items-center relative">
                                  <label class="sr-only" for="Quantity-{{ section.id }}-{{ item.key }}">
                                    {{- 'products.quantity.label' | t -}}
                                  </label>
                                  <input class="quantity__input input text-center w-full h-full"
                                    type="number"
                                    name="updates[]"
                                    aria-label="{{ 'products.quantity.input_label' | t: product: item.product.title | escape }}"
                                    id="Quantity-{{ section.id }}-{{ item.key }}"
                                    data-index="{{ item.key }}"
                                    inputmode="numeric"
                                    autocomplete="off"
                                    data-quantity-variant-id="{{ item.variant.id }}"
                                    data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                    min="0"
                                    data-min="{{ item.variant.quantity_rule.min }}"
                                    {% if item.variant.quantity_rule.max != null %}
                                      max="{{ item.variant.quantity_rule.max }}"
                                    {% endif %}
                                    step="{{ item.variant.quantity_rule.increment }}"
                                    value="{{ item.quantity }}"
                                  />
                                  <div class="quantity__buttons absolute right-0 hidden lg:flex flex-col items-center justify-center h-full">
                                    <button type="button" name="plus" class="quantity__button flex justify-center w-full items-end" aria-label="{{ 'products.quantity.increase' | t: product: item.product.title | escape }}">
                                      {%- render 'icon', icon: 'increase', size: 'sm', class: 'stroke-1' -%}
                                    </button>
                                    <button type="button" name="minus" class="quantity__button flex justify-center w-full items-start" aria-label="{{ 'products.quantity.decrease' | t: product: item.product.title | escape }}">
                                      {%- render 'icon', icon: 'decrease', size: 'sm', class: 'stroke-1' -%}
                                    </button>
                                  </div>
                                </quantity-input>
                              </div>
                            {%- else -%}
                              <div class="cart-quantity flex items-center relative">
                                <label class="sr-only" for="Quantity-{{ section.id }}-{{ item.key }}">
                                  {{- 'products.quantity.label' | t -}}
                                </label>
                                <input class="quantity__input input text-center w-full h-full"
                                  type="number"
                                  name="updates[]"
                                  aria-label="{{ 'products.quantity.input_label' | t: product: item.product.title | escape }}"
                                  id="Quantity-{{ section.id }}-{{ item.key }}"
                                  data-index="{{ item.key }}"
                                  inputmode="numeric"
                                  autocomplete="off"
                                  data-quantity-variant-id="{{ item.variant.id }}"
                                  data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                  min="0"
                                  data-min="{{ item.variant.quantity_rule.min }}"
                                  {% if item.variant.quantity_rule.max != null %}
                                    max="{{ item.variant.quantity_rule.max }}"
                                  {% endif %}
                                  step="{{ item.variant.quantity_rule.increment }}"
                                  value="{{ item.quantity }}"
                                  disabled
                                />
                                <div class="quantity__buttons absolute right-0 hidden lg:flex flex-col items-center justify-center h-full sr-only">
                                  <button type="button" name="plus" class="quantity__button flex justify-center w-full items-end" aria-label="{{ 'products.quantity.increase' | t: product: item.product.title | escape }}" disabled>
                                    {%- render 'icon', icon: 'increase', size: 'sm', class: 'stroke-1' -%}
                                  </button>
                                  <button type="button" name="minus" class="quantity__button flex justify-center w-full items-start" aria-label="{{ 'products.quantity.decrease' | t: product: item.product.title | escape }}" disabled>
                                    {%- render 'icon', icon: 'decrease', size: 'sm', class: 'stroke-1' -%}
                                  </button>
                                </div>
                              </div>
                            {%- endunless -%}
                            <div class="text-xs relative">
                              <div id="Loader-{{ section.id }}-{{ item.key }}" class="loader absolute right-0 md:left-0" hidden>
                                {%- render 'icon', icon: 'rotator', size: 'xs', class: 'animate-rotator' -%}
                              </div>
                              <a class="link" href="{{ item.url_to_remove }}"{% unless is_gift_wrap_item %} is="cart-remove-button"{% else %} is="remove-gift-wrap"{% endunless %} data-index="{{ item.key }}" data-no-instant>{{ 'cart.general.remove' | t }}</a>
                            </div>
                          </div>
                        </td>

                        <td class="text-right hidden md:table-cell">
                          <span class="price text-base-xl">
                            {%- liquid
  assign line_total_with_addon = item.final_line_price | plus: addon_total
  if settings.currency_code_enabled
    echo line_total_with_addon | money_with_currency
  else
    echo line_total_with_addon | money
  endif
-%}

                          </span>
                        </td>
                      </tr>

                      {%- if is_jacq_parent or item.product.handle == 'paspakket' -%}
                        <tr class="jacq-wp-details-row" data-for-item="{{ item.key }}" data-open="1" aria-hidden="false">
                          <td colspan="3" class="jacq-wp-details-cell">
                            <div class="jacq-wp-details-panel" id="jacq-wp-panel-{{ item.key }}" data-jacq-wp-panel data-item-key="{{ item.key }}">
                              <div class="jacq-wp-details-content" data-jacq-wp-content></div>
                            </div>
                          </td>
                        </tr>
                      {%- endif -%}
                    {%- endcapture -%}

                    {%- liquid
                      unless is_gift_wrap_item
                        echo cart_item
                      else
                        assign cart_gift_wrap_item = cart_item
                      endunless
                    -%}
                  {%- endfor -%}

                  {%- liquid
                    if cart_gift_wrap_item
                      echo cart_gift_wrap_item
                    endif
                  -%}
                </tbody>
              </table>
            </cart-items>
          </form>

          {%- render 'gift-wrapping',
            section_id: section.id,
            gift_wrapping: gift_wrapping,
            gift_wrap_id: gift_wrap_id,
            gift_wraps_in_cart: gift_wraps_in_cart,
            items_in_cart: items_in_cart,
          -%}

          {%- if section.settings.show_shipping_calculator or section.settings.add_discount_code -%}
            <div class="grid gap-6 items-start{% if section.settings.show_shipping_calculator and section.settings.add_discount_code %} xl:grid-cols-2{% endif %}">
              {%- if section.settings.show_shipping_calculator -%}
                <div class="cart-details">
                  <details class="details" is="accordion-details">
                    <summary class="details__summary flex items-center justify-between gap-2 cursor-pointer">
                      <span class="text-sm md:text-2xl font-medium leading-none">{{ 'general.cart.shipping_calculator.caption' | t }}</span>
                      <svg class="icon icon-chevron-down" viewBox="0 0 18 10" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M1 1L9 9L17 1"></path>
                      </svg>
                    </summary>
                    <form class="details__content grid gap-4 md:gap-6" action="{{ routes.cart_url }}" method="POST" novalidate is="shipping-calculator">
                      <div class="grid{% unless section.settings.add_discount_code %} xl:flex{% endunless %} gap-4">
                        <country-province class="grid{% unless section.settings.add_discount_code %} xl:flex{% endunless %} gap-4"{% if shop.customer_accounts_enabled and customer %} data-country="{{ customer.default_address.country }}"{% if customer.default_address.province != '' %} data-province="{{ customer.default_address.province }}"{% endif %}{% endif %}>
                          <div class="field">
                            <select
                              name="address[country]"
                              class="select is-floating"
                              autocomplete="country"
                              is="custom-select"
                              id="ShippingCalculatorCountry-{{ section.id }}"
                            >
                              {{- all_country_option_tags -}}
                            </select>
                            {%- render 'icon', icon: 'chevron-up', size: 'sm', class: 'absolute pointer-events-none' -%}
                            <label class="label is-floating" for="ShippingCalculatorCountry-{{ section.id }}">{{ 'customer.addresses.country' | t }}</label>
                          </div>
                          <div class="field" hidden>
                            <select
                              name="address[province]"
                              class="select is-floating"
                              autocomplete="address-level1"
                              is="custom-select"
                              id="ShippingCalculatorProvince-{{ section.id }}"
                            >
                            </select>
                            {%- render 'icon', icon: 'chevron-up', size: 'sm', class: 'absolute pointer-events-none' -%}
                            <label class="label is-floating" for="ShippingCalculatorProvince-{{ section.id }}">{{ 'customer.addresses.province' | t }}</label>
                          </div>
                        </country-province>
                        <div class="field">
                          <input
                            name="address[zip]"
                            class="input is-floating"
                            type="text"
                            autocapitalize="characters"
                            autocomplete="postal-code"
                            placeholder=" "
                            id="ShippingCalculatorZip-{{ section.id }}"
                            {% if shop.customer_accounts_enabled and customer %}value="{{ customer.default_address.zip }}"{% endif %}
                          />
                          <label class="label is-floating" for="ShippingCalculatorZip-{{ section.id }}">{{ 'customer.addresses.zip' | t }}</label>
                        </div>
                        <div class="justify-self-start{% if section.settings.add_discount_code %} w-full{% endif %}">
                          <button class="button{% if section.settings.add_discount_code %} button--primary w-full{% else %} button--secondary button--fixed{% endif %}" type="submit" is="hover-button">
                            <span class="btn-fill" data-fill></span>
                            <span class="btn-text">{{ 'general.cart.shipping_calculator.button' | t }}</span>
                          </button>
                        </div>
                      </div>
                      <div class="alert alert--error alert--transparent flex gap-2d5" hidden>
                        {%- render 'icon', icon: 'alert-circle-filled', size: 'sm', class: 'shrink-0' -%}
                        <div class="grid gap-2 align-self-center text-sm leading-tight"></div>
                      </div>
                    </form>
                  </details>
                </div>
              {%- endif -%}
              
              {%- if section.settings.add_discount_code -%}
                {%- liquid
                  assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
                  for item in cart.items
                    for allocation in item.line_level_discount_allocations
                      if allocation.discount_application.type == 'discount_code'
                        assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
                      endif
                    endfor
                  endfor

                  assign discount_codes = discount_codes | uniq
                -%}
                <div class="cart-details">
                  <details class="details" is="accordion-details" id="CartDiscount-{{ section.id }}">
                    <summary class="details__summary flex items-center justify-between gap-2 cursor-pointer">
                      <p class="flex items-center gap-2d5">
                        <span class="text-sm md:text-2xl font-medium leading-none">{{ 'general.cart.discount.caption' | t }}</span>
                        {%- if discount_codes.size > 0 -%}
                          <span class="cart-discount__count flex items-center justify-center text-xs font-medium rounded-full">{{ discount_codes.size }}</span>
                        {%- endif -%}
                      </p>
                      <svg class="icon icon-chevron-down" viewBox="0 0 18 10" stroke="currentColor" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M1 1L9 9L17 1"></path>
                      </svg>
                    </summary>
                    <form class="details__content cart-discount grid gap-4 md:gap-6" action="{{ routes.cart_url }}" method="POST" novalidate is="cart-discount" data-section-id="{{ section.id }}">
                      <ul class="active-facets flex flex-wrap items-center gap-2" role="list" aria-label="{{ 'customer.order.discounts' | t | escape }}">
                        {%- for discount_code in discount_codes -%}
                          <li
                            class="removable-facet badge badge--highlight flex items-center justify-between gap-2 text-xs lg:text-sm leading-none rounded-full"
                            aria-label="{{ 'general.cart.discount.applied' | t: code: discount_code | escape }}"
                          >
                            <p class="facet-title">{{ discount_code }}</p>
                            <button type="button" class="block relative" aria-label="{{ 'general.cart.discount.remove' | t: code: discount_code | escape }}" is="discount-remove" data-magnet="3" data-discount="{{ discount_code }}">
                              <span class="btn-text" data-text>
                                {%- liquid
                                  render 'icon', icon: 'remove', size: 'xs'
                                  render 'icon', icon: 'loader', size: 'sm absolute opacity-0 invisible animate-spin'
                                -%}
                              </span>
                            </button>
                          </li>
                        {%- endfor -%}
                      </ul>
                      <div class="field">
                        <input type="text" name="discount" class="input is-floating" rows="3" placeholder=" " id="CartDiscountForm-{{ section.id }}"/>
                        <label class="label is-floating" for="CartDiscountForm-{{ section.id }}">{{ 'general.cart.discount.placeholder' | t }}</label>
                      </div>
                      <button class="button button--primary w-full" type="submit" is="hover-button">
                        <span class="btn-fill" data-fill></span>
                        <span class="btn-text">{{ 'general.cart.discount.button' | t }}</span>
                      </button>
                      <div class="alert alert--error alert--transparent flex gap-2d5" hidden>
                        {%- render 'icon', icon: 'alert-circle-filled', size: 'sm', class: 'shrink-0' -%}
                        <div class="grid gap-2 align-self-center text-sm leading-tight"></div>
                      </div>
                    </form>
                  </details>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <div class="grow-0 jacq-wp-sidebar-col" style="width:var(--wp-sidebar-width);flex:var(--wp-sidebar-flex, 0 0 var(--wp-sidebar-width));align-self:stretch;padding:0;margin-right:0;">
          <sticky-element class="flex flex-col gap-7d5 jacq-wp-sticky" style="display:block;width:100%;margin-top:var(--wp-sticky-top, 24px);position:static;inset-block-start:auto;">
            <div class="cart__sidebar flex flex-col gap-7d5 md:gap-10 jacq-wp-sidebar" style="width:100%;max-width:100%;padding:var(--wp-sidebar-padding, 0 56px 30px 56px);box-sizing:border-box;gap:12px;">

              {%- comment -%}
                "Ook aanbevolen" suggestion carousel — Warby-Parker
                inspired card pinned to the top of the right column.
                The three products are looked up by handle; any that
                are missing or sold-out silently drop out.
              {%- endcomment -%}
              {%- assign jacq_suggest_handles = 'boaz|grijs,nila|havana,kian|zilver' | split: ',' -%}
              {%- assign jacq_suggest_count = 0 -%}
              {%- capture jacq_suggest_cards -%}
                {%- for pair in jacq_suggest_handles -%}
                  {%- assign parts = pair | split: '|' -%}
                  {%- assign handle = parts[0] -%}
                  {%- assign want_color = parts[1] | downcase -%}
                  {%- assign sp = all_products[handle] -%}
                  {%- if sp == blank -%}{%- continue -%}{%- endif -%}
                  {%- assign matched_v = blank -%}
                  {%- for v in sp.variants -%}
                    {%- assign v_color = v.metafields.custom.kleur | default: v.title | downcase -%}
                    {%- if v_color contains want_color -%}{%- assign matched_v = v -%}{%- break -%}{%- endif -%}
                  {%- endfor -%}
                  {%- if matched_v == blank -%}{%- assign matched_v = sp.selected_or_first_available_variant -%}{%- endif -%}
                  {%- assign s_img = matched_v.image | default: sp.featured_image -%}
                  {%- assign s_color_label = matched_v.metafields.custom.kleur | default: matched_v.title -%}
                  {%- assign jacq_suggest_count = jacq_suggest_count | plus: 1 -%}
                  <div class="jacq-wp-suggest__slide" role="group">
                    <a class="jacq-wp-suggest__media" href="{{ sp.url }}?variant={{ matched_v.id }}" aria-label="{{ sp.title }}">
                      {%- if s_img -%}<img src="{{ s_img | image_url: width: 240 }}" alt="{{ sp.title | escape }}" loading="lazy" width="120" height="120">{%- endif -%}
                    </a>
                    <div class="jacq-wp-suggest__body">
                      <a class="jacq-wp-suggest__title" href="{{ sp.url }}?variant={{ matched_v.id }}">{{ sp.title }}</a>
                      <div class="jacq-wp-suggest__variant">{{ s_color_label }}</div>
                    </div>
                    <form method="post" action="{{ routes.cart_add_url }}" class="jacq-wp-suggest__form">
                      <input type="hidden" name="id" value="{{ matched_v.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="jacq-wp-suggest__add" aria-label="Voeg {{ sp.title }} toe">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true"><path d="M8 3.5v9M3.5 8h9"/></svg>
                      </button>
                    </form>
                  </div>
                {%- endfor -%}
              {%- endcapture -%}
              {%- if jacq_suggest_count > 0 -%}
                <section class="jacq-wp-suggest" aria-label="Ook aanbevolen">
                  <header class="jacq-wp-suggest__header">
                    <h3 class="jacq-wp-suggest__heading">Ook aanbevolen</h3>
                    <div class="jacq-wp-suggest__nav">
                      <button type="button" class="jacq-wp-suggest__navbtn" data-dir="-1" aria-label="Vorige">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 12L6 8l4-4"/></svg>
                      </button>
                      <button type="button" class="jacq-wp-suggest__navbtn" data-dir="1" aria-label="Volgende">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4l4 4-4 4"/></svg>
                      </button>
                    </div>
                  </header>
                  <div class="jacq-wp-suggest__track" data-suggest-track>{{ jacq_suggest_cards }}</div>
                </section>
              {%- endif -%}

              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when '@app' -%}
                    {%- render block -%}
                  
                  {%- when 'subtotal' -%}
                    {%- assign jacq_wp_savings = cart.original_total_price | minus: cart.total_price -%}
                    <div class="grid gap-3" {{ block.shopify_attributes }}>
                      <div class="jacq-wp-summary-lines">
                        <div class="jacq-wp-summary-line">
                          <span class="jacq-wp-summary-line__label">Item total</span>
                          <span class="jacq-wp-summary-line__value">{{ cart.original_total_price | money_without_trailing_zeros | replace: ',-', '' | replace: ' EUR', '' }}</span>
                        </div>

                        {%- if jacq_wp_savings > 0 -%}
                          <div class="jacq-wp-summary-line jacq-wp-summary-line--savings">
                            <span class="jacq-wp-summary-line__label">Total savings</span>
                            <span class="jacq-wp-summary-line__value">-{{ jacq_wp_savings | money_without_trailing_zeros | replace: ',-', '' | replace: ' EUR', '' }}</span>
                          </div>
                        {%- endif -%}

                        <div class="jacq-wp-summary-line">
                          <span class="jacq-wp-summary-line__label">Shipping</span>
                          <span class="jacq-wp-summary-line__value">Free</span>
                        </div>

                        <div class="jacq-wp-summary-line jacq-wp-summary-line--subtotal">
                          <span class="jacq-wp-summary-line__label">{{ 'cart.general.subtotal' | t }}</span>
                          <span class="jacq-wp-summary-line__value">{{ cart.total_price | money_without_trailing_zeros | replace: ',-', '' | replace: ' EUR', '' }}</span>
                        </div>
                      </div>

                      <div class="tax-note text-opacity text-2sm rte">
                        {%- liquid
                          if cart.taxes_included and shop.shipping_policy.body != blank
                            echo 'cart.general.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url
                          elsif cart.taxes_included
                            echo 'cart.general.taxes_included_but_shipping_at_checkout' | t
                          elsif shop.shipping_policy.body != blank
                            echo 'cart.general.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url
                          else
                            echo 'cart.general.taxes_and_shipping_at_checkout' | t
                          endif
                        -%}
                      </div>
                    </div>

                  {%- when 'cart_note' -%}
                    <cart-note class="grid gap-3 cart-note" {{ block.shopify_attributes }}>
                      <p class="font-medium leading-tight">{{ block.settings.heading | escape }}</p>
                      <div class="field">
                        <textarea
                          class="textarea is-floating"
                          rows="4"
                          id="CartNotForm-{{ block.id }}"
                          name="note"
                          form="cart"
                          placeholder=" "
                        >{{ cart.note }}</textarea>
                        <label class="label is-floating" for="CartNotForm-{{ block.id }}">{{ 'cart.general.note' | t }}</label>
                      </div>
                    </cart-note>

                  {%- when 'buttons' -%}
  <div class="grid gap-3" {{ block.shopify_attributes }}>
    <noscript>
      <button class="button button--secondary w-full" type="submit" name="update" form="cart">
        {{- 'cart.general.update' | t -}}
      </button>
    </noscript>
    <button class="button button--primary icon-with-text w-full" type="submit" name="checkout" form="cart" is="hover-button">
      <span class="btn-fill" data-fill></span>
      <span class="btn-text">
        {%- liquid
          render 'icon', icon: 'lock', size: 'sm'
          echo 'cart.general.checkout' | t
        -%}
      </span>
    </button>
          
                      {%- if block.settings.show_accelerated_buttons and additional_checkout_buttons -%}
                        <div class="additional-checkout-buttons additional-checkout-buttons--vertical">{{ content_for_additional_checkout_buttons }}</div>
                      {%- endif -%}
                    </div>

                  {%- when 'free_shipping' -%}
                    {%- liquid
                      if block.settings.minimum_amount != blank
                        assign minimum_amounts = block.settings.minimum_amount | remove: ' '
                        assign show_free_shipping_bar = false
              
                        if minimum_amounts contains ':'
                          assign minimum_amounts = minimum_amounts | split: ','
                          for amount in minimum_amounts
                            assign amount_parts = amount | split: ':'
                            assign currency_code = amount_parts | first | upcase
                            if currency_code == cart.currency.iso_code
                              assign minimum_amount = amount_parts | last
                              assign show_free_shipping_bar = true
                              break
                            endif
                          endfor
                        else
                          assign minimum_amount = minimum_amounts
                          assign show_free_shipping_bar = true
                        endif
                        
                        if show_free_shipping_bar
                          render 'free-shipping-bar', minimum_amount: minimum_amount
                        endif
                      endif
                    -%}

                  {%- when 'custom_field' -%}
                    {%- assign custom_name = block.settings.title | escape -%}
                    {%- assign custom_value = cart.attributes[custom_name] -%}
                    <div class="field" {{ block.shopify_attributes }}>
                      {%- if block.settings.type == 'checkbox' -%}
                        <label for="CartFormInput-{{ section.id }}-{{ block.id }}" class="flex items-center gap-3">
                          <input
                            type="hidden"
                            name="attributes[{{ custom_name }}]"
                            form="cart"
                            value="{{ block.settings.unchecked_value | escape }}"
                          />
                          <input
                            type="checkbox"
                            id="CartFormInput-{{ section.id }}-{{ block.id }}"
                            name="attributes[{{ custom_name }}]"
                            form="cart"
                            value="{{ block.settings.checked_value | escape }}"
                            {%- if block.settings.required %} required{% endif -%}
                          />
                          {{- block.settings.title | escape -}}
                        </label>
                        
                      {%- elsif block.settings.type == 'radio' -%}
                        <div class="grid gap-4">
                          <p>{{ block.settings.title | escape }}</p>
                          {%- assign options = block.settings.radio_options | split: ',' -%}
                          {%- if options.size > 0 -%}
                            <ul class="grid gap-2 leading-none" role="list">
                              {%- for option in options -%}
                                {%- assign option_2 = option | strip | escape -%}
                                <li>
                                  <label for="CartFormInput-{{ section.id }}-{{ block.id }}-{{ forloop.index0 }}" class="inline-flex items-center gap-3">
                                    <input
                                      type="radio"
                                      id="CartFormInput-{{ section.id }}-{{ block.id }}-{{ forloop.index0 }}"
                                      name="attributes[{{ custom_name }}]"
                                      form="cart"
                                      value="{{ option_2 }}"
                                      {%- if block.settings.required %} required{% endif -%}
                                      {%- if option_2 == custom_value %} checked{% endif -%}
                                    />
                                    {{- option_2 -}}
                                  </label>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>

                      {%- else -%}
                        {%- case block.settings.type -%}
                          {%- when 'text' -%}
                            <input
                              class="input is-floating"
                              type="text"
                              id="CartFormInput-{{ section.id }}-{{ block.id }}"
                              name="attributes[{{ custom_name }}]"
                              form="cart"
                              value="{{ custom_value | escape }}"
                              placeholder="{{ block.settings.title | escape }}"
                              {%- if block.settings.required %} required{% endif -%}
                            />
                            <label class="label is-floating" for="CartFormInput-{{ section.id }}-{{ block.id }}">{{ block.settings.title | escape }}</label>
        
                          {%- when 'textarea' -%}
                            <textarea
                              class="textarea is-floating"
                              rows="4"
                              id="CartFormInput-{{ section.id }}-{{ block.id }}"
                              name="attributes[{{ custom_name }}]"
                              form="cart"
                              placeholder=" "
                              {%- if block.settings.required %} required{% endif -%}
                            >{{ custom_value }}</textarea>
                            <label class="label is-floating" for="CartFormInput-{{ section.id }}-{{ block.id }}">{{ block.settings.title | escape }}</label>
        
                          {%- when 'select' -%}
                            {%- assign options = block.settings.select_options | split: ',' -%}
                            {%- if options.size > 0 -%}
                              <select
                                class="select is-floating"
                                id="CartFormInput-{{ section.id }}-{{ block.id }}"
                                name="attributes[{{ custom_name }}]"
                                form="cart"
                                {%- if block.settings.required %} required{% else %} is="custom-select"{% endif -%}
                              >
                                <option value="" disabled selected></option>
                                {%- for option in options -%}
                                  {%- assign option_2 = option | strip | escape -%}
                                  <option value="{{ option_2 }}"{% if option_2 == custom_value %} selected{% endif %}>{{ option_2 }}</option>
                                {%- endfor -%}
                              </select>
                              {%- render 'icon', icon: 'chevron-up', size: 'sm', class: 'absolute pointer-events-none' -%}
                            {%- endif -%}
                            <label class="label{% if options.size > 0 %} is-floating{% endif %}" for="CartFormInput-{{ section.id }}-{{ block.id }}">{{ block.settings.title | escape }}</label>
                        {%- endcase -%}
                      {%- endif -%}
                    </div>
                {%- endcase -%}
              {%- endfor -%}

              <div class="jacq-wp-trust" role="list">
                <div class="jacq-wp-trust__item" role="listitem">
                  <span class="jacq-wp-trust__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l9-4.5L21 8v8.5L12 21l-9-4.5z"/><path d="M3 8l9 4.5L21 8"/><path d="M12 12.5V21"/></svg>
                  </span>
                  <span class="jacq-wp-trust__label">Free UK delivery</span>
                </div>
                <div class="jacq-wp-trust__item" role="listitem">
                  <span class="jacq-wp-trust__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="5" width="17" height="15" rx="2.5"/><path d="M8 3.5v3M16 3.5v3M3.5 10h17"/></svg>
                  </span>
                  <span class="jacq-wp-trust__label">30-day returns</span>
                </div>
                <div class="jacq-wp-trust__item" role="listitem">
                  <span class="jacq-wp-trust__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="M9.2 12l2 2 3.6-3.8"/></svg>
                  </span>
                  <span class="jacq-wp-trust__label">2-year warranty</span>
                </div>
              </div>
            </div>
            {%- if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
              <div class="flex flex-col gap-3">
                <span class="text-xs text-opacity text-center">{{ 'cart.general.we_accept' | t }}</span>
                <div class="flex flex-wrap justify-center gap-2">
                  {%- liquid
                    for type in shop.enabled_payment_types
                      echo type | payment_type_svg_tag
                    endfor
                  -%}
                </div>
              </div>
            {%- endif -%}
          </sticky-element>
        </div>
      </main-cart>

      <div class="jacq-wp-mobile-checkout" role="region" aria-label="Checkout">
        {%- if additional_checkout_buttons -%}
          <div class="jacq-wp-mobile-checkout__accelerated additional-checkout-buttons">
            {{ content_for_additional_checkout_buttons }}
          </div>
        {%- endif -%}
        <button type="submit" name="checkout" form="cart" class="jacq-wp-mobile-checkout__cta">
          Volgende stap
        </button>
      </div>
    {%- endif -%}
  </div>
</div>

{%- comment -%}
  Custom carousel "2e montuur 50% korting" — bypasses the featured-collection
  section's product_limit cap (which Shopify Theme Customizer maxes at 8/12).
  Iterates collections['all'].products with our own limit of 16.
{%- endcomment -%}
{%- if cart.item_count > 0 -%}
  {%- assign jacq_carousel_collection = collections['wall-lights-kopie'] -%}
  {%- assign jacq_carousel_limit = 16 -%}
  {%- if jacq_carousel_collection.products.size > 0 -%}
    <div class="jacq-wp-custom-carousel">
      <div class="jacq-wp-custom-carousel__head">
        <h2 class="jacq-wp-custom-carousel__title">You may also like</h2>
      </div>
      <div class="jacq-wp-custom-carousel__track-wrap">
        <div class="jacq-wp-custom-carousel__track" id="JacqWpCarouselTrack">
          {%- for product in jacq_carousel_collection.products limit: jacq_carousel_limit -%}
            {%- comment -%}Skip specific products (Agnes wordt expliciet uitgesloten){%- endcomment -%}
            {%- if product.handle == 'agnes' -%}{%- continue -%}{%- endif -%}
            <div class="jacq-wp-custom-card">
              <a class="jacq-wp-custom-card__link" href="{{ product.url }}">
                <div class="jacq-wp-custom-card__media">
                  {%- if product.featured_image -%}
                    {{ product.featured_image | image_url: width: 440 | image_tag:
                       loading: 'lazy',
                       widths: '220,440',
                       sizes: '220px',
                       class: 'jacq-wp-custom-card__img',
                       alt: product.featured_image.alt | default: product.title | escape
                    }}
                  {%- endif -%}
                </div>
                <div class="jacq-wp-custom-card__info">
                  <p class="jacq-wp-custom-card__title">{{ product.title | escape }}</p>
                  <p class="jacq-wp-custom-card__price">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="jacq-wp-custom-card__price-sale">{{ product.price | money_without_trailing_zeros | replace: ',-', '' | replace: ' EUR', '' }}</span>
                      <span class="jacq-wp-custom-card__price-compare">{{ product.compare_at_price | money_without_trailing_zeros | replace: ',-', '' | replace: ' EUR', '' }}</span>
                    {%- else -%}
                      {{ product.price | money_without_trailing_zeros | replace: ',-', '' | replace: ' EUR', '' }}
                    {%- endif -%}
                  </p>
                </div>
              </a>
            </div>
          {%- endfor -%}
        </div>
        <button type="button" class="jacq-wp-custom-carousel__arrow jacq-wp-custom-carousel__arrow--prev" id="JacqWpCarouselPrev" aria-label="Previous" hidden>
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M15 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button type="button" class="jacq-wp-custom-carousel__arrow jacq-wp-custom-carousel__arrow--next" id="JacqWpCarouselNext" aria-label="Next">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <style>
      .jacq-wp-custom-carousel {
        background: #fff;
        padding: 24px 0 40px 32px;
      }
      .jacq-wp-custom-carousel__head {
        margin-bottom: 12px;
      }
      .jacq-wp-custom-carousel__title {
        font-size: 28px;
        font-weight: 500;
        letter-spacing: -0.02em;
        margin: 0;
        line-height: 1.2;
      }
      .jacq-wp-custom-carousel__track-wrap {
        position: relative;
      }
      .jacq-wp-custom-carousel__track {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        scroll-behavior: smooth;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding: 4px 0 8px;
      }
      .jacq-wp-custom-carousel__track::-webkit-scrollbar { display: none; }
      .jacq-wp-custom-card {
        flex: 0 0 220px;
        scroll-snap-align: start;
        text-decoration: none;
        color: inherit;
      }
      .jacq-wp-custom-card__link {
        text-decoration: none;
        color: inherit;
        display: block;
      }
      .jacq-wp-custom-card__media {
        width: 100%;
        aspect-ratio: 1 / 1;
        background: #f1f1f1;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px;
      }
      .jacq-wp-custom-card__img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }
      .jacq-wp-custom-card__info {
        padding: 10px 4px 0;
        text-align: center;
      }
      .jacq-wp-custom-card__title {
        margin: 0;
        font-size: 14px;
        font-weight: 500;
        color: var(--wp-text, #1d1d1f);
        letter-spacing: -0.01em;
      }
      .jacq-wp-custom-card__price {
        margin: 4px 0 0;
        font-size: 13px;
        color: var(--wp-text, #1d1d1f);
      }
      .jacq-wp-custom-card__price-sale { color: #d6234c; font-weight: 500; }
      .jacq-wp-custom-card__price-compare { color: #8a8a8e; text-decoration: line-through; margin-left: 6px; }
      .jacq-wp-custom-card__variants {
        display: flex;
        justify-content: center;
        gap: 6px;
        padding: 8px 4px 0;
      }
      .jacq-wp-custom-card__variant {
        width: 36px;
        height: 24px;
        background: #f1f1f1;
        border-radius: 6px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2px;
      }
      .jacq-wp-custom-card__variant img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }
      .jacq-wp-custom-carousel__arrow {
        position: absolute;
        top: calc(50% - 50px); /* center on the card image, not the card+variant area */
        transform: translateY(-50%);
        width: 44px; height: 44px;
        border: none;
        border-radius: 999px;
        background: var(--wp-blue, #0071e3);
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 6px 18px rgba(0,113,227,0.25);
        z-index: 2;
        transition: opacity .18s ease;
      }
      .jacq-wp-custom-carousel__arrow--prev { left: 14px; }
      .jacq-wp-custom-carousel__arrow--next { right: 14px; }
      .jacq-wp-custom-carousel__arrow[hidden] { display: none !important; }
      .jacq-wp-custom-carousel__arrow svg { width: 18px; height: 18px; }
      .jacq-wp-custom-carousel__arrow:hover { background: var(--wp-blue-hover, #2689ec); }
      @media (max-width: 767px) {
        .jacq-wp-custom-carousel { padding: 20px 0 32px 16px; }
        .jacq-wp-custom-card { flex-basis: 160px; }
        .jacq-wp-custom-carousel__title { font-size: 22px; }
        .jacq-wp-custom-carousel__arrow { display: none; }
      }
    </style>

    <script>
      (function(){
        var track = document.getElementById('JacqWpCarouselTrack');
        var next  = document.getElementById('JacqWpCarouselNext');
        var prev  = document.getElementById('JacqWpCarouselPrev');
        if (!track || !next) return;
        function getStep(){
          var card = track.querySelector('.jacq-wp-custom-card');
          return card ? card.offsetWidth + 10 : 230;
        }
        function updateArrows(){
          if (prev) prev.hidden = track.scrollLeft <= 4;
          if (next) next.hidden = (track.scrollLeft + track.clientWidth) >= (track.scrollWidth - 4);
        }
        next.addEventListener('click', function(){
          track.scrollBy({ left: getStep() * 3, behavior: 'smooth' });
        });
        if (prev) prev.addEventListener('click', function(){
          track.scrollBy({ left: -(getStep() * 3), behavior: 'smooth' });
        });
        track.addEventListener('scroll', updateArrows, { passive: true });
        window.addEventListener('resize', updateArrows);
        updateArrows();
      })();
    </script>
  {%- endif -%}
{%- endif -%}

{%- comment -%} Eyewear lens-adjustment modal removed for Meave. {%- endcomment -%}

<style>
/* ==== Lensaanpassing modal – Apple-ish (desktop dialog + mobile sheet) ==== */
#jacq-lens-modal{
  --jacq-bg:#ffffff;
  --jacq-panel-bg:#ffffff;
  --jacq-card-bg:#ffffff;
  --jacq-border-soft:rgba(0,0,0,0.06);
  --jacq-muted:#6e6e73;
  --jacq-text:#1d1d1f;
  --jacq-radius:18px;
  --jacq-shadow:0 18px 40px rgba(0,0,0,0.10);
  --jacq-blue:#0071E3;

  position:fixed;
  inset:0;
  z-index:2147483646;
  font-family:system-ui,-apple-system,BlinkMacSystemFont,"SF Pro Text","SF Pro Display",sans-serif;
  letter-spacing:-0.01em;
}
#jacq-lens-modal[hidden]{display:none !important;}
/* Backdrop zoals wizard (desktop) — bulletproof */
#jacq-lens-modal .jacq-lens-overlay{
  position:fixed;          /* i.p.v. absolute */
  inset:0;
  display:block !important; /* force: sommige themes zetten overlays op display:none */
  visibility:visible !important;

  background:rgba(0,0,0,0.38);
  -webkit-backdrop-filter: blur(14px);
  backdrop-filter: blur(14px);

  opacity:0;
  pointer-events:none;
  transition:opacity .32s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity;
  cursor:pointer;
  z-index:0;
}

#jacq-lens-modal.is-open .jacq-lens-overlay{
  opacity:1 !important;
  pointer-events:auto;
}

#jacq-lens-modal.is-closing .jacq-lens-overlay{opacity:0 !important;}


/* Zorg dat je panel erboven blijft */
#jacq-lens-modal .jacq-lens-wrap{ z-index:1; }




/* Scroll-lock zoals wizard (met scrollbar compensatie) */
html.jacq-lens-no-scroll{
  overflow:hidden;
  padding-right: var(--jacq-lens-scrollbar-comp, 0px);
}
@media (max-width: 768px){
  html.jacq-lens-no-scroll{ padding-right: 0px; }
}


#jacq-lens-modal .jacq-lens-wrap{
  position:absolute;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:
    max(14px, env(safe-area-inset-top))
    12px
    max(14px, env(safe-area-inset-bottom));
  overscroll-behavior:contain;
  z-index:1;
}

#jacq-lens-modal .jacq-lens-panel{
  width:min(560px, calc(100vw - 24px));
  max-height:min(80vh, 720px);
  background:var(--jacq-panel-bg);
  border:1px solid var(--jacq-border-soft);
  border-radius:28px;
  box-shadow:var(--jacq-shadow);
  overflow:hidden;

  display:flex;
  flex-direction:column;

  transform:translateY(18px) scale(.98);
  opacity:0;
  filter: blur(2px);
  transition:transform .55s cubic-bezier(0.22, 1, 0.36, 1), opacity .22s ease, filter .55s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: transform, opacity;
  position: relative;
z-index: 1;
}

#jacq-lens-modal.is-open .jacq-lens-panel{transform:translateY(0) scale(1);opacity:1;filter: blur(0);}

#jacq-lens-modal.is-closing .jacq-lens-panel{pointer-events:none;opacity:0;transform:translateY(18px) scale(.98);filter: blur(2px);}

@media (prefers-reduced-motion: reduce){
  #jacq-lens-modal .jacq-lens-overlay,
  #jacq-lens-modal .jacq-lens-panel,
  .jacq-lens-close{
    transition:none !important;
  }
}

/* Mobile = bottom sheet */
@media (max-width: 768px){
  #jacq-lens-modal .jacq-lens-wrap{align-items:flex-end;padding:0;}
  #jacq-lens-modal .jacq-lens-panel{
    width:100%;
    max-height:88vh;
    border-radius:22px 22px 0 0;
    transform:translateY(22px);
    position: relative;
z-index: 1;
  }
  #jacq-lens-modal.is-open .jacq-lens-panel{transform:translateY(0);}
}


.jacq-sr-only{
  position:absolute !important;
  width:1px;height:1px;
  padding:0;margin:-1px;
  overflow:hidden;
  clip:rect(0,0,0,0);
  white-space:nowrap;
  border:0;
}

.jacq-lens-header{
  display:flex;
  align-items:center;
  justify-content:flex-end;
  padding:14px 14px 0;
  background:transparent;
  border-bottom:none;
}

.jacq-lens-close{
  all:unset;
  box-sizing:border-box;
  width:34px;height:34px;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  color:rgba(60,60,67,0.72);
  cursor:pointer;
  background:rgba(120,120,128,0.12);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  box-shadow:0 1px 0 rgba(0,0,0,0.02);
  transition:background .18s ease, transform .18s ease, box-shadow .18s ease;
}
.jacq-lens-close svg{display:block;}
.jacq-lens-close:hover{background:rgba(120,120,128,0.18);}
.jacq-lens-close:active{transform:scale(0.96);background:rgba(120,120,128,0.22);}

.jacq-lens-body{
  padding:18px 18px 18px;
  overflow:auto;
  display:flex;
  flex-direction:column;
}


.jacq-lens-section-title{
  font-size:12px;
  font-weight:500;
  color:var(--jacq-muted);
  text-transform:uppercase;
  letter-spacing:0.06em;
  margin:8px 2px 8px;
}

.jacq-lens-card{
  background:var(--jacq-card-bg);
  border:none;
  border-radius:var(--jacq-radius);
  box-shadow:0 1px 1px rgba(0,0,0,0.04), 0 12px 28px rgba(0,0,0,0.10);
  overflow:hidden;}

.jacq-lens-card-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:10px;
}
@media (min-width: 900px){
  .jacq-lens-card-grid{grid-template-columns:repeat(3, 1fr);}
}

.jacq-lens-mini{padding:12px 12px 10px;}
.jacq-lens-mini__label{font-size:12px;font-weight:500;color:var(--jacq-muted);margin-bottom:4px;}
.jacq-lens-mini__value{font-size:14px;font-weight:400 !important;color:var(--jacq-text) !important;line-height:1.25;}
.jacq-lens-mini__meta{margin-top:10px;display:flex;justify-content:flex-start;}
.jacq-lens-badge{
  display:inline-flex;
  align-items:center;
  font-size:12px;
  font-weight:500;
  color:var(--jacq-text);
  padding:6px 10px;
  border-radius:999px;
  background:rgba(0,0,0,0.035);
}

.jacq-lens-note{
  margin:0 2px 10px;
  font-size:13px;
  color:var(--jacq-muted);
  font-weight:500;
}

.jacq-lens-eye-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:10px;
}
@media (min-width: 640px){
  .jacq-lens-eye-grid{grid-template-columns:1fr 1fr;}
}
.jacq-lens-eye{padding:12px;}
.jacq-lens-eye__title{font-size:13px;font-weight:400;color:var(--jacq-text);margin-bottom:10px;}

.jacq-lens-kv{
  display:grid;
  grid-template-columns:1fr auto;
  row-gap:8px;
  column-gap:12px;
  font-size:13px;
}
.jacq-lens-kv dt{color:var(--jacq-muted);font-weight:500;}
.jacq-lens-kv dd{margin:0;color:var(--jacq-text);font-weight:500;text-align:right;white-space:nowrap;}

/* Islands (Apple-ish) */
.jacq-island{
  background:#fff;
  border-radius:20px;
  box-shadow:0 18px 60px rgba(0,0,0,.14);
}

/* Title */
.jacq-modal-title strong{font-weight:700;}

/* Choices island (rows) */
.jacq-choice-row{
  display:grid;
  grid-template-columns: 1fr auto;
  align-items:center;
  gap:14px;
  padding:16px 18px;
}
.jacq-choice-left{min-width:0;}
.jacq-choice-k{
  font-size:12px;
  color:var(--jacq-muted);
  letter-spacing:.06em;
  text-transform:none;
  margin-bottom:4px;
}
.jacq-choice-v{
  font-size:14px;
  color:var(--jacq-text);
  font-weight:500;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  max-width:420px;
}
.jacq-choice-price{
  font-size:14px;
  font-weight:500;
  color:var(--jacq-text);
  font-variant-numeric:tabular-nums;
  white-space:nowrap;
  margin-left:auto;
  justify-self:end;
  line-height:1.2;
}

/* RX table (single card, clean grid) */
.jacq-rx-island{padding:14px 14px 8px;}
.jacq-lens-rx-table{
  width:100%;
  border-collapse:separate;
  border-spacing:0;
  font-size:13px;
}
.jacq-lens-rx-table thead th{
  padding:10px 12px;
  font-weight:600;
  font-size:12px;
  color:rgba(17,17,17,.72);
  text-align:center;
  background:transparent;
}
.jacq-lens-rx-table thead th:first-child{
  text-align:left;
  padding-left:14px;
}
.jacq-lens-rx-table tbody td{
  padding:14px 12px;
  border-top:1px solid var(--jacq-border-soft);
  vertical-align:middle;
  background:transparent;
}
.jacq-lens-rx-table tbody td.rx-label{
  color:rgba(17,17,17,.62);
  font-weight:600;
  text-align:left;
  padding-left:14px;
}
.jacq-lens-rx-table tbody td.rx-val{
  color:var(--jacq-text);
  font-weight:600;
  text-align:center;
  font-variant-numeric:tabular-nums;
}
.jacq-lens-rx-table tbody td:nth-child(3),
.jacq-lens-rx-table thead th:nth-child(3){
  border-left:1px solid var(--jacq-border-soft);
}

/* When PD is single value spanning both eyes, don't show the mid divider for that spanning row */
.jacq-lens-rx-table.no-mid-divider tbody td.rx-span{
  border-left:none !important;
}
.jacq-lens-rx-table tbody td.rx-span{
  text-align:center;
}
.jacq-lens-footer{
  position:sticky;
  bottom:calc(14px + env(safe-area-inset-bottom));
  margin-top:16px;
  padding:0;
  background:transparent;
  border-top:none;
  display:flex;
  justify-content:flex-end;
  gap:10px;
  pointer-events:auto;
}

.jacq-lens-footer .jacq-lens-btn{pointer-events:auto;}
.jacq-lens-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:12px 16px;
  border-radius:12px;
  text-decoration:none;
  font-weight:600;
  font-size:14px;
}
.jacq-lens-btn--primary{background:var(--jacq-blue);color:#fff;  box-shadow: 0 10px 24px rgba(0,0,0,.18), 0 2px 6px rgba(0,0,0,.10);
}
.jacq-lens-btn--primary:hover{filter:brightness(0.96);}

/* Primary action – Apple-like */
.jacq-lens-footer .jacq-lens-btn--primary{
  width:100%;
  border-radius:14px;
  height:46px;
  font-size:15px;
  font-weight:600;
  letter-spacing:-0.01em;
  box-shadow:0 14px 28px rgba(0,0,0,0.14);
}

@media (prefers-reduced-motion: reduce){
  #jacq-lens-modal .jacq-lens-overlay,
  #jacq-lens-modal .jacq-lens-panel{transition:none;}
}




/* Choices island (single "keuzes" eiland) */
.jacq-choice{
  padding:14px 14px 12px;
  display:flex;
  flex-direction:column;
  gap:4px;
  min-width:0;
}
.jacq-choice:not(:last-child){
  border-right:1px solid var(--jacq-border-soft);
}
.jacq-choice__label{
  font-size:12px;
  font-weight:500;
  color:var(--jacq-muted);
}
.jacq-choice__value{
  font-size:15px;
  font-weight:500;
  color:var(--jacq-text);
  line-height:1.25;
  word-break:break-word;
}
.jacq-choice__price{
  margin-top:10px;
  align-self:flex-start;
}

/* Mobile: stack choices */
@media (max-width: 768px){
    .jacq-choice:not(:last-child){
    border-right:none;
    border-bottom:1px solid var(--jacq-border-soft);
  }
}

/* RX table: fixed columns + vertical divider between eyes */
.jacq-lens-rx-table{
  table-layout:fixed;
}
.jacq-lens-rx-table colgroup col:first-child{width:44%;}
.jacq-lens-rx-table colgroup col:nth-child(2){width:28%;}
.jacq-lens-rx-table colgroup col:nth-child(3){width:28%;}
.jacq-lens-rx-table th:nth-child(3),
.jacq-lens-rx-table td:nth-child(3){
  border-left:1px solid var(--jacq-border-soft);
  padding-left:16px;
}
.jacq-lens-rx-table th:nth-child(2),
.jacq-lens-rx-table td:nth-child(2){
  padding-right:16px;
}
.jacq-lens-rx-table tbody td.rx-val{
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum" 1;
}
.jacq-lens-rx-table tbody td.rx-span{
  position:relative;
  padding-left:0;
  padding-right:0;
}
.jacq-lens-rx-table tbody td.rx-span::before{
  content:"";
  position:absolute;
  top:0; bottom:0;
  left:50%;
  width:1px;
  background:var(--jacq-border-soft);
}

/* Cart link 'Glazen' / 'Inhoud paspakket' not bold (theme override) */
.jacq-lens-open,
.jacq-lens-open strong,
.jacq-lens-open b,
.jacq-paspakket-open,
.jacq-paspakket-open strong,
.jacq-paspakket-open b{
  font-weight:400 !important;
}


/* ===== Desktop tune: centered, fully in view, no scrollbars ===== */
@media (min-width: 769px){
  #jacq-lens-modal .jacq-lens-panel{
    width:min(640px, calc(100vw - 48px));
    max-height:min(88vh, 820px);
  }
  .jacq-lens-body{
    overflow:visible; /* avoid scrollbars when content fits */
    padding:20px 22px 18px;
  }
  .jacq-lens-footer{
    bottom:18px;
    justify-content:center; /* more balanced like earlier versions */
  }
}

/* ===== Mobile tune: centered, fully visible without scroll when possible ===== */
@media (max-width: 768px){
  #jacq-lens-modal .jacq-lens-panel{
    width:min(560px, calc(100vw - 24px));
    max-height:min(86vh, 760px);
  }
  .jacq-lens-body{
    padding:18px 18px 16px;
  }
  .jacq-lens-footer{
    justify-content:center;
  }
}

/* ===== Desktop layout: compact centered like mobile ===== */
@media (min-width: 769px){
  /* equal space all around the popup */
  #jacq-lens-modal .jacq-lens-wrap{
    align-items:center !important;
    justify-content:center !important;
    padding:28px !important;
  }

  /* slightly smaller panel, fully inside viewport, rounded corners */
  #jacq-lens-modal .jacq-lens-panel{
    width:min(560px, calc(100vw - 56px)) !important;
    max-height:calc(100vh - 56px) !important;
    border-radius:28px !important;
  }

  /* match mobile look */
  .jacq-lens-body{
    padding:18px 18px 18px !important;
    overflow:auto !important;
  }
  .jacq-lens-footer{
    justify-content:center !important;
    margin-top:16px !important;
  }
}

/* ===== Desktop: make choice values (e.g. 'Glazen op sterkte') regular weight ===== */
@media (min-width: 769px){
  .jacq-choice-v{ font-weight:400 !important; }
}
/* WebwinkelKeur widget centeren */
#jacq-vw {
  display: flex;
  justify-content: center;
}
