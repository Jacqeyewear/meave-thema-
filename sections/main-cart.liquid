<script>
(() => {
  // "Ook aanbevolen" carousel — wire the prev/next buttons to scroll
  // the snap track by one slide. Disables buttons at the ends.
  document.querySelectorAll('.jacq-wp-suggest').forEach((root) => {
    const track = root.querySelector('[data-suggest-track]');
    const btns = root.querySelectorAll('.jacq-wp-suggest__navbtn');
    if (!track || !btns.length) return;
    function syncDisabled() {
      const max = Math.max(0, track.scrollWidth - track.clientWidth - 1);
      btns.forEach((b) => {
        const dir = Number(b.dataset.dir || 0);
        const atStart = track.scrollLeft <= 1;
        const atEnd = track.scrollLeft >= max;
        b.setAttribute('aria-disabled', (dir < 0 && atStart) || (dir > 0 && atEnd) ? 'true' : 'false');
      });
    }
    btns.forEach((b) => {
      b.addEventListener('click', () => {
        const dir = Number(b.dataset.dir || 0);
        const slides = track.querySelectorAll('.jacq-wp-suggest__slide');
        if (slides.length < 2) return;
        const step = slides[1].getBoundingClientRect().left - slides[0].getBoundingClientRect().left;
        track.scrollBy({ left: dir * step, behavior: 'smooth' });
      });
    });
    track.addEventListener('scroll', syncDisabled, { passive: true });
    window.addEventListener('resize', syncDisabled, { passive: true });
    syncDisabled();
  });

  // Quick-add (+ button on suggestion slides) — clones the entire
  // _jacq_bundle (configurator output) from the bril already in the
  // cart, so the new bril picks up the same Multifocaal / Index
  // glazen / coatings / prescription. Falls back to a plain submit
  // if anything goes sideways.
  document.querySelectorAll('.jacq-wp-suggest__form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('.jacq-wp-suggest__add');
      const variantId = form.querySelector('input[name="id"]').value;
      if (!variantId || btn?.disabled) return;
      btn?.setAttribute('disabled', 'true');
      btn?.classList.add('is-loading');
      try {
        const cart = await fetch('/cart.js', { headers: { 'Accept': 'application/json' } }).then((r) => r.json());
        const items = cart.items || [];

        // Find the source bril = first item that is a JACQ bundle
        // parent (has _jacq_bundle and isn't a _jacq_child). If we
        // can't find one, fall back to any item with properties.
        const parent = items.find((i) =>
          i.properties && i.properties._jacq_bundle && i.properties._jacq_child !== '1'
        ) || items.find((i) => i.properties && Object.keys(i.properties).length > 0);

        const bodyItems = [];

        if (parent) {
          // Generate a fresh bundle id for the new bril so it stays
          // grouped with its own children in the cart UI.
          const newBundle = 'pkt_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
          const cloneProps = (src, opts) => {
            const out = {};
            Object.entries(src || {}).forEach(([k, v]) => {
              if (k === '_jacq_bundle') return;          // replaced below
              if (k === '_jacq_child') return;            // re-applied below for children
              if (k.startsWith('_') && !opts?.keepInternal) return;
              out[k] = v;
            });
            out._jacq_bundle = newBundle;
            if (opts?.isChild) out._jacq_child = '1';
            return out;
          };

          // 1) New bril (parent)
          bodyItems.push({
            id: Number(variantId),
            quantity: 1,
            properties: cloneProps(parent.properties)
          });

          // 2) Each child item (glazen, coatings, index…) — same
          // variant, same properties minus the bundle/child marker
          // which we re-stamp with the new bundle id.
          const sourceBundle = parent.properties._jacq_bundle;
          const children = items.filter((i) =>
            i.properties &&
            i.properties._jacq_bundle === sourceBundle &&
            i.properties._jacq_child === '1'
          );
          children.forEach((c) => {
            bodyItems.push({
              id: c.variant_id,
              quantity: c.quantity || 1,
              properties: cloneProps(c.properties, { isChild: true })
            });
          });
        } else {
          // No source bril yet — just add the variant bare.
          bodyItems.push({ id: Number(variantId), quantity: 1 });
        }

        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: bodyItems })
        });
        if (!res.ok) throw new Error('add failed: ' + res.status);
        window.location.reload();
      } catch (err) {
        console.warn('[JACQ] quick-add failed, falling back to form submit', err);
        btn?.removeAttribute('disabled');
        btn?.classList.remove('is-loading');
        form.submit();
      }
    });
  });
})();
</script>

<script>
(() => {
  const modal = document.getElementById('jacq-lens-modal');
  if (!modal) return;

  // Belangrijk: verplaats modal naar <body> zodat fixed/backdrop-filter niet wordt begrensd
// door parent transforms/containers (dit voorkomt de "witte strook" glitch).
if (modal.parentNode !== document.body) document.body.appendChild(modal);

  const contentEl = modal.querySelector('.jacq-lens-content');
  const panelEl   = modal.querySelector('.jacq-lens-panel');
  const editEl    = modal.querySelector('[data-edit]');
  const closeBtn  = modal.querySelector('.jacq-lens-close');

  
  const overlayEl = modal.querySelector('.jacq-lens-overlay');
let fallbackTargets = [];

function pickFallbackTarget(){
  // 1) Theme main wrapper (meestal stabiel)
  const main = document.getElementById('MainContent') || document.querySelector('main');
  if (main) return main;

  // 2) Cart wrapper in dit template
  const cart = document.querySelector('.cart');
  if (cart) return cart;

  // 3) Anders niks
  return null;
}



function lockScrollWithCompensation(){
  const doc = document.documentElement;
  const scrollBarWidth = window.innerWidth - doc.clientWidth;
  if (scrollBarWidth > 0) doc.style.setProperty('--jacq-lens-scrollbar-comp', scrollBarWidth + 'px');
  else doc.style.removeProperty('--jacq-lens-scrollbar-comp');

  doc.classList.add('jacq-lens-no-scroll');
}

function unlockScrollWithCompensation(){
  const doc = document.documentElement;
  doc.classList.remove('jacq-lens-no-scroll');
  doc.style.removeProperty('--jacq-lens-scrollbar-comp');
}

  const esc = (s) => String(s ?? '')
    .replaceAll('&','&amp;').replaceAll('<','&lt;')
    .replaceAll('>','&gt;').replaceAll('"','&quot;')
    .replaceAll("'","&#39;");

  const isEmpty = (v) => {
    const s = String(v ?? '').trim();
    return !s || s === '-' || s === '—' || s === 'undefined' || s === 'null';
  };

  const fmtNum = (v) => {
    if (isEmpty(v)) return '—';
    const s = String(v).trim();
    const n = Number(s);
    if (Number.isFinite(n)) {
      // 0.00 -> 0, 1.50 -> 1.5
      return esc(String(n).replace(/\.0+$/,'').replace(/(\.\d*[1-9])0+$/,'$1'));
    }
    return esc(s);
  };

  const fmtIndexLabel = (v) => {
    const s = String(v ?? '').trim();
    if (!s) return '—';
    // If already contains an index number, keep it
    const num = (s.match(/1\.(?:\d{2})/i) || [])[0];
    if (num) return s;

    const k = s.toLowerCase();
    if (k.includes('basis')) return s + ' 1.56';
    if (k.includes('comfort')) return s + ' 1.60';
    if (k.includes('premium')) return s + ' 1.67';
    if (k.includes('luxe')) return s + ' 1.74';
    return s;
  };

  const fmtDeg = (v) => {
    if (isEmpty(v)) return '—';
    const s = String(v).trim();
    return esc(s.endsWith('°') ? s : `${s}°`);
  };

  const fmtPrism = (amount, dir) => {
    if (isEmpty(amount)) return '—';
    const a = fmtNum(amount);
    const d = isEmpty(dir) ? null : fmtDeg(dir);
    return d ? `${a}Δ · ${d}` : `${a}Δ`;
  };

  const euro = (n) => {
    const num = Number(n || 0);
    return num > 0 ? `£${num.toFixed(0)}` : 'Free';
  };

  function computePrices(p){
    const modeMap  = {
      'Zonder sterkte': 0,
      'Glazen op sterkte': 0,
      'Multifocaal': 95
    };
    const coatMap  = { 'Blauwlicht filter': 20 };
    const indexMap = { 'Basis':0, 'Comfort':35, 'Premium':65, 'Luxe':95 };

    const modeKey  = p['Glazen'] || p['Lenses'] || p['Glas'];
    const indexKey = p['Lensindex'];

    return {
      modePrice:  modeMap[modeKey] || 0,
      coatPrice:  coatMap[p['Coating']] || 0,
      indexPrice: indexMap[indexKey] || 0
    };
  }

  function miniCard(label, value, priceLabel){
    return `
      <div class="jacq-island jacq-rx-island">
        <div class="jacq-lens-mini">
          <div class="jacq-lens-mini__label">${esc(label)}</div>
          <div class="jacq-lens-mini__value">${isEmpty(value) ? '—' : esc(value)}</div>
          <div class="jacq-lens-mini__meta"><span class="jacq-lens-badge">${esc(priceLabel)}</span></div>
        </div>
      </div>
    `;
  }

  function eyeCard(title, rowsHtml){
    return `
      <div class="jacq-island jacq-rx-island">
        <div class="jacq-lens-eye">
          <div class="jacq-lens-eye__title">${esc(title)}</div>
          <dl class="jacq-lens-kv">
            ${rowsHtml}
          </dl>
        </div>
      </div>
    `;
  }

  function pdCard(pdSingle, pdLeft, pdRight){
    if (!isEmpty(pdSingle)) {
      return `
        <div class="jacq-island jacq-rx-island">
          <div class="jacq-lens-eye">
            <div class="jacq-lens-eye__title">Pupilafstand</div>
            <dl class="jacq-lens-kv">
              <dt>PD</dt><dd>${fmtNum(pdSingle)}</dd>
            </dl>
          </div>
        </div>
      `;
    }

    if (!isEmpty(pdLeft) || !isEmpty(pdRight)) {
      return `
        <div class="jacq-island jacq-rx-island">
          <div class="jacq-lens-eye">
            <div class="jacq-lens-eye__title">Pupilafstand</div>
            <dl class="jacq-lens-kv">
              <dt>Linkeroog</dt><dd>${fmtNum(pdLeft)}</dd>
              <dt>Rechteroog</dt><dd>${fmtNum(pdRight)}</dd>
            </dl>
          </div>
        </div>
      `;
    }

    return '';
  }

  function render(p, line){
    const glazen  = p['Glazen']  || p['Lenses'] || p['Glas'] || '-';
    const coating = p['Coating'] || '-';
    const index   = p['Lensindex'] || '-';
    const source  = p['Voorschrift bron'] || '-';

    const { modePrice, coatPrice, indexPrice } = computePrices(p);

    // NB: Wizard code bewaart OD/OS “omgekeerd” (zie addToCartCompound mapping),
    // dus: Linkeroog = OD keys, Rechteroog = OS keys (hier compenseren we dat voor display).
    const left = {
  sph: p['OS SPH'], cyl: p['OS CYL'], ax: p['OS AX'], add: p['OS ADD'],
  prism: p['Prisma (OS)'], prismDir: p['Prisma richting (OS)']
};
const right = {
  sph: p['OD SPH'], cyl: p['OD CYL'], ax: p['OD AX'], add: p['OD ADD'],
  prism: p['Prisma (OD)'], prismDir: p['Prisma richting (OD)']
};

    const isMultifocal = String(glazen || '').toLowerCase().includes('multifocaal');

    const showSph   = !isEmpty(left.sph)  || !isEmpty(right.sph);
    const showCyl   = !isEmpty(left.cyl)  || !isEmpty(right.cyl);
    const showAx    = !isEmpty(left.ax)   || !isEmpty(right.ax);
    const showAdd   = isMultifocal && (!isEmpty(left.add) || !isEmpty(right.add));
    const showPrism = !isEmpty(left.prism) || !isEmpty(right.prism);

    // PD (single of per-oog)
    const pdSingle = p['PD'];
    const pdLeft   = p['PD (OS)'];
    const pdRight  = p['PD (OD)'];

    // Sommige setups vullen PD maar aan één kant: behandel dat als één waarde (voor beide ogen).
    let pdMode = 'none'; // 'single' | 'split'
    let pdSpanVal = '';
    if (!isEmpty(pdSingle)) {
      pdMode = 'single';
      pdSpanVal = pdSingle;
    } else if (!isEmpty(pdLeft) && isEmpty(pdRight)) {
      pdMode = 'single';
      pdSpanVal = pdLeft;
    } else if (!isEmpty(pdRight) && isEmpty(pdLeft)) {
      pdMode = 'single';
      pdSpanVal = pdRight;
    } else if (!isEmpty(pdLeft) || !isEmpty(pdRight)) {
      pdMode = 'split';
    }

    const showPd = pdMode !== 'none';

    // Bouw één overzichtelijke RX-tabel (1 kaart) met alleen velden die echt gevuld zijn
    const rxRows = [];
    if (showSph) rxRows.push({ label:'Sterkte',     left: fmtNum(left.sph), right: fmtNum(right.sph) });
    if (showCyl) rxRows.push({ label:'Cilinder',    left: fmtNum(left.cyl), right: fmtNum(right.cyl) });
    if (showAx)  rxRows.push({ label:'As',          left: fmtDeg(left.ax),  right: fmtDeg(right.ax)  });
    if (showAdd) rxRows.push({ label:'Additie',     left: fmtNum(left.add), right: fmtNum(right.add) });

    if (showPd) {
      if (pdMode === 'single') {
        rxRows.push({ label:'Pupilafstand', left: fmtNum(pdSpanVal), right:'', span:true });
      } else {
        rxRows.push({ label:'Pupilafstand', left: fmtNum(pdLeft), right: fmtNum(pdRight) });
      }
    }

    if (showPrism) {
      rxRows.push({
        label:'Prisma',
        left:  fmtPrism(left.prism, left.prismDir),
        right: fmtPrism(right.prism, right.prismDir)
      });
    }

    const rxRowsHtml = rxRows.map(r => {
      if (r.span) return `<tr><td class="rx-label">${esc(r.label)}</td><td class="rx-val rx-span" colspan="2">${r.left}</td></tr>`;
      return `<tr><td class="rx-label">${esc(r.label)}</td><td class="rx-val">${r.left}</td><td class="rx-val">${r.right}</td></tr>`;
    }).join('');

    const summaryHtml = `
  <h2 class="jacq-modal-title"><strong>Controleer</strong> je keuzes</h2>

    <div class="jacq-island jacq-choices-island">
    <div class="jacq-choice-row">
      <div class="jacq-choice-left">
        <div class="jacq-choice-k">Glazen</div>
        <div class="jacq-choice-v">${esc(glazen || '—')}</div>
      </div>
      <div class="jacq-choice-price">${euro(modePrice)}</div>
    </div>

    ${!isEmpty(index) ? `
      <div class="jacq-choice-row">
        <div class="jacq-choice-left">
          <div class="jacq-choice-k">Lensindex</div>
          <div class="jacq-choice-v">${esc(fmtIndexLabel(index))}</div>
        </div>
        <div class="jacq-choice-price">${euro(indexPrice)}</div>
      </div>
    ` : ''}

    <div class="jacq-choice-row">
      <div class="jacq-choice-left">
        <div class="jacq-choice-k">Coating</div>
        <div class="jacq-choice-v">${esc(coating || '—')}</div>
      </div>
      <div class="jacq-choice-price">${euro(coatPrice)}</div>
    </div>
  </div>
`;

    let rxHtml = `
      <div class="jacq-modal-subtitle"><strong>Controleer</strong> je voorschrift</div>
      <div class="jacq-island jacq-rx-island">
        <div class="jacq-lens-eye">
    `;

    if (rxRows.length) {
      rxHtml += `
          <table class="jacq-lens-rx-table${(!isEmpty(pdSingle) ? " no-mid-divider" : "")}">
            <colgroup>
              <col>
              <col>
              <col>
            </colgroup>
<thead>
              <tr>
                <th></th>
                <th>Linkeroog</th>
                <th>Rechteroog</th>
              </tr>
            </thead>
            <tbody>
              ${rxRowsHtml}
            </tbody>
          </table>
      `;
    } else {
      rxHtml += `
          <dl class="jacq-lens-kv">
            <dt>Status</dt><dd>${!isEmpty(source) ? esc(source) : '—'}</dd>
          </dl>
      `;
    }

    rxHtml += `
        </div>
      </div>
    `;

    contentEl.innerHTML = summaryHtml + `<div style="margin-top:12px;">${rxHtml}</div>`;

    // Bewerken link (zelfde gedrag als je oude modal)
    if (editEl && line) {
      const base = line.url || '#';
      const sep  = base.includes('?') ? '&' : '?';
      editEl.setAttribute(
        'href',
        `${base}${sep}jacq_wizard=1&jacq_edit=${encodeURIComponent(line.key)}#jacq-open`
      );
      editEl.setAttribute('data-no-instant', '');
    }
  }

  async function fetchCart(){
    const r = await fetch('/cart.js', { headers:{ 'Accept':'application/json' } });
    return r.json();
  }
  async function getLineByKey(key){
    const cart = await fetchCart();
    return (cart.items || []).find(x => x.key === key) || null;
  }

  function getScrollbarWidth(){
  return Math.max(0, window.innerWidth - document.documentElement.clientWidth);
}
function lockBodyScroll(){
  const sw = getScrollbarWidth();
  if (sw) document.body.style.paddingRight = sw + 'px';
  document.documentElement.classList.add('jacq-modal-lock');
}
function unlockBodyScroll(){
  document.documentElement.classList.remove('jacq-modal-lock');
  document.body.style.paddingRight = '';
}



  function openModal(props, line){
  lockBodyScroll();
  render(props, line);

  modal.classList.remove('is-closing');
  modal.hidden = false;
  modal.setAttribute('aria-hidden','false');

  // Force reflow so animation always triggers
  void modal.offsetHeight;

  requestAnimationFrame(() => {
    modal.classList.add('is-open');
    if (closeBtn && closeBtn.focus) closeBtn.focus({ preventScroll: true });
  });
}

  function closeModal(){
  if (modal.hidden) return;
  if (modal.classList.contains('is-closing')) return;

  unlockBodyScroll();

  modal.classList.remove('is-open');
  modal.classList.add('is-closing');

  const finish = () => {
    modal.hidden = true;
    modal.setAttribute('aria-hidden','true');
    modal.classList.remove('is-closing');
  };

  const endTarget = panelEl || overlayEl;
  if (endTarget){
    endTarget.addEventListener('transitionend', finish, {once:true});
    setTimeout(finish, 800); // safety
  } else {
    setTimeout(finish, 420);
  }
}

  // --- Inline expand helpers (Warby Parker–style) ---
  function getInlinePanelFor(itemKey){
    return document.querySelector(`tr.jacq-wp-details-row[data-for-item="${CSS.escape(itemKey)}"] .jacq-wp-details-panel`);
  }

  function closeOtherPanels(except){
    document.querySelectorAll('tr.jacq-wp-details-row[data-open="1"]').forEach(row => {
      if (row === except) return;
      row.removeAttribute('data-open');
      row.setAttribute('aria-hidden', 'true');
      const key = row.getAttribute('data-for-item');
      const trig = document.querySelector(`a[data-jacq-wp-toggle][data-item-key="${CSS.escape(key)}"]`);
      if (trig) {
        trig.setAttribute('aria-expanded', 'false');
        const lbl = trig.querySelector('.jacq-wp-toggle__label');
        if (lbl) lbl.textContent = lbl.dataset.labelClosed || 'Details';
      }
    });
  }

  function toggleInlinePanel(toggleEl, panel){
    const row = panel.closest('tr.jacq-wp-details-row');
    const isOpen = row.getAttribute('data-open') === '1';
    closeOtherPanels(isOpen ? null : row);
    if (isOpen) {
      row.removeAttribute('data-open');
      row.setAttribute('aria-hidden', 'true');
      toggleEl.setAttribute('aria-expanded', 'false');
      const lbl = toggleEl.querySelector('.jacq-wp-toggle__label');
      if (lbl) lbl.textContent = lbl.dataset.labelClosed || 'Details';
    } else {
      row.setAttribute('data-open', '1');
      row.setAttribute('aria-hidden', 'false');
      toggleEl.setAttribute('aria-expanded', 'true');
      const lbl = toggleEl.querySelector('.jacq-wp-toggle__label');
      if (lbl) lbl.textContent = lbl.dataset.labelOpen || 'Sluiten';
    }
  }

  function renderInlineWP(panel, p, line){
    const glazen  = p['Glazen']  || p['Lenses'] || p['Glas'] || '-';
    const coating = p['Coating'] || '-';
    const index   = p['Lensindex'] || '-';
    const { modePrice, coatPrice, indexPrice } = computePrices(p);

    const left = {
      sph: p['OS SPH'], cyl: p['OS CYL'], ax: p['OS AX'], add: p['OS ADD'],
      prism: p['Prisma (OS)'], prismDir: p['Prisma richting (OS)']
    };
    const right = {
      sph: p['OD SPH'], cyl: p['OD CYL'], ax: p['OD AX'], add: p['OD ADD'],
      prism: p['Prisma (OD)'], prismDir: p['Prisma richting (OD)']
    };
    const isMultifocal = String(glazen || '').toLowerCase().includes('multifocaal');
    const showSph   = !isEmpty(left.sph)  || !isEmpty(right.sph);
    const showCyl   = !isEmpty(left.cyl)  || !isEmpty(right.cyl);
    const showAx    = !isEmpty(left.ax)   || !isEmpty(right.ax);
    const showAdd   = isMultifocal && (!isEmpty(left.add) || !isEmpty(right.add));
    const showPrism = !isEmpty(left.prism) || !isEmpty(right.prism);

    const pdSingle = p['PD'];
    const pdLeft   = p['PD (OS)'];
    const pdRight  = p['PD (OD)'];
    let pdMode = 'none', pdSpanVal = '';
    if (!isEmpty(pdSingle)) { pdMode = 'single'; pdSpanVal = pdSingle; }
    else if (!isEmpty(pdLeft)  && isEmpty(pdRight)) { pdMode = 'single'; pdSpanVal = pdLeft; }
    else if (!isEmpty(pdRight) && isEmpty(pdLeft))  { pdMode = 'single'; pdSpanVal = pdRight; }
    else if (!isEmpty(pdLeft)  || !isEmpty(pdRight)) pdMode = 'split';
    const showPd = pdMode !== 'none';

    const rxRows = [];
    if (showSph) rxRows.push({ label:'Sterkte',  left: fmtNum(left.sph), right: fmtNum(right.sph) });
    if (showCyl) rxRows.push({ label:'Cilinder', left: fmtNum(left.cyl), right: fmtNum(right.cyl) });
    if (showAx)  rxRows.push({ label:'As',       left: fmtDeg(left.ax),  right: fmtDeg(right.ax)  });
    if (showAdd) rxRows.push({ label:'Additie',  left: fmtNum(left.add), right: fmtNum(right.add) });
    if (showPd) {
      if (pdMode === 'single') rxRows.push({ label:'Pupilafstand', left: fmtNum(pdSpanVal), right:'', span:true });
      else rxRows.push({ label:'Pupilafstand', left: fmtNum(pdLeft), right: fmtNum(pdRight) });
    }
    if (showPrism) rxRows.push({
      label:'Prisma',
      left:  fmtPrism(left.prism, left.prismDir),
      right: fmtPrism(right.prism, right.prismDir)
    });

    const rxRowsHtml = rxRows.map(r => {
      if (r.span) return `<tr><td class="rx-label">${esc(r.label)}</td><td class="rx-val rx-span" colspan="2">${r.left}</td></tr>`;
      return `<tr><td class="rx-label">${esc(r.label)}</td><td class="rx-val">${r.left}</td><td class="rx-val">${r.right}</td></tr>`;
    }).join('');

    const editHref = (line && line.url) ? `${line.url}${line.url.includes('?') ? '&' : '?'}jacq_wizard=1&jacq_edit=${encodeURIComponent(line.key)}#jacq-open` : '#';

    const editHeader = `
      <div class="jacq-wp-edit-row">
        <a class="jacq-wp-edit-link" href="${editHref}" data-no-instant>Bewerken</a>
      </div>
    `;

    const detailRows = [
      { label: 'Glazen',    value: glazen,                  price: modePrice  },
    ];
    if (!isEmpty(index))   detailRows.push({ label: 'Lensindex', value: fmtIndexLabel(index), price: indexPrice });
    if (!isEmpty(coating)) detailRows.push({ label: 'Coating',   value: coating,              price: coatPrice  });

    const detailsHtml = detailRows.map(r => `
      <div class="jacq-wp-detail-row">
        <div>
          <div class="jacq-wp-detail-label">${esc(r.label)}</div>
          <div class="jacq-wp-detail-value">${isEmpty(r.value) ? '—' : esc(r.value)}</div>
        </div>
        <div class="jacq-wp-detail-price${r.price > 0 ? '' : ' jacq-wp-detail-price--free'}">${euro(r.price)}</div>
      </div>
    `).join('');

    const rxHtml = rxRows.length ? `
      <div class="jacq-island jacq-rx-island">
        <div class="jacq-lens-eye">
          <table class="jacq-lens-rx-table${(!isEmpty(pdSingle) ? ' no-mid-divider' : '')}">
            <colgroup><col><col><col></colgroup>
            <thead><tr><th></th><th>Linkeroog</th><th>Rechteroog</th></tr></thead>
            <tbody>${rxRowsHtml}</tbody>
          </table>
        </div>
      </div>
    ` : '';

    const source = p['Voorschrift bron'];
    const noteHtml = !isEmpty(source) ? `
      <div class="jacq-wp-rx-note">
        <div class="jacq-wp-rx-note__main">
          <span class="jacq-wp-rx-note__label">Voorschrift</span>
          <span class="jacq-wp-rx-note__value">${esc(source)}</span>
        </div>
      </div>
    ` : '';

    const content = panel.querySelector('[data-jacq-wp-content]');
    content.innerHTML = editHeader + detailsHtml + noteHtml + rxHtml;
  }

  document.addEventListener('click', async (e) => {
    const a = e.target.closest('.jacq-lens-open');
    if (!a) return;

    e.preventDefault();
    e.stopPropagation();

    const itemKey = a.dataset.itemKey;
    const panel = getInlinePanelFor(itemKey);

    // If closing, no need to fetch fresh data
    const row = panel ? panel.closest('tr.jacq-wp-details-row') : null;
    if (panel && row && row.getAttribute('data-open') === '1') {
      toggleInlinePanel(a, panel);
      return;
    }

    const line = await getLineByKey(itemKey);

    const d = a.dataset;
    let props = {
      'Glazen'  : d.glazen,
      'Coating' : d.coating,
      'Lensindex': d.index,
      'Voorschrift bron': d.rxSource,

      'OD SPH'  : d.odSph,  'OD CYL': d.odCyl,  'OD AX': d.odAx,  'OD ADD': d.odAdd,
      'OS SPH'  : d.osSph,  'OS CYL': d.osCyl,  'OS AX': d.osAx,  'OS ADD': d.osAdd,

      'PD'      : d.pd,     'PD (OD)': d.pdOd,  'PD (OS)': d.pdOs,

      'Prisma (OD)' : d.odPrism,
      'Prisma richting (OD)' : d.odPrismDir,
      'Prisma (OS)' : d.osPrism,
      'Prisma richting (OS)' : d.osPrismDir,
    };

    // Override uit cart line.properties (bron van waarheid)
    if (line && line.properties) {
      const lp = line.properties;
      const hasDualPd   = !isEmpty(lp['PD (OD)']) || !isEmpty(lp['PD (OS)']);
      const hasSinglePd = !isEmpty(lp['PD']);
      if (hasDualPd) props['PD'] = '-';
      if (hasSinglePd && !hasDualPd) {
        props['PD (OD)'] = '-';
        props['PD (OS)'] = '-';
      }
      for (const k of Object.keys(lp)) {
        if (hasDualPd && k === 'PD') continue;
        if (!isEmpty(lp[k])) props[k] = lp[k];
      }
    }

    if (panel) {
      renderInlineWP(panel, props, line);
      toggleInlinePanel(a, panel);
    } else {
      // Fallback: keep legacy modal behavior if inline panel is missing
      openModal(props, line);
    }
  });

  modal.addEventListener('click', (e) => {
    if (e.target.matches('[data-close]') || e.target.closest('[data-close]')) {
      e.preventDefault();
      closeModal();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  // Auto-render the inline details panel on page load for any cart-item that
  // is server-rendered with data-open="1". So the user sees the details
  // expanded immediately without having to click "Details".
  async function autoRenderOpenDetails(){
    const openRows = document.querySelectorAll('tr.jacq-wp-details-row[data-open="1"]');
    for (const row of openRows) {
      const itemKey = row.getAttribute('data-for-item');
      if (!itemKey) continue;
      const panel = row.querySelector('.jacq-wp-details-panel');
      if (!panel) continue;
      const content = panel.querySelector('[data-jacq-wp-content]');
      if (!content || content.innerHTML.trim()) continue;

      // Glazen item — find the trigger to read data-* attributes
      const trigger = document.querySelector(`.jacq-lens-open[data-item-key="${CSS.escape(itemKey)}"]`);
      if (!trigger) continue;

      const line = await getLineByKey(itemKey);
      const d = trigger.dataset;
      let props = {
        'Glazen'  : d.glazen,
        'Coating' : d.coating,
        'Lensindex': d.index,
        'Voorschrift bron': d.rxSource,
        'OD SPH'  : d.odSph,  'OD CYL': d.odCyl,  'OD AX': d.odAx,  'OD ADD': d.odAdd,
        'OS SPH'  : d.osSph,  'OS CYL': d.osCyl,  'OS AX': d.osAx,  'OS ADD': d.osAdd,
        'PD'      : d.pd,     'PD (OD)': d.pdOd,  'PD (OS)': d.pdOs,
        'Prisma (OD)' : d.odPrism, 'Prisma richting (OD)' : d.odPrismDir,
        'Prisma (OS)' : d.osPrism, 'Prisma richting (OS)' : d.osPrismDir,
      };
      if (line && line.properties) {
        const lp = line.properties;
        const hasDualPd   = !isEmpty(lp['PD (OD)']) || !isEmpty(lp['PD (OS)']);
        const hasSinglePd = !isEmpty(lp['PD']);
        if (hasDualPd) props['PD'] = '-';
        if (hasSinglePd && !hasDualPd) { props['PD (OD)'] = '-'; props['PD (OS)'] = '-'; }
        for (const k of Object.keys(lp)) {
          if (hasDualPd && k === 'PD') continue;
          if (!isEmpty(lp[k])) props[k] = lp[k];
        }
      }
      renderInlineWP(panel, props, line);
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', autoRenderOpenDetails);
  } else {
    autoRenderOpenDetails();
  }
})();
</script>

<script>
(function(){
  const jsonHdr = { 'Content-Type':'application/json', 'Accept':'application/json' };

  // Verwijder hele bundel op basis van line item key (id)
  async function removeBundleByKey(itemKey){
    try {
      const res  = await fetch('/cart.js', { headers:{ 'Accept':'application/json' }});
      const cart = await res.json();
      const items = cart.items || [];
      const item  = items.find(i => i.key === itemKey);

      // Als we het item niet vinden, verwijder dan alleen deze regel
      if (!item) {
        await fetch('/cart/change.js', { method:'POST', headers: jsonHdr, body: JSON.stringify({ id: itemKey, quantity: 0 }) });
        location.reload(); return;
      }

      const bundle = item.properties && item.properties._jacq_bundle;

      // Geen bundel → alleen deze regel weg
      if (!bundle) {
        await fetch('/cart/change.js', { method:'POST', headers: jsonHdr, body: JSON.stringify({ id: itemKey, quantity: 0 }) });
        location.reload(); return;
      }

      // Verwijder álle regels met dezelfde bundel (parent + children)
      for (const it of items) {
        if (it.properties && it.properties._jacq_bundle === bundle) {
          await fetch('/cart/change.js', {
            method:'POST', headers: jsonHdr, body: JSON.stringify({ id: it.key, quantity: 0 })
          });
        }
      }
    } finally {
      location.reload();
    }
  }

  // Fix bfcache: cart kan "bevroren" terugkomen met oude data-item-key + oude data-* props
window.addEventListener('pageshow', (ev) => {
  if (ev.persisted) window.location.reload();
});

  // Voor thema's die 'line=' gebruiken i.p.v. 'id='
  async function removeBundleByLine(lineIndex){
    const res  = await fetch('/cart.js', { headers:{ 'Accept':'application/json' }});
    const cart = await res.json();
    const items = cart.items || [];
    const idx   = Math.max(0, Number(lineIndex) - 1);
    const item  = items[idx];
    if (item) await removeBundleByKey(item.key);
    else location.reload();
  }

  // A) Intercept elke verwijder-link: /cart/change?...&quantity=0
  document.addEventListener('click', function(e){
    const a = e.target.closest('a[href*="/cart/change"][href*="quantity=0"]');
    if (!a) return;

    e.preventDefault();
    const u    = new URL(a.getAttribute('href'), location.origin);
    const id   = u.searchParams.get('id');   // line item key (zoals in jouw theme)
    const line = u.searchParams.get('line'); // fallback voor andere themes

    if (id)   removeBundleByKey(id);
    else if (line) removeBundleByLine(line);
    else location.href = a.href; // ultimate fallback
  }, { capture: true });

  // B) Safety net: opruimen van 'weeskinderen' bij paginalaad
  (async () => {
    try {
      const res  = await fetch('/cart.js', { headers:{ 'Accept':'application/json' }});
      const cart = await res.json();
      const items = cart.items || [];

      // Verzamel bundels die nog een parent (geen _jacq_child) in de cart hebben
      const parentBundles = new Set(
        items
          .filter(it => !(it.properties && it.properties._jacq_child == '1'))
          .map(it => it.properties && it.properties._jacq_bundle)
          .filter(Boolean)
      );

      // Vind kinderen zonder parent
      const orphans = items.filter(it =>
        it.properties && it.properties._jacq_child == '1' &&
        !parentBundles.has(it.properties._jacq_bundle)
      );

      if (orphans.length) {
        for (const it of orphans) {
          await fetch('/cart/change.js', {
            method:'POST', headers: jsonHdr, body: JSON.stringify({ id: it.key, quantity: 0 })
          });
        }
        location.reload();
      }
    } catch (e) {
      console.warn('[JACQ] orphan cleanup skipped', e);
    }
  })();
})();
</script>

