<section class="meave-faq">
  <div class="meave-faq__inner">
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="meave-faq__intro rte">{{ section.settings.text }}</div>
    {%- endif -%}

    <div class="meave-faq__list">
      {%- for block in section.blocks -%}
        <details class="meave-faq__item" {{ block.shopify_attributes }}>
          <summary>
            <span>{{ block.settings.question | escape }}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
          </summary>
          <div class="meave-faq__answer rte">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .meave-faq {
    padding: 96px 20px;
    background: #faf9f7;
    color: #15120f;
  }

  .meave-faq__inner {
    max-width: 820px;
    margin: 0 auto;
  }

  .meave-faq h2 {
    margin: 0;
    text-align: center;
    font-size: clamp(30px, 3.5vw, 46px);
    letter-spacing: -.04em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .meave-faq__intro {
    max-width: 570px;
    margin: 18px auto 44px;
    color: #6b635a;
    text-align: center;
    font-size: 16px;
    line-height: 1.65;
  }

  .meave-faq__intro p {
    margin: 0;
  }

  .meave-faq__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .meave-faq__item {
    overflow: hidden;
    border: 1px solid rgba(21, 18, 15, .06);
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 1px 2px rgba(32, 25, 18, .04);
    transition: box-shadow .3s ease;
  }

  .meave-faq__item[open] {
    box-shadow: 0 14px 34px rgba(32, 25, 18, .07);
  }

  .meave-faq__item summary {
    display: flex;
    min-height: 68px;
    padding: 22px 26px;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    cursor: pointer;
    font-size: 17px;
    font-weight: 600;
    list-style: none;
  }

  .meave-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .meave-faq__item summary svg {
    width: 20px;
    flex: 0 0 20px;
    color: #9a712e;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 1.8;
    transition: transform .3s cubic-bezier(.22, 1, .36, 1);
  }

  .meave-faq__item[open] summary svg {
    transform: rotate(135deg);
  }

  .meave-faq__answer {
    padding: 0 26px 26px;
    color: #6b635a;
    font-size: 15.5px;
    line-height: 1.7;
  }

  .meave-faq__answer p {
    margin: 0;
  }

  @media (max-width: 560px) {
    .meave-faq {
      padding: 64px 16px;
    }

    .meave-faq__item summary {
      min-height: 60px;
      padding: 20px;
      font-size: 15px;
    }

    .meave-faq__answer {
      padding: 0 20px 22px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave product FAQ",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product questions"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Introduction",
      "default": "<p>Everything you need to choose and style your light with confidence.</p>"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Where should I use this lamp?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Use it beside mirrors, over bedside tables or anywhere the room needs a softer layer of light.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave product FAQ",
      "blocks": [
        {
          "type": "question"
        },
        {
          "type": "question"
        },
        {
          "type": "question"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
