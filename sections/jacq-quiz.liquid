{% comment %}
  JACQ – Brillen Quiz (Warby Parker-achtig, Apple-stijl)
  Bestand: sections/jacq-quiz.liquid
  Vereist: assets/jacq-quiz.css en assets/jacq-quiz.js
  Gebruikt door: templates/page.quiz.json
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

{{ 'jacq-quiz.css' | asset_url | stylesheet_tag }}

<section id="jacq-quiz" class="jacq-quiz" data-jacq-quiz>
  <div class="jacq-quiz__progress" aria-hidden="true">
    <div class="jacq-quiz__progress-fill" data-jacq-progress></div>
  </div>

  <div class="jacq-quiz__container">
    <div class="jacq-quiz__stage" data-jacq-stage>
      <!-- Stappen worden client-side gerenderd via jacq-quiz.js -->
      <div class="jacq-quiz__loading">Quiz laden…</div>
    </div>
  </div>
</section>

<script>
  window.JACQ_QUIZ_PRODUCTS = [
    {%- assign first_block = true -%}
    {%- for product in collections['brillen-op-sterkte'].products -%}
      {%- if product.metafields.custom.pasvorm != blank -%}
        {%- unless first_block -%},{%- endunless -%}
        {%- assign first_block = false -%}
        {
          "id": {{ product.id | json }},
          "title": {{ product.title | json }},
          "handle": {{ product.handle | json }},
          "image": {{ product.featured_image | image_url: width: 600 | json }},
          "price": {{ product.price | money_without_currency | json }},
          "type": "bril",
          "voor": [
            {%- if product.metafields.custom.brillen_voor.value -%}
              {%- for item in product.metafields.custom.brillen_voor.value -%}
                {%- if item.label.value != blank -%}{{ item.label.value | json }}
                {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                {%- else -%}{{ item | json }}{%- endif -%}
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            {%- else -%}"Unisex"{%- endif -%}
          ],
          "vorm": [
            {%- if product.metafields.custom.vorm.value -%}
              {%- for item in product.metafields.custom.vorm.value -%}
                {%- if item.label.value != blank -%}{{ item.label.value | json }}
                {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                {%- else -%}{{ item | json }}{%- endif -%}
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          ],
          "materiaal": [
            {%- if product.metafields.custom.materiaal.value -%}
              {%- for item in product.metafields.custom.materiaal.value -%}
                {%- if item.label.value != blank -%}{{ item.label.value | json }}
                {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                {%- else -%}{{ item | json }}{%- endif -%}
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          ],
          "pasvorm": {{ product.metafields.custom.pasvorm | json }},
          "kleuren": [
            {%- for variant in product.variants -%}
              {{ variant.title | json }}{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ],
          "variants": [
            {%- for variant in product.variants -%}
              {
                "title": {{ variant.title | json }},
                "id": {{ variant.id | json }},
                "image": {%- if variant.image -%}{{ variant.image | image_url: width: 600 | json }}{%- else -%}null{%- endif -%}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        }
      {%- endif -%}
    {%- endfor -%}
    {%- for product in collections['zonnebrillen'].products -%}
      {%- if product.metafields.custom.pasvorm != blank -%}
        {%- unless first_block -%},{%- endunless -%}
        {%- assign first_block = false -%}
        {
          "id": {{ product.id | json }},
          "title": {{ product.title | json }},
          "handle": {{ product.handle | json }},
          "image": {{ product.featured_image | image_url: width: 600 | json }},
          "price": {{ product.price | money_without_currency | json }},
          "type": "zonnebril",
          "voor": [
            {%- if product.metafields.custom.brillen_voor.value -%}
              {%- for item in product.metafields.custom.brillen_voor.value -%}
                {%- if item.label.value != blank -%}{{ item.label.value | json }}
                {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                {%- else -%}{{ item | json }}{%- endif -%}
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            {%- else -%}"Unisex"{%- endif -%}
          ],
          "vorm": [
            {%- if product.metafields.custom.vorm.value -%}
              {%- for item in product.metafields.custom.vorm.value -%}
                {%- if item.label.value != blank -%}{{ item.label.value | json }}
                {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                {%- else -%}{{ item | json }}{%- endif -%}
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          ],
          "materiaal": [
            {%- if product.metafields.custom.materiaal.value -%}
              {%- for item in product.metafields.custom.materiaal.value -%}
                {%- if item.label.value != blank -%}{{ item.label.value | json }}
                {%- elsif item.name.value != blank -%}{{ item.name.value | json }}
                {%- elsif item.title.value != blank -%}{{ item.title.value | json }}
                {%- elsif item.system.handle -%}{{ item.system.handle | json }}
                {%- else -%}{{ item | json }}{%- endif -%}
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          ],
          "pasvorm": {{ product.metafields.custom.pasvorm | json }},
          "kleuren": [
            {%- for variant in product.variants -%}
              {{ variant.title | json }}{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ],
          "variants": [
            {%- for variant in product.variants -%}
              {
                "title": {{ variant.title | json }},
                "id": {{ variant.id | json }},
                "image": {%- if variant.image -%}{{ variant.image | image_url: width: 600 | json }}{%- else -%}null{%- endif -%}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        }
      {%- endif -%}
    {%- endfor -%}
  ];
</script>

<script src="{{ 'jacq-quiz.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "JACQ – Brillen Quiz",
  "class": "section jacq-quiz-section",
  "settings": [
    {
      "type": "header",
      "content": "Quiz instellingen"
    },
    {
      "type": "paragraph",
      "content": "De quiz draait volledig client-side. Product data wordt opgehaald uit de collecties 'brillen-op-sterkte' en 'zonnebrillen'."
    }
  ],
  "presets": [
    { "name": "JACQ – Brillen Quiz" }
  ]
}
{% endschema %}