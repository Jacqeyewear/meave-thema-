<!-- JSON-LD: FAQPage -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wat als ik 2 PD-getallen heb, zoals 31/32?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dat zijn je monopupillaire afstanden: de afstand van elk oog apart tot het midden van je neus. Rechts is meestal iets groter dan links. Vul ze gewoon apart in bij het bestellen. Heb je maar één getal, dan is dat je totale PD."
      }
    },
    {
      "@type": "Question",
      "name": "Ik heb geen recept. Wat nu?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gebruik methode 1 (liniaal) of methode 2 (pasje + foto). Beide leveren een nauwkeurige meting op als je de instructies volgt. Meet 3× en neem het gemiddelde voor de beste uitkomst."
      }
    },
    {
      "@type": "Question",
      "name": "Ik zit tussen twee waardes in. Welke kies ik?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rond af naar het dichtstbijzijnde hele getal. Bij twijfel: kies het kleinste. Bij hogere sterktes (boven ±3.0) is nauwkeurigheid extra belangrijk."
      }
    },
    {
      "@type": "Question",
      "name": "Wat gebeurt er als mijn PD niet klopt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Een onjuiste PD zorgt dat de optische centra van je glazen niet voor je pupillen zitten. Dat kan leiden tot wazig zicht, dubbelzien of hoofdpijn. Bij lage sterktes (onder ±1.5) merk je het nauwelijks; bij hogere sterktes wel."
      }
    },
    {
      "@type": "Question",
      "name": "Hoe nauwkeurig moet mijn PD zijn?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Voor sterktes tot ±2.0 is een afwijking van 1–2 mm meestal geen probleem. Daarboven is precisie belangrijker. Twijfel je? Meet vaker en neem het gemiddelde, of vraag het je opticien."
      }
    }
  ]
}
</script>

<!-- JSON-LD: HowTo (Method 1) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Pupilafstand meten met een liniaal en spiegel",
  "description": "Meet je pupilafstand (PD) thuis in 60 seconden met een liniaal en spiegel. Nauwkeurig en zonder opticien.",
  "totalTime": "PT1M",
  "supply": [
    { "@type": "HowToSupply", "name": "Liniaal (met millimeters)" },
    { "@type": "HowToSupply", "name": "Spiegel" }
  ],
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Positie innemen",
      "text": "Ga recht voor een spiegel staan. Hoofd stil, schouders recht."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Liniaal plaatsen",
      "text": "Houd een liniaal horizontaal op je neusbrug, net onder je ogen."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Afstand aflezen",
      "text": "Sluit één oog, zet 0 op het midden van je pupil en lees met het andere oog de afstand tot het midden van je andere pupil (in mm)."
    }
  ]
}
</script>

