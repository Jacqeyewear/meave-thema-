<script>
(function() {
  var root = document.querySelector('.jpd[data-section-id="{{ section.id }}"]');
  if (!root) return;

  /* ── Intersection Observer: fade-up on scroll ── */
  var reveals = root.querySelectorAll('.jpd-reveal');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
    reveals.forEach(function(el) { io.observe(el); });
  } else {
    reveals.forEach(function(el) { el.classList.add('is-visible'); });
  }

  /* ── Tab switching ── */
  var tabs = root.querySelectorAll('.jpd-tab');
  var panels = root.querySelectorAll('.jpd-method');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.getAttribute('data-tab');

      tabs.forEach(function(t) {
        t.classList.remove('jpd-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('jpd-tab--active');
      tab.setAttribute('aria-selected', 'true');

      panels.forEach(function(p) {
        p.classList.remove('jpd-method--active');
        p.hidden = true;
      });

      var activePanel = root.querySelector('#jpd-method-' + target);
      if (activePanel) {
        activePanel.hidden = false;
        /* Trigger reflow for animation */
        void activePanel.offsetWidth;
        activePanel.classList.add('jpd-method--active');
      }
    });

    /* Keyboard: arrow keys for tab navigation */
    tab.addEventListener('keydown', function(e) {
      var tabArr = Array.prototype.slice.call(tabs);
      var idx = tabArr.indexOf(tab);
      var newIdx = idx;

      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        newIdx = (idx + 1) % tabArr.length;
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        newIdx = (idx - 1 + tabArr.length) % tabArr.length;
      }

      if (newIdx !== idx) {
        tabArr[newIdx].focus();
        tabArr[newIdx].click();
      }
    });
  });

  /* ── FAQ accordion ── */
  var faqButtons = root.querySelectorAll('.jpd-faq-q');
  faqButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      var answer = btn.nextElementSibling;

      if (expanded) {
        answer.style.maxHeight = '0';
        btn.setAttribute('aria-expanded', 'false');
      } else {
        var inner = answer.querySelector('.jpd-faq-a__inner');
        answer.style.maxHeight = inner.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  /* ── Sticky bottom CTA bar ── */
  var stickyBar = root.querySelector('.jpd-sticky-bar');
  var stickyClose = root.querySelector('.jpd-sticky-bar__close');
  var stickyDismissed = false;

  if (stickyBar) {
    stickyBar.hidden = false;

    function checkScroll() {
      if (stickyDismissed) return;
      var scrollPercent = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      if (scrollPercent > 0.6) {
        stickyBar.classList.add('is-visible');
      } else {
        stickyBar.classList.remove('is-visible');
      }
    }

    var ticking = false;
    window.addEventListener('scroll', function() {
      if (!ticking) {
        requestAnimationFrame(function() {
          checkScroll();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    if (stickyClose) {
      stickyClose.addEventListener('click', function() {
        stickyDismissed = true;
        stickyBar.classList.remove('is-visible');
        setTimeout(function() { stickyBar.hidden = true; }, 400);
      });
    }
  }
})();
</script>

