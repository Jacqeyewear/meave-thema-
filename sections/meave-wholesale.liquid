{% comment %}
  Meave – Wholesale / B2B page section.
  Self-contained, Meave-styled (Apple-inspired: generous whitespace, soft
  panels, minimal borders). Includes a Shopify contact form for trade enquiries.
{% endcomment %}

<section class="mvw" data-section-id="{{ section.id }}">

  <header class="mvw-hero">
    <div class="mvw-wrap mvw-wrap--narrow">
      <p class="mvw-eyebrow">{{ section.settings.eyebrow | default: 'Meave London — Trade' }}</p>
      <h1 class="mvw-title">{{ section.settings.heading | default: 'Wholesale & partnerships' }}</h1>
      <p class="mvw-lede">{{ section.settings.intro | default: 'Bring warm, wireless wall lighting to your store, studio or hospitality space. Meave works with retailers, interior designers and hospitality partners across the UK with trade pricing and dedicated support.' }}</p>
      <div class="mvw-hero__cta">
        <a class="mvw-btn" href="#mvw-form">{{ section.settings.cta_label | default: 'Become a stockist' }}</a>
        <a class="mvw-link" href="#mvw-benefits">See trade benefits <span aria-hidden="true">&rsaquo;</span></a>
      </div>
    </div>
  </header>

  <div class="mvw-wrap">

    <div class="mvw-stats">
      <div class="mvw-stat"><strong>150,000+</strong><span>Happy customers</span></div>
      <div class="mvw-stat"><strong>Wireless</strong><span>No-wiring install</span></div>
      <div class="mvw-stat"><strong>2-year</strong><span>Warranty on every light</span></div>
      <div class="mvw-stat"><strong>UK</strong><span>Fast tracked delivery</span></div>
    </div>

    <div class="mvw-grid" id="mvw-benefits">
      <article class="mvw-card">
        <span class="mvw-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5 12 4l9 5.5M5 11v8h14v-8"/></svg></span>
        <h3>Trade pricing</h3>
        <p>Competitive wholesale margins with low minimum order quantities so you can test before you scale.</p>
      </article>
      <article class="mvw-card">
        <span class="mvw-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16v12H4zM4 7l8 6 8-6"/></svg></span>
        <h3>Dedicated support</h3>
        <p>A single point of contact for orders, stock and after-sales — plus marketing assets for your channels.</p>
      </article>
      <article class="mvw-card">
        <span class="mvw-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="M9.2 12l2 2 3.6-3.8"/></svg></span>
        <h3>Renter-friendly</h3>
        <p>Wireless, rechargeable lights that install in seconds — ideal for retail displays and hospitality fit-outs.</p>
      </article>
    </div>

    <div class="mvw-steps">
      <h2 class="mvw-h2">How it works</h2>
      <ol class="mvw-steps__list">
        <li><span class="mvw-steps__num">1</span><div><strong>Apply</strong><p>Tell us about your business using the form below.</p></div></li>
        <li><span class="mvw-steps__num">2</span><div><strong>Get approved</strong><p>We review your application and share the trade catalogue and pricing.</p></div></li>
        <li><span class="mvw-steps__num">3</span><div><strong>Order &amp; grow</strong><p>Place your first order and we handle the rest, from delivery to support.</p></div></li>
      </ol>
    </div>

  </div>

  <div class="mvw-formband">
    <div class="mvw-wrap mvw-wrap--narrow">
      <div class="mvw-form" id="mvw-form">
        <div class="mvw-form__intro">
          <h2 class="mvw-h2">{{ section.settings.form_heading | default: 'Request trade access' }}</h2>
          <p>{{ section.settings.form_intro | default: 'Fill in your details and our wholesale team will get back to you within 2 working days.' }}</p>
        </div>

        {%- form 'contact', class: 'mvw-form__fields' -%}
          {%- if form.posted_successfully? -%}
            <p class="mvw-form__success">Thanks — we have received your enquiry and will be in touch soon.</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="mvw-form__error">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          <input type="hidden" name="contact[subject]" value="Wholesale enquiry">
          <div class="mvw-row">
            <label>Company name<input type="text" name="contact[company]" required></label>
            <label>Contact name<input type="text" name="contact[name]" required></label>
          </div>
          <div class="mvw-row">
            <label>Email<input type="email" name="contact[email]" required></label>
            <label>Phone<input type="tel" name="contact[phone]"></label>
          </div>
          <label>Website / Instagram<input type="text" name="contact[website]"></label>
          <label>Tell us about your business<textarea name="contact[body]" rows="4" required></textarea></label>
          <button type="submit" class="mvw-btn mvw-btn--full">{{ section.settings.submit_label | default: 'Send enquiry' }}</button>
        {%- endform -%}
      </div>
    </div>
  </div>

</section>

{% stylesheet %}
  .mvw {
    --mvw-ink:#1d1d1f;
    --mvw-muted:#6e6e73;
    --mvw-soft:#f5f5f7;
    --mvw-blue:#0071e3;
    --mvw-blue-hover:#0077ed;
    display:block;
    color:var(--mvw-ink);
    font-family:inherit;
    -webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;
  }
  .mvw-wrap { max-width:1080px; margin:0 auto; padding-inline:24px; }
  .mvw-wrap--narrow { max-width:820px; }

  /* Hero — centered, lots of air */
  .mvw-hero { text-align:center; padding:96px 0 28px; }
  .mvw-eyebrow { margin:0 0 16px; font-size:13px; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:var(--mvw-blue); }
  .mvw-title { margin:0 auto 20px; max-width:14ch; font-size:clamp(40px,6vw,64px); line-height:1.05; font-weight:600; letter-spacing:-.025em; }
  .mvw-lede { margin:0 auto 30px; max-width:60ch; font-size:clamp(18px,2vw,21px); line-height:1.5; color:var(--mvw-muted); }
  .mvw-hero__cta { display:flex; flex-wrap:wrap; align-items:center; justify-content:center; gap:10px 26px; }

  /* Buttons & links */
  .mvw-btn { display:inline-flex; align-items:center; justify-content:center; min-height:50px; padding:13px 28px; border:none; border-radius:999px; background:var(--mvw-blue); color:#fff; font:inherit; font-size:16px; font-weight:500; letter-spacing:-.01em; cursor:pointer; text-decoration:none; transition:background .16s ease; }
  .mvw-btn:hover { background:var(--mvw-blue-hover); }
  .mvw-btn--full { width:100%; margin-top:6px; }
  .mvw-link { color:var(--mvw-blue); font-size:16px; font-weight:500; text-decoration:none; }
  .mvw-link span { transition:transform .16s ease; display:inline-block; }
  .mvw-link:hover span { transform:translateX(3px); }

  /* Stats — borderless, airy */
  .mvw-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:24px; margin:64px 0 96px; text-align:center; }
  .mvw-stat { display:grid; gap:6px; }
  .mvw-stat strong { font-size:clamp(28px,3.4vw,38px); font-weight:600; letter-spacing:-.03em; }
  .mvw-stat span { font-size:14px; color:var(--mvw-muted); }

  /* Benefit cards — soft grey panels, no borders */
  .mvw-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:104px; }
  .mvw-card { padding:36px 32px; border-radius:24px; background:var(--mvw-soft); }
  .mvw-card__icon { display:inline-flex; width:50px; height:50px; align-items:center; justify-content:center; border-radius:50%; background:#fff; color:var(--mvw-blue); margin-bottom:22px; }
  .mvw-card__icon svg { width:24px; height:24px; }
  .mvw-card h3 { margin:0 0 10px; font-size:20px; font-weight:600; letter-spacing:-.015em; }
  .mvw-card p { margin:0; font-size:16px; line-height:1.55; color:var(--mvw-muted); }

  /* Section headings */
  .mvw-h2 { margin:0 0 36px; font-size:clamp(28px,3.4vw,40px); font-weight:600; letter-spacing:-.025em; text-align:center; }

  /* How it works */
  .mvw-steps { margin-bottom:104px; }
  .mvw-steps__list { list-style:none; margin:0; padding:0; display:grid; grid-template-columns:repeat(3,1fr); gap:32px; }
  .mvw-steps__list li { display:flex; flex-direction:column; align-items:center; text-align:center; gap:16px; }
  .mvw-steps__num { flex:0 0 auto; width:44px; height:44px; display:grid; place-items:center; border-radius:50%; background:var(--mvw-soft); color:var(--mvw-ink); font-weight:600; font-size:18px; }
  .mvw-steps__list strong { display:block; font-size:18px; font-weight:600; margin-bottom:6px; letter-spacing:-.01em; }
  .mvw-steps__list p { margin:0; font-size:15px; color:var(--mvw-muted); line-height:1.55; max-width:34ch; }

  /* Form — full-width soft band, single clean card */
  .mvw-formband { background:var(--mvw-soft); padding:80px 0 96px; }
  .mvw-form { display:block; }
  .mvw-form__intro { text-align:center; margin-bottom:36px; }
  .mvw-form__intro p { color:var(--mvw-muted); font-size:17px; line-height:1.55; margin:14px auto 0; max-width:48ch; }
  .mvw-form__fields { display:grid; gap:16px; max-width:620px; margin:0 auto; }
  .mvw-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .mvw-form label { display:grid; gap:8px; font-size:12px; font-weight:600; letter-spacing:.02em; color:var(--mvw-muted); }
  .mvw-form input, .mvw-form textarea { width:100%; padding:14px 16px; border:1px solid rgba(0,0,0,.10); border-radius:12px; background:#fff; font:inherit; font-size:16px; color:var(--mvw-ink); transition:border-color .14s ease, box-shadow .14s ease; }
  .mvw-form input:focus, .mvw-form textarea:focus { outline:none; border-color:var(--mvw-blue); box-shadow:0 0 0 4px rgba(0,113,227,.15); }
  .mvw-form__success { padding:14px 16px; border-radius:12px; background:#eef6f0; color:#1c6b3f; font-size:15px; font-weight:500; }
  .mvw-form__error { padding:14px 16px; border-radius:12px; background:#fbecec; color:#a32d2d; font-size:15px; font-weight:500; }

  @media (max-width:860px){
    .mvw-hero { padding-top:64px; }
    .mvw-grid, .mvw-steps__list { grid-template-columns:1fr; }
    .mvw-stats { grid-template-columns:repeat(2,1fr); gap:36px 24px; margin:48px 0 72px; }
    .mvw-grid { gap:16px; margin-bottom:72px; }
    .mvw-steps { margin-bottom:72px; }
    .mvw-steps__list { gap:40px; }
    .mvw-formband { padding:56px 0 72px; }
    .mvw-row { grid-template-columns:1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave – Wholesale",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Meave London — Trade" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wholesale & partnerships" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Bring warm, wireless wall lighting to your store, studio or hospitality space. Meave works with retailers, interior designers and hospitality partners across the UK with trade pricing and dedicated support." },
    { "type": "text", "id": "cta_label", "label": "Hero button", "default": "Become a stockist" },
    { "type": "text", "id": "form_heading", "label": "Form heading", "default": "Request trade access" },
    { "type": "textarea", "id": "form_intro", "label": "Form intro", "default": "Fill in your details and our wholesale team will get back to you within 2 working days." },
    { "type": "text", "id": "submit_label", "label": "Submit button", "default": "Send enquiry" }
  ],
  "presets": [{ "name": "Meave – Wholesale" }]
}
{% endschema %}
