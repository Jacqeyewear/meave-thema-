<section class="meave-comparison">
  <div class="meave-comparison__inner">
    <div class="meave-comparison__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="meave-comparison__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="meave-comparison__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="meave-comparison__table" role="table" aria-label="{{ section.settings.heading | escape }}">
      <div class="meave-comparison__row meave-comparison__row--head" role="row">
        <div role="columnheader">{{ section.settings.feature_label | escape }}</div>
        <div role="columnheader">{{ section.settings.brand_label | escape }}</div>
        <div role="columnheader">{{ section.settings.other_label | escape }}</div>
      </div>
      {%- for block in section.blocks -%}
        <div class="meave-comparison__row" role="row" {{ block.shopify_attributes }}>
          <div role="cell">{{ block.settings.feature | escape }}</div>
          <div role="cell">
            <span class="meave-comparison__mark meave-comparison__mark--{{ block.settings.meave }}">
              {%- if block.settings.meave == 'yes' -%}
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12.5 4.2 4.2L19 7"/></svg>
                <span class="visually-hidden">Yes</span>
              {%- else -%}
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 7 10 10M17 7 7 17"/></svg>
                <span class="visually-hidden">No</span>
              {%- endif -%}
            </span>
          </div>
          <div role="cell">
            <span class="meave-comparison__mark meave-comparison__mark--{{ block.settings.others }}">
              {%- if block.settings.others == 'yes' -%}
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12.5 4.2 4.2L19 7"/></svg>
                <span class="visually-hidden">Yes</span>
              {%- else -%}
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 7 10 10M17 7 7 17"/></svg>
                <span class="visually-hidden">No</span>
              {%- endif -%}
            </span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .meave-comparison {
    padding: 88px 20px;
    background: #fff;
    color: #15120f;
  }

  .meave-comparison__inner {
    display: grid;
    max-width: 1120px;
    margin: 0 auto;
    align-items: center;
    gap: 68px;
    grid-template-columns: .85fr 1.15fr;
  }

  .meave-comparison__eyebrow {
    margin: 0 0 10px;
    color: #9a712e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .meave-comparison h2 {
    margin: 0 0 20px;
    font-size: clamp(30px, 3.4vw, 48px);
    letter-spacing: -.04em;
    line-height: 1.06;
  }

  .meave-comparison__text {
    color: #5d554c;
    font-size: 16px;
    line-height: 1.7;
  }

  .meave-comparison__text p {
    margin: 0;
  }

  .meave-comparison__table {
    overflow: hidden;
    border: 1px solid #e5e5ea;
    border-radius: 18px;
    box-shadow: 0 14px 34px rgba(32, 25, 18, .08);
  }

  .meave-comparison__row {
    display: grid;
    grid-template-columns: 1.5fr .75fr .75fr;
  }

  .meave-comparison__row > div {
    display: grid;
    min-height: 58px;
    padding: 14px;
    border-bottom: 1px solid #e8e3de;
    place-items: center;
    text-align: center;
  }

  .meave-comparison__row > div:first-child {
    background: #f7f2ec;
    place-items: center start;
    text-align: left;
    font-weight: 600;
  }

  .meave-comparison__row--head > div {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  .meave-comparison__row--head > div:nth-child(2) {
    color: #fff;
    background: #15120f;
  }

  .meave-comparison__row:last-child > div {
    border-bottom: 0;
  }

  .meave-comparison__mark {
    display: grid;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    place-items: center;
  }

  .meave-comparison__mark svg {
    width: 16px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .meave-comparison__mark--yes {
    color: #506a50;
    background: #e9f0e7;
  }

  .meave-comparison__mark--no {
    color: #9f4d3c;
    background: #f8eae6;
  }

  @media (max-width: 900px) {
    .meave-comparison__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  @media (max-width: 560px) {
    .meave-comparison {
      padding: 62px 14px;
    }

    .meave-comparison__row {
      grid-template-columns: 1.35fr .72fr .72fr;
    }

    .meave-comparison__row > div {
      padding: 12px 8px;
      font-size: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave comparison",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Meave London"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Furniture-shop polish, lighting-shop focus"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every detail is made clear before checkout: finish, placement, shade style and room mood.</p>"
    },
    {
      "type": "text",
      "id": "feature_label",
      "label": "Feature label",
      "default": "Feature"
    },
    {
      "type": "text",
      "id": "brand_label",
      "label": "Brand label",
      "default": "Meave"
    },
    {
      "type": "text",
      "id": "other_label",
      "label": "Other label",
      "default": "Others"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Warm layered light"
        },
        {
          "type": "select",
          "id": "meave",
          "label": "Meave",
          "options": [
            {
              "value": "yes",
              "label": "Yes"
            },
            {
              "value": "no",
              "label": "No"
            }
          ],
          "default": "yes"
        },
        {
          "type": "select",
          "id": "others",
          "label": "Others",
          "options": [
            {
              "value": "yes",
              "label": "Yes"
            },
            {
              "value": "no",
              "label": "No"
            }
          ],
          "default": "no"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave comparison",
      "blocks": [
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
