<section class="meave-comparison">
  <div class="meave-comparison__inner">
    <div class="meave-comparison__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="meave-comparison__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="meave-comparison__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="meave-comparison__list">
      <span class="meave-comparison__band" aria-hidden="true"></span>
      <div class="meave-comparison__labels">
        <span class="meave-comparison__labelFeature">{{ section.settings.feature_label | escape }}</span>
        <span class="meave-comparison__label meave-comparison__label--brand">{{ section.settings.brand_label | escape }}</span>
        <span class="meave-comparison__label">{{ section.settings.other_label | escape }}</span>
      </div>
      {%- for block in section.blocks -%}
        <div class="meave-comparison__row" {{ block.shopify_attributes }}>
          <span class="meave-comparison__feature">{{ block.settings.feature | escape }}</span>
          <span class="meave-comparison__cell meave-comparison__cell--brand">
            {%- if block.settings.meave == 'yes' -%}
              <span class="meave-comparison__mark meave-comparison__mark--yes" role="img" aria-label="{{ section.settings.brand_label | escape }}: included">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12.5 4.2 4.2L19 7"/></svg>
              </span>
            {%- else -%}
              <span class="meave-comparison__mark meave-comparison__mark--no" role="img" aria-label="{{ section.settings.brand_label | escape }}: not included"></span>
            {%- endif -%}
          </span>
          <span class="meave-comparison__cell">
            {%- if block.settings.others == 'yes' -%}
              <span class="meave-comparison__mark meave-comparison__mark--yes" role="img" aria-label="{{ section.settings.other_label | escape }}: included">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 12.5 4.2 4.2L19 7"/></svg>
              </span>
            {%- else -%}
              <span class="meave-comparison__mark meave-comparison__mark--no" role="img" aria-label="{{ section.settings.other_label | escape }}: not included"></span>
            {%- endif -%}
          </span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .meave-comparison {
    padding: 96px 20px;
    background: #fff;
    color: #15120f;
  }

  .meave-comparison__inner {
    display: grid;
    max-width: 1120px;
    margin: 0 auto;
    align-items: center;
    gap: 72px;
    grid-template-columns: .85fr 1.15fr;
  }

  .meave-comparison__eyebrow {
    margin: 0 0 14px;
    color: #9a712e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .meave-comparison h2 {
    margin: 0 0 22px;
    font-size: clamp(30px, 3.4vw, 48px);
    letter-spacing: -.04em;
    line-height: 1.06;
    text-wrap: balance;
  }

  .meave-comparison__text {
    color: #6b635a;
    font-size: 16px;
    line-height: 1.7;
  }

  .meave-comparison__text p {
    margin: 0;
  }

  /* Airy comparison list with a soft highlighted Meave column */
  .meave-comparison__list {
    --feature-col: minmax(0, 1fr);
    --mark-col: 96px;
  }

  .meave-comparison__labels,
  .meave-comparison__row {
    display: grid;
    align-items: center;
    grid-template-columns: var(--feature-col) var(--mark-col) var(--mark-col);
  }

  .meave-comparison__labels {
    padding-bottom: 16px;
  }

  .meave-comparison__labelFeature {
    color: #8a8178;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .meave-comparison__label {
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .meave-comparison__label--brand {
    color: #9a712e;
  }

  .meave-comparison__row {
    position: relative;
    min-height: 64px;
    border-top: 1px solid rgba(21, 18, 15, .09);
  }

  .meave-comparison__row:last-child {
    border-bottom: 1px solid rgba(21, 18, 15, .09);
  }

  .meave-comparison__feature {
    padding-right: 16px;
    font-size: 16px;
    font-weight: 600;
  }

  .meave-comparison__cell {
    display: grid;
    height: 100%;
    place-items: center;
  }

  /* Soft highlight band behind the Meave column */
  .meave-comparison__list {
    position: relative;
  }

  .meave-comparison__band {
    position: absolute;
    z-index: 0;
    top: 34px;
    bottom: 0;
    right: var(--mark-col);
    width: var(--mark-col);
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(184, 137, 61, .08), rgba(184, 137, 61, .03));
    pointer-events: none;
  }

  .meave-comparison__labels,
  .meave-comparison__row {
    position: relative;
    z-index: 1;
  }

  .meave-comparison__mark {
    position: relative;
    display: grid;
    place-items: center;
  }

  .meave-comparison__mark--yes {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    color: #fff;
    background: linear-gradient(150deg, #c69748, #936024);
    box-shadow: 0 6px 14px rgba(147, 96, 36, .32);
  }

  .meave-comparison__mark--yes svg {
    width: 17px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.6;
  }

  /* "No" is a quiet muted dash, not a loud cross */
  .meave-comparison__mark--no {
    width: 18px;
    height: 2px;
    border-radius: 99px;
    background: #cfc8bf;
  }

  @media (max-width: 900px) {
    .meave-comparison__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 560px) {
    .meave-comparison {
      padding: 64px 16px;
    }

    .meave-comparison__list {
      --mark-col: 72px;
    }

    .meave-comparison__feature {
      font-size: 14.5px;
    }

    .meave-comparison__mark--yes {
      width: 28px;
      height: 28px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave comparison",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Meave London"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Furniture-shop polish, lighting-shop focus"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every detail is made clear before checkout: finish, placement, shade style and room mood.</p>"
    },
    {
      "type": "text",
      "id": "feature_label",
      "label": "Feature label",
      "default": "Feature"
    },
    {
      "type": "text",
      "id": "brand_label",
      "label": "Brand label",
      "default": "Meave"
    },
    {
      "type": "text",
      "id": "other_label",
      "label": "Other label",
      "default": "Others"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature",
          "default": "Warm layered light"
        },
        {
          "type": "select",
          "id": "meave",
          "label": "Meave",
          "options": [
            {
              "value": "yes",
              "label": "Yes"
            },
            {
              "value": "no",
              "label": "No"
            }
          ],
          "default": "yes"
        },
        {
          "type": "select",
          "id": "others",
          "label": "Others",
          "options": [
            {
              "value": "yes",
              "label": "Yes"
            },
            {
              "value": "no",
              "label": "No"
            }
          ],
          "default": "no"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave comparison",
      "blocks": [
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
