<section class="meave-benefits">
  <div class="meave-benefits__grid">
    {%- for block in section.blocks -%}
      <div class="meave-benefits__item" {{ block.shopify_attributes }}>
        <span class="meave-benefits__index" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
        <div class="meave-benefits__body">
          {%- if block.settings.heading != blank -%}
            <h2>{{ block.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="meave-benefits__text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .meave-benefits {
    padding: 80px 20px;
    background: #fff;
    color: #15120f;
  }

  .meave-benefits__grid {
    display: grid;
    max-width: 1200px;
    margin: 0 auto;
    column-gap: 0;
    row-gap: 40px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .meave-benefits__item {
    position: relative;
    padding: 4px 36px;
  }

  /* Hairline divider between columns */
  .meave-benefits__item + .meave-benefits__item::before {
    content: "";
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 0;
    width: 1px;
    background: rgba(21, 18, 15, .1);
  }

  .meave-benefits__item:first-child {
    padding-left: 0;
  }

  .meave-benefits__index {
    display: block;
    margin-bottom: 20px;
    color: #b8893d;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .14em;
    font-variant-numeric: tabular-nums;
  }

  .meave-benefits__item h2 {
    margin: 0 0 12px;
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -.01em;
    line-height: 1.25;
  }

  .meave-benefits__text {
    color: #6b635a;
    font-size: 15px;
    line-height: 1.6;
  }

  .meave-benefits__text p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .meave-benefits__grid {
      row-gap: 36px;
      column-gap: 32px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .meave-benefits__item {
      padding: 4px 0;
    }

    .meave-benefits__item + .meave-benefits__item::before {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .meave-benefits {
      padding: 52px 18px;
    }

    .meave-benefits__grid {
      row-gap: 30px;
      grid-template-columns: 1fr;
    }

    .meave-benefits__index {
      margin-bottom: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave benefits",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Warm glow"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Soft shades and balanced finishes for layered light.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave benefits",
      "blocks": [
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
