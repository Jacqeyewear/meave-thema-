<section class="meave-benefits">
  <div class="meave-benefits__grid">
    {%- for block in section.blocks -%}
      <div class="meave-benefits__item" {{ block.shopify_attributes }}>
        <span class="meave-benefits__mark" aria-hidden="true"></span>
        {%- if block.settings.heading != blank -%}
          <h2>{{ block.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <div class="meave-benefits__text rte">{{ block.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .meave-benefits {
    padding: 64px 20px;
    background: #faf9f7;
    color: #15120f;
  }

  .meave-benefits__grid {
    display: grid;
    max-width: 1180px;
    margin: 0 auto;
    gap: 16px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .meave-benefits__item {
    position: relative;
    display: flex;
    min-height: 150px;
    padding: 32px 26px;
    border: 1px solid rgba(21, 18, 15, .06);
    border-radius: 20px;
    background: #fff;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    box-shadow: 0 1px 2px rgba(32, 25, 18, .04);
    transition: transform .4s cubic-bezier(.22, 1, .36, 1), box-shadow .4s cubic-bezier(.22, 1, .36, 1);
  }

  .meave-benefits__item:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(32, 25, 18, .08);
  }

  .meave-benefits__mark {
    display: block;
    width: 26px;
    height: 3px;
    margin-bottom: 18px;
    border-radius: 99px;
    background: linear-gradient(90deg, #b8893d, #9a712e);
  }

  .meave-benefits__item h2 {
    margin: 0 0 9px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .1em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .meave-benefits__text {
    color: #6b635a;
    font-size: 14.5px;
    line-height: 1.55;
  }

  .meave-benefits__text p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .meave-benefits__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .meave-benefits {
      padding: 40px 16px;
    }

    .meave-benefits__grid {
      gap: 12px;
      grid-template-columns: 1fr;
    }

    .meave-benefits__item {
      min-height: 0;
      padding: 24px 22px;
    }

    .meave-benefits__mark {
      margin-bottom: 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave benefits",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Warm glow"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Soft shades and balanced finishes for layered light.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave benefits",
      "blocks": [
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
