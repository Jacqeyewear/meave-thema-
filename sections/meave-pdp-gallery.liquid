<section class="meave-gallery">
  <div class="meave-gallery__heading">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="meave-gallery__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.text != blank -%}
      <div class="meave-gallery__intro rte">{{ section.settings.text }}</div>
    {%- endif -%}
  </div>

  <div class="meave-gallery__rail">
    {%- for block in section.blocks -%}
      {%- liquid
        assign media_index = forloop.index0
        assign fallback_media = product.media[media_index]
        if fallback_media == blank
          assign fallback_media = product.featured_media
        endif
      -%}
      <figure class="meave-gallery__card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{- block.settings.image
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              widths: '280,420,560,720,900',
              sizes: '(min-width: 990px) 28vw, 72vw',
              alt: block.settings.alt
          -}}
        {%- elsif fallback_media != blank -%}
          {{- fallback_media.preview_image
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              widths: '280,420,560,720,900',
              sizes: '(min-width: 990px) 28vw, 72vw',
              alt: product.title
          -}}
        {%- else -%}
          {{- 'product-1' | placeholder_svg_tag: 'meave-gallery__placeholder' -}}
        {%- endif -%}
      </figure>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .meave-gallery {
    overflow: hidden;
    padding: 72px 0 54px;
    background: #fff;
    color: #15120f;
  }

  .meave-gallery__heading {
    display: flex;
    max-width: 1180px;
    margin: 0 auto 30px;
    padding: 0 20px;
    align-items: end;
    justify-content: space-between;
    gap: 32px;
  }

  .meave-gallery__eyebrow {
    margin: 0 0 10px;
    color: #9a712e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .meave-gallery__heading h2 {
    max-width: 650px;
    margin: 0;
    font-size: clamp(28px, 3vw, 44px);
    letter-spacing: -.035em;
    line-height: 1.08;
  }

  .meave-gallery__intro {
    max-width: 390px;
    color: #5d554c;
    line-height: 1.65;
  }

  .meave-gallery__intro p {
    margin: 0;
  }

  .meave-gallery__rail {
    display: flex;
    overflow-x: auto;
    padding: 0 max(20px, calc((100vw - 1180px) / 2)) 16px;
    gap: 12px;
    scroll-padding-inline: 20px;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
  }

  .meave-gallery__rail::-webkit-scrollbar {
    display: none;
  }

  .meave-gallery__card {
    flex: 0 0 clamp(235px, 27vw, 340px);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    margin: 0;
    border-radius: 18px;
    background: #eee9e3;
    scroll-snap-align: start;
  }

  .meave-gallery__card img,
  .meave-gallery__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s cubic-bezier(.22, 1, .36, 1);
  }

  .meave-gallery__card:hover img {
    transform: scale(1.035);
  }

  @media (max-width: 700px) {
    .meave-gallery {
      padding: 54px 0 38px;
    }

    .meave-gallery__heading {
      display: block;
      padding: 0 14px;
    }

    .meave-gallery__intro {
      margin-top: 14px;
    }

    .meave-gallery__rail {
      padding-inline: 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave image rail",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Styled at home"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made for the rooms you actually live in"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>See the finish, scale and glow from every angle before choosing the right light for your room.</p>"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alternative text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave image rail",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
