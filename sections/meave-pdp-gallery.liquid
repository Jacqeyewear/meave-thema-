<section class="meave-gallery">
  <div class="meave-gallery__heading">
    {%- if section.settings.eyebrow != blank -%}
      <p class="meave-gallery__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="meave-gallery__intro rte">{{ section.settings.text }}</div>
    {%- endif -%}
  </div>

  <div class="meave-gallery__grid" data-count="{{ section.blocks.size }}">
    {%- for block in section.blocks -%}
      {%- liquid
        assign media_index = forloop.index0
        assign fallback_media = product.media[media_index]
        if fallback_media == blank
          assign fallback_media = product.featured_media
        endif
      -%}
      <figure class="meave-gallery__cell" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{- block.settings.image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              widths: '420,560,720,900,1100,1400',
              sizes: '(min-width: 990px) 50vw, 100vw',
              alt: block.settings.alt
          -}}
        {%- elsif fallback_media != blank -%}
          {{- fallback_media.preview_image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              widths: '420,560,720,900,1100,1400',
              sizes: '(min-width: 990px) 50vw, 100vw',
              alt: product.title
          -}}
        {%- else -%}
          {{- 'product-1' | placeholder_svg_tag: 'meave-gallery__placeholder' -}}
        {%- endif -%}
      </figure>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .meave-gallery {
    padding: 110px 20px 100px;
    background: #fff;
    color: #15120f;
  }

  .meave-gallery__heading {
    max-width: 720px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .meave-gallery__eyebrow {
    margin: 0 0 16px;
    color: #9a712e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .meave-gallery__heading h2 {
    margin: 0;
    font-size: clamp(32px, 4vw, 54px);
    letter-spacing: -.045em;
    line-height: 1.04;
    text-wrap: balance;
  }

  .meave-gallery__intro {
    max-width: 540px;
    margin: 20px auto 0;
    color: #6b635a;
    font-size: 17px;
    line-height: 1.6;
  }

  .meave-gallery__intro p {
    margin: 0;
  }

  /* Editorial bento mosaic */
  .meave-gallery__grid {
    display: grid;
    max-width: 1240px;
    margin: 0 auto;
    gap: 16px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-auto-rows: clamp(168px, 20vw, 250px);
  }

  .meave-gallery__cell {
    position: relative;
    overflow: hidden;
    margin: 0;
    border-radius: 24px;
    background: #f0ece6;
  }

  /* First image becomes the hero (2x2) */
  .meave-gallery__cell:first-child {
    grid-column: span 2;
    grid-row: span 2;
  }

  .meave-gallery__cell img,
  .meave-gallery__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .8s cubic-bezier(.22, 1, .36, 1);
  }

  .meave-gallery__cell:hover img {
    transform: scale(1.045);
  }

  /* 3-image layouts: keep a balanced hero + stacked pair */
  .meave-gallery__grid[data-count="3"] {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .meave-gallery__grid[data-count="3"] .meave-gallery__cell:first-child {
    grid-column: span 1;
  }

  @media (max-width: 990px) {
    .meave-gallery__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: clamp(160px, 32vw, 220px);
    }

    .meave-gallery__grid[data-count="3"] .meave-gallery__cell:first-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .meave-gallery {
      padding: 64px 16px 56px;
    }

    .meave-gallery__heading {
      margin-bottom: 36px;
    }

    .meave-gallery__grid {
      gap: 12px;
      grid-auto-rows: clamp(150px, 44vw, 220px);
    }

    .meave-gallery__cell {
      border-radius: 18px;
    }

    .meave-gallery__cell:first-child {
      grid-column: span 2;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave image rail",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Styled at home"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Made for the rooms you actually live in"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>See the finish, scale and glow from every angle before choosing the right light for your room.</p>"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alternative text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave image rail",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
