<section class="meave-reviews">
  <div class="meave-reviews__inner">
    <div class="meave-reviews__head">
      <p class="meave-reviews__eyebrow">Reviews</p>
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    {%- if section.settings.show_summary -%}
      <div class="meave-reviews__summary">
        <div class="meave-reviews__score">
          <span class="meave-reviews__scoreNum">{{ section.settings.rating_average | escape }}</span>
          <div class="meave-reviews__scoreStars" role="img" aria-label="{{ section.settings.rating_average | escape }} out of 5">
            {%- for star in (1..5) -%}
              <svg class="is-active" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.8 14.8 8.5l6.3.9-4.6 4.4 1.1 6.3-5.6-3-5.6 3 1.1-6.3-4.6-4.4 6.3-.9L12 2.8Z"/></svg>
            {%- endfor -%}
          </div>
          <span class="meave-reviews__scoreCount">{{ section.settings.rating_count | escape }}</span>
        </div>
        <div class="meave-reviews__bars">
          {%- assign pcts = section.settings.pct_5 | append: ',' | append: section.settings.pct_4 | append: ',' | append: section.settings.pct_3 | append: ',' | append: section.settings.pct_2 | append: ',' | append: section.settings.pct_1 | split: ',' -%}
          {%- for pct in pcts -%}
            <div class="meave-reviews__bar">
              <span class="meave-reviews__barLabel">{{ 5 | minus: forloop.index0 }}</span>
              <svg class="meave-reviews__barStar" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.8 14.8 8.5l6.3.9-4.6 4.4 1.1 6.3-5.6-3-5.6 3 1.1-6.3-4.6-4.4 6.3-.9L12 2.8Z"/></svg>
              <span class="meave-reviews__barTrack"><span class="meave-reviews__barFill" style="width: {{ pct }}%;"></span></span>
              <span class="meave-reviews__barPct">{{ pct }}%</span>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="meave-reviews__grid">
      {%- for block in section.blocks -%}
        <article class="meave-review" {{ block.shopify_attributes }}>
          <div class="meave-review__stars" role="img" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for star in (1..5) -%}
              <svg class="{% if star <= block.settings.rating %}is-active{% endif %}" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.8 14.8 8.5l6.3.9-4.6 4.4 1.1 6.3-5.6-3-5.6 3 1.1-6.3-4.6-4.4 6.3-.9L12 2.8Z"/>
              </svg>
            {%- endfor -%}
          </div>
          {%- if block.settings.quote != blank -%}
            <div class="meave-review__quote rte">{{ block.settings.quote }}</div>
          {%- endif -%}
          {%- if block.settings.image != blank -%}
            <figure class="meave-review__photo">
              {{- block.settings.image
                | image_url: width: 720
                | image_tag:
                  loading: 'lazy',
                  widths: '320,480,640,720',
                  sizes: '(min-width: 990px) 360px, 86vw',
                  alt: block.settings.image_alt
              -}}
              <span class="meave-review__photoTag" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="12" cy="12" r="3.2"/><path d="M8 5l1.2-2h5.6L16 5"/></svg>
                Customer photo
              </span>
            </figure>
          {%- endif -%}
          {%- if block.settings.author != blank -%}
            <div class="meave-review__author">
              <span class="meave-review__avatar" aria-hidden="true">{{ block.settings.author | strip | slice: 0 | upcase }}</span>
              <span class="meave-review__who">
                <span class="meave-review__name">{{ block.settings.author | escape }}</span>
                {%- if block.settings.verified -%}
                  <span class="meave-review__verified">
                    <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m8.5 12 2.3 2.3 4.7-4.9"/></svg>
                    Verified buyer
                  </span>
                {%- endif -%}
              </span>
            </div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .meave-reviews {
    padding: 110px 20px;
    background: #faf9f7;
    color: #15120f;
  }

  .meave-reviews__inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .meave-reviews__head {
    margin: 0 auto 52px;
    text-align: center;
  }

  .meave-reviews__eyebrow {
    margin: 0 0 16px;
    color: #9a712e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .meave-reviews h2 {
    max-width: 720px;
    margin: 0 auto;
    font-size: clamp(30px, 3.4vw, 48px);
    letter-spacing: -.045em;
    line-height: 1.06;
    text-wrap: balance;
  }

  /* Aggregate rating summary */
  .meave-reviews__summary {
    display: grid;
    max-width: 640px;
    margin: -16px auto 48px;
    padding: 30px 36px;
    align-items: center;
    gap: 36px;
    grid-template-columns: auto 1fr;
    border-radius: 22px;
    background: #fff;
    box-shadow: 0 1px 3px rgba(32, 25, 18, .05);
  }

  .meave-reviews__score {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    padding-right: 36px;
    border-right: 1px solid rgba(21, 18, 15, .08);
  }

  .meave-reviews__scoreNum {
    font-size: 50px;
    font-weight: 700;
    letter-spacing: -.04em;
    line-height: 1;
  }

  .meave-reviews__scoreStars {
    display: flex;
    gap: 3px;
  }

  .meave-reviews__scoreStars svg {
    width: 16px;
    color: #b8893d;
    fill: currentColor;
  }

  .meave-reviews__scoreCount {
    color: #6b635a;
    font-size: 12.5px;
    font-weight: 500;
    white-space: nowrap;
  }

  .meave-reviews__bars {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .meave-reviews__bar {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .meave-reviews__barLabel {
    width: 10px;
    color: #6b635a;
    font-size: 12px;
    font-weight: 600;
    text-align: right;
  }

  .meave-reviews__barStar {
    width: 12px;
    height: 12px;
    color: #c9c2b8;
    fill: currentColor;
  }

  .meave-reviews__barTrack {
    position: relative;
    flex: 1 1 auto;
    height: 7px;
    border-radius: 99px;
    background: #ece8e1;
    overflow: hidden;
  }

  .meave-reviews__barFill {
    position: absolute;
    inset: 0 auto 0 0;
    border-radius: 99px;
    background: linear-gradient(90deg, #c69748, #9a712e);
  }

  .meave-reviews__barPct {
    width: 34px;
    color: #6b635a;
    font-size: 11.5px;
    font-weight: 500;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .meave-reviews__grid {
    display: grid;
    align-items: stretch;
    gap: 24px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .meave-review {
    position: relative;
    display: flex;
    overflow: hidden;
    padding: 36px 34px 30px;
    border-radius: 24px;
    background: #fff;
    flex-direction: column;
    text-align: left;
    box-shadow: 0 1px 3px rgba(32, 25, 18, .05);
    transition: transform .45s cubic-bezier(.22, 1, .36, 1), box-shadow .45s cubic-bezier(.22, 1, .36, 1);
  }

  .meave-review:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(32, 25, 18, .09);
  }

  .meave-review__stars {
    display: flex;
    position: relative;
    margin-bottom: 18px;
    gap: 4px;
  }

  .meave-review__stars svg {
    width: 15px;
    color: #e4dfd8;
    fill: currentColor;
  }

  .meave-review__stars svg.is-active {
    color: #b8893d;
  }

  .meave-review__quote {
    position: relative;
    color: #33302b;
    font-size: 17px;
    line-height: 1.62;
    letter-spacing: -.005em;
    flex: 1 1 auto;
  }

  .meave-review__quote p {
    margin: 0;
  }

  .meave-review__photo {
    position: relative;
    overflow: hidden;
    margin: 22px 0 0;
    aspect-ratio: 4 / 3;
    border-radius: 16px;
    background: #f0ece6;
  }

  .meave-review__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .7s cubic-bezier(.22, 1, .36, 1);
  }

  .meave-review:hover .meave-review__photo img {
    transform: scale(1.04);
  }

  .meave-review__photoTag {
    position: absolute;
    bottom: 9px;
    left: 9px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 9px;
    border-radius: 999px;
    background: rgba(21, 18, 15, .42);
    color: rgba(255, 255, 255, .92);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: .01em;
    backdrop-filter: blur(8px);
  }

  .meave-review__photoTag svg {
    width: 12px;
    height: 12px;
  }

  .meave-review__author {
    display: flex;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(21, 18, 15, .06);
    align-items: center;
    gap: 12px;
  }

  .meave-review__avatar {
    display: grid;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #f1ece4;
    color: #9a712e;
    place-items: center;
    font-size: 13px;
    font-weight: 700;
  }

  .meave-review__who {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .meave-review__name {
    font-size: 13.5px;
    font-weight: 600;
    letter-spacing: .01em;
    color: #1d1a16;
  }

  .meave-review__verified {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: #5d6b50;
    font-size: 11.5px;
    font-weight: 500;
  }

  .meave-review__verified svg {
    width: 13px;
    height: 13px;
    color: #6f8a55;
  }

  @media (max-width: 900px) {
    /* Swipeable carousel keeps reviews compact on phones/tablets */
    .meave-reviews__grid {
      display: flex;
      overflow-x: auto;
      margin: 0 -20px;
      padding: 4px 20px 12px;
      gap: 14px;
      grid-template-columns: none;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .meave-reviews__grid::-webkit-scrollbar {
      display: none;
    }

    .meave-review {
      flex: 0 0 84%;
      scroll-snap-align: center;
    }
  }

  @media (max-width: 640px) {
    .meave-reviews__summary {
      grid-template-columns: 1fr;
      gap: 22px;
      padding: 26px 24px;
    }

    .meave-reviews__score {
      padding: 0 0 22px;
      border-right: 0;
      border-bottom: 1px solid rgba(21, 18, 15, .08);
    }
  }

  @media (max-width: 560px) {
    .meave-reviews {
      padding: 64px 16px;
    }

    .meave-reviews__head {
      margin-bottom: 32px;
    }

    .meave-reviews__summary {
      margin-bottom: 36px;
    }

    .meave-reviews__grid {
      margin: 0 -16px;
      padding: 4px 16px 12px;
    }

    .meave-review {
      flex-basis: 86%;
      padding: 30px 26px 26px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave reviews",
  "max_blocks": 50,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved for easy lighting upgrades"
    },
    {
      "type": "header",
      "content": "Rating summary"
    },
    {
      "type": "checkbox",
      "id": "show_summary",
      "label": "Show rating summary",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_average",
      "label": "Average rating",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "rating_count",
      "label": "Review count label",
      "default": "Based on 1,284 reviews"
    },
    {
      "type": "range",
      "id": "pct_5",
