<section class="meave-reviews">
  <div class="meave-reviews__inner">
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="meave-reviews__grid">
      {%- for block in section.blocks -%}
        <article class="meave-review" {{ block.shopify_attributes }}>
          <div class="meave-review__stars" role="img" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for star in (1..5) -%}
              <svg class="{% if star <= block.settings.rating %}is-active{% endif %}" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.8 14.8 8.5l6.3.9-4.6 4.4 1.1 6.3-5.6-3-5.6 3 1.1-6.3-4.6-4.4 6.3-.9L12 2.8Z"/>
              </svg>
            {%- endfor -%}
          </div>
          {%- if block.settings.quote != blank -%}
            <div class="meave-review__quote rte">{{ block.settings.quote }}</div>
          {%- endif -%}
          {%- if block.settings.author != blank -%}
            <p class="meave-review__author">{{ block.settings.author | escape }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .meave-reviews {
    padding: 96px 20px;
    background: #faf9f7;
    color: #15120f;
  }

  .meave-reviews__inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .meave-reviews h2 {
    max-width: 720px;
    margin: 0 auto 48px;
    text-align: center;
    font-size: clamp(28px, 3vw, 42px);
    letter-spacing: -.04em;
    line-height: 1.1;
    text-wrap: balance;
  }

  .meave-reviews__grid {
    display: grid;
    align-items: stretch;
    gap: 20px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .meave-review {
    display: flex;
    padding: 38px 34px;
    border: 1px solid rgba(21, 18, 15, .06);
    border-radius: 24px;
    background: #fff;
    flex-direction: column;
    text-align: left;
    box-shadow: 0 1px 2px rgba(32, 25, 18, .04);
    transition: transform .4s cubic-bezier(.22, 1, .36, 1), box-shadow .4s cubic-bezier(.22, 1, .36, 1);
  }

  .meave-review:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 48px rgba(32, 25, 18, .1);
  }

  .meave-review__stars {
    display: flex;
    margin-bottom: 22px;
    gap: 4px;
  }

  .meave-review__stars svg {
    width: 17px;
    color: #ddd8d1;
    fill: currentColor;
  }

  .meave-review__stars svg.is-active {
    color: #b8893d;
  }

  .meave-review__quote {
    color: #2e2924;
    font-size: 17px;
    line-height: 1.65;
    flex: 1 1 auto;
  }

  .meave-review__quote p {
    margin: 0;
  }

  .meave-review__author {
    margin: 26px 0 0;
    padding-top: 22px;
    border-top: 1px solid rgba(21, 18, 15, .08);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .meave-reviews__grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin: 0 auto;
    }
  }

  @media (max-width: 560px) {
    .meave-reviews {
      padding: 64px 16px;
    }

    .meave-review {
      padding: 30px 26px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave reviews",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved for easy lighting upgrades"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Review",
          "default": "<p>The finish looks beautiful and the warm glow made the room feel complete.</p>"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Charlotte J."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave reviews",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
