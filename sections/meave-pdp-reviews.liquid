<section class="meave-reviews">
  <div class="meave-reviews__inner">
    <div class="meave-reviews__head">
      <p class="meave-reviews__eyebrow">Reviews</p>
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>

    <div class="meave-reviews__grid">
      {%- for block in section.blocks -%}
        <article class="meave-review" {{ block.shopify_attributes }}>
          <span class="meave-review__quoteMark" aria-hidden="true">&rdquo;</span>
          <div class="meave-review__stars" role="img" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for star in (1..5) -%}
              <svg class="{% if star <= block.settings.rating %}is-active{% endif %}" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.8 14.8 8.5l6.3.9-4.6 4.4 1.1 6.3-5.6-3-5.6 3 1.1-6.3-4.6-4.4 6.3-.9L12 2.8Z"/>
              </svg>
            {%- endfor -%}
          </div>
          {%- if block.settings.quote != blank -%}
            <div class="meave-review__quote rte">{{ block.settings.quote }}</div>
          {%- endif -%}
          {%- if block.settings.author != blank -%}
            <div class="meave-review__author">
              <span class="meave-review__avatar" aria-hidden="true">{{ block.settings.author | strip | slice: 0 | upcase }}</span>
              <span class="meave-review__name">{{ block.settings.author | escape }}</span>
            </div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .meave-reviews {
    padding: 110px 20px;
    background: #faf9f7;
    color: #15120f;
  }

  .meave-reviews__inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .meave-reviews__head {
    margin: 0 auto 52px;
    text-align: center;
  }

  .meave-reviews__eyebrow {
    margin: 0 0 16px;
    color: #9a712e;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .meave-reviews h2 {
    max-width: 720px;
    margin: 0 auto;
    font-size: clamp(30px, 3.4vw, 48px);
    letter-spacing: -.045em;
    line-height: 1.06;
    text-wrap: balance;
  }

  .meave-reviews__grid {
    display: grid;
    align-items: stretch;
    gap: 24px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .meave-review {
    position: relative;
    display: flex;
    overflow: hidden;
    padding: 40px 36px 34px;
    border-radius: 26px;
    background: #fff;
    flex-direction: column;
    text-align: left;
    box-shadow: 0 1px 2px rgba(32, 25, 18, .04), 0 18px 44px rgba(32, 25, 18, .06);
    transition: transform .45s cubic-bezier(.22, 1, .36, 1), box-shadow .45s cubic-bezier(.22, 1, .36, 1);
  }

  .meave-review:hover {
    transform: translateY(-5px);
    box-shadow: 0 28px 60px rgba(32, 25, 18, .12);
  }

  .meave-review__quoteMark {
    position: absolute;
    top: 6px;
    right: 26px;
    color: rgba(184, 137, 61, .16);
    font-size: 120px;
    font-weight: 700;
    line-height: 1;
    pointer-events: none;
  }

  .meave-review__stars {
    display: flex;
    position: relative;
    margin-bottom: 20px;
    gap: 4px;
  }

  .meave-review__stars svg {
    width: 17px;
    color: #ddd8d1;
    fill: currentColor;
  }

  .meave-review__stars svg.is-active {
    color: #b8893d;
  }

  .meave-review__quote {
    position: relative;
    color: #2e2924;
    font-size: 18px;
    line-height: 1.6;
    flex: 1 1 auto;
  }

  .meave-review__quote p {
    margin: 0;
  }

  .meave-review__author {
    display: flex;
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(21, 18, 15, .08);
    align-items: center;
    gap: 14px;
  }

  .meave-review__avatar {
    display: grid;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(140deg, #b8893d, #8a6326);
    color: #fff;
    place-items: center;
    font-size: 15px;
    font-weight: 700;
  }

  .meave-review__name {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: .01em;
  }

  @media (max-width: 900px) {
    /* Swipeable carousel keeps reviews compact on phones/tablets */
    .meave-reviews__grid {
      display: flex;
      overflow-x: auto;
      margin: 0 -20px;
      padding: 4px 20px 12px;
      gap: 14px;
      grid-template-columns: none;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .meave-reviews__grid::-webkit-scrollbar {
      display: none;
    }

    .meave-review {
      flex: 0 0 84%;
      scroll-snap-align: center;
    }
  }

  @media (max-width: 560px) {
    .meave-reviews {
      padding: 64px 16px;
    }

    .meave-reviews__head {
      margin-bottom: 36px;
    }

    .meave-reviews__grid {
      margin: 0 -16px;
      padding: 4px 16px 12px;
    }

    .meave-review {
      flex-basis: 86%;
      padding: 30px 26px 26px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave reviews",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved for easy lighting upgrades"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Review",
          "default": "<p>The finish looks beautiful and the warm glow made the room feel complete.</p>"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Charlotte J."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Meave reviews",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
