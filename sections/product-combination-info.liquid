<section class="jacq-pack" style="--jacq-bg: {{ section.settings.page_bg }};">
  <div class="jacq-pack__wrap">
    {% if section.settings.heading != blank %}
      <h2 class="jacq-pack__title">{{ section.settings.heading }}</h2>
    {% endif %}

    <div
      class="jacq-pack__card"
      style="
        --card-bg: {{ section.settings.card_bg }};
        --card-radius: {{ section.settings.card_radius }}px;
        --card-pad-y: {{ section.settings.card_pad_y }}px;
        --card-pad-x: {{ section.settings.card_pad_x }}px;
        --gap: {{ section.settings.items_gap }}px;
        --maxw: {{ section.settings.max_width }}px;
      "
    >
      <!-- ✅ Alleen afbeeldingen in het grijze vak -->
      <div class="jacq-pack__items jacq-pack__items--images">
        {% for block in section.blocks %}
          <div class="jacq-pack__cell" {{ block.shopify_attributes }}>
            <div class="jacq-pack__imgwrap">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1400
                  | image_tag:
                    class: 'jacq-pack__img',
                    loading: 'lazy',
                    widths: '320, 480, 640, 800, 1000, 1400',
                    sizes: '(min-width: 990px) 280px, (min-width: 700px) 40vw, 90vw',
                    alt: block.settings.caption | escape
                }}
              {% else %}
                <div class="jacq-pack__placeholder">Upload afbeelding</div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- ✅ Captions buiten het grijze vak (Apple-style) -->
    <div class="jacq-pack__captions" style="--gap: {{ section.settings.items_gap }}px; --maxw: {{ section.settings.max_width }}px;">
      {% for block in section.blocks %}
        <div class="jacq-pack__cell">
          {% if block.settings.caption != blank %}
            <p class="jacq-pack__caption">{{ block.settings.caption }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .jacq-pack{ background: var(--jacq-bg); }
  .jacq-pack__wrap{
    margin: 0 auto;
    padding: 56px 20px;
    max-width: 1200px;
  }
  .jacq-pack__title{
    margin: 0 0 28px;
    text-align: center;
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: clamp(26px, 2.6vw, 40px);
    line-height: 1.15;
    color: #111;
  }

  .jacq-pack__card{
    margin: 0 auto;
    max-width: var(--maxw);
    background: var(--card-bg);
    border-radius: var(--card-radius);
    padding: var(--card-pad-y) var(--card-pad-x);
  }

  /* ✅ 3 kolommen desktop */
  .jacq-pack__items{
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--gap);
    align-items: center;
  }

  .jacq-pack__cell{ text-align: center; }

  .jacq-pack__imgwrap{
    display: grid;
    place-items: center;
    min-height: 260px;
  }
  .jacq-pack__img{
    display: block;
    width: 100%;
    height: auto;
    max-width: 340px;
    max-height: 300px;
    object-fit: contain;
  }
  .jacq-pack__placeholder{
    width: 100%;
    max-width: 340px;
    height: 240px;
    border-radius: 12px;
    background: rgba(0,0,0,0.04);
    display: grid;
    place-items: center;
    color: rgba(0,0,0,0.55);
    font-size: 14px;
  }

  /* ✅ captions onder de kaart, zelfde grid + max-width */
  .jacq-pack__captions{
    margin: 18px auto 0;
    max-width: var(--maxw);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--gap);
    align-items: start;
  }
  .jacq-pack__caption{
    margin: 0;
    font-size: 16px;
    color: #111;
  }

  @media (max-width: 900px){
    .jacq-pack__items{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .jacq-pack__captions{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 700px){
    .jacq-pack__wrap{ padding: 42px 16px; }
    .jacq-pack__card{ padding: 22px 16px; }
    .jacq-pack__items{ grid-template-columns: 1fr; }
    .jacq-pack__captions{ grid-template-columns: 1fr; margin-top: 14px; }
    .jacq-pack__imgwrap{ min-height: 220px; }
  }
</style>

{% schema %}
{
  "name": "Inhoud van de verpakking",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titel", "default": "Inhoud van de verpakking" },
    { "type": "color", "id": "page_bg", "label": "Achtergrond pagina", "default": "#ffffff" },
    { "type": "color", "id": "card_bg", "label": "Achtergrond kaart", "default": "#f5f5f7" },
    { "type": "range", "id": "max_width", "min": 700, "max": 1400, "step": 10, "unit": "px", "label": "Max breedte kaart", "default": 1100 },
    { "type": "range", "id": "card_radius", "min": 0, "max": 28, "step": 1, "unit": "px", "label": "Hoekradius kaart", "default": 22 },
    { "type": "range", "id": "card_pad_y", "min": 16, "max": 100, "step": 1, "unit": "px", "label": "Padding kaart (boven/onder)", "default": 70 },
    { "type": "range", "id": "card_pad_x", "min": 16, "max": 100, "step": 1, "unit": "px", "label": "Padding kaart (links/rechts)", "default": 60 },
    { "type": "range", "id": "items_gap", "min": 10, "max": 100, "step": 1, "unit": "px", "label": "Ruimte tussen items", "default": 80 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Afbeelding" },
        { "type": "text", "id": "caption", "label": "Tekst onder afbeelding", "default": "Voorbeeld tekst" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Inhoud van de verpakking (3 items)",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
