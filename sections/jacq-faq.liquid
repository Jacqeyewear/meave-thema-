{% assign secid = 'jacq-faq-' | append: section.id %}

<section id="{{ secid }}" class="jacq-faq">
  <div class="wrap">
    {%- if section.settings.heading != blank -%}<h2 class="title">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="faq-list" role="list">
      {%- for block in section.blocks -%}
        <details class="faq" {{ block.shopify_attributes }}>
          <summary class="q">{{ block.settings.question }}</summary>
          <div class="a rte">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>

  <style>
    #{{ secid }}{ padding: 40px 16px; }
    @media (min-width: 990px){ #{{ secid }}{ padding: 72px 24px; } }
    #{{ secid }} .wrap{ max-width: 900px; margin:0 auto; }
    #{{ secid }} .title{ font-size: clamp(1.6rem, 3vw, 2.2rem); margin:0 0 .6rem; }
    #{{ secid }} .faq{ border:1px solid rgba(0,0,0,.08); border-radius:16px; padding:.8rem 1rem; background: rgba(0,0,0,.02); margin-bottom:.7rem; }
    #{{ secid }} .q{ cursor:pointer; font-weight:700; outline:none; }
    #{{ secid }} .a{ margin-top:.5rem; }
    .color-inverse #{{ secid }} .faq{ background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.15); }
  </style>

  {% schema %}
  {
    "name": "Jacq FAQ",
    "settings": [
      { "type": "text", "id": "heading", "label": "Titel", "default": "Veelgestelde vragen" }
    ],
    "blocks": [
      { "type": "item", "name": "Vraag", "limit": 12, "settings": [
        { "type": "text", "id": "question", "label": "Vraag", "default": "Hoe vraag ik een retourlabel aan?" },
        { "type": "richtext", "id": "answer", "label": "Antwoord", "default": "<p>Klik op ‘Start retour’ en volg de stappen.</p>" }
      ] }
    ],
    "presets": [{ "name": "Jacq FAQ" }]
  }
  {% endschema %}
