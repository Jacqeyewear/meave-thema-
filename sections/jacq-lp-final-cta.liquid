{% comment %}
  Section: Jacq LP Afsluitende CTA
  Herhaalt de kernbelofte en stuurt door naar de collectie.
{% endcomment %}

{% assign secid = 'jacq-lp-final-cta-' | append: section.id %}

{%- liquid
  case section.settings.bg
    when 'light'
      assign bgcol = '#f7f7f8'
      assign txtcol = '#1d1d1d'
    when 'white'
      assign bgcol = '#ffffff'
      assign txtcol = '#1d1d1d'
    else
      assign bgcol = '#111111'
      assign txtcol = '#ffffff'
  endcase
-%}

<section id="{{ secid }}" class="jacq-lp-final-cta">
  <div class="wrap">
    {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="title">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.sub != blank -%}<p class="sub">{{ section.settings.sub }}</p>{%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="cta">
        {%- render 'button',
          label: section.settings.cta_label,
          link: section.settings.cta_link,
          style: section.settings.cta_style,
          size: 'lg',
          show_icon: true
        -%}
      </div>
    {%- endif -%}
  </div>

  <style>
    #{{ secid }}{
      --acc: {{ section.settings.accent | default: '#FFA816' }};
      --bg: {{ bgcol }};
      --txt: {{ txtcol }};
      background: var(--bg);
      color: var(--txt);
      padding: {{ section.settings.pad_m }}px 16px;
      position: relative;
      overflow: hidden;
    }
    #{{ secid }}::before{
      content:""; position:absolute; inset:0; z-index:0; pointer-events:none;
      background:
        radial-gradient(800px 460px at 50% -30%, color-mix(in oklab, var(--acc) 18%, transparent), transparent);
    }
    @media (min-width: 990px){ #{{ secid }}{ padding: {{ section.settings.pad_d }}px 24px; } }

    #{{ secid }} .wrap{
      position: relative; z-index: 1;
      max-width: 760px; margin: 0 auto; text-align: center;
    }
    #{{ secid }} .eyebrow{
      text-transform: uppercase; letter-spacing: .14em; font-size: .78rem; font-weight: 700;
      color: var(--acc); margin: 0 0 .6rem;
    }
    #{{ secid }} .title{ font-size: clamp(1.8rem, 3.6vw, 2.8rem); margin: 0 0 .7rem; letter-spacing: -.02em; line-height: 1.12; }
    #{{ secid }} .sub{ font-size: 1.08rem; line-height: 1.6; color: color-mix(in oklab, var(--txt) 80%, transparent); margin: 0 0 1.6rem; }
    #{{ secid }} .cta{ display: flex; justify-content: center; }
  </style>

  {% schema %}
  {
    "name": "Jacq LP Afsluit-CTA",
    "tag": "section",
    "class": "jacq-lp-section",
    "settings": [
      { "type": "select", "id": "bg", "label": "Achtergrond", "default": "dark",
        "options": [
          { "value": "dark", "label": "Donker" },
          { "value": "light", "label": "Licht (grijs)" },
          { "value": "white", "label": "Wit" }
        ]
      },
      { "type": "color", "id": "accent", "label": "Accentkleur", "default": "#FFA816" },
      { "type": "text", "id": "eyebrow", "label": "Label", "default": "Klaar om te kijken?" },
      { "type": "text", "id": "heading", "label": "Titel", "default": "Een bril op sterkte met de zorg van een echte opticien, gewoon thuis." },
      { "type": "text", "id": "sub", "label": "Subtitel", "default": "Op maat geslepen, 100 dagen proefdragen en 2 jaar garantie." },
      { "type": "header", "content": "Knop" },
      { "type": "text", "id": "cta_label", "label": "Knoptekst", "default": "Bekijk alle brillen" },
      { "type": "url", "id": "cta_link", "label": "Knoplink" },
      { "type": "select", "id": "cta_style", "label": "Knopstijl", "default": "primary",
        "options": [
          { "value": "primary", "label": "Primair" },
          { "value": "secondary", "label": "Secundair" }
        ]
      },
      { "type": "header", "content": "Ruimte" },
      { "type": "range", "id": "pad_m", "label": "Verticale ruimte mobiel", "min": 24, "max": 120, "step": 4, "default": 56, "unit": "px" },
      { "type": "range", "id": "pad_d", "label": "Verticale ruimte desktop", "min": 24, "max": 200, "step": 4, "default": 104, "unit": "px" }
    ],
    "presets": [
      { "name": "Jacq LP Afsluit-CTA" }
    ]
  }
  {% endschema %}
</section>