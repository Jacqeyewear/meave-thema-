{%- liquid
  assign story_media = section.settings.image
  if story_media == blank
    assign story_media = product.media[1].preview_image
  endif
  if story_media == blank
    assign story_media = product.featured_media.preview_image
  endif
-%}

<section class="meave-story" style="--meave-story-height: {{ section.settings.height }}px;">
  <div class="meave-story__media">
    {%- if story_media != blank -%}
      {{- story_media
        | image_url: width: 2400
        | image_tag:
          loading: 'lazy',
          widths: '750,1100,1500,2000,2400',
          sizes: '100vw',
          alt: section.settings.image_alt
      -}}
    {%- else -%}
      {{- 'lifestyle-1' | placeholder_svg_tag: 'meave-story__placeholder' -}}
    {%- endif -%}
  </div>
  <div class="meave-story__content">
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="meave-story__text rte">{{ section.settings.text }}</div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .meave-story {
    position: relative;
    display: flex;
    overflow: hidden;
    min-height: var(--meave-story-height);
    align-items: center;
    color: #fff;
    background: #28231f;
  }

  .meave-story__media,
  .meave-story::after {
    position: absolute;
    inset: 0;
  }

  .meave-story__media img,
  .meave-story__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .meave-story::after {
    content: "";
    background: linear-gradient(90deg, rgba(21, 18, 15, .76) 0%, rgba(21, 18, 15, .42) 48%, rgba(21, 18, 15, .08) 100%);
  }

  .meave-story__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 78px 20px;
  }

  .meave-story h2 {
    max-width: 520px;
    margin: 0 0 20px;
    color: inherit;
    font-size: clamp(34px, 5vw, 64px);
    letter-spacing: -.045em;
    line-height: 1.02;
  }

  .meave-story__text {
    max-width: 480px;
    color: rgba(255, 255, 255, .86);
    font-size: 17px;
    line-height: 1.75;
  }

  .meave-story__text p {
    margin: 0;
  }

  @media (max-width: 600px) {
    .meave-story {
      min-height: max(500px, calc(var(--meave-story-height) * .78));
    }

    .meave-story::after {
      background: rgba(21, 18, 15, .7);
    }

    .meave-story__content {
      padding: 64px 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave story image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alternative text",
      "default": "Meave lighting styled in a calm interior"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limitless elegance, considered light"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Warm wall lighting gives entryways, bedrooms and lounge corners the finished feeling usually reserved for styled interiors.</p>"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height",
      "min": 420,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 620
    }
  ],
  "presets": [
    {
      "name": "Meave story image"
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
