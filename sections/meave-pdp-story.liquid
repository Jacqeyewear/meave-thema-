{%- liquid
  assign story_media = section.settings.image
  if story_media == blank
    assign story_media = product.media[1].preview_image
  endif
  if story_media == blank
    assign story_media = product.featured_media.preview_image
  endif

  comment
    The theme's JSON template isn't syncing, so the heading/text are remapped
    here in liquid to a simpler, less pretentious copy.
  endcomment
  assign story_heading = section.settings.heading
  if story_heading == blank or story_heading == 'Limitless elegance, considered light'
    assign story_heading = 'A warmer, more finished home'
  endif
  assign story_text = section.settings.text
  assign story_text_plain = story_text | strip_html
  if story_text == blank or story_text_plain contains 'finished feeling usually reserved'
    assign story_text = '<p>Soft, wireless wall lighting that makes hallways, bedrooms and living-room corners feel calm and complete, with no wiring needed.</p>'
  endif
-%}

<section class="meave-story" style="--meave-story-height: {{ section.settings.height }}px;">
  <div class="meave-story__media">
    {%- if story_media != blank -%}
      {{- story_media
        | image_url: width: 2400
        | image_tag:
          loading: 'lazy',
          widths: '750,1100,1500,2000,2400',
          sizes: '100vw',
          alt: section.settings.image_alt
      -}}
    {%- else -%}
      {{- 'lifestyle-1' | placeholder_svg_tag: 'meave-story__placeholder' -}}
    {%- endif -%}
  </div>
  <div class="meave-story__content">
    {%- if story_heading != blank -%}
      <h2>{{ story_heading | escape }}</h2>
    {%- endif -%}
    {%- if story_text != blank -%}
      <div class="meave-story__text rte">{{ story_text }}</div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .meave-story {
    position: relative;
    display: flex;
    overflow: hidden;
    min-height: var(--meave-story-height);
    align-items: center;
    color: #fff;
    background: #28231f;
  }

  .meave-story__media,
  .meave-story::after {
    position: absolute;
    inset: 0;
  }

  .meave-story__media img,
  .meave-story__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .meave-story::after {
    content: "";
    background: linear-gradient(90deg, rgba(15, 13, 10, .82) 0%, rgba(15, 13, 10, .5) 46%, rgba(15, 13, 10, .06) 100%);
  }

  .meave-story__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 78px 20px;
  }

  .meave-story h2 {
    max-width: 560px;
    margin: 0 0 18px;
    color: inherit;
    font-size: clamp(28px, 3.6vw, 46px);
    font-weight: 500;
    letter-spacing: -.025em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .meave-story__text {
    max-width: 480px;
    color: rgba(255, 255, 255, .88);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.6;
  }

  .meave-story__text p {
    margin: 0;
  }

  @media (max-width: 600px) {
    .meave-story {
      min-height: max(500px, calc(var(--meave-story-height) * .78));
    }

    .meave-story::after {
      background: rgba(21, 18, 15, .7);
    }

    .meave-story__content {
      padding: 64px 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Meave story image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alternative text",
      "default": "Meave lighting styled in a calm interior"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limitless elegance, considered light"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Warm wall lighting gives entryways, bedrooms and lounge corners the finished feeling usually reserved for styled interiors.</p>"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height",
      "min": 420,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 620
    }
  ],
  "presets": [
    {
      "name": "Meave story image"
    }
  ],
  "enabled_on": {
    "templates": [
      "product"
    ]
  }
}
{% endschema %}
