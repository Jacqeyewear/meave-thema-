          "settings": {
            "title": "Stap 1: spoel eerst (altijd)",
            "body": "<p>Spoel stof en zand weg met lauw water. Dit is de belangrijkste stap tegen krassen.</p>"
          }
        },
        "howto-2": {
          "type": "howto_step",
          "settings": {
            "title": "Stap 2: reinig met iets milds",
            "body": "<p>Gebruik een druppel milde afwasmiddel (geen handzeep met moisturizers). Wrijf zacht met je vingers over beide kanten.</p>"
          }
        },
        "howto-3": {
          "type": "howto_step",
          "settings": {
            "title": "Stap 3: spoel grondig na",
            "body": "<p>Spoel alle zeepresten weg; resten geven waas en vlekken.</p>"
          }
        },
        "howto-4": {
          "type": "howto_step",
          "settings": {
            "title": "Stap 4: droog correct",
            "body": "<p>Dep droog met een schone microvezeldoek. Niet ‘schuren’. Vervang je doek als hij vettig is.</p>"
          }
        },
        "howto-5": {
          "type": "howto_step",
          "settings": {
            "title": "Stap 5: onderhoud je doek en neuspads",
            "body": "<p>Was microvezel zonder wasverzachter. Maak ook neusbrug en neuspads schoon; daar zit vaak vet dat terug smeert.</p>"
          }
        },
        "table-1": {
