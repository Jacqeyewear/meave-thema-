tem);\n    });\n  });\n\n  var fp = root.querySelector('.mfaq-panel.is-active');\n  if (fp && window.innerWidth >= 768) { var fi = fp.querySelector('.mfaq-item'); if (fi) setTimeout(function () { openItem(fi); }, 300); }\n\n  function openItem(it) {\n    var b = it.querySelector('.mfaq-trigger'), p = it.querySelector('.mfaq-answer');\n    if (!b || !p) return;\n    it.classList.add('is-open'); b.setAttribute('aria-expanded', 'true'); p.setAttribute('aria-hidden', 'false');\n    p.style.height = '0px'; p.offsetHeight; p.style.height = p.scrollHeight + 'px';\n  }\n  function closeItem(it) {\n    var b = it.querySelector('.mfaq-trigger'), p = it.querySelector('.mfaq-answer');\n    if (!b || !p) return;\n    it.classList.remove('is-open'); b.setAttribute('aria-expanded', 'false'); p.setAttribute('aria-hidden', 'true');\n    var h = p.style.height === 'auto' ? p.scrollHeight : parseFloat(p.style.height) || 0;\n    p.style.height = h + 'px'; p.offsetHeight; p.style.height = '0px';\n  }\n})();\n</script>\n\n<script type=\"application/ld+json\">\n{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Are the lights wireless?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Every light runs on a rechargeable bulb, so there's no wiring and no outlet needed.\"}},{\"@type\":\"Question\",\"name\":\"Do I need a professional to install them?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. Each light comes with 3M adhesive pads for a tool-free setup. Screws are also included for a permanent fix.\"}},{\"@type\":\"Question\",\"name\":\"How long does delivery take?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Orders are typically delivered within 3 working days across the UK, with a tracking link by email.\"}},{\"@type\":\"Question\",\"name\":\"How much is shipping?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Free on every UK order, with no minimum spend.\"}},{\"@type\":\"Question\",\"name\":