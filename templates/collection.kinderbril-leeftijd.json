    "custom_liquid_FjMgFT": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  .cart__sidebar .jacq-kcart-guarantee {\n    margin: -8px 0 16px;\n  }\n\n  /* Wrapper — confetti dots leven hier (achter de kaart) */\n  .jacq-kcart-guarantee {\n    background: transparent !important;\n    position: relative;\n  }\n\n  /* Confetti dots op de sectie-achtergrond */\n  .jacq-kcart-bg-dot {\n    position: absolute;\n    border-radius: 50%;\n    pointer-events: none;\n    z-index: 0;\n  }\n  .jacq-kcart-bg-dot--1  { width: 10px; height: 10px; background: #FF5C8A; top: -8px;   left: 4%;   opacity: 0.45; }\n  .jacq-kcart-bg-dot--2  { width: 8px;  height: 8px;  background: #0071E3; top: -14px;  right: 8%;  opacity: 0.5; }\n  .jacq-kcart-bg-dot--3  { width: 14px; height: 14px; background: #FF5C8A; bottom: -10px; right: 4%; opacity: 0.3; }\n  .jacq-kcart-bg-dot--4  { width: 9px;  height: 9px;  background: #0071E3; bottom: -14px; left: 6%;  opacity: 0.4; }\n  .jacq-kcart-bg-dot--5  { width: 6px;  height: 6px;  background: #FF5C8A; top: 30%;    left: -6px; opacity: 0.55; }\n  .jacq-kcart-bg-dot--6  { width: 7px;  height: 7px;  background: #0071E3; bottom: 30%; right: -8px; opacity: 0.5; }\n  .jacq-kcart-bg-dot--7  { width: 8px;  height: 8px;  background: #FF5C8A; top: -6px;   left: 38%;  opacity: 0.4; }\n  .jacq-kcart-bg-dot--8  { width: 5px;  height: 5px;  background: #0071E3; bottom: -6px; left: 42%;  opacity: 0.5; }\n\n  /* Witte kaart — staat boven de dots */\n  .jacq-kcart-guarantee-inner {\n    position: relative;\n    z-index: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    padding: 14px 18px;\n    border-radius: 24px;\n    background: #ffffff;\n    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.06);\n    font-family: inherit;\n    border: none;\n  }\n\n  .jacq-kcart-guarantee-items {\n    display: flex;\n    flex-direction: row;\n    gap: 14px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    padding-bottom: 4px;\n  }\n  .jacq-kcart-guarantee-items::-webkit-scrollbar { display: none; }\n  .jacq-kcart-guarantee-items { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .jacq-kcart-guarantee-item {\n    flex: 0 0 100%;\n    scroll-snap-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    gap: 8px;\n  }\n\n  .jacq-kcart-guarantee-icon {\n    flex-shrink: 0;\n    color: #0071E3;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    animation: jkcartIconPulse 3.6s ease-in-out infinite;\n  }\n  @keyframes jkcartIconPulse {\n    0%, 100% { transform: scale(1); }\n    50%      { transform: scale(1.08); }\n  }\n  .jacq-kcart-guarantee-item:nth-child(2) .jacq-kcart-guarantee-icon { animation-delay: 0.4s; }\n  .jacq-kcart-guarantee-item:nth-child(3) .jacq-kcart-guarantee-icon { animation-delay: 0.8s; }\n\n  .jacq-kcart-guarantee-icon svg {\n    width: 22px;\n    height: 22px;\n    display: block;\n  }\n\n  .jacq-kcart-guarantee-text-main {\n    font-size: 15px;\n    font-weight: 500;\n    color: #111827;\n  }\n\n  .jacq-kcart-guarantee-text-sub {\n    font-size: 13px;\n    color: #6b7280;\n    line-height: 1.45;\n  }\n\n  .jacq-kcart-guarantee-dots {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 6px;\n    margin-top: 2px;\n  }\n\n  .jacq-kcart-guarantee-dot {\n    width: 6px;\n    height: 6px;\n    border-radius: 999px;\n    background: #d1d5db;\n    transition: background-color 0.18s ease, transform 0.18s ease;\n    cursor: pointer;\n    border: none;\n    padding: 0;\n  }\n\n  .jacq-kcart-guarantee-dot.is-active {\n    background: #0071E3;\n    transform: scale(1.2);\n  }\n\n  @media (min-width: 768px) {\n    .jacq-kcart-guarantee-inner {\n      padding: 18px 22px;\n    }\n\n    .jacq-kcart-guarantee-items {\n      overflow-x: visible;\n      scroll-snap-type: none;\n      gap: 24px;\n      justify-content: space-between;\n    }\n\n    .jacq-kcart-guarantee-item {\n      flex: 1 1 0;\n      gap: 6px;\n      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\n    }\n    .jacq-kcart-guarantee-item:hover { transform: translateY(-2px); }\n\n    .jacq-kcart-guarantee-item:nth-child(1) { order: 2; }\n    .jacq-kcart-guarantee-item:nth-child(2) { order: 1; }\n    .jacq-kcart-guarantee-item:nth-child(3) { order: 3; }\n\n    .jacq-kcart-guarantee-dots { display: none; }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .jacq-kcart-guarantee-icon { animation: none !important; }\n  }\n</style>\n\n<div class=\"jacq-kcart-guarantee\">\n\n  <span class=\"jacq-kcart-bg-dot jacq-kcart-bg-dot--1\"></span>\n  <span class=\"jacq-kcart-bg-dot jacq-kcart-bg-dot--2\"></span>\n  <span class=\"jacq-kcart-bg-dot jacq-kcart-bg-dot--3\"></span>\n  <span class=\"jacq-kcart-bg-dot jacq-kcart-bg-dot--4\"></span>\n  <span class=\"jacq-kcart-bg-dot jacq-kcart-bg-dot--5\"></span>\n  <span class=\"jacq-kcart-bg-dot jacq-kcart-bg-dot--6\"></span>\n  <span class=\"jacq-kcart-bg-dot jacq-kcart-bg-dot--7\"></span>\n  <span class=\"jacq-kcart-bg-dot jacq-kcart-bg-dot--8\"></span>\n\n  <div class=\"jacq-kcart-guarantee-inner\">\n    <div class=\"jacq-kcart-guarantee-items\">\n      <div class=\"jacq-kcart-guarantee-item\">\n        <div class=\"jacq-kcart-guarantee-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M5 13.2 9.2 17.5 19 7.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"jacq-kcart-guarantee-text-main\">Niet goed, geld terug</div>\n          <div class=\"jacq-kcart-guarantee-text-sub\">Niet tevreden? Geld terug.</div>\n        </div>\n      </div>\n\n      <div class=\"jacq-kcart-guarantee-item\">\n        <div class=\"jacq-kcart-guarantee-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><rect x=\"3.5\" y=\"5\" width=\"17\" height=\"15\" rx=\"2\" ry=\"2\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"/><path d=\"M8 3.5v3M16 3.5v3M4 9h16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"jacq-kcart-guarantee-text-main\">100 dagen proefdragen</div>\n          <div class=\"jacq-kcart-guarantee-text-sub\">100 dagen om je bril uit te proberen.</div>\n        </div>\n      </div>\n\n      <div class=\"jacq-kcart-guarantee-item\">\n        <div class=\"jacq-kcart-guarantee-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M6.5 4.5 9 4a1 1 0 0 1 1 .6l1.1 2.6a1 1 0 0 1-.2 1.1l-1.4 1.4a9.5 9.5 0 0 0 4.8 4.8l1.4-1.4a1 1 0 0 1 1.1-.2l2.6 1.1a1 1 0 0 1 .6 1l-.5 2.5a1 1 0 0 1-1 .8A15.5 15.5 0 0 1 4 6.5a1 1 0 0 1 .8-1z\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"jacq-kcart-guarantee-text-main\">Klantenservice</div>\n          <div class=\"jacq-kcart-guarantee-text-sub\">Bereikbaar maandag t/m vrijdag 09:00–17:00.</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"jacq-kcart-guarantee-dots\">\n      <button type=\"button\" class=\"jacq-kcart-guarantee-dot is-active\" aria-label=\"Slide 1\"></button>\n      <button type=\"button\" class=\"jacq-kcart-guarantee-dot\" aria-label=\"Slide 2\"></button>\n      <button type=\"button\" class=\"jacq-kcart-guarantee-dot\" aria-label=\"Slide 3\"></button>\n    </div>\n  </div>\n</div>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    var root = document.querySelector('.jacq-kcart-guarantee');\n    if (!root) return;\n    var track = root.querySelector('.jacq-kcart-guarantee-items');\n    var slides = Array.prototype.slice.call(root.querySelectorAll('.jacq-kcart-guarantee-item'));\n    var dots = Array.prototype.slice.call(root.querySelectorAll('.jacq-kcart-guarantee-dot'));\n    if (!track || !slides.length || dots.length !== slides.length) return;\n\n    function updateDots() {\n      var center = track.scrollLeft + track.clientWidth / 2;\n      var activeIndex = 0;\n      var minDist = Infinity;\n      slides.forEach(function (slide, index) {\n        var slideCenter = slide.offsetLeft + slide.offsetWidth / 2;\n        var dist = Math.abs(slideCenter - center);\n        if (dist < minDist) { minDist = dist; activeIndex = index; }\n      });\n      dots.forEach(function (dot, index) {\n        dot.classList.toggle('is-active', index === activeIndex);\n      });\n    }\n\n    var ticking = false;\n    track.addEventListener('scroll', function () {\n      if (!ticking) {\n        window.requestAnimationFrame(function () { updateDots(); ticking = false; });\n        ticking = true;\n      }\n    });\n    dots.forEach(function (dot, index) {\n      dot.addEventListener('click', function () {\n        var slide = slides[index];\n        if (!slide) return;\n        track.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });\n      });\n    });\n    updateDots();\n  });\n</script>",
