    "custom_liquid_FjMgFT": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  /* JACQ – cart guarantees (Apple-ish, zelfde idee als sidebar-card) */\n  .cart__sidebar .jacq-cart-guarantee {\n    margin: -8px 0 16px;\n  }\n\n  .jacq-cart-guarantee-inner {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    padding: 14px 18px;\n    border-radius: 24px;\n    background: #ffffff;\n    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.06);\n    font-family: inherit;\n    border: none;\n  }\n\n  /* === Mobile: slider met 1 slide per view, zonder scrollbar === */\n  .jacq-cart-guarantee-items {\n    display: flex;\n    flex-direction: row;\n    gap: 14px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    padding-bottom: 4px;\n  }\n\n  /* Scrollbar verbergen */\n  .jacq-cart-guarantee-items::-webkit-scrollbar {\n    display: none;\n  }\n  .jacq-cart-guarantee-items {\n    -ms-overflow-style: none;  /* IE/Edge */\n    scrollbar-width: none;     /* Firefox */\n  }\n\n  .jacq-cart-guarantee-item {\n    flex: 0 0 100%;            /* precies 1 slide per view */\n    scroll-snap-align: center;\n    display: flex;\n    flex-direction: column;    /* icon boven tekst */\n    align-items: center;       /* alles centreren */\n    text-align: center;\n    gap: 8px;\n  }\n\n  .jacq-cart-guarantee-icon {\n    flex-shrink: 0;\n    color: #0071E3;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .jacq-cart-guarantee-icon svg {\n    width: 22px;\n    height: 22px;\n    display: block;\n  }\n\n  .jacq-cart-guarantee-text-main {\n    font-size: 15px;\n    font-weight: 500;\n    color: #111827;\n  }\n\n  .jacq-cart-guarantee-text-sub {\n    font-size: 13px;\n    color: #6b7280;\n    line-height: 1.45;\n  }\n\n  /* Slider dots (alleen mobile zichtbaar) */\n  .jacq-cart-guarantee-dots {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 6px;\n    margin-top: 2px;\n  }\n\n  .jacq-cart-guarantee-dot {\n    width: 6px;\n    height: 6px;\n    border-radius: 999px;\n    background: #d1d5db;\n    transition: background-color 0.18s ease, transform 0.18s ease;\n  }\n\n  .jacq-cart-guarantee-dot.is-active {\n    background: #111827;\n    transform: scale(1.1);\n  }\n\n  /* === Desktop: 3 gelijke kolommen, gecentreerd, geen slider/dots === */\n  @media (min-width: 768px) {\n    .jacq-cart-guarantee-inner {\n      padding: 18px 22px;\n    }\n\n    .jacq-cart-guarantee-items {\n      overflow-x: visible;\n      scroll-snap-type: none;\n      gap: 24px;\n      justify-content: space-between;\n    }\n\n    .jacq-cart-guarantee-item {\n      flex: 1 1 0;\n      gap: 6px;\n    }\n\n    /* Alleen op desktop: volgorde aanpassen */\n    .jacq-cart-guarantee-item:nth-child(1) { /* Niet goed, geld terug */\n      order: 2;                     /* MIDDEN */\n    }\n\n    .jacq-cart-guarantee-item:nth-child(2) { /* 100 dagen proefdragen */\n      order: 1;                     /* LINKS */\n    }\n\n    .jacq-cart-guarantee-item:nth-child(3) { /* Klantenservice */\n      order: 3;                     /* RECHTS */\n    }\n\n    /* Dots verbergen op desktop */\n    .jacq-cart-guarantee-dots {\n      display: none;\n    }\n  }\n</style>\n\n<div class=\"jacq-cart-guarantee\">\n  <div class=\"jacq-cart-guarantee-inner\">\n    <div class=\"jacq-cart-guarantee-items\">\n      <!-- Niet goed, geld terug -->\n      <div class=\"jacq-cart-guarantee-item\">\n        <div class=\"jacq-cart-guarantee-icon\">\n          <!-- check icon -->\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"M5 13.2 9.2 17.5 19 7.5\"\n                  fill=\"none\"\n                  stroke=\"currentColor\"\n                  stroke-width=\"1.8\"\n                  stroke-linecap=\"round\"\n                  stroke-linejoin=\"round\"/>\n          </svg>\n        </div>\n        <div>\n          <div class=\"jacq-cart-guarantee-text-main\">\n            Niet goed, geld terug\n          </div>\n          <div class=\"jacq-cart-guarantee-text-sub\">\n            Niet tevreden? Geld terug.\n          </div>\n        </div>\n      </div>\n\n      <!-- 100 dagen proefdragen -->\n      <div class=\"jacq-cart-guarantee-item\">\n        <div class=\"jacq-cart-guarantee-icon\">\n          <!-- calendar icon -->\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <rect x=\"3.5\" y=\"5\" width=\"17\" height=\"15\" rx=\"2\" ry=\"2\"\n                  fill=\"none\"\n                  stroke=\"currentColor\"\n                  stroke-width=\"1.8\"/>\n            <path d=\"M8 3.5v3M16 3.5v3M4 9h16\"\n                  fill=\"none\"\n                  stroke=\"currentColor\"\n                  stroke-width=\"1.8\"\n                  stroke-linecap=\"round\"/>\n          </svg>\n        </div>\n        <div>\n          <div class=\"jacq-cart-guarantee-text-main\">\n            100 dagen proefdragen\n          </div>\n          <div class=\"jacq-cart-guarantee-text-sub\">\n            100 dagen om je bril uit te proberen.\n          </div>\n        </div>\n      </div>\n\n      <!-- Klantenservice -->\n      <div class=\"jacq-cart-guarantee-item\">\n        <div class=\"jacq-cart-guarantee-icon\">\n          <!-- telefoon / klantenservice icon -->\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path\n              d=\"M6.5 4.5 9 4a1 1 0 0 1 1 .6l1.1 2.6a1 1 0 0 1-.2 1.1l-1.4 1.4a9.5 9.5 0 0 0 4.8 4.8l1.4-1.4a1 1 0 0 1 1.1-.2l2.6 1.1a1 1 0 0 1 .6 1l-.5 2.5a1 1 0 0 1-1 .8A15.5 15.5 0 0 1 4 6.5a1 1 0 0 1 .8-1z\"\n              fill=\"none\"\n              stroke=\"currentColor\"\n              stroke-width=\"1.8\"\n              stroke-linecap=\"round\"\n              stroke-linejoin=\"round\"\n            />\n          </svg>\n        </div>\n        <div>\n          <div class=\"jacq-cart-guarantee-text-main\">\n            Klantenservice\n          </div>\n          <div class=\"jacq-cart-guarantee-text-sub\">\n            Bereikbaar maandag t/m vrijdag 09:00–17:00.\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Slider dots -->\n    <div class=\"jacq-cart-guarantee-dots\">\n      <span class=\"jacq-cart-guarantee-dot is-active\"></span>\n      <span class=\"jacq-cart-guarantee-dot\"></span>\n      <span class=\"jacq-cart-guarantee-dot\"></span>\n    </div>\n  </div>\n</div>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    var root = document.querySelector('.jacq-cart-guarantee');\n    if (!root) return;\n\n    var track = root.querySelector('.jacq-cart-guarantee-items');\n    var slides = Array.prototype.slice.call(\n      root.querySelectorAll('.jacq-cart-guarantee-item')\n    );\n    var dots = Array.prototype.slice.call(\n      root.querySelectorAll('.jacq-cart-guarantee-dot')\n    );\n\n    if (!track || !slides.length || dots.length !== slides.length) return;\n\n    function updateDots() {\n      var center = track.scrollLeft + track.clientWidth / 2;\n      var activeIndex = 0;\n      var minDist = Infinity;\n\n      slides.forEach(function (slide, index) {\n        var slideCenter = slide.offsetLeft + slide.offsetWidth / 2;\n        var dist = Math.abs(slideCenter - center);\n        if (dist < minDist) {\n          minDist = dist;\n          activeIndex = index;\n        }\n      });\n\n      dots.forEach(function (dot, index) {\n        dot.classList.toggle('is-active', index === activeIndex);\n      });\n    }\n\n    // Update bij scroll\n    var ticking = false;\n    track.addEventListener('scroll', function () {\n      if (!ticking) {\n        window.requestAnimationFrame(function () {\n          updateDots();\n          ticking = false;\n        });\n        ticking = true;\n      }\n    });\n\n    // Dots klikken om naar slide te scrollen\n    dots.forEach(function (dot, index) {\n      dot.addEventListener('click', function () {\n        var slide = slides[index];\n        if (!slide) return;\n        track.scrollTo({\n          left: slide.offsetLeft,\n          behavior: 'smooth'\n        });\n      });\n    });\n\n    // Init state\n    updateDots();\n  });\n</script>",
