    "custom_liquid_promoBanner": {
      "type": "custom-liquid",
      "name": "Promo banner",
      "settings": {
        "liquid": "<style>\n  .jacq-promo-banner-card{\n    display:grid;\n    grid-template-columns:auto 1fr;\n    column-gap:clamp(14px,3vw,56px);\n    row-gap:2px;\n    width:100%;\n    padding:16px clamp(18px,3vw,44px);\n    background:linear-gradient(135deg,#ffffff 0%,#fafcfe 100%);\n    border:1px solid rgba(15,23,42,0.06);\n    border-radius:16px;\n    box-shadow:0 1px 2px rgba(15,23,42,0.03),0 12px 32px rgba(15,23,42,0.04);\n    box-sizing:border-box;\n    font-family:-apple-system,BlinkMacSystemFont,'HelveticaNow-Regular','Helvetica Neue',Helvetica,Arial,sans-serif;\n    -webkit-font-smoothing:antialiased;\n    align-items:center;\n  }\n  .jacq-promo-banner-card__title{\n    grid-column:1;\n    grid-row:1;\n    font-size:clamp(20px,2.4vw,28px);\n    font-weight:700;\n    color:#0a0a0a;\n    line-height:1.1;\n    letter-spacing:-0.025em;\n    margin:0;\n  }\n  .jacq-promo-banner-card__subtitle{\n    grid-column:1;\n    grid-row:2;\n    font-size:clamp(12px,1.1vw,15px);\n    color:#52606d;\n    font-weight:400;\n    line-height:1.3;\n    margin:0;\n  }\n  .jacq-promo-banner-card__usps{\n    grid-column:2;\n    grid-row:1 / span 2;\n    align-self:center;\n    justify-self:end;\n    display:flex;\n    align-items:center;\n    gap:clamp(14px,2vw,32px);\n    list-style:none;\n    padding:0;\n    margin:0;\n  }\n  .jacq-promo-banner-card__usp{\n    display:flex;\n    align-items:center;\n    gap:9px;\n    font-size:clamp(12px,0.9vw,13.5px);\n    color:#1a1a1a;\n    font-weight:500;\n    line-height:1.2;\n    white-space:nowrap;\n  }\n  .jacq-promo-banner-card__icon{\n    flex-shrink:0;\n    width:20px;\n    height:20px;\n    color:#0071E3;\n  }\n  @media (max-width:1100px){\n    .jacq-promo-banner-card__usp:nth-child(n+4){display:none;}\n  }\n  @media (max-width:900px){\n    .jacq-promo-banner-card__usp:nth-child(n+3){display:none;}\n  }\n  @media (max-width:768px){\n    .jacq-promo-banner-card{padding:14px 18px;border-radius:14px;column-gap:12px;}\n    .jacq-promo-banner-card__usps{display:none;}\n    .jacq-promo-banner-card__title{font-size:22px;}\n    .jacq-promo-banner-card__subtitle{font-size:13px;}\n  }\n</style>\n\n<div class=\"jacq-promo-banner-card\" aria-label=\"2+1 gratis\">\n  <h2 class=\"jacq-promo-banner-card__title\">2+1 gratis</h2>\n  <p class=\"jacq-promo-banner-card__subtitle\">Een bril voor elke gelegenheid</p>\n  <ul class=\"jacq-promo-banner-card__usps\">\n    <li class=\"jacq-promo-banner-card__usp\">\n      <svg class=\"jacq-promo-banner-card__icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M21 12a9 9 0 1 1-3-6.7L21 8\"/><path d=\"M21 3v5h-5\"/></svg>\n      <span>100 dagen bedenktijd</span>\n    </li>\n    <li class=\"jacq-promo-banner-card__usp\">\n      <svg class=\"jacq-promo-banner-card__icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linejoin=\"round\" stroke-linecap=\"round\" aria-hidden=\"true\"><path d=\"M6 3h12l3 5-9 13L3 8z\"/><path d=\"M11 3 8 8l4 13 4-13-3-5\"/><path d=\"M3 8h18\"/></svg>\n      <span>Vakkundig afgewerkt</span>\n    </li>\n    <li class=\"jacq-promo-banner-card__usp\">\n      <svg class=\"jacq-promo-banner-card__icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M20.6 12.6 12.6 20.6a2 2 0 0 1-2.8 0L3 13.8V3h10.8l6.8 6.8a2 2 0 0 1 0 2.8z\"/><circle cx=\"7.5\" cy=\"7.5\" r=\"1.4\"/></svg>\n      <span>Eerlijk geprijsd</span>\n    </li>\n    <li class=\"jacq-promo-banner-card__usp\">\n      <svg class=\"jacq-promo-banner-card__icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"m9 12 2 2 4-4\"/></svg>\n      <span>2 jaar garantie</span>\n    </li>\n  </ul>\n</div>",
