        "liquid": "<style>\n  #meave-faq *, #meave-faq *::before, #meave-faq *::after { box-sizing: border-box; }\n\n  #meave-faq {\n    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    background: #ffffff;\n    color: #1D1D1F;\n    padding: 56px 0;\n    opacity: 0;\n    transform: translateY(20px);\n    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n\n  #meave-faq.is-visible { opacity: 1; transform: translateY(0); }\n\n  .mfaq-wrap { max-width: none; margin: 0 auto; }\n\n  .mfaq-header { text-align: center; margin-bottom: 32px; }\n  .mfaq-title {\n    font-size: 28px; font-weight: 700; letter-spacing: -0.035em;\n    line-height: 1.1; color: #1D1D1F; margin: 0;\n  }\n  .mfaq-sub {\n    font-size: 15px; color: #86868b; margin: 10px 0 0;\n    font-weight: 400; letter-spacing: -0.01em;\n  }\n\n  .mfaq-body { display: flex; flex-direction: column; gap: 12px; }\n\n  .mfaq-nav {\n    display: flex; gap: 0; background: #F5F5F7;\n    border-radius: 12px; padding: 3px; position: relative;\n  }\n\n  .mfaq-nav-btn {\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\n    gap: 4px; flex: 1; padding: 10px 4px;\n    background: transparent; border: none; cursor: pointer; border-radius: 10px;\n    font-family: inherit; font-size: 10px; font-weight: 500;\n    color: #86868b; letter-spacing: 0; text-align: center;\n    transition: color 0.4s cubic-bezier(0.22, 1, 0.36, 1), background 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);\n    position: relative; z-index: 1; -webkit-tap-highlight-color: transparent;\n  }\n  .mfaq-nav-btn:active { transform: scale(0.95); }\n  .mfaq-nav-btn.is-active {\n    color: #1D1D1F; font-weight: 600; background: #fff;\n    box-shadow: 0 0.5px 1px rgba(0,0,0,0.04), 0 6px 14px -6px rgba(0,0,0,0.1);\n  }\n\n  .mfaq-nav-icon {\n    width: 32px; height: 32px; border-radius: 8px; background: transparent;\n    display: flex; align-items: center; justify-content: center; flex: 0 0 32px;\n    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .mfaq-nav-icon svg { width: 17px; height: 17px; transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1); }\n  .mfaq-nav-btn.is-active .mfaq-nav-icon { background: rgba(224,169,59,0.16); transform: scale(1.08); }\n  .mfaq-nav-btn.is-active .mfaq-nav-icon svg { stroke: #B07F1E; }\n  .mfaq-nav-label { transition: color 0.4s ease; }\n\n  .mfaq-content {\n    background: #fff; border-radius: 20px; padding: 24px 20px;\n    box-shadow: 0 0.5px 1px rgba(0,0,0,0.03), 0 6px 16px -8px rgba(0,0,0,0.08), 0 14px 32px -12px rgba(0,0,0,0.07);\n  }\n\n  .mfaq-panel { display: none; opacity: 0; }\n  .mfaq-panel.is-active { display: block; animation: mfaqIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards; }\n  .mfaq-panel.is-leaving { display: block; animation: mfaqOut 0.2s cubic-bezier(0.4, 0, 1, 1) forwards; }\n  @keyframes mfaqIn {\n    0% { opacity: 0; transform: translateY(8px) scale(0.995); }\n    40% { opacity: 1; }\n    100% { opacity: 1; transform: translateY(0) scale(1); }\n  }\n  @keyframes mfaqOut {\n    0% { opacity: 1; transform: translateY(0); }\n    100% { opacity: 0; transform: translateY(-4px); }\n  }\n\n  .mfaq-cat-head { margin-bottom: 12px; }\n  .mfaq-cat-title {\n    font-size: 20px; font-weight: 600; letter-spacing: -0.025em;\n    color: #1D1D1F; margin: 0 0 2px;\n  }\n  .mfaq-cat-desc {\n    font-size: 13px; color: #aeaeb2; margin: 0; font-weight: 400;\n    letter-spacing: -0.005em; line-height: 1.45;\n  }\n\n  .mfaq-item { border-top: 1px solid #f0f0f2; }\n  .mfaq-item:first-child { border-top: none; }\n  .mfaq-item:last-child { margin-bottom: 0; }\n\n  .mfaq-trigger {\n    width: 100%; background: transparent; border: none; cursor: pointer;\n    display: flex; align-items: center; justify-content: space-between; gap: 16px;\n    padding: 16px 0; text-align: left; font-family: inherit;\n  }\n  .mfaq-q {\n    font-size: 14px; font-weight: 500; color: #1D1D1F;\n    letter-spacing: -0.01em; line-height: 1.4; transition: color 0.25s ease;\n  }\n  .mfaq-trigger:hover .mfaq-q { color: #B07F1E; }\n\n  .mfaq-plus {\n    width: 22px; height: 22px; flex: 0 0 22px; border-radius: 50%;\n    background: #F5F5F7; display: flex; align-items: center; justify-content: center;\n    transition: background 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.6s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .mfaq-plus svg {\n    width: 12px; height: 12px; stroke: #c7c7cc; stroke-width: 1.8;\n    stroke-linecap: round; fill: none; transition: stroke 0.4s ease;\n  }\n  .mfaq-trigger:hover .mfaq-plus { background: rgba(224,169,59,0.14); }\n  .mfaq-trigger:hover .mfaq-plus svg { stroke: #B07F1E; }\n  .mfaq-item.is-open .mfaq-plus {\n    background: linear-gradient(135deg, #F4CE6A 0%, #E0A93B 100%);\n    transform: rotate(45deg); box-shadow: 0 2px 8px rgba(193,140,30,0.32);\n  }\n  .mfaq-item.is-open .mfaq-plus svg { stroke: #4A3408; }\n\n  .mfaq-answer { height: 0; overflow: hidden; transition: height 700ms cubic-bezier(0.22, 1, 0.36, 1); }\n  .mfaq-answer-inner {\n    padding: 0 0 20px 0; font-size: 13px; line-height: 1.75; color: #6e6e73;\n    letter-spacing: -0.005em; max-width: 100%; word-break: break-word;\n    opacity: 0; transform: translateY(-3px);\n    transition: opacity 600ms cubic-bezier(0.22, 1, 0.36, 1) 50ms, transform 700ms cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .mfaq-item.is-open .mfaq-answer-inner { opacity: 1; transform: translateY(0); }\n  .mfaq-answer-inner strong { color: #1D1D1F; font-weight: 600; }\n\n  .mfaq-footer {\n    margin-top: 16px; background: #fff; border-radius: 16px; padding: 20px 24px;\n    display: flex; align-items: center; justify-content: space-between; gap: 16px;\n    box-shadow: 0 0.5px 1px rgba(0,0,0,0.04), 0 6p