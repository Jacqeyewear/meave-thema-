mfaq-nav-btn {\n      flex-direction: row; align-items: center; justify-content: flex-start; gap: 14px; padding: 12px 16px;\n      border-radius: 14px; font-size: 14px; text-align: left; box-shadow: none; background: transparent;\n    }\n    .mfaq-nav-btn:hover { background: #F5F5F7; box-shadow: none; }\n    .mfaq-nav-btn.is-active { background: #F5F5F7; color: #1D1D1F; box-shadow: none; }\n    .mfaq-nav-icon { width: 36px; height: 36px; border-radius: 10px; flex: 0 0 36px; transform: none; }\n    .mfaq-nav-icon svg { width: 17px; height: 17px; }\n    .mfaq-nav-btn.is-active .mfaq-nav-icon {\n      background: linear-gradient(135deg, #F4CE6A 0%, #E0A93B 100%);\n      box-shadow: 0 2px 8px rgba(193,140,30,0.28); transform: none;\n    }\n    .mfaq-nav-btn.is-active .mfaq-nav-icon svg { stroke: #4A3408; }\n    .mfaq-nav-label { font-size: 14px; line-height: normal; }\n\n    .mfaq-content { padding: 36px 40px; border-radius: 24px; }\n    .mfaq-cat-title { font-size: 24px; }\n    .mfaq-cat-desc { font-size: 14px; }\n    .mfaq-q { font-size: 16px; }\n    .mfaq-answer-inner { font-size: 14px; max-width: none; padding: 0 0 24px 0; }\n    .mfaq-plus { width: 26px; height: 26px; flex: 0 0 26px; }\n    .mfaq-plus svg { width: 13px; height: 13px; }\n\n    .mfaq-footer { margin-top: 20px; padding: 24px 32px; border-radius: 20px; }\n    .mfaq-footer-left { font-size: 15px; }\n    .mfaq-footer-left p { font-size: 13px; }\n  }\n\n  @media (min-width: 1200px) {\n    .mfaq-body { grid-template-columns: 280px 1fr; gap: 0 56px; }\n    .mfaq-nav-btn { padding: 14px 18px; font-size: 15px; }\n    .mfaq-content { padding: 40px 48px; }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    *, *::before, *::after { transition: none !important; animation: none !important; }\n  }\n</style>\n\n<section id=\"meave-faq\" data-meave-faq>\n  <div class=\"mfaq-wrap\">\n\n    <div class=\"mfaq-header\">\n      <h2 class=\"mfaq-title\">Frequently asked questions</h2>\n      <p class=\"mfaq-sub\">Everything you need to know, in plain words.</p>\n    </div>\n\n    <div class=\"mfaq-body\">\n\n      <nav class=\"mfaq-nav\" aria-label=\"FAQ categories\">\n        <button class=\"mfaq-nav-btn is-active\" data-target=\"product\" type=\"button\">\n          <span class=\"mfaq-nav-icon\">\n            <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#86868b\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M6 12h4\"/><path d=\"M6.5 14h3\"/><path d=\"M8 2a4 4 0 0 1 2.5 7.1c-.4.4-.6.9-.6 1.4H6.1c0-.5-.2-1-.6-1.4A4 4 0 0 1 8 2z\"/></svg>\n          </span>\n          <span class=\"mfaq-nav-label\" data-short=\"Product\">Product &amp; setup</span>\n        </button>\n\n        <button class=\"mfaq-nav-btn\" data-target=\"shipping\" type=\"button\">\n          <span class=\"mfaq-nav-icon\">\n            <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#86868b\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"1\" y=\"4\" width=\"9\" height=\"7\" rx=\"1\"/><path d=\"M10 6.5l3.5 1.5V11.5h-3.5\"/><circle cx=\"3.5\" cy=\"12\" r=\"1.2\"/><circle cx=\"11.5\" cy=\"12\" r=\"1.2\"/></svg>\n          </span>\n          <span class=\"mfaq-nav-label\" data-short=\"Shipping\">Shipping &amp; delivery</span>\n        </button>\n\n        <button class=\"mfaq-nav-btn\" data-target=\"returns\" type=\"button\">\n          <span class=\"mfaq-nav-icon\">\n            <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#86868b\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 8a5 5 0 1 1 1.5 3.5\"/><path d=\"M3 5v3h3\"/></svg>\n          </span>\n          <span class=\"mfaq-nav-label\" data-short=\"Returns\">Returns &amp; warranty</span>\n        </button>\n\n        <button class=\"mfaq-nav-btn\" data-target=\"orders\" type=\"button\">\n          <span class=\"mfaq-nav-icon\">\n            <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#86868b\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"2\" width=\"10\" height=\"12\" rx=\"1.5\"/><path d=\"M6 5.5h4M6 8h4M6 10.5h2\"/></svg>\n          </span>\n          <span class=\"mfaq-nav-label\" data-short=\"Support\">Orders &amp; support</span>\n        </button>\n      </nav>\n\n      <div class=\"mfaq-content\">\n\n        <div class=\"mfaq-panel is-active\" data-panel=\"product\">\n          <div class=\"mfaq-cat-head\">\n            <h3 class=\"mfaq-cat-title\">Product &amp; setup</h3>\n            <p class=\"mfaq-cat-desc\">What you get and how to set it up.</p>\n          </div>\n          <div class=\"mfaq-list\">\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Are the lights wireless?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Yes. Every light runs on a rechargeable bulb, so there's no wiring and no outlet needed. Charge it, mount it, done.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Do I need a professional to install them?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">No. Each light comes with <strong>3M adhesive pads</strong> for a tool-free setup. Screws are also included if you'd prefer a permanent fix. It takes a couple of minutes.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Can I control the brightness and colour?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Yes. The included remote lets you adjust brightness, switch colour temperature and set a timer.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How long does the battery last?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Several days on a single charge with normal use. Recharge with any USB-C cable. Fully charge before first use for the best battery life.</div></div></div>\n          </div>\n        </div>\n\n        <div class=\"mfaq-panel\" data-panel=\"shipping\">\n          <div class=\"mfaq-cat-head\">\n            <h3 class=\"mfaq-cat-title\">Shipping &amp; delivery</h3>\n            <p class=\"mfaq-cat-desc\">When and how your order arrives.</p>\n          </div>\n          <div class=\"mfaq-list\">\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How long does delivery take?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Orders are typically delivered within <strong>3 working days</strong> across the UK. You'll get a tracking link by email as soon as your order ships.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How much is shipping?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Free on every UK order. No minimum spend.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Can I track my order?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Yes. Once your order ships you'll receive a tracked link by email so you can follow it to your door.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">What if my order arrives damaged?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Just email us a photo and we'll sort it straight away, either a free replacement or a refund.</div></div></div>\n          </div>\n        </div>\n\n        <div class=\"mfaq-panel\" data-panel=\"returns\">\n          <div class=\"mfaq-cat-head\">\n            <h3 class=\"mfaq-cat-title\">Returns &amp; warranty</h3>\n            <p class=\"mfaq-cat-desc\">Risk-free, every order.</p>\n          </div>\n          <div class=\"mfaq-list\">\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">What is your return policy?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">You have <strong>30 days from delivery</strong> to return your order for a full refund. Not for you? Email us and we'll start the return, no fuss.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Is there a warranty?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Yes, a <strong>2-year warranty</strong> against manufacturing defects on every light. Something not right? We'll replace it or refund you.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How do I start a return?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Email us with your order number and we'll send you everything you need.</div></div></div>\n          </div>\n        </div>\n\n        <div class=\"mfaq-panel\" data-panel=\"orders\">\n          <div class=\"mfaq-cat-head\">\n            <h3 class=\"mfaq-cat-title\">Orders &amp; support</h3>\n            <p class=\"mfaq-cat-desc\">Payment, contact and response times.</p>\n          </div>\n          <div class=\"mfaq-list\">\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How can I pay?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">All major cards, plus Apple Pay, Google Pay, PayPal and Shop Pay. Every payment is processed over a secure connection.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Can I change or cancel my order?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">If it hasn't shipped yet, yes. Email us as soon as you can and we'll do our best to update it.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How do I contact you?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">By email, any day of the week. We usually reply within 24 hours.</div></div></div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <div class=\"mfaq-footer\">\n      <div class=\"mfaq-footer-left\">\n        Still have a question?\n        <p>We're happy to help by email.</p>\n      </div>\n      <div class=\"mfaq-footer-links\">\n        <a href=\"/pages/contact\" class=\"mfaq-footer-link mfaq-footer-link--contact\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg>\n          Contact us\n        </a>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n<script>\n(function () {\n  var root = document.querySelector('[data-meave-faq]');\n  if (!root) return;\n\n  if ('IntersectionObserver' in window) {\n    var fadeObserver = new IntersectionObserver(function (entries) {\n      entries.forEach(function (entry) {\n        if (entry.isIntersecting) { entry.target.classList.add('is-visible'); fadeObserver.unobserve(entry.target); }\n      });\n    }, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });\n    fadeObserver.observe(root);\n  } else {\n    root.classList.add('is-visible');\n  }\n\n  var navBtns = Array.prototype.slice.call(root.querySelectorAll('.mfaq-nav-btn'));\n  var panels = Array.prototype.slice.call(root.querySelectorAll('.mfaq-panel'));\n\n  navBtns.forEach(function (btn) {\n    btn.addEventListener('click', function () {\n      var target = btn.getAttribute('data-target');\n      var currentPanel = root.querySelector('.mfaq-panel.is-active');\n      var nextPanel = root.querySelector('.mfaq-panel[data-panel=\"' + target + '\"]');\n      if (currentPanel === nextPanel) return;\n\n      navBtns.forEach(function (b) { b.classList.remove('is-active'); });\n      btn.classList.add('is-active');\n\n      if (currentPanel) {\n        currentPanel.querySelectorAll('.mfaq-item.is-open').forEach(function (it) { closeItem(it); });\n        currentPanel.classList.remove('is-active');\n        currentPanel.classList.add('is-leaving');\n        setTimeout(function () {\n          currentPanel.classList.remove('is-leaving');\n          panels.forEach(function (p) { p.classList.remove('is-active'); });\n          if (nextPanel) {\n            nextPanel.classList.add('is-active');\n            if (window.innerWidth >= 768) {\n              var fi = nextPanel.querySelector('.mfaq-item');\n              if (fi) setTimeout(function () { openItem(fi); }, 200);\n            }\n          }\n        }, 250);\n      } else {\n        panels.forEach(function (p) { p.classList.remove('is-active'); });\n        if (nextPanel) nextPanel.classList.add('is-active');\n      }\n\n      if (window.innerWidth < 768) {\n        var content = root.querySelector('.mfaq-content');\n        if (content) setTimeout(function () { content.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 320);\n      }\n    });\n  });\n\n  root.querySelectorAll('.mfaq-item').forEach(function (item) {\n    var btn = item.querySelector('.mfaq-trigger'), panel = item.querySelector('.mfaq-answer');\n    if (!btn || !panel) return;\n    panel.style.height = '0px';\n    panel.addEventListener('transitionend', function (e) { if (e.propertyName === 'height' && item.classList.contains('is-open')) panel.style.height = 'auto'; });\n    btn.addEventListener('click', function () {\n      var isOpen = item.classList.contains('is-open'), list = item.closest('.mfaq-list');\n      if (list) list.querySelectorAll('.mfaq-item').forEach(function (sib) { if (sib !== item) closeItem(sib); });\n      isOpen ? closeItem(item) : openItem(item);\n    });\n  });\n\n  var fp = root.querySelector('.mfaq-panel.is-active');\n  if (fp && window.innerWidth >= 768) { var fi = fp.querySelector('.mfaq-item'); if (fi) setTimeout(function () { openItem(fi); }, 300); }\n\n  function openItem(it) {\n    var b = it.querySelector('.mfaq-trigger'), p = it.querySelector('.mfaq-answer');\n    if (!b || !p) return;\n    it.classList.add('is-open'); b.setAttribute('aria-expanded', 'true'); p.setAttribute('aria-hidden', 'false');\n    p.style.height = '0px'; p.offsetHeight; p.style.height = p.scrollHeight + 'px';\n  }\n  function closeItem(it) {\n    var b = it.querySelector('.mfaq-trigger'), p = it.querySelector('.mfaq-answer');\n    if (!b || !p) return;\n    it.classList.remove('is-open'); b.setAttribute('aria-expanded', 'false'); p.setAttribute('aria-hidden', 'true');\n    var h = p.style.height === 'auto' ? p.scrollHeight : parseFloat(p.style.height) || 0;\n    p.style.height = h + 'px'; p.offsetHeight; p.style.height = '0px';\n  }\n})();\n</script>\n\n<script type=\"application/ld+json\">\n{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Are the lights wireless?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Every light runs on a rechargeable bulb, so there's no wiring and no outlet needed.\"}},{\"@type\":\"Question\",\"name\":\"Do I need a professional to install them?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. Each light comes with 3M adhesive pads for a tool-free setup. Screws are also included for a permanent fix.\"}},{\"@type\":\"Question\",\"name\":\"How long does delivery take?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Orders are typically delivered within 3 working days across the UK, with a tracking link by email.\"}},{\"@type\":\"Question\",\"name\":\"How much is shipping?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Free on every UK order, with no minimum spend.\"}},{\"@type\":\"Question\",\"name\":\"What is your return policy?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You have 30 days from delivery to return your order for a full refund.\"}},{\"@type\":\"Question\",\"name\":\"Is there a warranty?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, a 2-year warranty against manufacturing defects on every light.\"}},{\"@type\":\"Question\",\"name\":\"How can I pay?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"All major cards, plus Apple Pay, Google Pay, PayPal and Shop Pay, processed over a secure connection.\"}},{\"@type\":\"Question\",\"name\":\"How do I contact you?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"By email, any day of the week. We usually reply within 24 hours.\"}}]}\n</script>",
