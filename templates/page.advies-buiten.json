          "settings": {
            "title": "Stap 2: maak schoon zonder krassen (stof eerst weg)",
            "body": "<p>Stof en zand zijn de grootste ‘krassers’. Spoel eerst, reinig mild, dep droog. Zie <a href='/pages/bril-schoonmaken'>bril schoonmaken</a>.</p>"
          }
        },
        "howto-3": {
          "type": "howto_step",
          "settings": {
            "title": "Stap 3: kies coatings die buiten het meeste opleveren",
            "body": "<p>Anti-reflectie voor rust, water/vet-afstotend voor onderhoud. Overzicht: <a href='/pages/coatings'>coatings</a>.</p>"
          }
        },
        "howto-4": {
          "type": "howto_step",
          "settings": {
            "title": "Stap 4: pasvorm voor buitengebruik",
            "body": "<p>Een bril die schuift door zweet of wind geeft irritatie. Een kleine afstelling kan veel schelen.</p>"
          }
        },
        "howto-5": {
          "type": "howto_step",
          "settings": {
            "title": "Stap 5: pak ‘droge ogen door wind’ slim aan",
            "body": "<p>Wind kan ogen droger maken. Knipper bewust, neem pauzes en overweeg bescherming (pet/kap/zijscherm) bij extreme wind.</p>"
          }
        },
        "table-1": {
          "type": "table",
