        "related_richtext": "<ul><li><a href='/pages/zonneglazen-op-sterkte'>Zonneglazen op sterkte</a></li><li><a href='/pages/anti-reflectie'>Anti-reflectie</a></li><li><a href='/pages/water-vet-afstotend'>Water- & vetafstotend</a></li><li><a href='/pages/coatings'>Coatings overzicht</a></li><li><a href='/pages/bril-schoonmaken'>Bril schoonmaken</a></li><li><a href='/pages/bril-afstellen'>Bril afstellen</a></li></ul>"
      },
