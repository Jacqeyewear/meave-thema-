    "custom_liquid_FjMgFT": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  .cart__sidebar .meave-cart-guarantee {\n    margin: -8px 0 16px;\n  }\n\n  /* Force section wrapper achtergrond gelijk aan pagina */\n  .meave-cart-guarantee {\n    background: transparent !important;\n  }\n\n  .meave-cart-guarantee-inner {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    padding: 14px 18px;\n    border-radius: 24px;\n    background: #ffffff;\n    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.06);\n    font-family: inherit;\n    border: none;\n  }\n\n  .meave-cart-guarantee-items {\n    display: flex;\n    flex-direction: row;\n    gap: 14px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    padding-bottom: 4px;\n  }\n  .meave-cart-guarantee-items::-webkit-scrollbar { display: none; }\n  .meave-cart-guarantee-items { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .meave-cart-guarantee-item {\n    flex: 0 0 100%;\n    scroll-snap-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    gap: 8px;\n  }\n\n  .meave-cart-guarantee-icon {\n    flex-shrink: 0;\n    color: #E0A93B;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .meave-cart-guarantee-icon svg {\n    width: 22px;\n    height: 22px;\n    display: block;\n  }\n\n  .meave-cart-guarantee-text-main {\n    font-size: 15px;\n    font-weight: 500;\n    color: #111827;\n  }\n\n  .meave-cart-guarantee-text-sub {\n    font-size: 13px;\n    color: #6b7280;\n    line-height: 1.45;\n  }\n\n  .meave-cart-guarantee-dots {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 6px;\n    margin-top: 2px;\n  }\n\n  .meave-cart-guarantee-dot {\n    width: 6px;\n    height: 6px;\n    border-radius: 999px;\n    background: #d1d5db;\n    transition: background-color 0.18s ease, transform 0.18s ease;\n  }\n\n  .meave-cart-guarantee-dot.is-active {\n    background: #111827;\n    transform: scale(1.1);\n  }\n\n  @media (min-width: 768px) {\n    .meave-cart-guarantee-inner {\n      padding: 18px 22px;\n    }\n\n    .meave-cart-guarantee-items {\n      overflow-x: visible;\n      scroll-snap-type: none;\n      gap: 24px;\n      justify-content: space-between;\n    }\n\n    .meave-cart-guarantee-item {\n      flex: 1 1 0;\n      gap: 6px;\n    }\n\n    .meave-cart-guarantee-item:nth-child(1) { order: 2; }\n    .meave-cart-guarantee-item:nth-child(2) { order: 1; }\n    .meave-cart-guarantee-item:nth-child(3) { order: 3; }\n\n    .meave-cart-guarantee-dots { display: none; }\n  }\n</style>\n\n<div class=\"meave-cart-guarantee\">\n  <div class=\"meave-cart-guarantee-inner\">\n    <div class=\"meave-cart-guarantee-items\">\n      <div class=\"meave-cart-guarantee-item\">\n        <div class=\"meave-cart-guarantee-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M5 13.2 9.2 17.5 19 7.5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"meave-cart-guarantee-text-main\">Money-back guarantee</div>\n          <div class=\"meave-cart-guarantee-text-sub\">Not satisfied? Full refund.</div>\n        </div>\n      </div>\n\n      <div class=\"meave-cart-guarantee-item\">\n        <div class=\"meave-cart-guarantee-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><rect x=\"3.5\" y=\"5\" width=\"17\" height=\"15\" rx=\"2\" ry=\"2\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"/><path d=\"M8 3.5v3M16 3.5v3M4 9h16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"meave-cart-guarantee-text-main\">30-day trial</div>\n          <div class=\"meave-cart-guarantee-text-sub\">30 days to try it at home.</div>\n        </div>\n      </div>\n\n      <div class=\"meave-cart-guarantee-item\">\n        <div class=\"meave-cart-guarantee-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M6.5 4.5 9 4a1 1 0 0 1 1 .6l1.1 2.6a1 1 0 0 1-.2 1.1l-1.4 1.4a9.5 9.5 0 0 0 4.8 4.8l1.4-1.4a1 1 0 0 1 1.1-.2l2.6 1.1a1 1 0 0 1 .6 1l-.5 2.5a1 1 0 0 1-1 .8A15.5 15.5 0 0 1 4 6.5a1 1 0 0 1 .8-1z\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"meave-cart-guarantee-text-main\">Customer service</div>\n          <div class=\"meave-cart-guarantee-text-sub\">Available Monday to Friday, 9am–5pm.</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"meave-cart-guarantee-dots\">\n      <span class=\"meave-cart-guarantee-dot is-active\"></span>\n      <span class=\"meave-cart-guarantee-dot\"></span>\n      <span class=\"meave-cart-guarantee-dot\"></span>\n    </div>\n  </div>\n</div>\n\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    var root = document.querySelector('.meave-cart-guarantee');\n    if (!root) return;\n    var track = root.querySelector('.meave-cart-guarantee-items');\n    var slides = Array.prototype.slice.call(root.querySelectorAll('.meave-cart-guarantee-item'));\n    var dots = Array.prototype.slice.call(root.querySelectorAll('.meave-cart-guarantee-dot'));\n    if (!track || !slides.length || dots.length !== slides.length) return;\n\n    function updateDots() {\n      var center = track.scrollLeft + track.clientWidth / 2;\n      var activeIndex = 0;\n      var minDist = Infinity;\n      slides.forEach(function (slide, index) {\n        var slideCenter = slide.offsetLeft + slide.offsetWidth / 2;\n        var dist = Math.abs(slideCenter - center);\n        if (dist < minDist) { minDist = dist; activeIndex = index; }\n      });\n      dots.forEach(function (dot, index) {\n        dot.classList.toggle('is-active', index === activeIndex);\n      });\n    }\n\n    var ticking = false;\n    track.addEventListener('scroll', function () {\n      if (!ticking) {\n        window.requestAnimationFrame(function () { updateDots(); ticking = false; });\n        ticking = true;\n      }\n    });\n    dots.forEach(function (dot, index) {\n      dot.addEventListener('click', function () {\n        var slide = slides[index];\n        if (!slide) return;\n        track.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });\n      });\n    });\n    updateDots();\n  });\n</script>",
