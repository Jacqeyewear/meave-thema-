        "liquid": "<style>\n  .jacq-qb{\n    display:flex !important;\n    align-items:center !important;\n    gap:14px !important;\n    width:100% !important;\n    max-width:560px !important;\n    margin:-16px auto 0 0 !important;\n    padding:12px 18px !important;\n    background:#fff !important;\n    border:none !important;\n    border-radius:14px !important;\n    box-shadow:\n      0 1px 2px rgba(0,0,0,0.04),\n      0 3px 10px rgba(0,0,0,0.05),\n      0 10px 28px rgba(0,0,0,0.06) !important;\n    font-family:'HelveticaNow-Regular','Helvetica Now Text','Helvetica Neue',Helvetica,Arial,sans-serif !important;\n    -webkit-font-smoothing:antialiased !important;\n    box-sizing:border-box !important;\n    position:relative !important;\n    text-decoration:none !important;\n    color:inherit !important;\n    cursor:pointer !important;\n    -webkit-tap-highlight-color:transparent !important;\n    transition:transform 0.25s cubic-bezier(0.16,1,0.3,1), box-shadow 0.25s cubic-bezier(0.16,1,0.3,1) !important;\n  }\n  .jacq-qb:hover{\n    transform:translateY(-1px) !important;\n    box-shadow:\n      0 1px 2px rgba(0,0,0,0.04),\n      0 4px 14px rgba(0,0,0,0.07),\n      0 14px 32px rgba(0,113,227,0.10) !important;\n  }\n  .jacq-qb:active{transform:scale(0.995) !important;}\n  .jacq-qb *,.jacq-qb *::before,.jacq-qb *::after{box-sizing:border-box !important;}\n\n  .jacq-qb__text{\n    flex:1 1 auto !important;\n    min-width:0 !important;\n    font-size:14px !important;\n    font-weight:500 !important;\n    color:#1D1D1F !important;\n    letter-spacing:-0.01em !important;\n    line-height:1.35 !important;\n    margin:0 !important;\n    padding:0 !important;\n  }\n  .jacq-qb__cta{\n    color:#0071E3 !important;\n    font-weight:600 !important;\n    white-space:nowrap !important;\n  }\n  .jacq-qb__arrow{\n    flex-shrink:0 !important;\n    color:#0071E3 !important;\n    display:inline-flex !important;\n    align-items:center !important;\n    justify-content:center !important;\n    transition:transform 0.25s cubic-bezier(0.16,1,0.3,1) !important;\n  }\n  .jacq-qb__arrow svg{\n    width:14px !important;\n    height:14px !important;\n    display:block !important;\n  }\n  .jacq-qb:hover .jacq-qb__arrow{transform:translateX(3px) !important;}\n\n  @media(max-width:640px){\n    .jacq-qb{\n      padding:11px 14px !important;\n      gap:10px !important;\n      border-radius:12px !important;\n    }\n    .jacq-qb__text{font-size:13px !important;line-height:1.35 !important;}\n    .jacq-qb__arrow svg{width:13px !important;height:13px !important;}\n  }\n</style>\n<a class=\"jacq-qb\" href=\"/pages/quiz\">\n  <span class=\"jacq-qb__text\">Welke bril past bij jou? <span class=\"jacq-qb__cta\">Doe de 6-vragen quiz</span></span>\n  <span class=\"jacq-qb__arrow\" aria-hidden=\"true\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M13 5l7 7-7 7\"/></svg>\n  </span>\n</a>",
