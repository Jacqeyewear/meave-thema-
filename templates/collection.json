        "liquid": "<style>\n  .meave-promo-banner-card{\n    display:grid;\n    grid-template-columns:auto 1fr;\n    column-gap:clamp(14px,3vw,56px);\n    row-gap:3px;\n    width:100%;\n    padding:18px clamp(20px,3vw,44px);\n    background:#ffffff;\n    border:0.5px solid rgba(0,0,0,0.06);\n    border-radius:20px;\n    box-shadow:0 0.5px 1px rgba(0,0,0,0.03),0 6px 16px -8px rgba(0,0,0,0.08),0 14px 32px -12px rgba(0,0,0,0.07);\n    box-sizing:border-box;\n    font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',Helvetica,Arial,sans-serif;\n    -webkit-font-smoothing:antialiased;\n    align-items:center;\n  }\n  .meave-promo-banner-card__title{\n    grid-column:1;\n    grid-row:1;\n    font-size:clamp(20px,2.4vw,28px);\n    font-weight:600;\n    color:#1d1d1f;\n    line-height:1.05;\n    letter-spacing:-0.03em;\n    margin:0;\n  }\n  .meave-promo-banner-card__subtitle{\n    grid-column:1;\n    grid-row:2;\n    font-size:clamp(12px,1.1vw,15px);\n    color:#86868b;\n    font-weight:400;\n    line-height:1.3;\n    letter-spacing:-0.01em;\n    margin:0;\n  }\n  .meave-promo-banner-card__usps{\n    grid-column:2;\n    grid-row:1 / span 2;\n    align-self:center;\n    justify-self:end;\n    display:flex;\n    align-items:center;\n    gap:clamp(14px,2vw,32px);\n    list-style:none;\n    padding:0;\n    margin:0;\n  }\n  .meave-promo-banner-card__usp{\n    display:flex;\n    align-items:center;\n    gap:10px;\n    font-size:clamp(12px,0.9vw,13.5px);\n    color:#1d1d1f;\n    font-weight:500;\n    letter-spacing:-0.01em;\n    line-height:1.2;\n    white-space:nowrap;\n  }\n  .meave-promo-banner-card__icon{\n    flex-shrink:0;\n    width:34px;\n    height:34px;\n    padding:7px;\n    border-radius:999px;\n    background:#f5f5f7;\n    color:#1d1d1f;\n    box-sizing:border-box;\n  }\n  @media (max-width:1100px){\n    .meave-promo-banner-card__usp:nth-child(n+4){display:none;}\n  }\n  @media (max-width:900px){\n    .meave-promo-banner-card__usp:nth-child(n+3){display:none;}\n  }\n  @media (max-width:768px){\n    .meave-promo-banner-card{padding:16px 20px;border-radius:18px;column-gap:12px;}\n    .meave-promo-banner-card__usps{display:none;}\n    .meave-promo-banner-card__title{font-size:22px;}\n    .meave-promo-banner-card__subtitle{font-size:13px;}\n  }\n</style>\n<div class=\"meave-promo-banner-card\" aria-label=\"Buy 4, get 2 free\">\n  <h2 class=\"meave-promo-banner-card__title\">Buy 4, get 2 free</h2>\n  <p class=\"meave-promo-banner-card__subtitle\">On every light, all collections</p>\n  <ul class=\"meave-promo-banner-card__usps\">\n    <li class=\"meave-promo-banner-card__usp\">\n      <svg class=\"meave-promo-banner-card__icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M21 12a9 9 0 1 1-3-6.7L21 8\"/><path d=\"M21 3v5h-5\"/></svg>\n      <span>30-day returns</span>\n    </li>\n    <li class=\"meave-promo-banner-card__usp\">\n      <svg class=\"meave-promo-banner-card__icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M12 3 5 6v5c0 4.2 2.9 7.5 7 9 4.1-1.5 7-4.8 7-9V6z\"/><path d=\"m9 12 2 2 4-4.5\"/></svg>\n      <span>2-year warranty</span>\n    </li>\n    <li class=\"meave-promo-banner-card__usp\">\n      <svg class=\"meave-promo-banner-card__icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M9 18h6\"/><path d=\"M10 21h4\"/><path d=\"M12 3a6 6 0 0 1 4 10.5c-.6.6-1 1.3-1 2.1H9c0-.8-.4-1.5-1-2.1A6 6 0 0 1 12 3z\"/></svg>\n      <span>Wireless &amp; tool-free</span>\n    </li>\n    <li class=\"meave-promo-banner-card__usp\">\n      <svg class=\"meave-promo-banner-card__icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"1\" y=\"6\" width=\"14\" height=\"10\" rx=\"1.5\"/><path d=\"M15 9h4l3 3v4h-7\"/><circle cx=\"5.5\" cy=\"18\" r=\"1.6\"/><circle cx=\"17.5\" cy=\"18\" r=\"1.6\"/></svg>\n      <span>Free UK delivery</span>\n    </li>\n  </ul>\n</div>",
