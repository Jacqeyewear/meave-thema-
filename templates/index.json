19.92 7.00,20.66 6.20,17.80 3.34,17.00 4.08,14.12 2.00,12.00 4.08,9.88 3.34,7.00 6.20,6.20 7.00,3.34 9.88,4.08\"\n      />\n      <path\n        d=\"M8.4 12.2 10.6 14.4 15.8 9.4\"\n        fill=\"none\"\n        stroke=\"black\"\n        stroke-width=\"2.1\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n      />\n    </mask>\n  </defs>\n  <rect width=\"24\" height=\"24\" fill=\"currentColor\" mask=\"url(#jacq-seal-mask-{{ jacq_uid }})\"></rect>\n</svg>\n{% endcapture %}\n\n<div class=\"jacq-benefits\" role=\"list\">\n  <!-- 1: 2 jaar garantie (altijd zichtbaar) -->\n  <div class=\"jacq-benefit\" role=\"listitem\">\n    {{ jacq_seal_icon }}\n    2 jaar garantie\n  </div>\n\n  <!-- 2: Niet goed, geld terug (desktop only) -->\n  <div class=\"jacq-benefit is-refund\" role=\"listitem\">\n    {{ jacq_seal_icon }}\n    Niet goed, geld terug!\n  </div>\n\n  <!-- 3: Gratis verzending (mobile + desktop) -->\n  <div class=\"jacq-benefit is-third\" role=\"listitem\">\n    {{ jacq_seal_icon }}\n    Gratis verzending\n  </div>\n</div>"
