      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  #meave-reviews *, #meave-reviews *::before, #meave-reviews *::after { box-sizing: border-box; }\n\n  #meave-reviews {\n    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    background: #ffffff;\n    color: #1D1D1F;\n    padding: 56px 0;\n    overflow: hidden;\n    opacity: 0;\n    transform: translateY(20px);\n    transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1);\n  }\n  #meave-reviews.is-visible { opacity: 1; transform: translateY(0); }\n\n  .mrev-header { text-align: center; margin-bottom: 32px; padding: 0 20px; }\n  .mrev-title {\n    font-size: 28px; font-weight: 700;\n    letter-spacing: -0.035em; line-height: 1.1; color: #1D1D1F; margin: 0;\n  }\n  .mrev-title b { color: #C18C1E; font-weight: 700; }\n  .mrev-sub {\n    font-size: 15px; color: #86868b; margin: 10px 0 0;\n    font-weight: 400; letter-spacing: -0.01em;\n  }\n\n  .mrev-viewport {\n    width: 100vw;\n    margin-left: calc(50% - 50vw);\n    overflow-x: auto;\n    overflow-y: hidden;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    padding: 30px 0 34px;\n  }\n  .mrev-viewport::-webkit-scrollbar { display: none; }\n  .mrev-viewport { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .mrev-track {\n    display: flex;\n    gap: 16px;\n    padding: 0 calc(50vw - 165px);\n    align-items: center;\n  }\n\n  .mrev-card {\n    flex: 0 0 330px;\n    scroll-snap-align: center;\n    background: #ffffff;\n    border: 0.5px solid rgba(0,0,0,0.05);\n    border-radius: 22px;\n    padding: 30px 26px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    box-shadow:\n      0 0.5px 1px rgba(0,0,0,0.03),\n      0 6px 16px -8px rgba(0,0,0,0.07),\n      0 12px 28px -12px rgba(0,0,0,0.06);\n    transform: scale(0.94);\n    opacity: 0.78;\n    transition: transform 0.5s cubic-bezier(0.22,1,0.36,1), opacity 0.5s cubic-bezier(0.22,1,0.36,1), box-shadow 0.5s cubic-bezier(0.22,1,0.36,1);\n  }\n  .mrev-card.is-center {\n    transform: scale(1);\n    opacity: 1;\n    box-shadow:\n      0 1px 2px rgba(0,0,0,0.04),\n      0 10px 24px -8px rgba(0,0,0,0.1),\n      0 24px 48px -16px rgba(0,0,0,0.12);\n  }\n\n  .mrev-stars {\n    display: inline-flex;\n    gap: 3px;\n    margin-bottom: 16px;\n  }\n  .mrev-stars svg { width: 16px; height: 16px; display: block; }\n\n  .mrev-text {\n    font-size: 14.5px;\n    line-height: 1.6;\n    color: #1D1D1F;\n    letter-spacing: -0.01em;\n    margin: 0 0 22px;\n    font-weight: 400;\n  }\n\n  .mrev-person { display: flex; flex-direction: column; align-items: center; gap: 11px; }\n  .mrev-avatar {\n    width: 52px; height: 52px; border-radius: 999px;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 17px; font-weight: 600; letter-spacing: 0.01em;\n    color: #ffffff;\n    background: linear-gradient(135deg, #F7DA8A 0%, #E0A93B 100%);\n    box-shadow: 0 2px 8px rgba(0,113,227,0.28);\n  }\n\n  .mrev-person-info { display: flex; flex-direction: column; align-items: center; gap: 2px; }\n  .mrev-name {\n    display: inline-flex; align-items: center; gap: 5px;\n    font-size: 12px; font-weight: 600; letter-spacing: 0.06em;\n    text-transform: uppercase; color: #1D1D1F;\n  }\n  .mrev-verified-badge {\n    width: 13px; height: 13px; flex-shrink: 0;\n    display: inline-flex; align-items: center; justify-content: center;\n  }\n  .mrev-loc {\n    font-size: 10.5px; font-weight: 500; letter-spacing: 0.02em; color: #C18C1E;\n  }\n\n  .mrev-dots {\n    display: flex; justify-content: center; align-items: center;\n    gap: 7px; margin-top: 22px;\n  }\n  .mrev-dot {\n    width: 7px; height: 7px; border-radius: 999px; border: none; padding: 0;\n    background: #d2d2d7; cursor: pointer;\n    transition: background-color 0.25s ease, transform 0.25s ease, width 0.25s ease;\n  }\n  .mrev-dot.is-active {\n    background: #0071e3;\n    width: 20px;\n  }\n\n  @media (min-width: 768px) {\n    #meave-reviews { padding: 80px 0; }\n    .mrev-header { margin-bottom: 44px; }\n    .mrev-title { font-size: 48px; }\n    .mrev-sub { font-size: 18px; }\n    .mrev-track { padding: 0 calc(50vw - 230px); gap: 22px; }\n    .mrev-card { flex: 0 0 440px; padding: 38px 40px; border-radius: 26px; }\n    .mrev-text { font-size: 16px; line-height: 1.65; }\n    .mrev-stars svg { width: 17px; height: 17px; }\n    .mrev-avatar { width: 58px; height: 58px; font-size: 19px; }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    *, *::before, *::after { transition: none !important; }\n  }\n</style>\n\n<section id=\"meave-reviews\" data-meave-reviews>\n  <svg width=\"0\" height=\"0\" style=\"position:absolute\" aria-hidden=\"true\">\n    <defs>\n      <linearGradient id=\"meaveStarGold\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n        <stop offset=\"0%\" stop-color=\"#F4CE6A\"/>\n        <stop offset=\"100%\" stop-color=\"#E0A93B\"/>\n      </linearGradient>\n    </defs>\n  </svg>\n\n  <div class=\"mrev-header\">\n    <h2 class=\"mrev-title\">Loved in <b>75,000+</b> homes</h2>\n    <p class=\"mrev-sub\">Real reviews from real MEAVE customers.</p>\n  </div>\n\n  <div class=\"mrev-viewport\" id=\"mrevViewport\">\n    <div class=\"mrev-track\" id=\"mrevTrack\">\n\n      <article class=\"mrev-card\">\n        <span class=\"mrev-stars\" aria-label=\"5 out of 5 stars\">\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n        </span>\n        <p class=\"mrev-text\">Really pleased with these. Warm light and they went up in a few minutes without any fuss. The hallway feels much cosier now.</p>\n        <div class=\"mrev-person\">\n          <div class=\"mrev-avatar\" aria-hidden=\"true\">SH</div>\n          <div class=\"mrev-person-info\">\n            <div class=\"mrev-name\">Susan H.\n              <span class=\"mrev-verified-badge\"><svg viewBox=\"0 0 24 24\" fill=\"#3897F0\"><path d=\"M12 1l2.4 2.1 3.2-.3 1.3 2.9 2.9 1.3-.3 3.2L23.6 12l-2.1 2.4.3 3.2-2.9 1.3-1.3 2.9-3.2-.3L12 23.6l-2.4-2.1-3.2.3-1.3-2.9-2.9-1.3.3-3.2L.4 12l2.1-2.4-.3-3.2 2.9-1.3 1.3-2.9 3.2.3z\"/><path d=\"M10.3 14.9l-2.5-2.5-1.3 1.3 3.8 3.8 6.7-6.7-1.3-1.3z\" fill=\"#fff\"/></svg></span>\n            </div>\n            <div class=\"mrev-loc\">Manchester</div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mrev-card\">\n        <span class=\"mrev-stars\" aria-label=\"5 out of 5 stars\">\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n        </span>\n        <p class=\"mrev-text\">We rent, so not being able to drill was a problem until I found these. They look fitted but come off cleanly. Handy for us.</p>\n        <div class=\"mrev-person\">\n          <div class=\"mrev-avatar\" aria-hidden=\"true\">PD</div>\n          <div class=\"mrev-person-info\">\n            <div class=\"mrev-name\">Paul D.\n              <span class=\"mrev-verified-badge\"><svg viewBox=\"0 0 24 24\" fill=\"#3897F0\"><path d=\"M12 1l2.4 2.1 3.2-.3 1.3 2.9 2.9 1.3-.3 3.2L23.6 12l-2.1 2.4.3 3.2-2.9 1.3-1.3 2.9-3.2-.3L12 23.6l-2.4-2.1-3.2.3-1.3-2.9-2.9-1.3.3-3.2L.4 12l2.1-2.4-.3-3.2 2.9-1.3 1.3-2.9 3.2.3z\"/><path d=\"M10.3 14.9l-2.5-2.5-1.3 1.3 3.8 3.8 6.7-6.7-1.3-1.3z\" fill=\"#fff\"/></svg></span>\n            </div>\n            <div class=\"mrev-loc\">London</div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mrev-card\">\n        <span class=\"mrev-stars\" aria-label=\"5 out of 5 stars\">\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"#d2d2d7\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n        </span>\n        <p class=\"mrev-text\">Good for reading in bed and the battery lasts well. Took a little while to arrive but happy with it. Would buy again.</p>\n        <div class=\"mrev-person\">\n          <div class=\"mrev-avatar\" aria-hidden=\"true\">CW</div>\n          <div class=\"mrev-person-info\">\n            <div class=\"mrev-name\">Carol W.\n              <span class=\"mrev-verified-badge\"><svg viewBox=\"0 0 24 24\" fill=\"#3897F0\"><path d=\"M12 1l2.4 2.1 3.2-.3 1.3 2.9 2.9 1.3-.3 3.2L23.6 12l-2.1 2.4.3 3.2-2.9 1.3-1.3 2.9-3.2-.3L12 23.6l-2.4-2.1-3.2.3-1.3-2.9-2.9-1.3.3-3.2L.4 12l2.1-2.4-.3-3.2 2.9-1.3 1.3-2.9 3.2.3z\"/><path d=\"M10.3 14.9l-2.5-2.5-1.3 1.3 3.8 3.8 6.7-6.7-1.3-1.3z\" fill=\"#fff\"/></svg></span>\n            </div>\n            <div class=\"mrev-loc\">Bristol</div>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mrev-card\">\n        <span class=\"mrev-stars\" aria-label=\"5 out of 5 stars\">\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n          <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveStarGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n        </span>\n        <p class=\"mrev-text\">Put two by the bathroom mirror. Look smart and no electrician needed, which saved a fair bit. Pleased with them.</p>\n        <div class=\"mrev-person\">\n          <div class=\"mrev-avatar\" aria-hidden=\"true\">AM</div>\n          <div class=\"mrev-person-info\">\n            <div class=\"mrev-name\">Andrew M.\n              <span class=\"mrev-verified-badge\"><svg viewBox=\"0 0 24 24\" fill=\"#3897F0\"><path d=\"M12 1l2.4 2.1 3.2-.3 1.3 2.9 2.9 1.3-.3 3.2L23.6 12l-2.1 2.4.3 3.2-2.9 1.3-1.3 2.9-3.2-.3L12 23.6l-2.4-2.1-3.2.3-1.3-2.9-2.9-1.3.3-3.2L.4 12l2.1-2.4-.3-3.2 2.9-1.3 1.3-2.9 3.2.3z\"/><path d=\"M10.3 14.9l-2.5-2.5-1.3 1.3 3.8 3.8 6.7-6.7-1.3-1.3z\" fill=\"#fff\"/></svg></span>\n            </div>\n            <div class=\"mrev-loc\">Leeds</div>\n          </div>\n        </div>\n      </article>\n\n    </div>\n  </div>\n\n  <div class=\"mrev-dots\" id=\"mrevDots\"></div>\n</section>\n\n<script>\n(function () {\n  var root = document.querySelector('[data-meave-reviews]');\n  if (!root) return;\n\n  if ('IntersectionObserver' in window) {\n    var fade = new IntersectionObserver(function (entries) {\n      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); fade.unobserve(e.target); } });\n    }, { threshold: 0.08 });\n    fade.observe(root);\n  } else { root.classList.add('is-visible'); }\n\n  var viewport = root.querySelector('#mrevViewport');\n  var track = root.querySelector('#mrevTrack');\n  var cards = Array.prototype.slice.call(track.querySelectorAll('.mrev-card'));\n  var dotsWrap = root.querySelector('#mrevDots');\n\n  cards.forEach(function (_, i) {\n    var b = document.createElement('button');\n    b.className = 'mrev-dot' + (i === 0 ? ' is-active' : '');\n    b.setAttribute('aria-label', 'Go to review ' + (i + 1));\n    b.addEventListener('click', function () {\n      var c = cards[i];\n      viewport.scrollTo({ left: c.offsetLeft - (viewport.clientWidth - c.offsetWidth) / 2, behavior: 'smooth' });\n    });\n    dotsWrap.appendChild(b);\n  });\n  var dots = Array.prototype.slice.call(dotsWrap.children);\n\n  function update() {\n    var center = viewport.scrollLeft + viewport.clientWidth / 2;\n    var active = 0, min = Infinity;\n    cards.forEach(function (c, i) {\n      var cc = c.offsetLeft + c.offsetWidth / 2;\n      var d = Math.abs(cc - center);\n      if (d < min) { min = d; active = i; }\n    });\n    cards.forEach(function (c, i) { c.classList.toggle('is-center', i === active); });\n    dots.forEach(function (d, i) { d.classList.toggle('is-active', i === active); });\n  }\n\n  var ticking = false;\n  viewport.addEventListener('scroll', function () {\n    if (!ticking) { window.requestAnimationFrame(function () { update(); ticking = false; }); ticking = true; }\n  }, { passive: true });\n\n  window.addEventListener('resize', update);\n\n  requestAnimationFrame(function () {\n    var startIndex = window.innerWidth >= 768 ? Math.floor(cards.length / 2) : 0;\n    var c = cards[startIndex];\n    viewport.scrollLeft = c.offsetLeft - (viewport.clientWidth - c.offsetWidth) / 2;\n    update();\n  });\n})();\n</script>",
