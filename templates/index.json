      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  .meave-usp-bar {\n    background: #1d1d1f;\n    padding: 0;\n    margin: 0;\n    width: 100vw;\n    margin-left: calc(-50vw + 50%);\n    font-family: 'HelveticaNow-Regular', 'Helvetica Now Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;\n  }\n\n  .meave-usp-inner {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    max-width: none;\n    margin: 0 auto;\n    padding: 0 40px;\n  }\n\n  .meave-usp-item {\n    flex: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 16px 20px;\n    position: relative;\n  }\n\n  .meave-usp-item + .meave-usp-item::before {\n    content: '';\n    position: absolute;\n    left: 0;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 1px;\n    height: 18px;\n    background: rgba(255,255,255,0.2);\n  }\n\n  .meave-usp-text {\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: -0.01em;\n    color: rgba(255,255,255,0.88);\n    white-space: nowrap;\n  }\n\n  .meave-usp-mobile {\n    display: none;\n  }\n\n  @media (max-width: 767px) {\n    .meave-usp-inner {\n      display: none;\n    }\n\n    .meave-usp-mobile {\n      display: block;\n      text-align: center;\n      padding: 13px 20px;\n    }\n\n    .meave-usp-mobile-text {\n      font-size: 13px;\n      font-weight: 600;\n      letter-spacing: -0.01em;\n      color: rgba(255,255,255,0.88);\n      white-space: nowrap;\n    }\n  }\n\n  @media (min-width: 1024px) {\n    .meave-usp-item {\n      padding: 18px 24px;\n    }\n\n    .meave-usp-text {\n      font-size: 14px;\n    }\n  }\n</style>\n\n<div class=\"meave-usp-bar\">\n  <div class=\"meave-usp-inner\">\n    <div class=\"meave-usp-item\">\n      <span class=\"meave-usp-text\">Free Delivery</span>\n    </div>\n\n    <div class=\"meave-usp-item\">\n      <span class=\"meave-usp-text\">30-Day Returns</span>\n    </div>\n\n    <div class=\"meave-usp-item\">\n      <span class=\"meave-usp-text\">2-Year Warranty</span>\n    </div>\n\n    <div class=\"meave-usp-item\">\n      <span class=\"meave-usp-text\">Tracked Shipping</span>\n    </div>\n  </div>\n\n  <div class=\"meave-usp-mobile\">\n    <span class=\"meave-usp-mobile-text\">Free Delivery · 30-Day Returns · Tracked Shipping</span>\n  </div>\n</div>",
