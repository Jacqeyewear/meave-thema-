isplay:inline !important; }\n  }\n\n  /* ✅ alleen link reset + klikbaar, verder exact hetzelfde */\n  a.jacq-rating-pill{\n    text-decoration:none;\n    color:inherit;\n    cursor:pointer;\n    -webkit-tap-highlight-color: transparent;\n  }\n  a.jacq-rating-pill:focus-visible{\n    outline:none;\n  }\n</style>\n\n<a\n  class=\"jacq-rating-pill\"\n  href=\"https://nl.trustpilot.com/review/jacqeyewear.nl\"\n  target=\"_blank\"\n  rel=\"noopener noreferrer\"\n  role=\"img\"\n  aria-label=\"Beoordeeld met een 4.3/5 op Trustpilot. lees wat onze klanten zeggen.\"\n>\n  <span class=\"jacq-rating-stars\" aria-hidden=\"true\">\n    {% for i in (1..4) %}\n      <span class=\"jacq-star-box\">\n        <svg class=\"jacq-star\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n          <path fill=\"#fff\" d=\"M12 17.3 6.2 20.7l1.6-6.7L2.6 9.7l6.9-.6L12 2.8l2.5 6.3 6.9.6-5.2 4.3 1.6 6.7z\"/>\n        </svg>\n      </span>\n    {% endfor %}\n\n    <span class=\"jacq-star-box jacq-star-box--p20\">\n      <svg class=\"jacq-star\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n        <path fill=\"#fff\" d=\"M12 17.3 6.2 20.7l1.6-6.7L2.6 9.7l6.9-.6L12 2.8l2.5 6.3 6.9.6-5.2 4.3 1.6 6.7z\"/>\n      </svg>\n    </span>\n  </span>\n\n  <span class=\"jacq-rating-text\">\n    <span class=\"jacq-mobile\">Beoordeeld met een 4.3/5 op Trustpilot </span>\n    <span class=\"jacq-desktop\">Beoordeeld met een 4.3/5 op <span class=\"jacq-trustpilot\">Trustpilot</span> · lees wat onze klanten zeggen</span>\n  </span>\n</a>"
          }
