    "custom_liquid_jGLXh7": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  #meave-faq *, #meave-faq *::before, #meave-faq *::after { box-sizing: border-box; }\n\n  #meave-faq {\n    font-family: inherit;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    background: #ffffff;\n    color: #1D1D1F;\n    padding: 56px 0;\n    opacity: 0;\n    transform: translateY(20px);\n    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n\n  #meave-faq.is-visible { opacity: 1; transform: translateY(0); }\n\n  .mfaq-wrap { max-width: none; margin: 0 auto; }\n\n  .mfaq-header { text-align: center; margin-bottom: 32px; }\n  .mfaq-title {\n    font-size: 28px; font-weight: 500; letter-spacing: -0.025em;\n    line-height: 1.1; color: #1D1D1F; margin: 0;\n  }\n  .mfaq-sub {\n    font-size: 16px; color: #6e6e73; margin: 10px 0 0;\n    font-weight: 400; letter-spacing: -0.01em;\n  }\n\n  .mfaq-body { display: flex; flex-direction: column; gap: 12px; }\n\n  .mfaq-nav {\n    display: flex; gap: 0; background: #F5F5F7;\n    border-radius: 12px; padding: 3px; position: relative;\n  }\n\n  .mfaq-nav-btn {\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\n    gap: 4px; flex: 1; padding: 10px 4px;\n    background: transparent; border: none; cursor: pointer; border-radius: 10px;\n    font-family: inherit; font-size: 10px; font-weight: 500;\n    color: #86868b; letter-spacing: 0; text-align: center;\n    transition: color 0.4s cubic-bezier(0.22, 1, 0.36, 1), background 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);\n    position: relative; z-index: 1; -webkit-tap-highlight-color: transparent;\n  }\n  .mfaq-nav-btn:active { transform: scale(0.95); }\n  .mfaq-nav-btn.is-active {\n    color: #1D1D1F; font-weight: 600; background: #fff;\n    box-shadow: 0 0.5px 1px rgba(0,0,0,0.04), 0 6px 14px -6px rgba(0,0,0,0.1);\n  }\n\n  .mfaq-nav-icon {\n    width: 32px; height: 32px; border-radius: 8px; background: transparent;\n    display: flex; align-items: center; justify-content: center; flex: 0 0 32px;\n    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .mfaq-nav-icon svg { width: 17px; height: 17px; transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1); }\n  .mfaq-nav-btn.is-active .mfaq-nav-icon { background: rgba(0,113,227,0.12); transform: scale(1.08); }\n  .mfaq-nav-btn.is-active .mfaq-nav-icon svg { stroke: #0071e3; }\n  .mfaq-nav-label { transition: color 0.4s ease; }\n\n  .mfaq-content {\n    background: #fff; border-radius: 20px; padding: 24px 20px;\n    box-shadow: 0 0.5px 1px rgba(0,0,0,0.03), 0 6px 16px -8px rgba(0,0,0,0.08), 0 14px 32px -12px rgba(0,0,0,0.07);\n  }\n\n  .mfaq-panel { display: none; opacity: 0; }\n  .mfaq-panel.is-active { display: block; animation: mfaqIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards; }\n  .mfaq-panel.is-leaving { display: block; animation: mfaqOut 0.2s cubic-bezier(0.4, 0, 1, 1) forwards; }\n  @keyframes mfaqIn {\n    0% { opacity: 0; transform: translateY(8px) scale(0.995); }\n    40% { opacity: 1; }\n    100% { opacity: 1; transform: translateY(0) scale(1); }\n  }\n  @keyframes mfaqOut {\n    0% { opacity: 1; transform: translateY(0); }\n    100% { opacity: 0; transform: translateY(-4px); }\n  }\n\n  .mfaq-cat-head { margin-bottom: 12px; }\n  .mfaq-cat-title {\n    font-size: 20px; font-weight: 600; letter-spacing: -0.025em;\n    color: #1D1D1F; margin: 0 0 2px;\n  }\n  .mfaq-cat-desc {\n    font-size: 13px; color: #aeaeb2; margin: 0; font-weight: 400;\n    letter-spacing: -0.005em; line-height: 1.45;\n  }\n\n  .mfaq-item { border-top: 1px solid #f0f0f2; }\n  .mfaq-item:first-child { border-top: none; }\n  .mfaq-item:last-child { margin-bottom: 0; }\n\n  .mfaq-trigger {\n    width: 100%; background: transparent; border: none; cursor: pointer;\n    display: flex; align-items: center; justify-content: space-between; gap: 16px;\n    padding: 16px 0; text-align: left; font-family: inherit;\n  }\n  .mfaq-q {\n    font-size: 14px; font-weight: 500; color: #1D1D1F;\n    letter-spacing: -0.01em; line-height: 1.4; transition: color 0.25s ease;\n  }\n  .mfaq-trigger:hover .mfaq-q { color: #0071e3; }\n\n  .mfaq-plus {\n    width: 22px; height: 22px; flex: 0 0 22px; border-radius: 50%;\n    background: #F5F5F7; display: flex; align-items: center; justify-content: center;\n    transition: background 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.6s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .mfaq-plus svg {\n    width: 12px; height: 12px; stroke: #c7c7cc; stroke-width: 1.8;\n    stroke-linecap: round; fill: none; transition: stroke 0.4s ease;\n  }\n  .mfaq-trigger:hover .mfaq-plus { background: rgba(0,113,227,0.10); }\n  .mfaq-trigger:hover .mfaq-plus svg { stroke: #0071e3; }\n  .mfaq-item.is-open .mfaq-plus {\n    background: #0071e3;\n    transform: rotate(45deg); box-shadow: 0 2px 8px rgba(0,113,227,0.32);\n  }\n  .mfaq-item.is-open .mfaq-plus svg { stroke: #ffffff; }\n\n  .mfaq-answer { height: 0; overflow: hidden; transition: height 700ms cubic-bezier(0.22, 1, 0.36, 1); }\n  .mfaq-answer-inner {\n    padding: 0 0 20px 0; font-size: 13px; line-height: 1.75; color: #6e6e73;\n    letter-spacing: -0.005em; max-width: 100%; word-break: break-word;\n    opacity: 0; transform: translateY(-3px);\n    transition: opacity 600ms cubic-bezier(0.22, 1, 0.36, 1) 50ms, transform 700ms cubic-bezier(0.22, 1, 0.36, 1);\n  }\n  .mfaq-item.is-open .mfaq-answer-inner { opacity: 1; transform: translateY(0); }\n  .mfaq-answer-inner strong { color: #1D1D1F; font-weight: 600; }\n\n  .mfaq-footer {\n    margin-top: 16px; background: #fff; border-radius: 16px; padding: 20px 24px;\n    display: flex; align-items: center; justify-content: space-between; gap: 16px;\n    box-shadow: 0 0.5px 1px rgba(0,0,0,0.04), 0 6px 16px -8px rgba(0,0,0,0.09);\n  }\n  .mfaq-footer-left { font-size: 14px; font-weight: 500; color: #1D1D1F; letter-spacing: -0.01em; }\n  .mfaq-footer-left p { margin: 2px 0 0; font-size: 12px; font-weight: 400; color: #86868b; }\n  .mfaq-footer-links { display: flex; gap: 8px; flex-shrink: 0; }\n  .mfaq-footer-link {\n    display: inline-flex; align-items: center; gap: 6px; padding: 10px 18px;\n    border-radius: 980px; font-family: inherit; font-size: 13px; font-weight: 500;\n    letter-spacing: -0.01em; text-decoration: none; white-space: nowrap;\n    border: none; cursor: pointer; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .mfaq-footer-link svg { width: 14px; height: 14px; flex-shrink: 0; }\n  .mfaq-footer-link--contact {\n    background: #0071e3; color: #ffffff;\n    box-shadow: 0 2px 6px rgba(0,113,227,0.28);\n  }\n  .mfaq-footer-link--contact:hover {\n    transform: translateY(-1px); box-shadow: 0 6px 16px rgba(0,113,227,0.4);\n  }\n  .mfaq-footer-link--contact:active { transform: scale(0.97); }\n\n  @media (max-width: 767px) {\n    .mfaq-footer { flex-direction: column; text-align: center; gap: 12px; padding: 18px 20px; }\n    .mfaq-footer-left p { display: none; }\n    .mfaq-footer-links { width: 100%; }\n    .mfaq-footer-link { flex: 1; justify-content: center; padding: 12px 16px; }\n    .mfaq-nav-label { font-size: 0; line-height: 0; }\n    .mfaq-nav-label::after { content: attr(data-short); font-size: 11px; line-height: 1.2; }\n  }\n\n  @media (min-width: 768px) {\n    #meave-faq { padding: 80px 0; }\n    .mfaq-header { margin-bottom: 48px; }\n    .mfaq-title { font-size: 44px; }\n    .mfaq-sub { font-size: 17px; }\n\n    .mfaq-body { display: grid; grid-template-columns: 240px 1fr; gap: 0 40px; align-items: start; }\n\n    .mfaq-nav {\n      display: flex; flex-direction: column; gap: 4px;\n      position: sticky; top: 32px; background: transparent; padding: 0; border-radius: 0;\n    }\n    .mfaq-nav-btn {\n      flex-direction: row; align-items: center; justify-content: flex-start; gap: 14px; padding: 12px 16px;\n      border-radius: 14px; font-size: 14px; text-align: left; box-shadow: none; background: transparent;\n    }\n    .mfaq-nav-btn:hover { background: #F5F5F7; box-shadow: none; }\n    .mfaq-nav-btn.is-active { background: #F5F5F7; color: #1D1D1F; box-shadow: none; }\n    .mfaq-nav-icon { width: 36px; height: 36px; border-radius: 10px; flex: 0 0 36px; transform: none; }\n    .mfaq-nav-icon svg { width: 17px; height: 17px; }\n    .mfaq-nav-btn.is-active .mfaq-nav-icon {\n      background: #0071e3;\n      box-shadow: 0 2px 8px rgba(0,113,227,0.28); transform: none;\n    }\n    .mfaq-nav-btn.is-active .mfaq-nav-icon svg { stroke: #ffffff; }\n    .mfaq-nav-label { font-size: 14px; line-height: normal; }\n\n    .mfaq-content { padding: 36px 40px; border-radius: 24px; }\n    .mfaq-cat-title { font-size: 24px; }\n    .mfaq-cat-desc { font-size: 14px; }\n    .mfaq-q { font-size: 16px; }\n    .mfaq-answer-inner { font-size: 14px; max-width: none; padding: 0 0 24px 0; }\n    .mfaq-plus { width: 26px; height: 26px; flex: 0 0 26px; }\n    .mfaq-plus svg { width: 13px; height: 13px; }\n\n    .mfaq-footer { margin-top: 20px; padding: 24px 32px; border-radius: 20px; }\n    .mfaq-footer-left { font-size: 15px; }\n    .mfaq-footer-left p { font-size: 13px; }\n  }\n\n  @media (min-width: 1200px) {\n    .mfaq-body { grid-template-columns: 280px 1fr; gap: 0 56px; }\n    .mfaq-nav-btn { padding: 14px 18px; font-size: 15px; }\n    .mfaq-content { padding: 40px 48px; }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    *, *::before, *::after { transition: none !important; animation: none !important; }\n  }\n</style>\n\n<section id=\"meave-faq\" data-meave-faq>\n  <div class=\"mfaq-wrap\">\n\n    <div class=\"mfaq-header\">\n      <h2 class=\"mfaq-title\">Frequently asked questions</h2>\n      <p class=\"mfaq-sub\">Everything you need to know, in plain words.</p>\n    </div>\n\n    <div class=\"mfaq-body\">\n\n      <nav class=\"mfaq-nav\" aria-label=\"FAQ categories\">\n        <button class=\"mfaq-nav-btn is-active\" data-target=\"product\" type=\"button\">\n          <span class=\"mfaq-nav-icon\">\n            <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#86868b\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M6 12h4\"/><path d=\"M6.5 14h3\"/><path d=\"M8 2a4 4 0 0 1 2.5 7.1c-.4.4-.6.9-.6 1.4H6.1c0-.5-.2-1-.6-1.4A4 4 0 0 1 8 2z\"/></svg>\n          </span>\n          <span class=\"mfaq-nav-label\" data-short=\"Product\">Product &amp; setup</span>\n        </button>\n\n        <button class=\"mfaq-nav-btn\" data-target=\"shipping\" type=\"button\">\n          <span class=\"mfaq-nav-icon\">\n            <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#86868b\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"1\" y=\"4\" width=\"9\" height=\"7\" rx=\"1\"/><path d=\"M10 6.5l3.5 1.5V11.5h-3.5\"/><circle cx=\"3.5\" cy=\"12\" r=\"1.2\"/><circle cx=\"11.5\" cy=\"12\" r=\"1.2\"/></svg>\n          </span>\n          <span class=\"mfaq-nav-label\" data-short=\"Shipping\">Shipping &amp; delivery</span>\n        </button>\n\n        <button class=\"mfaq-nav-btn\" data-target=\"returns\" type=\"button\">\n          <span class=\"mfaq-nav-icon\">\n            <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#86868b\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 8a5 5 0 1 1 1.5 3.5\"/><path d=\"M3 5v3h3\"/></svg>\n          </span>\n          <span class=\"mfaq-nav-label\" data-short=\"Returns\">Returns &amp; warranty</span>\n        </button>\n\n        <button class=\"mfaq-nav-btn\" data-target=\"orders\" type=\"button\">\n          <span class=\"mfaq-nav-icon\">\n            <svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"#86868b\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"2\" width=\"10\" height=\"12\" rx=\"1.5\"/><path d=\"M6 5.5h4M6 8h4M6 10.5h2\"/></svg>\n          </span>\n          <span class=\"mfaq-nav-label\" data-short=\"Support\">Orders &amp; support</span>\n        </button>\n      </nav>\n\n      <div class=\"mfaq-content\">\n\n        <div class=\"mfaq-panel is-active\" data-panel=\"product\">\n          <div class=\"mfaq-cat-head\">\n            <h3 class=\"mfaq-cat-title\">Product &amp; setup</h3>\n            <p class=\"mfaq-cat-desc\">What you get and how to set it up.</p>\n          </div>\n          <div class=\"mfaq-list\">\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Are the lights wireless?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Yes. Every light runs on a rechargeable bulb, so there's no wiring and no outlet needed. Charge it, mount it, done.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Do I need a professional to install them?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">No. Each light comes with <strong>3M adhesive pads</strong> for a tool-free setup. Screws are also included if you'd prefer a permanent fix. It takes a couple of minutes.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Can I control the brightness and colour?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Yes. The included remote lets you adjust brightness, switch colour temperature and set a timer.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How long does the battery last?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Several days on a single charge with normal use. Recharge with any USB-C cable. Fully charge before first use for the best battery life.</div></div></div>\n          </div>\n        </div>\n\n        <div class=\"mfaq-panel\" data-panel=\"shipping\">\n          <div class=\"mfaq-cat-head\">\n            <h3 class=\"mfaq-cat-title\">Shipping &amp; delivery</h3>\n            <p class=\"mfaq-cat-desc\">When and how your order arrives.</p>\n          </div>\n          <div class=\"mfaq-list\">\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How long does delivery take?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Orders are typically delivered within <strong>3 working days</strong> across the UK. You'll get a tracking link by email as soon as your order ships.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How much is shipping?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Free on every UK order. No minimum spend.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Can I track my order?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Yes. Once your order ships you'll receive a tracked link by email so you can follow it to your door.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">What if my order arrives damaged?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Just email us a photo and we'll sort it straight away, either a free replacement or a refund.</div></div></div>\n          </div>\n        </div>\n\n        <div class=\"mfaq-panel\" data-panel=\"returns\">\n          <div class=\"mfaq-cat-head\">\n            <h3 class=\"mfaq-cat-title\">Returns &amp; warranty</h3>\n            <p class=\"mfaq-cat-desc\">Risk-free, every order.</p>\n          </div>\n          <div class=\"mfaq-list\">\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">What is your return policy?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">You have <strong>30 days from delivery</strong> to return your order for a full refund. Not for you? Email us and we'll start the return, no fuss.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Is there a warranty?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Yes, a <strong>2-year warranty</strong> against manufacturing defects on every light. Something not right? We'll replace it or refund you.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How do I start a return?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">Email us with your order number and we'll send you everything you need.</div></div></div>\n          </div>\n        </div>\n\n        <div class=\"mfaq-panel\" data-panel=\"orders\">\n          <div class=\"mfaq-cat-head\">\n            <h3 class=\"mfaq-cat-title\">Orders &amp; support</h3>\n            <p class=\"mfaq-cat-desc\">Payment, contact and response times.</p>\n          </div>\n          <div class=\"mfaq-list\">\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How can I pay?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">All major cards, plus Apple Pay, Google Pay, PayPal and Shop Pay. Every payment is processed over a secure connection.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">Can I change or cancel my order?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">If it hasn't shipped yet, yes. Email us as soon as you can and we'll do our best to update it.</div></div></div>\n            <div class=\"mfaq-item\"><button class=\"mfaq-trigger\" type=\"button\" aria-expanded=\"false\"><span class=\"mfaq-q\">How do I contact you?</span><span class=\"mfaq-plus\"><svg viewBox=\"0 0 16 16\"><path d=\"M8 3v10M3 8h10\"/></svg></span></button><div class=\"mfaq-answer\" aria-hidden=\"true\"><div class=\"mfaq-answer-inner\">By email, any day of the week. We usually reply within 24 hours.</div></div></div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <div class=\"mfaq-footer\">\n      <div class=\"mfaq-footer-left\">\n        Still have a question?\n        <p>We're happy to help by email.</p>\n      </div>\n      <div class=\"mfaq-footer-links\">\n        <a href=\"/pages/contact\" class=\"mfaq-footer-link mfaq-footer-link--contact\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg>\n          Contact us\n        </a>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n<script>\n(function () {\n  var root = document.querySelector('[data-meave-faq]');\n  if (!root) return;\n\n  if ('IntersectionObserver' in window) {\n    var fadeObserver = new IntersectionObserver(function (entries) {\n      entries.forEach(function (entry) {\n        if (entry.isIntersecting) { entry.target.classList.add('is-visible'); fadeObserver.unobserve(entry.target); }\n      });\n    }, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });\n    fadeObserver.observe(root);\n  } else {\n    root.classList.add('is-visible');\n  }\n\n  var navBtns = Array.prototype.slice.call(root.querySelectorAll('.mfaq-nav-btn'));\n  var panels = Array.prototype.slice.call(root.querySelectorAll('.mfaq-panel'));\n\n  navBtns.forEach(function (btn) {\n    btn.addEventListener('click', function () {\n      var target = btn.getAttribute('data-target');\n      var currentPanel = root.querySelector('.mfaq-panel.is-active');\n      var nextPanel = root.querySelector('.mfaq-panel[data-panel=\"' + target + '\"]');\n      if (currentPanel === nextPanel) return;\n\n      navBtns.forEach(function (b) { b.classList.remove('is-active'); });\n      btn.classList.add('is-active');\n\n      if (currentPanel) {\n        currentPanel.querySelectorAll('.mfaq-item.is-open').forEach(function (it) { closeItem(it); });\n        currentPanel.classList.remove('is-active');\n        currentPanel.classList.add('is-leaving');\n        setTimeout(function () {\n          currentPanel.classList.remove('is-leaving');\n          panels.forEach(function (p) { p.classList.remove('is-active'); });\n          if (nextPanel) {\n            nextPanel.classList.add('is-active');\n            if (window.innerWidth >= 768) {\n              var fi = nextPanel.querySelector('.mfaq-item');\n              if (fi) setTimeout(function () { openItem(fi); }, 200);\n            }\n          }\n        }, 250);\n      } else {\n        panels.forEach(function (p) { p.classList.remove('is-active'); });\n        if (nextPanel) nextPanel.classList.add('is-active');\n      }\n\n      if (window.innerWidth < 768) {\n        var content = root.querySelector('.mfaq-content');\n        if (content) setTimeout(function () { content.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 320);\n      }\n    });\n  });\n\n  root.querySelectorAll('.mfaq-item').forEach(function (item) {\n    var btn = item.querySelector('.mfaq-trigger'), panel = item.querySelector('.mfaq-answer');\n    if (!btn || !panel) return;\n    panel.style.height = '0px';\n    panel.addEventListener('transitionend', function (e) { if (e.propertyName === 'height' && item.classList.contains('is-open')) panel.style.height = 'auto'; });\n    btn.addEventListener('click', function () {\n      var isOpen = item.classList.contains('is-open'), list = item.closest('.mfaq-list');\n      if (list) list.querySelectorAll('.mfaq-item').forEach(function (sib) { if (sib !== item) closeItem(sib); });\n      isOpen ? closeItem(item) : openItem(item);\n    });\n  });\n\n  var fp = root.querySelector('.mfaq-panel.is-active');\n  if (fp && window.innerWidth >= 768) { var fi = fp.querySelector('.mfaq-item'); if (fi) setTimeout(function () { openItem(fi); }, 300); }\n\n  function openItem(it) {\n    var b = it.querySelector('.mfaq-trigger'), p = it.querySelector('.mfaq-answer');\n    if (!b || !p) return;\n    it.classList.add('is-open'); b.setAttribute('aria-expanded', 'true'); p.setAttribute('aria-hidden', 'false');\n    p.style.height = '0px'; p.offsetHeight; p.style.height = p.scrollHeight + 'px';\n  }\n  function closeItem(it) {\n    var b = it.querySelector('.mfaq-trigger'), p = it.querySelector('.mfaq-answer');\n    if (!b || !p) return;\n    it.classList.remove('is-open'); b.setAttribute('aria-expanded', 'false'); p.setAttribute('aria-hidden', 'true');\n    var h = p.style.height === 'auto' ? p.scrollHeight : parseFloat(p.style.height) || 0;\n    p.style.height = h + 'px'; p.offsetHeight; p.style.height = '0px';\n  }\n})();\n</script>\n\n<script type=\"application/ld+json\">\n{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Are the lights wireless?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Every light runs on a rechargeable bulb, so there's no wiring and no outlet needed.\"}},{\"@type\":\"Question\",\"name\":\"Do I need a professional to install them?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. Each light comes with 3M adhesive pads for a tool-free setup. Screws are also included for a permanent fix.\"}},{\"@type\":\"Question\",\"name\":\"How long does delivery take?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Orders are typically delivered within 3 working days across the UK, with a tracking link by email.\"}},{\"@type\":\"Question\",\"name\":\"How much is shipping?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Free on every UK order, with no minimum spend.\"}},{\"@type\":\"Question\",\"name\":\"What is your return policy?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You have 30 days from delivery to return your order for a full refund.\"}},{\"@type\":\"Question\",\"name\":\"Is there a warranty?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, a 2-year warranty against manufacturing defects on every light.\"}},{\"@type\":\"Question\",\"name\":\"How can I pay?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"All major cards, plus Apple Pay, Google Pay, PayPal and Shop Pay, processed over a secure connection.\"}},{\"@type\":\"Question\",\"name\":\"How do I contact you?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"By email, any day of the week. We usually reply within 24 hours.\"}}]}\n</script>",
