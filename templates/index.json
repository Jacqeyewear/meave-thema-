    "custom_liquid_CirTBi": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  #meave-trust *, #meave-trust *::before, #meave-trust *::after { box-sizing: border-box; }\n\n  #meave-trust {\n    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    background: #ffffff;\n    color: #1D1D1F;\n    padding: 56px 0;\n    opacity: 0;\n    transform: translateY(20px);\n    transition: opacity 0.8s cubic-bezier(0.22,1,0.36,1), transform 0.8s cubic-bezier(0.22,1,0.36,1);\n  }\n  #meave-trust.is-visible { opacity: 1; transform: translateY(0); }\n\n  .mtrust-grid { display: flex; flex-direction: column; gap: 28px; }\n  .mtrust-left { display: flex; flex-direction: column; align-items: center; text-align: center; }\n\n  .mtrust-title {\n    font-size: 28px; font-weight: 700; letter-spacing: -0.035em;\n    line-height: 1.1; color: #1D1D1F; margin: 0 0 28px; text-align: center;\n  }\n  .mtrust-title b { color: #C18C1E; font-weight: 700; }\n\n  .mtrust-reviewer { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }\n  .mtrust-avatar {\n    width: 46px; height: 46px; border-radius: 999px; flex-shrink: 0;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 15px; font-weight: 600; color: #ffffff;\n    background: linear-gradient(135deg, #F7DA8A 0%, #E0A93B 100%);\n    box-shadow: 0 2px 8px rgba(0,113,227,0.28);\n  }\n  .mtrust-reviewer-info { display: flex; flex-direction: column; gap: 4px; align-items: flex-start; }\n  .mtrust-reviewer-name {\n    display: inline-flex; align-items: center; gap: 5px;\n    font-size: 14px; font-weight: 600; color: #1D1D1F; letter-spacing: -0.01em;\n  }\n  .mtrust-badge { width: 14px; height: 14px; flex-shrink: 0; }\n  .mtrust-meta { display: flex; align-items: center; gap: 10px; }\n  .mtrust-stars { display: inline-flex; gap: 2px; }\n  .mtrust-stars svg { width: 14px; height: 14px; }\n  .mtrust-date { font-size: 12px; color: #86868b; font-weight: 400; }\n\n  .mtrust-review-title {\n    font-size: 17px; font-weight: 600; letter-spacing: -0.02em;\n    line-height: 1.3; color: #1D1D1F; margin: 0 0 12px;\n  }\n  .mtrust-review-text {\n    font-size: 14.5px; line-height: 1.65; color: #6e6e73;\n    letter-spacing: -0.005em; margin: 0; max-width: 460px;\n  }\n\n  .mtrust-photo {\n    width: 100%; border-radius: 18px; overflow: hidden;\n    box-shadow:\n      0 0.5px 1px rgba(0,0,0,0.03),\n      0 6px 16px -8px rgba(0,0,0,0.08),\n      0 16px 36px -14px rgba(0,0,0,0.08);\n  }\n  .mtrust-photo img { display: block; width: 100%; height: auto; }\n\n  @media (min-width: 768px) {\n    #meave-trust { padding: 80px 0; }\n    .mtrust-grid { flex-direction: row; align-items: center; gap: 48px; }\n    .mtrust-left { flex: 0 0 42%; max-width: 42%; }\n    .mtrust-photo { flex: 1 1 0; }\n    .mtrust-title { font-size: 48px; margin-bottom: 36px; }\n    .mtrust-review-title { font-size: 19px; }\n    .mtrust-review-text { font-size: 15px; }\n    .mtrust-photo { border-radius: 22px; }\n  }\n\n  @media (min-width: 1200px) {\n    .mtrust-grid { gap: 64px; }\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    *, *::before, *::after { transition: none !important; }\n  }\n</style>\n\n<section id=\"meave-trust\" data-meave-trust>\n  <svg width=\"0\" height=\"0\" style=\"position:absolute\" aria-hidden=\"true\">\n    <defs>\n      <linearGradient id=\"meaveTrustGold\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n        <stop offset=\"0%\" stop-color=\"#F4CE6A\"/>\n        <stop offset=\"100%\" stop-color=\"#E0A93B\"/>\n      </linearGradient>\n    </defs>\n  </svg>\n\n  <div class=\"mtrust-grid\">\n\n    <div class=\"mtrust-left\">\n      <h2 class=\"mtrust-title\">Made for real<br><b>British</b> homes</h2>\n\n      <div class=\"mtrust-reviewer\">\n        <div class=\"mtrust-avatar\" aria-hidden=\"true\">BM</div>\n        <div class=\"mtrust-reviewer-info\">\n          <span class=\"mtrust-reviewer-name\">Brenda M.\n            <svg class=\"mtrust-badge\" viewBox=\"0 0 24 24\" fill=\"#3897F0\" aria-hidden=\"true\"><path d=\"M12 1l2.4 2.1 3.2-.3 1.3 2.9 2.9 1.3-.3 3.2L23.6 12l-2.1 2.4.3 3.2-2.9 1.3-1.3 2.9-3.2-.3L12 23.6l-2.4-2.1-3.2.3-1.3-2.9-2.9-1.3.3-3.2L.4 12l2.1-2.4-.3-3.2 2.9-1.3 1.3-2.9 3.2.3z\"/><path d=\"M10.3 14.9l-2.5-2.5-1.3 1.3 3.8 3.8 6.7-6.7-1.3-1.3z\" fill=\"#fff\"/></svg>\n          </span>\n          <span class=\"mtrust-meta\">\n            <span class=\"mtrust-stars\" aria-label=\"5 out of 5 stars\">\n              <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveTrustGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveTrustGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveTrustGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveTrustGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n              <svg viewBox=\"0 0 24 24\" fill=\"url(#meaveTrustGold)\"><path d=\"M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.8 5.8 20.9l1.6-6.8L2.2 8.9l6.9-.6z\"/></svg>\n            </span>\n            <span class=\"mtrust-date\">8 May 2025</span>\n          </span>\n        </div>\n      </div>\n\n      <h3 class=\"mtrust-review-title\">Lovely lights, easy from start to finish</h3>\n      <p class=\"mtrust-review-text\">My lamps arrived safely and were really easy to put up. Once they were on the wall they added a lovely warmth to the entrance way. Very pleased with them.</p>\n    </div>\n\n    <div class=\"mtrust-photo\">\n      <img src=\"{{ 'meavegirid.jpg' | asset_url }}\" alt=\"MEAVE wireless wall lights styled in modern British homes\" loading=\"lazy\" width=\"1200\" height=\"800\">\n    </div>\n\n  </div>\n</section>\n\n<script>\n(function () {\n  var root = document.querySelector('[data-meave-trust]');\n  if (!root) return;\n  if ('IntersectionObserver' in window) {\n    var obs = new IntersectionObserver(function (entries) {\n      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); } });\n    }, { threshold: 0.1 });\n    obs.observe(root);\n  } else { root.classList.add('is-visible'); }\n})();\n</script>",
