      "settings": {
        "liquid": "<style>\n  #meave-vp{background:#fff;color:#1d1d1f;padding:72px 20px;-webkit-font-smoothing:antialiased;font-family:var(--font-body-family,inherit);}\n  #meave-vp .mvp-wrap{max-width:1080px;margin:0 auto;}\n  #meave-vp .mvp-head{text-align:center;margin:0 auto 44px;}\n  #meave-vp .mvp-eyebrow{margin:0 0 12px;color:#6e6e73;font-size:12px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;}\n  #meave-vp .mvp-title{margin:0;font-family:var(--font-heading-family,inherit);font-size:clamp(26px,3.2vw,42px);font-weight:500;letter-spacing:-.025em;line-height:1.1;}\n  #meave-vp .mvp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}\n  #meave-vp .mvp-card{background:#f5f5f7;border-radius:18px;padding:34px 28px;text-align:center;}\n  #meave-vp .mvp-ic{width:48px;height:48px;margin:0 auto 18px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 2px rgba(0,0,0,.05),0 8px 20px -10px rgba(0,0,0,.14);}\n  #meave-vp .mvp-ic svg{width:22px;height:22px;stroke:#0071e3;stroke-width:1.6;fill:none;stroke-linecap:round;stroke-linejoin:round;}\n  #meave-vp .mvp-h{margin:0 0 8px;font-family:var(--font-heading-family,inherit);font-size:19px;font-weight:500;letter-spacing:-.015em;color:#1d1d1f;}\n  #meave-vp .mvp-p{margin:0;color:#6e6e73;font-size:15px;line-height:1.6;}\n  @media(max-width:749px){#meave-vp{padding:44px 16px;}#meave-vp .mvp-grid{grid-template-columns:1fr;gap:12px;}#meave-vp .mvp-card{padding:26px 24px;}#meave-vp .mvp-head{margin-bottom:30px;}}\n</style>\n<section id=\"meave-vp\">\n  <div class=\"mvp-wrap\">\n    <div class=\"mvp-head\">\n      <p class=\"mvp-eyebrow\">Why Meave London</p>\n      <h2 class=\"mvp-title\">Lighting that finishes a room</h2>\n    </div>\n    <div class=\"mvp-grid\">\n      <div class=\"mvp-card\">\n        <span class=\"mvp-ic\"><svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 20h4L18.5 9.5a2.12 2.12 0 0 0-3-3L5 17v3z\"/><path d=\"M13.5 6.5l3 3\"/></svg></span>\n        <h3 class=\"mvp-h\">Designed in London</h3>\n        <p class=\"mvp-p\">Drawn and refined in our London studio, with the proportions of a proper designer fitting.</p>\n      </div>\n      <div class=\"mvp-card\">\n        <span class=\"mvp-ic\"><svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"4\"/><path d=\"M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4\"/></svg></span>\n        <h3 class=\"mvp-h\">Warm, flattering light</h3>\n        <p class=\"mvp-p\">A soft, golden glow that makes hallways, bedrooms and quiet corners feel calm and complete.</p>\n      </div>\n      <div class=\"mvp-card\">\n        <span class=\"mvp-ic\"><svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M13 3l2.3 6.2L22 11.5l-6.7 2.3L13 20l-2.3-6.2L4 11.5l6.7-2.3L13 3z\"/><path d=\"M5 4v3M3.5 5.5h3\"/></svg></span>\n        <h3 class=\"mvp-h\">Easy to live with</h3>\n        <p class=\"mvp-p\">Simple to set up and built to last, so the right light is never a big project.</p>\n      </div>\n    </div>\n  </div>\n</section>"
      }
    },
    "home-founder": {
