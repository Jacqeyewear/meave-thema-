    "custom_liquid_8xQqzt": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  .meave-colnav {\n    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    padding: 0;\n    position: relative;\n    width: 100vw;\n    margin-left: calc(50% - 50vw);\n    margin-right: calc(50% - 50vw);\n  }\n\n  .meave-colnav::before,\n  .meave-colnav::after {\n    content: '';\n    position: absolute;\n    top: 0; bottom: 0;\n    width: 32px;\n    pointer-events: none;\n    z-index: 2;\n    transition: opacity 0.3s ease;\n  }\n  .meave-colnav::before { left: 0; background: linear-gradient(to right, #fff 0%, rgba(255,255,255,0) 100%); opacity: 0; }\n  .meave-colnav::after { right: 0; background: linear-gradient(to left, #fff 0%, rgba(255,255,255,0) 100%); opacity: 1; }\n  .meave-colnav.is-scrolled::before { opacity: 1; }\n  .meave-colnav.is-end::after { opacity: 0; }\n\n  .meave-colnav-track {\n    display: flex;\n    flex-wrap: nowrap;\n    gap: 8px;\n    overflow-x: auto;\n    -webkit-overflow-scrolling: touch;\n    padding: 22px 20px;\n  }\n  .meave-colnav-track::-webkit-scrollbar { display: none; }\n  .meave-colnav-track { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .meave-colnav-pill {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    padding: 9px 16px;\n    border-radius: 12px;\n    border: none;\n    background: #fff;\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.9),\n      0 1px 2px rgba(0,0,0,0.06),\n      0 4px 12px -2px rgba(0,0,0,0.08),\n      0 10px 24px -8px rgba(0,0,0,0.06);\n    color: #1D1D1F;\n    font-size: 13px;\n    font-weight: 500;\n    letter-spacing: -0.01em;\n    white-space: nowrap;\n    text-decoration: none;\n    flex-shrink: 0;\n    cursor: pointer;\n    -webkit-tap-highlight-color: transparent;\n    opacity: 0;\n    transform: translateY(14px);\n    transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1),\n                transform 0.45s cubic-bezier(0.22,1,0.36,1),\n                box-shadow 0.45s cubic-bezier(0.22,1,0.36,1),\n                color 0.35s ease;\n  }\n\n  .meave-colnav-pill svg {\n    width: 16px; height: 16px;\n    flex-shrink: 0;\n    color: #86868b;\n    transition: color 0.35s ease, transform 0.45s cubic-bezier(0.22,1,0.36,1);\n  }\n\n  .meave-colnav.is-visible .meave-colnav-pill { opacity: 1; transform: translateY(0); }\n\n  .meave-colnav-pill:nth-child(1) { transition-delay: 0s; }\n  .meave-colnav-pill:nth-child(2) { transition-delay: 0.04s; }\n  .meave-colnav-pill:nth-child(3) { transition-delay: 0.08s; }\n  .meave-colnav-pill:nth-child(4) { transition-delay: 0.12s; }\n  .meave-colnav-pill:nth-child(5) { transition-delay: 0.16s; }\n  .meave-colnav-pill:nth-child(6) { transition-delay: 0.20s; }\n  .meave-colnav-pill:nth-child(7) { transition-delay: 0.24s; }\n  .meave-colnav-pill:nth-child(8) { transition-delay: 0.28s; }\n\n  @keyframes meaveSwipeHint {\n    0%   { transform: translateX(0); }\n    20%  { transform: translateX(-12px); }\n    40%  { transform: translateX(0); }\n    60%  { transform: translateX(-8px); }\n    80%  { transform: translateX(0); }\n    100% { transform: translateX(0); }\n  }\n  .meave-colnav.is-visible:not(.is-scrolled) .meave-colnav-track {\n    animation: meaveSwipeHint 1.6s ease-in-out 0.9s 1;\n  }\n\n  .meave-colnav.is-visible .meave-colnav-pill:hover {\n    color: #1D1D1F;\n    transform: translateY(-3px);\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.9),\n      0 2px 6px rgba(0,0,0,0.08),\n      0 10px 22px -6px rgba(0,0,0,0.12),\n      0 20px 40px -12px rgba(0,0,0,0.12);\n  }\n  .meave-colnav.is-visible .meave-colnav-pill:hover svg {\n    color: #1D1D1F;\n    transform: scale(1.12) rotate(-4deg);\n  }\n  .meave-colnav.is-visible .meave-colnav-pill:active {\n    transform: translateY(-1px) scale(0.97);\n    transition-duration: 0.12s;\n  }\n\n  /* Featured pill — goud, icoon + shimmer + glow */\n  .meave-colnav-pill--featured {\n    background: #0071e3;\n    color: #ffffff;\n    gap: 8px;\n    padding: 9px 17px 9px 14px;\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.45),\n      0 2px 6px rgba(0,113,227,0.28),\n      0 8px 20px -4px rgba(0,113,227,0.32);\n    position: relative;\n    overflow: hidden;\n  }\n  .meave-colnav-pill--featured svg { color: #ffffff; position: relative; z-index: 1; }\n  .meave-colnav-pill--featured span { position: relative; z-index: 1; }\n  .meave-colnav.is-visible .meave-colnav-pill--featured:hover {\n    color: #ffffff;\n    transform: translateY(-3px);\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.5),\n      0 2px 6px rgba(0,113,227,0.32),\n      0 14px 30px -6px rgba(193,140,30,0.42);\n  }\n  .meave-colnav.is-visible .meave-colnav-pill--featured:hover svg {\n    color: #ffffff;\n    transform: scale(1.15) rotate(0deg);\n  }\n  .meave-colnav-pill--featured::before {\n    content: '';\n    position: absolute;\n    top: 0; left: -75%;\n    width: 50%; height: 100%;\n    background: linear-gradient(105deg, transparent 0%, transparent 30%, rgba(255,255,255,0.55) 50%, transparent 70%, transparent 100%);\n    pointer-events: none;\n  }\n  @keyframes meaveShimmer { 0% { left: -75%; } 100% { left: 175%; } }\n  .meave-colnav.is-visible .meave-colnav-pill--featured::before {\n    animation: meaveShimmer 2.4s cubic-bezier(0.4,0,0.2,1) 1.4s infinite;\n  }\n\n  /* Sale pill — rood met zachte glow-pulse */\n  .meave-colnav-pill--sale {\n    background: linear-gradient(135deg, #d12626 0%, #b91c1c 100%);\n    color: #fff;\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.15),\n      0 2px 6px rgba(185,28,28,0.25),\n      0 8px 18px -4px rgba(185,28,28,0.3);\n  }\n  .meave-colnav-pill--sale svg { color: #ffd7d7; }\n  .meave-colnav.is-visible .meave-colnav-pill--sale {\n    animation: meaveSaleGlow 2.8s ease-in-out infinite;\n  }\n  @keyframes meaveSaleGlow {\n    0%, 100% { box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 2px 6px rgba(185,28,28,0.25), 0 8px 18px -4px rgba(185,28,28,0.3); }\n    50% { box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 2px 8px rgba(185,28,28,0.4), 0 10px 26px -2px rgba(185,28,28,0.5); }\n  }\n  .meave-colnav.is-visible .meave-colnav-pill--sale:hover {\n    color: #fff;\n    transform: translateY(-3px);\n    animation: none;\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.18),\n      0 2px 6px rgba(185,28,28,0.3),\n      0 14px 30px -6px rgba(185,28,28,0.45);\n  }\n  .meave-colnav.is-visible .meave-colnav-pill--sale:hover svg { color: #fff; }\n\n  .meave-colnav-pill--optional { display: inline-flex; }\n\n  @media (min-width: 768px) {\n    .meave-colnav { padding: 0; width: auto; margin-left: 0; margin-right: 0; }\n    .meave-colnav::before, .meave-colnav::after { display: none; }\n    .meave-colnav.is-visible:not(.is-scrolled) .meave-colnav-track { animation: none; }\n    .meave-colnav-track {\n      flex-wrap: nowrap;\n      justify-content: center;\n      overflow-x: visible;\n      padding: 24px 0;\n      gap: 10px;\n      width: 100%;\n    }\n    .meave-colnav-pill {\n      font-size: clamp(12px, 0.9vw, 15px);\n      padding: clamp(9px, 0.7vw, 13px) clamp(14px, 1.3vw, 24px);\n    }\n    .meave-colnav-pill svg { width: clamp(15px, 1vw, 18px); height: clamp(15px, 1vw, 18px); }\n    .meave-colnav-pill--featured,\n    .meave-colnav-pill--sale {\n      padding: clamp(9px, 0.7vw, 13px) clamp(14px, 1.3vw, 24px);\n    }\n    .meave-colnav-pill--featured { padding-left: clamp(12px, 1.1vw, 20px); }\n  }\n\n  @media (min-width: 768px) and (max-width: 1300px) {\n    .meave-colnav-pill--optional { display: none; }\n  }\n</style>\n\n<div class=\"meave-colnav\" id=\"meaveColNav\">\n  <div class=\"meave-colnav-track\" id=\"meaveColNavTrack\">\n\n    <a href=\"/collections/all\" class=\"meave-colnav-pill meave-colnav-pill--featured\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 18h6\"/><path d=\"M10 21h4\"/><path d=\"M12 3a6 6 0 0 1 4 10.5c-.6.6-1 1.3-1 2.1H9c0-.8-.4-1.5-1-2.1A6 6 0 0 1 12 3z\"/></svg>\n      <span>Shop all</span>\n    </a>\n\n    <a href=\"/collections/wall-lights\" class=\"meave-colnav-pill\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 3v18\"/><path d=\"M5 8h6\"/><path d=\"M11 6l3 4h-6z\"/><path d=\"M9 10v2a2 2 0 0 0 4 0v-2\"/></svg>\n      Wall Lights\n    </a>\n\n    <a href=\"/collections/table-lamps\" class=\"meave-colnav-pill\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 4h6l2 7H7z\"/><path d=\"M12 11v7\"/><path d=\"M8 20h8\"/></svg>\n      Table Lamps\n    </a>\n\n    <a href=\"/collections/ceiling-lights\" class=\"meave-colnav-pill\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 3v3\"/><path d=\"M7 6h10l-1.5 6h-7z\"/><path d=\"M10 15a2 2 0 0 0 4 0\"/></svg>\n      Ceiling Lights\n    </a>\n\n    <a href=\"/collections/lampshades\" class=\"meave-colnav-pill meave-colnav-pill--optional\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M8 6h8l2 6H6z\"/><path d=\"M9 12v6\"/><path d=\"M15 12v6\"/><path d=\"M9 18h6\"/></svg>\n      Lampshades\n    </a>\n\n    <a href=\"/collections/outdoor-lights\" class=\"meave-colnav-pill\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 4h6l-1 3h-4z\"/><path d=\"M8 7h8l1 13H7z\"/><path d=\"M10 20v-9\"/><path d=\"M14 20v-9\"/></svg>\n      Outdoor Lights\n    </a>\n\n    <a href=\"/collections/accessories\" class=\"meave-colnav-pill\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M12 3v2\"/><path d=\"M12 19v2\"/><path d=\"M3 12h2\"/><path d=\"M19 12h2\"/><path d=\"M5.6 5.6l1.4 1.4\"/><path d=\"M17 17l1.4 1.4\"/><path d=\"M18.4 5.6L17 7\"/><path d=\"M7 17l-1.4 1.4\"/></svg>\n      Accessories\n    </a>\n\n  </div>\n</div>\n\n<script>\n(function(){\n  var nav = document.getElementById('meaveColNav');\n  var track = document.getElementById('meaveColNavTrack');\n  if (!nav || !track) return;\n\n  if ('IntersectionObserver' in window) {\n    var obs = new IntersectionObserver(function(entries){\n      entries.forEach(function(e){ if (e.isIntersecting) { nav.classList.add('is-visible'); obs.unobserve(nav); } });\n    }, { threshold: 0.15 });\n    obs.observe(nav);\n  } else {\n    nav.classList.add('is-visible');\n  }\n\n  function updateFades(){\n    var maxScroll = track.scrollWidth - track.clientWidth;\n    track.scrollLeft > 4 ? nav.classList.add('is-scrolled') : nav.classList.remove('is-scrolled');\n    track.scrollLeft >= maxScroll - 4 ? nav.classList.add('is-end') : nav.classList.remove('is-end');\n  }\n  track.addEventListener('scroll', updateFades, { passive: true });\n  window.addEventListener('resize', updateFades);\n  updateFades();\n})();\n</script>",
