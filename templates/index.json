><div class=\"jacq-compare-row-text\">Anti-kras coating</div></div>\n          <div class=\"jacq-compare-row\"><div class=\"jacq-compare-row-icon jacq-compare-row-icon--paid\"><svg viewBox=\"0 0 24 24\"><path d=\"M5 12l5 5L20 7\"/></svg></div><div class=\"jacq-compare-row-text\">Ontspiegeling</div><div class=\"jacq-compare-row-extra\">+&euro;&euro;&euro;</div></div>\n          <div class=\"jacq-compare-row\"><div class=\"jacq-compare-row-icon jacq-compare-row-icon--check\"><svg viewBox=\"0 0 24 24\"><path d=\"M5 12l5 5L20 7\"/></svg></div><div class=\"jacq-compare-row-text\">Niet goed, geld terug</div></div>\n          <div class=\"jacq-compare-row\"><div class=\"jacq-compare-row-icon jacq-compare-row-icon--cross\"><svg viewBox=\"0 0 24 24\"><path d=\"M18 6L6 18M6 6l12 12\"/></svg></div><div class=\"jacq-compare-row-text\">Gratis verzending</div></div>\n        </div>\n        <div class=\"jacq-compare-trustpilot\">\n          <div class=\"jacq-compare-tp-stars\">\n            <span class=\"jacq-compare-tp-star-box\"><svg viewBox=\"0 0 24 24\"><path fill=\"#fff\" d=\"M12 17.3 6.2 20.7l1.6-6.7L2.6 9.7l6.9-.6L12 2.8l2.5 6.3 6.9.6-5.2 4.3 1.6 6.7z\"/></svg></span>\n            <span class=\"jacq-compare-tp-star-box\"><svg viewBox=\"0 0 24 24\"><path fill=\"#fff\" d=\"M12 17.3 6.2 20.7l1.6-6.7L2.6 9.7l6.9-.6L12 2.8l2.5 6.3 6.9.6-5.2 4.3 1.6 6.7z\"/></svg></span>\n            <span class=\"jacq-compare-tp-star-box\"><svg viewBox=\"0 0 24 24\"><path fill=\"#fff\" d=\"M12 17.3 6.2 20.7l1.6-6.7L2.6 9.7l6.9-.6L12 2.8l2.5 6.3 6.9.6-5.2 4.3 1.6 6.7z\"/></svg></span>\n            <span class=\"jacq-compare-tp-star-box\"><svg viewBox=\"0 0 24 24\"><path fill=\"#fff\" d=\"M12 17.3 6.2 20.7l1.6-6.7L2.6 9.7l6.9-.6L12 2.8l2.5 6.3 6.9.6-5.2 4.3 1.6 6.7z\"/></svg></span>\n            <span class=\"jacq-compare-tp-star-box jacq-compare-tp-star-box--empty\"><svg viewBox=\"0 0 24 24\"><path fill=\"#fff\" d=\"M12 17.3 6.2 20.7l1.6-6.7L2.6 9.7l6.9-.6L12 2.8l2.5 6.3 6.9.6-5.2 4.3 1.6 6.7z\"/></svg></span>\n          </div>\n          <div class=\"jacq-compare-tp-info\"><span class=\"jacq-compare-tp-score\">4.0</span><span class=\"jacq-compare-tp-label\">Trustpilot</span></div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"jacq-compare-dots\" id=\"jacqCompareDots\">\n    <span class=\"jacq-compare-dot is-active\"></span>\n    <span class=\"jacq-compare-dot\"></span>\n    <span class=\"jacq-compare-dot\"></span>\n    <span class=\"jacq-compare-dot\"></span>\n  </div>\n\n  <div class=\"jacq-compare-disclaimer-wrap\">\n    <button class=\"jacq-compare-disclaimer-toggle\" id=\"jacqDisclaimerToggle\">Prijsverantwoording *</button>\n    <div class=\"jacq-compare-disclaimer-text\" id=\"jacqDisclaimerText\">Vergelijking op basis van een complete enkelvoudige bril met dunne glazen (index 1.56–1.6), inclusief anti-kras coating en ontspiegeling. Bij alle opticiens is een montuur van &euro;50 gekozen. Hans Anders prijs is inclusief de huidige kortingsactie (geldig t/m 31 maart 2026). Prijzen zijn indicatief en gebaseerd op openbaar beschikbare prijsinformatie per februari 2026. Werkelijke prijzen kunnen afwijken per winkel en configuratie.</div>\n  </div>\n\n  <div class=\"jacq-compare-explain\">\n    <button class=\"jacq-compare-explain-toggle\" id=\"jacqExplainToggle\">\n      Hoe kan JACQ. zo scherp geprijsd zijn?\n      <svg class=\"jacq-compare-explain-chevron\" viewBox=\"0 0 12 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M2.5 4.5L6 8L9.5 4.5\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </button>\n    <div class=\"jacq-compare-explain-content\" id=\"jacqExplainContent\">\n      <p class=\"jacq-compare-explain-text\">Wij hebben geen fysieke winkels en geen dure winkelmedewerkers. Daardoor besparen we flink op kosten en dat voordeel geven we direct aan jou door. Je betaalt dus puur voor je bril, niets meer.</p>\n    </div>\n  </div>\n\n</div>\n\n<!-- canvas-confetti CDN -->\n<script src=\"https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js\"></script>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n  var track = document.getElementById('jacqCompareTrack');\n  var dotsWrap = document.getElementById('jacqCompareDots');\n  if (!track || !dotsWrap) return;\n\n  var cards = Array.prototype.slice.call(track.querySelectorAll('.jacq-compare-card'));\n  var dots = Array.prototype.slice.call(dotsWrap.querySelectorAll('.jacq-compare-dot'));\n  var isMobile = window.innerWidth < 768;\n  var counterDone = false;\n  var currentMode = 'enkelvoudig';\n\n  /* ── Animated counter (initial entrance) ── */\n  function animateCounters() {\n    if (counterDone) return;\n    counterDone = true;\n    var els = track.querySelectorAll('[data-target]');\n    var attr = currentMode === 'enkelvoudig' ? 'data-target-enkel' : 'data-target';\n    els.forEach(function (el) {\n      var target = parseInt(el.getAttribute(attr), 10);\n      /* Reset to €0 to guarantee visible animation */\n      el.textContent = '\\u20AC0';\n      var duration = 1200;\n      var start = performance.now();\n      function tick(now) {\n        var progress = Math.min((now - start) / duration, 1);\n        var ease = 1 - Math.pow(1 - progress, 3);\n        var current = Math.round(ease * target);\n        el.textContent = '\\u20AC' + current;\n        if (progress < 1) requestAnimationFrame(tick);\n      }\n      requestAnimationFrame(tick);\n    });\n  }\n\n  /* ── Animate price from current to new value ── */\n  function animateTo(el, target) {\n    var current = parseInt(el.textContent.replace(/[^\\d]/g, ''), 10) || 0;\n    var duration = 600;\n    var start = performance.now();\n    var from = current;\n    function tick(now) {\n      var progress = Math.min((now - start) / duration, 1);\n      var ease = 1 - Math.pow(1 - progress, 3);\n      var val = Math.round(from + (target - from) * ease);\n      el.textContent = '\\u20AC' + val;\n      if (progress < 1) requestAnimationFrame(tick);\n    }\n    requestAnimationFrame(tick);\n  }\n\n  /* ── Confetti celebration (canvas-confetti) ── */\n  function fireConfetti() {\n    if (typeof confetti === 'undefined') return;\n\n    var jacqCard = document.querySelector('.jacq-compare-card--jacq');\n    if (!jacqCard) return;\n    var rect = jacqCard.getBoundingClientRect();\n    var originX = (rect.left + rect.width / 2) / window.innerWidth;\n    var originY = (rect.top + rect.height / 2) / window.innerHeight;\n\n    var defaults = {\n      origin: { x: originX, y: originY },\n      colors: ['#0071E3', '#34C759', '#FFD60A', '#FF9500', '#AF52DE', '#FF375F'],\n      zIndex: 9999,\n      spread: 360,\n      ticks: 100,\n      gravity: 0.6,\n      decay: 0.94,\n      startVelocity: 25,\n      scalar: 1,\n    };\n\n    confetti({ ...defaults, particleCount: 50 });\n    confetti({ ...defaults, particleCount: 20, scalar: 0.6 });\n\n    setTimeout(function () {\n      confetti({ ...defaults, particleCount: 35, startVelocity: 20 });\n      confetti({ ...defaults, particleCount: 15, scalar: 0.5 });\n    }, 200);\n\n    setTimeout(function () {\n      confetti({ ...defaults, particleCount: 20, startVelocity: 15, scalar: 0.8 });\n    }, 400);\n  }\n\n  /* ── Scroll-triggered entrance ── */\n  if ('IntersectionObserver' in window) {\n    track.classList.add('jacq-anim-ready');\n    var observer = new IntersectionObserver(function (entries) {\n      entries.forEach(function (entry) {\n        if (entry.isIntersecting) {\n          var innerCards = entry.target.querySelectorAll('.jacq-compare-card');\n          innerCards.forEach(function (c) { c.classList.add('is-visible'); });\n          observer.unobserve(entry.target);\n          setTimeout(animateCounters, 300);\n          setTimeout(fireConfetti, 1400);\n          if (isMobile) {\n            setTimeout(function () {\n              var cardWidth = cards[0].offsetWidth;\n              var peekAmount = Math.round(cardWidth * 0.3);\n              track.scrollTo({ left: peekAmount, behavior: 'smooth' });\n              setTimeout(function () {\n                track.scrollTo({ left: 0, behavior: 'smooth' });\n              }, 700);\n            }, 1000);\n          }\n        }\n      });\n    }, { threshold: 0.1 });\n    observer.observe(track);\n    setTimeout(function () {\n      cards.forEach(function (c) { c.classList.add('is-visible'); });\n      animateCounters();\n    }, 2000);\n  }\n\n  /* ── Dots / scroll tracking ── */\n  function updateDots() {\n    var center = track.scrollLeft + track.clientWidth / 2;\n    var active = 0, min = Infinity;\n    cards.forEach(function (c, i) {\n      var d = Math.abs(c.offsetLeft + c.offsetWidth / 2 - center);\n      if (d < min) { min = d; active = i; }\n    });\n    dots.forEach(function (d, i) { d.classList.toggle('is-active', i === active); });\n  }\n  var scrollTick = false;\n  track.addEventListener('scroll', function () {\n    if (!scrollTick) { requestAnimationFrame(function () { updateDots(); scrollTick = false; }); scrollTick = true; }\n  });\n  dots.forEach(function (d, i) {\n    d.addEventListener('click', function () {\n      var c = cards[i];\n      if (c) track.scrollTo({ left: c.offsetLeft - (track.clientWidth - c.offsetWidth) / 2, behavior: 'smooth' });\n    });\n  });\n  updateDots();\n\n  /* ── Switch toggle ── */\n  var switchBtns = document.querySelectorAll('.jacq-compare-switch-opt');\n\n  function switchPrices(mode) {\n    if (mode === currentMode) return;\n    currentMode = mode;\n\n    switchBtns.forEach(function (b) {\n      b.classList.toggle('is-active', b.getAttribute('data-mode') === mode);\n    });\n\n    var els = track.querySelectorAll('[data-target]');\n    els.forEach(function (el) {\n      var target = mode === 'enkelvoudig'\n        ? parseInt(el.getAttribute('data-target-enkel'), 10)\n        : parseInt(el.getAttribute('data-target'), 10);\n      animateTo(el, target);\n    });\n\n    var inclEls = track.querySelectorAll('.jacq-compare-included');\n    inclEls.forEach(function (el) {\n      var txt = mode === 'enkelvoudig' ? el.getAttribute('data-enkel') : el.getAttribute('data-multi');\n      if (txt) el.innerHTML = txt;\n    });\n\n    var disclaimerText = document.getElementById('jacqDisclaimerText');\n    if (disclaimerText) {\n      var type = mode === 'enkelvoudig' ? 'enkelvoudige' : 'multifocale';\n      disclaimerText.textContent = 'Vergelijking op basis van een complete ' + type + ' bril met dunne glazen (index 1.56\\u20131.6), inclusief anti-kras coating en ontspiegeling. Bij alle opticiens is een montuur van \\u20AC50 gekozen. Hans Anders prijs is inclusief de huidige kortingsactie (geldig t/m 31 maart 2026). Prijzen zijn indicatief en gebaseerd op openbaar beschikbare prijsinformatie per februari 2026. Werkelijke prijzen kunnen afwijken per winkel en configuratie.';\n    }\n  }\n\n  switchBtns.forEach(function (btn) {\n    btn.addEventListener('click', function () {\n      switchPrices(btn.getAttribute('data-mode'));\n    });\n  });\n\n  /* ── Disclaimer toggle ── */\n  var toggle = document.getElementById('jacqDisclaimerToggle');\n  var text = document.getElementById('jacqDisclaimerText');\n  if (toggle && text) {\n    toggle.addEventListener('click', function () {\n      text.classList.toggle('is-open');\n      toggle.textContent = text.classList.contains('is-open') ? 'Sluiten' : 'Prijsverantwoording *';\n    });\n  }\n\n  /* ── Price explanation toggle ── */\n  var explainToggle = document.getElementById('jacqExplainToggle');\n  var explainContent = document.getElementById('jacqExplainContent');\n  if (explainToggle && explainContent) {\n    explainToggle.addEventListener('click', function () {\n      var isOpen = explainToggle.classList.toggle('is-open');\n      if (isOpen) {\n        explainContent.style.maxHeight = explainContent.scrollHeight + 'px';\n        explainContent.classList.add('is-open');\n      } else {\n        explainContent.style.maxHeight = '0';\n        explainContent.classList.remove('is-open');\n      }\n    });\n  }\n\n});\n</script>",
