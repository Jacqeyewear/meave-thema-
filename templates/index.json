    "custom_liquid_n4LAEk": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  /* ===== JACQ – Handige info (accordion, \"origineel\" look) ===== */\n  .jacq-info{\n    width: 100%;\n    color: #1D1D1D;\n    font-family: inherit;\n  }\n\n  .jacq-info__wrap{\n    width: 100%;\n    margin: 0;\n    padding: 0;\n  }\n\n  .jacq-info__title{\n    margin: 0 0 32px;\n    text-align: center;\n    font-weight: 700;\n    letter-spacing: -0.02em;\n    color: #1D1D1D;\n    font-size: clamp(24px, 5.6vw, 48px);\n    line-height: 1.05;\n  }\n\n  .jacq-info__list{\n    border-top: 0;\n  }\n\n  .jacq-info-item{\n    border-bottom: 1px solid rgba(29,29,29,0.14);\n  }\n  .jacq-info-item:last-child{\n    border-bottom: 0;\n  }\n\n  .jacq-info-trigger{\n    width: 100%;\n    border: 0;\n    background: transparent;\n    cursor: pointer;\n\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n\n    padding: 28px 0;\n    text-align: left;\n  }\n\n  .jacq-info-label{\n    font-size: 18px;\n    font-weight: 500;\n    line-height: 1.15;\n    color: #1D1D1D;\n  }\n  @media (min-width: 768px){\n    .jacq-info-label{ font-size: 22px; }\n  }\n\n  .jacq-info-icon{\n    width: 22px;\n    height: 22px;\n    flex: 0 0 22px;\n    position: relative;\n    transform: rotate(0deg);\n    transition: transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n  .jacq-info-icon::before,\n  .jacq-info-icon::after{\n    content:\"\";\n    position:absolute;\n    left:50%;\n    top:50%;\n    width: 16px;\n    height: 2px;\n    background: #1D1D1D;\n    transform: translate(-50%, -50%);\n    border-radius: 999px;\n  }\n  .jacq-info-icon::after{\n    width: 2px;\n    height: 16px;\n  }\n\n  .jacq-info-item.is-open .jacq-info-icon{\n    transform: rotate(45deg);\n  }\n\n  .jacq-info-panel{\n    height: 0;\n    overflow: hidden;\n    transition: height 280ms cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n\n  .jacq-info-panel-inner{\n    padding: 0 0 28px;\n    color: #1D1D1D;\n    font-size: 15px;\n    line-height: 1.6;\n\n    opacity: 0;\n    transform: translateY(-6px);\n    transition:\n      opacity 200ms ease,\n      transform 280ms cubic-bezier(0.2, 0.8, 0.2, 1);\n  }\n\n  .jacq-info-item.is-open .jacq-info-panel-inner{\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .jacq-info-panel-inner a{\n    color: inherit;\n    text-decoration: underline;\n    text-underline-offset: 2px;\n  }\n\n  @media (max-width: 767px){\n    .jacq-info-trigger{ padding: 24px 0; }\n    .jacq-info-panel-inner{\n      font-size: 14px;\n      padding-bottom: 24px;\n      max-width: 300px;\n    }\n  }\n\n  @media (prefers-reduced-motion: reduce){\n    .jacq-info-icon,\n    .jacq-info-panel,\n    .jacq-info-panel-inner{\n      transition: none !important;\n    }\n  }\n</style>\n\n<div class=\"jacq-info\" data-jacq-info>\n  <div class=\"jacq-info__wrap\">\n    <h2 class=\"jacq-info__title\">Handige info</h2>\n\n    <div class=\"jacq-info__list\">\n\n      <div class=\"jacq-info-item\">\n        <button class=\"jacq-info-trigger\" type=\"button\" aria-expanded=\"false\">\n          <span class=\"jacq-info-label\">Verzendtijd</span>\n          <span class=\"jacq-info-icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"jacq-info-panel\" aria-hidden=\"true\">\n          <div class=\"jacq-info-panel-inner\">\n            Onze brillen worden op maat gemaakt en bijna altijd binnen 7–10 werkdagen bezorgd.<br>\n            Zodra je bestelling is verzonden, ontvang je per e-mail de track &amp; trace.<br>\n            Meer weten? Bekijk <a href=\"https://jacqeyewear.nl/pages/verzending-levertijd\">verzending &amp; levertijd</a>.\n          </div>\n        </div>\n      </div>\n\n      <div class=\"jacq-info-item\">\n        <button class=\"jacq-info-trigger\" type=\"button\" aria-expanded=\"false\">\n          <span class=\"jacq-info-label\">Retourneren</span>\n          <span class=\"jacq-info-icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"jacq-info-panel\" aria-hidden=\"true\">\n          <div class=\"jacq-info-panel-inner\">\n            Niet goed? Geld terug.<br>\n            Je hebt 100 dagen bedenktijd. Geen haast dus.<br>\n            Bekijk hoe het werkt bij <a href=\"https://jacqeyewear.nl/pages/retour-ruil-garantie\">retour, ruilen &amp; garantie</a>.\n          </div>\n        </div>\n      </div>\n\n      <div class=\"jacq-info-item\">\n        <button class=\"jacq-info-trigger\" type=\"button\" aria-expanded=\"false\">\n          <span class=\"jacq-info-label\">Betalingen</span>\n          <span class=\"jacq-info-icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"jacq-info-panel\" aria-hidden=\"true\">\n          <div class=\"jacq-info-panel-inner\">\n            Je kunt veilig betalen met onder andere iDEAL, Klarna en je creditcard.<br>\n            Zo kies je altijd de manier die bij jou past.\n          </div>\n        </div>\n      </div>\n\n      <div class=\"jacq-info-item\">\n        <button class=\"jacq-info-trigger\" type=\"button\" aria-expanded=\"false\">\n          <span class=\"jacq-info-label\">Garantie</span>\n          <span class=\"jacq-info-icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"jacq-info-panel\" aria-hidden=\"true\">\n          <div class=\"jacq-info-panel-inner\">\n            Je krijgt 2 jaar garantie op je bril.<br>\n            Fabricagefout? Dan krijg je je geld terug of een gratis vervanging.<br>\n            Meer weten? Bekijk <a href=\"https://jacqeyewear.nl/pages/retour-ruil-garantie\">retour, ruilen &amp; garantie</a>.\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n  (function(){\n    var roots = document.querySelectorAll('[data-jacq-info]');\n    if (!roots.length) return;\n\n    roots.forEach(function(root){\n      var items = Array.prototype.slice.call(root.querySelectorAll('.jacq-info-item'));\n\n      items.forEach(function(item){\n        var btn = item.querySelector('.jacq-info-trigger');\n        var panel = item.querySelector('.jacq-info-panel');\n        if (!btn || !panel) return;\n\n        panel.style.height = '0px';\n        panel.setAttribute('aria-hidden','true');\n        btn.setAttribute('aria-expanded','false');\n\n        panel.addEventListener('transitionend', function(e){\n          if (e.propertyName !== 'height') return;\n          if (item.classList.contains('is-open')) panel.style.height = 'auto';\n          else panel.style.height = '0px';\n        });\n\n        btn.addEventListener('click', function(){\n          var isOpen = item.classList.contains('is-open');\n\n          items.forEach(function(other){\n            if (other !== item) closeItem(other);\n          });\n\n          if (isOpen) closeItem(item);\n          else openItem(item);\n        });\n\n        function openItem(it){\n          var b = it.querySelector('.jacq-info-trigger');\n          var p = it.querySelector('.jacq-info-panel');\n          if (!b || !p) return;\n\n          it.classList.add('is-open');\n          b.setAttribute('aria-expanded','true');\n          p.setAttribute('aria-hidden','false');\n\n          p.style.height = '0px';\n          p.offsetHeight;\n          p.style.height = p.scrollHeight + 'px';\n        }\n\n        function closeItem(it){\n          var b = it.querySelector('.jacq-info-trigger');\n          var p = it.querySelector('.jacq-info-panel');\n          if (!b || !p) return;\n\n          it.classList.remove('is-open');\n          b.setAttribute('aria-expanded','false');\n          p.setAttribute('aria-hidden','true');\n\n          p.style.height = (p.style.height === 'auto' ? p.scrollHeight : p.scrollHeight) + 'px';\n          p.offsetHeight;\n          p.style.height = '0px';\n        }\n      });\n    });\n  })();\n</script>",
