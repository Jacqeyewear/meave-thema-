      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  .jacq-cta-band {\n    margin: 16px 0;\n  }\n  .jacq-cta-inner {\n    display: flex;\n    align-items: stretch;\n    border-radius: 24px;\n    background: #1D1D1F;\n    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.06);\n    font-family: inherit;\n    border: none;\n    overflow: hidden;\n    position: relative;\n    min-height: 260px;\n  }\n\n  /* ── Gradient glow behind content ── */\n  .jacq-cta-inner::before {\n    content: '';\n    position: absolute;\n    bottom: -30%;\n    left: -10%;\n    width: 60%;\n    height: 80%;\n    background: radial-gradient(ellipse at center, rgba(0,113,227,0.15) 0%, transparent 70%);\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  /* Left — text */\n  .jacq-cta-left {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding: 44px 40px;\n    position: relative;\n    z-index: 1;\n  }\n  .jacq-cta-title {\n    font-size: 22px;\n    font-weight: 700;\n    letter-spacing: -0.035em;\n    line-height: 1.06;\n    color: #ffffff;\n    margin: 0 0 12px;\n  }\n  .jacq-cta-sub {\n    font-size: 15px;\n    color: rgba(255, 255, 255, 0.5);\n    line-height: 1.5;\n    margin: 0 0 26px;\n    max-width: none;\n    font-weight: 400;\n    letter-spacing: -0.01em;\n  }\n  .jacq-mobile-br {\n    display: inline;\n  }\n  .jacq-desktop-br {\n    display: none;\n  }\n  .jacq-cta-btn {\n    display: inline-flex;\n    align-items: center;\n    align-self: flex-start;\n    padding: 14px 30px;\n    border-radius: 999px;\n    border: none;\n    background: #0071E3;\n    color: #ffffff;\n    font-size: 15px;\n    font-weight: 400;\n    font-family: inherit;\n    cursor: pointer;\n    text-decoration: none;\n    letter-spacing: -0.01em;\n    transition: transform 0.35s cubic-bezier(0, 0, .15, 1), box-shadow 0.35s, background 0.3s;\n  }\n  .jacq-cta-btn:hover {\n    background: #0077ED;\n    transform: scale(1.04);\n    box-shadow: 0 6px 24px rgba(0, 113, 227, 0.3);\n  }\n  .jacq-cta-btn:active {\n    transform: scale(0.98);\n  }\n  /* Right — huge horizontal logo (desktop) */\n  .jacq-cta-right {\n    flex: 0 0 45%;\n    position: relative;\n    overflow: hidden;\n    display: none;\n  }\n  .jacq-cta-logo {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 130%;\n    max-width: none;\n    height: auto;\n    filter: brightness(0) invert(1);\n    opacity: 1;\n    pointer-events: none;\n  }\n\n  /* ── Mobile ── */\n  @media (max-width: 767px) {\n    .jacq-cta-inner {\n      min-height: auto;\n      flex-direction: column;\n    }\n    .jacq-cta-inner::before {\n      bottom: -20%;\n      left: -20%;\n      width: 80%;\n      height: 70%;\n      background: radial-gradient(ellipse at center, rgba(0,113,227,0.12) 0%, transparent 70%);\n    }\n    .jacq-cta-left {\n      padding: 36px 28px 40px;\n      align-items: flex-start;\n      text-align: left;\n    }\n    .jacq-cta-title {\n      font-size: 28px;\n      line-height: 1.08;\n      margin-bottom: 10px;\n    }\n    .jacq-cta-sub {\n      font-size: 14px;\n      max-width: none;\n      margin-bottom: 24px;\n      line-height: 1.55;\n    }\n    .jacq-cta-btn {\n      padding: 13px 28px;\n      font-size: 14px;\n      align-self: flex-start;\n    }\n  }\n\n  /* ── Large desktop ── */\n  @media (min-width: 1024px) {\n    .jacq-mobile-br {\n      display: none;\n    }\n    .jacq-desktop-br {\n      display: inline;\n    }\n    .jacq-cta-inner {\n      min-height: 300px;\n    }\n    .jacq-cta-left {\n      padding: 56px 56px;\n    }\n    .jacq-cta-right {\n      display: block;\n      flex: 0 0 50%;\n    }\n    .jacq-cta-logo {\n      width: 110%;\n    }\n    .jacq-cta-title {\n      font-size: 52px;\n    }\n    .jacq-cta-sub {\n      font-size: 17px;\n    }\n    .jacq-cta-inner::before {\n      display: none;\n    }\n  }\n</style>\n<div class=\"jacq-cta-band\">\n  <div class=\"jacq-cta-inner\">\n    <div class=\"jacq-cta-left\">\n      <div class=\"jacq-cta-title\">Jouw nieuwe bril<br class=\"jacq-desktop-br\"> begint hier.</div>\n      <div class=\"jacq-cta-sub\">Brillen op sterkte vanaf €50.<br>Duurzame materialen en 100 dagen<br class=\"jacq-mobile-br\"> om verliefd te worden.</div>\n      <a href=\"https://jacqeyewear.nl/collections/brillen-op-sterkte\" class=\"jacq-cta-btn\">Bekijk de collectie</a>\n    </div>\n    <div class=\"jacq-cta-right\">\n      <img class=\"jacq-cta-logo\" src=\"https://jacqeyewear.nl/cdn/shop/files/Logo_01_copy_2.svg?v=1762204480\" alt=\"\" aria-hidden=\"true\" loading=\"lazy\">\n    </div>\n  </div>\n</div>",
