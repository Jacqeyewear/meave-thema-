      "name": "t:sections.custom-liquid.name",
      "settings": {
        "liquid": "<style>\n  /* ===== JACQ USP Section ===== */\n  #jacq-usp {\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;\n    -webkit-font-smoothing: antialiased;\n    margin: 16px 0;\n  }\n\n  /* Container */\n  .jacq-usp-inner {\n    border-radius: 24px;\n    background: #ffffff;\n    box-shadow: 0 18px 40px rgba(0,0,0,0.06);\n    border: none;\n    overflow: hidden;\n  }\n\n  /* Mobile: horizontal slider */\n  .jacq-usp-items {\n    display: flex;\n    gap: 0;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n  }\n  .jacq-usp-items::-webkit-scrollbar { display: none; }\n  .jacq-usp-items { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .jacq-usp-item {\n    flex: 0 0 100%;\n    scroll-snap-align: center;\n    padding: 28px 24px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    gap: 10px;\n    position: relative;\n  }\n\n  .jacq-usp-icon {\n    width: 44px;\n    height: 44px;\n    border-radius: 50%;\n    background: rgba(0, 113, 227, 0.06);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .jacq-usp-icon svg {\n    width: 20px;\n    height: 20px;\n    color: #0071E3;\n    stroke: #0071E3;\n    fill: none;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .jacq-usp-name {\n    font-size: 15px;\n    font-weight: 600;\n    color: #111827;\n    letter-spacing: -0.01em;\n    line-height: 1.25;\n  }\n\n  .jacq-usp-desc {\n    font-size: 13px;\n    color: #6b7280;\n    line-height: 1.5;\n    max-width: 26ch;\n  }\n\n  /* Dots */\n  .jacq-usp-dots {\n    display: flex;\n    justify-content: center;\n    gap: 6px;\n    padding: 4px 0 16px;\n  }\n\n  .jacq-usp-dot {\n    width: 6px;\n    height: 6px;\n    border-radius: 999px;\n    background: #d1d5db;\n    transition: background .2s, width .3s cubic-bezier(.2,.9,.3,1);\n    cursor: pointer;\n  }\n\n  .jacq-usp-dot.is-active {\n    background: #111827;\n    width: 18px;\n  }\n\n  /* ===== Desktop: 2x2 grid with dividers ===== */\n  @media (min-width: 768px) {\n    .jacq-usp-inner {\n      padding: 0;\n    }\n\n    .jacq-usp-items {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 0;\n      overflow: visible;\n      scroll-snap-type: none;\n    }\n\n    .jacq-usp-item {\n      flex: initial;\n      scroll-snap-align: unset;\n      padding: 32px 28px;\n      align-items: center;\n      text-align: center;\n      flex-direction: column;\n      gap: 10px;\n    }\n\n    /* Vertical divider: right column items */\n    .jacq-usp-item:nth-child(2),\n    .jacq-usp-item:nth-child(4) {\n      border-left: 1px solid rgba(0,0,0,0.05);\n    }\n\n    /* Horizontal divider: bottom row */\n    .jacq-usp-item:nth-child(3),\n    .jacq-usp-item:nth-child(4) {\n      border-top: 1px solid rgba(0,0,0,0.05);\n    }\n\n    .jacq-usp-text-wrap {\n      display: flex;\n      flex-direction: column;\n      gap: 4px;\n    }\n\n    .jacq-usp-desc {\n      max-width: none;\n    }\n\n    .jacq-usp-name {\n      font-size: 16px;\n    }\n\n    .jacq-usp-desc {\n      font-size: 14px;\n    }\n\n    .jacq-usp-dots {\n      display: none;\n    }\n\n    /* Hover */\n    .jacq-usp-item {\n      transition: background .3s;\n    }\n\n    .jacq-usp-item:hover {\n      background: rgba(0,0,0,0.012);\n    }\n  }\n</style>\n\n<div id=\"jacq-usp\">\n\n  <div class=\"jacq-usp-inner\">\n    <div class=\"jacq-usp-items\">\n\n      <!-- 1: Gratis verzending -->\n      <div class=\"jacq-usp-item\">\n        <div class=\"jacq-usp-icon\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M5 18h1a2 2 0 1 0 4 0h4a2 2 0 1 0 4 0h1\"/><path d=\"M16 8h4l2 4v4h-4\"/><rect x=\"1\" y=\"4\" width=\"15\" height=\"12\" rx=\"1\"/><circle cx=\"8\" cy=\"18\" r=\"2\"/><circle cx=\"18\" cy=\"18\" r=\"2\"/></svg>\n        </div>\n        <div class=\"jacq-usp-text-wrap\">\n          <div class=\"jacq-usp-name\">Gratis verzending</div>\n          <div class=\"jacq-usp-desc\">Op maat gemaakt en binnen 7–10 werkdagen bezorgd. Met track & trace.</div>\n        </div>\n      </div>\n\n      <!-- 2: 100 dagen proefdragen -->\n      <div class=\"jacq-usp-item\">\n        <div class=\"jacq-usp-icon\">\n          <svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"/><path d=\"M16 2v4M8 2v4M3 10h18\"/></svg>\n        </div>\n        <div class=\"jacq-usp-text-wrap\">\n          <div class=\"jacq-usp-name\">100 dagen proefdragen</div>\n          <div class=\"jacq-usp-desc\">100 dagen om je bril uit te proberen. Niet tevreden? Geld terug.</div>\n        </div>\n      </div>\n\n      <!-- 3: 2 jaar garantie -->\n      <div class=\"jacq-usp-item\">\n        <div class=\"jacq-usp-icon\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n        </div>\n        <div class=\"jacq-usp-text-wrap\">\n          <div class=\"jacq-usp-name\">2 jaar garantie</div>\n          <div class=\"jacq-usp-desc\">Fabricagefout? Geld terug of gratis vervanging. Geen gedoe.</div>\n        </div>\n      </div>\n\n      <!-- 4: Veilig betalen -->\n      <div class=\"jacq-usp-item\">\n        <div class=\"jacq-usp-icon\">\n          <svg viewBox=\"0 0 24 24\"><rect x=\"1\" y=\"4\" width=\"22\" height=\"16\" rx=\"2\" ry=\"2\"/><path d=\"M1 10h22\"/></svg>\n        </div>\n        <div class=\"jacq-usp-text-wrap\">\n          <div class=\"jacq-usp-name\">Veilig betalen</div>\n          <div class=\"jacq-usp-desc\">iDEAL, Klarna, creditcard. Kies wat bij je past.</div>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"jacq-usp-dots\">\n      <span class=\"jacq-usp-dot is-active\"></span>\n      <span class=\"jacq-usp-dot\"></span>\n      <span class=\"jacq-usp-dot\"></span>\n      <span class=\"jacq-usp-dot\"></span>\n    </div>\n  </div>\n</div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n  var root = document.getElementById('jacq-usp');\n  if (!root) return;\n  var track = root.querySelector('.jacq-usp-items');\n  var slides = Array.prototype.slice.call(root.querySelectorAll('.jacq-usp-item'));\n  var dots = Array.prototype.slice.call(root.querySelectorAll('.jacq-usp-dot'));\n  if (!track || !slides.length || dots.length !== slides.length) return;\n\n  function update() {\n    var center = track.scrollLeft + track.clientWidth / 2;\n    var idx = 0, min = Infinity;\n    slides.forEach(function (s, i) {\n      var d = Math.abs(s.offsetLeft + s.offsetWidth / 2 - center);\n      if (d < min) { min = d; idx = i; }\n    });\n    dots.forEach(function (d, i) { d.classList.toggle('is-active', i === idx); });\n  }\n\n  var t = false;\n  track.addEventListener('scroll', function () {\n    if (!t) { window.requestAnimationFrame(function () { update(); t = false; }); t = true; }\n  });\n  dots.forEach(function (d, i) {\n    d.addEventListener('click', function () {\n      if (slides[i]) track.scrollTo({ left: slides[i].offsetLeft, behavior: 'smooth' });\n    });\n  });\n  update();\n});\n</script>",
