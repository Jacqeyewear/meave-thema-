        "liquid": "<style>\n  #meave-band{position:relative;width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw);min-height:clamp(420px,56vw,640px);display:flex;align-items:flex-end;overflow:hidden;background:#1d1d1f;}\n  #meave-band .mband-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}\n  #meave-band::after{content:\"\";position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.58),rgba(0,0,0,.08) 55%,rgba(0,0,0,0));}\n  #meave-band .mband-inner{position:relative;z-index:1;max-width:1280px;margin:0 auto;width:100%;padding:0 24px 56px;color:#fff;font-family:var(--font-body-family,inherit);-webkit-font-smoothing:antialiased;}\n  #meave-band .mband-eyebrow{margin:0 0 12px;font-size:12px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;opacity:.85;}\n  #meave-band .mband-title{margin:0 0 14px;font-family:var(--font-heading-family,inherit);font-size:clamp(30px,4.2vw,52px);font-weight:500;letter-spacing:-.025em;line-height:1.05;max-width:18ch;text-shadow:0 2px 18px rgba(0,0,0,.28);}\n  #meave-band .mband-sub{margin:0 0 26px;font-size:clamp(15px,1.5vw,18px);line-height:1.55;max-width:44ch;opacity:.92;}\n  #meave-band .mband-btn{display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border-radius:980px;background:#fff;color:#1d1d1f;font-size:15px;font-weight:500;letter-spacing:-.01em;text-decoration:none;transition:transform .3s cubic-bezier(.16,1,.3,1),box-shadow .3s;}\n  #meave-band .mband-btn:hover{transform:translateY(-1px);box-shadow:0 10px 24px rgba(0,0,0,.28);}\n  @media(max-width:749px){#meave-band{min-height:clamp(380px,92vw,520px);}#meave-band .mband-inner{padding:0 18px 40px;}}\n</style>\n<section id=\"meave-band\">\n  <img class=\"mband-bg\" src=\"https://cdn.shopify.com/s/files/1/1012/9004/9878/files/ChatGPT_Image_Jun_18_2026_03_16_21_PM_3.png?v=1782217194\" alt=\"Warm Meave lighting in a calm London interior\" loading=\"lazy\">\n  <div class=\"mband-inner\">\n    <p class=\"mband-eyebrow\">Designed in London</p>\n    <h2 class=\"mband-title\">Light that feels like part of the room</h2>\n    <p class=\"mband-sub\">Warm, considered lighting that makes everyday spaces feel calm, finished and unmistakably yours.</p>\n    <a class=\"mband-btn\" href=\"/collections/wall-lights\">Shop Wall Lights</a>\n  </div>\n</section>"
      }
